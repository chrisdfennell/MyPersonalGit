@page "/settings"
@page "/settings/{Tab}"
@using MyPersonalGit.Data
@using MyPersonalGit.Models
@using MyPersonalGit.Services
@using UserProfileModel = MyPersonalGit.Models.UserProfile
@inject IUserProfileService ProfileService
@inject IGpgKeyService GpgKeyService
@inject ITwoFactorService TwoFactorService
@inject IAuthService AuthService
@inject IOAuthService OAuthService
@inject CurrentUserService UserService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Settings - MyPersonalGit</PageTitle>

@if (!UserService.IsLoggedIn)
{
    <div class="container py-5 text-center">
        <i class="bi bi-gear" style="font-size: 4rem; color: #6c757d;"></i>
        <h3 class="mt-3">Authentication Required</h3>
        <p class="text-muted">Please sign in to access your settings.</p>
        <a href="/login" class="btn btn-primary">Sign in</a>
    </div>
}
else
{
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3">
            <div class="list-group">
                <a class="list-group-item list-group-item-action @(ActiveTab == "profile" ? "active" : "")" 
                   @onclick='() => SetTab("profile")' style="cursor: pointer;">
                    <i class="bi bi-person"></i> Profile
                </a>
                <a class="list-group-item list-group-item-action @(ActiveTab == "account" ? "active" : "")" 
                   @onclick='() => SetTab("account")' style="cursor: pointer;">
                    <i class="bi bi-shield-lock"></i> Account Security
                </a>
                <a class="list-group-item list-group-item-action @(ActiveTab == "ssh" ? "active" : "")"
                   @onclick='() => SetTab("ssh")' style="cursor: pointer;">
                    <i class="bi bi-key"></i> SSH Keys
                </a>
                <a class="list-group-item list-group-item-action @(ActiveTab == "gpg" ? "active" : "")"
                   @onclick='() => SetTab("gpg")' style="cursor: pointer;">
                    <i class="bi bi-shield-lock-fill"></i> GPG Keys
                </a>
                <a class="list-group-item list-group-item-action @(ActiveTab == "tokens" ? "active" : "")" 
                   @onclick='() => SetTab("tokens")' style="cursor: pointer;">
                    <i class="bi bi-code-square"></i> Access Tokens
                </a>
                <a class="list-group-item list-group-item-action @(ActiveTab == "sessions" ? "active" : "")" 
                   @onclick='() => SetTab("sessions")' style="cursor: pointer;">
                    <i class="bi bi-laptop"></i> Sessions
                </a>
                <a class="list-group-item list-group-item-action @(ActiveTab == "notifications" ? "active" : "")"
                   @onclick='() => SetTab("notifications")' style="cursor: pointer;">
                    <i class="bi bi-bell"></i> Notifications
                </a>
                <a class="list-group-item list-group-item-action @(ActiveTab == "linked" ? "active" : "")"
                   @onclick='() => SetTab("linked")' style="cursor: pointer;">
                    <i class="bi bi-link-45deg"></i> Linked Accounts
                </a>
            </div>
        </div>

        <div class="col-md-9">
            @if (ActiveTab == "profile")
            {
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Public Profile</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Avatar URL</label>
                            <input type="text" class="form-control" @bind="UserProfileData.AvatarUrl" placeholder="https://example.com/avatar.jpg" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <input type="text" class="form-control" @bind="UserProfileData.FullName" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Bio</label>
                            <textarea class="form-control" rows="3" @bind="UserProfileData.Bio"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Company</label>
                            <input type="text" class="form-control" @bind="UserProfileData.Company" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Location</label>
                            <input type="text" class="form-control" @bind="UserProfileData.Location" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Website</label>
                            <input type="url" class="form-control" @bind="UserProfileData.Website" placeholder="https://example.com" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Twitter Username</label>
                            <div class="input-group">
                                <span class="input-group-text">@("@")</span>
                                <input type="text" class="form-control" @bind="UserProfileData.TwitterHandle" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" @bind="UserProfileData.IsPublic" id="isPublic" />
                                <label class="form-check-label" for="isPublic">
                                    Make profile public
                                </label>
                            </div>
                        </div>
                        <button class="btn btn-primary" @onclick="SaveProfile">
                            <i class="bi bi-check-lg"></i> Save Profile
                        </button>
                    </div>
                </div>
            }
            else if (ActiveTab == "account")
            {
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Change Password</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Current Password</label>
                            <input type="password" class="form-control" @bind="CurrentPassword" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">New Password</label>
                            <input type="password" class="form-control" @bind="NewPassword" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Confirm New Password</label>
                            <input type="password" class="form-control" @bind="ConfirmPassword" />
                        </div>
                        <button class="btn btn-primary" @onclick="ChangePassword">
                            <i class="bi bi-shield-check"></i> Update Password
                        </button>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Two-Factor Authentication</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(TwoFactorMessage))
                        {
                            <div class="alert @(TwoFactorMessageIsError ? "alert-danger" : "alert-success") alert-dismissible">
                                @TwoFactorMessage
                                <button type="button" class="btn-close" @onclick='() => TwoFactorMessage = ""'></button>
                            </div>
                        }

                        @if (TwoFactor.IsEnabled && !ShowTwoFactorSetup)
                        {
                            <div class="alert alert-success">
                                <i class="bi bi-shield-check"></i> Two-factor authentication is enabled
                            </div>
                            <p>Enabled on @TwoFactor.EnabledAt?.ToString("g")</p>

                            @if (ShowRecoveryCodes && RecoveryCodes.Length > 0)
                            {
                                <div class="alert alert-warning">
                                    <strong>Recovery Codes</strong>
                                    <p class="mb-2">Save these codes in a safe place. Each code can only be used once.</p>
                                    <div class="bg-dark text-light p-3 rounded font-monospace">
                                        @foreach (var recoveryCode in RecoveryCodes)
                                        {
                                            <div>@recoveryCode</div>
                                        }
                                    </div>
                                </div>
                            }

                            <div class="d-flex gap-2">
                                <button class="btn btn-outline-primary" @onclick="RegenerateRecoveryCodes">
                                    <i class="bi bi-arrow-repeat"></i> Regenerate Recovery Codes
                                </button>
                                <button class="btn btn-danger" @onclick='() => ShowDisable2FAConfirm = true'>
                                    <i class="bi bi-x-circle"></i> Disable 2FA
                                </button>
                            </div>

                            @if (ShowDisable2FAConfirm)
                            {
                                <div class="mt-3 p-3 border rounded">
                                    <p class="mb-2"><strong>Enter your current TOTP code to disable 2FA:</strong></p>
                                    <div class="input-group" style="max-width: 300px;">
                                        <input type="text" class="form-control font-monospace" @bind="Disable2FACode"
                                               placeholder="000000" maxlength="6" inputmode="numeric" />
                                        <button class="btn btn-danger" @onclick="Disable2FA">Confirm</button>
                                        <button class="btn btn-secondary" @onclick='() => { ShowDisable2FAConfirm = false; Disable2FACode = ""; }'>Cancel</button>
                                    </div>
                                </div>
                            }
                        }
                        else if (ShowTwoFactorSetup)
                        {
                            <div class="mb-3">
                                <h6>Step 1: Add to your authenticator app</h6>
                                <p>Scan the QR code or manually enter this URI in your authenticator app:</p>
                                <div class="bg-light p-3 rounded mb-3">
                                    <code class="text-break">@TwoFactorSetupUri</code>
                                </div>
                                <p class="small text-muted">
                                    <strong>Secret key:</strong> <code>@TwoFactorSetupSecret</code>
                                </p>
                            </div>

                            <div class="mb-3">
                                <h6>Step 2: Verify setup</h6>
                                <p>Enter the 6-digit code from your authenticator app to confirm setup:</p>
                                <div class="input-group" style="max-width: 300px;">
                                    <input type="text" class="form-control font-monospace text-center" @bind="VerifySetupCode"
                                           placeholder="000000" maxlength="6" inputmode="numeric" />
                                    <button class="btn btn-primary" @onclick="VerifyAndActivate2FA">Verify</button>
                                </div>
                            </div>

                            <button class="btn btn-secondary" @onclick="Cancel2FASetup">Cancel</button>

                            @if (ShowRecoveryCodes && RecoveryCodes.Length > 0)
                            {
                                <div class="alert alert-warning mt-3">
                                    <strong>Save your recovery codes!</strong>
                                    <p class="mb-2">These codes can be used to access your account if you lose your authenticator device. Each code can only be used once. Store them securely.</p>
                                    <div class="bg-dark text-light p-3 rounded font-monospace">
                                        @foreach (var recoveryCode in RecoveryCodes)
                                        {
                                            <div>@recoveryCode</div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="alert alert-warning">
                                <i class="bi bi-shield-exclamation"></i> Two-factor authentication is not enabled
                            </div>
                            <p>Add an extra layer of security to your account by enabling two-factor authentication.</p>
                            <button class="btn btn-primary" @onclick="Enable2FA">
                                <i class="bi bi-shield-plus"></i> Enable 2FA
                            </button>
                        }
                    </div>
                </div>
            }
            else if (ActiveTab == "ssh")
            {
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">SSH Keys</h5>
                        <button class="btn btn-primary btn-sm" @onclick='() => ShowAddSshKey = true'>
                            <i class="bi bi-plus-lg"></i> Add SSH Key
                        </button>
                    </div>
                    <div class="card-body">
                        @if (SshKeys.Count == 0)
                        {
                            <p class="text-muted">No SSH keys configured</p>
                        }
                        else
                        {
                            <div class="list-group">
                                @foreach (var key in SshKeys)
                                {
                                    <div class="list-group-item">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="mb-1">@key.Title</h6>
                                                <p class="mb-1 font-monospace small">@key.Fingerprint</p>
                                                <small class="text-muted">
                                                    Added @key.CreatedAt.ToString("MMM d, yyyy")
                                                    @if (key.LastUsed.HasValue)
                                                    {
                                                        <span> • Last used @key.LastUsed.Value.ToString("MMM d, yyyy")</span>
                                                    }
                                                </small>
                                            </div>
                                            <button class="btn btn-danger btn-sm" @onclick="() => DeleteSshKey(key.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
            else if (ActiveTab == "gpg")
            {
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">GPG Keys</h5>
                        <button class="btn btn-primary btn-sm" @onclick='() => ShowAddGpgKey = true'>
                            <i class="bi bi-plus-lg"></i> Add GPG Key
                        </button>
                    </div>
                    <div class="card-body">
                        @if (GpgKeys.Count == 0)
                        {
                            <p class="text-muted">No GPG keys configured. Add a GPG key to sign and verify commits.</p>
                        }
                        else
                        {
                            <div class="list-group">
                                @foreach (var key in GpgKeys)
                                {
                                    <div class="list-group-item">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="mb-1">
                                                    <i class="bi bi-shield-lock-fill text-success"></i>
                                                    <span class="font-monospace">@key.KeyId</span>
                                                    @if (key.IsVerified)
                                                    {
                                                        <span class="badge bg-success ms-2">Verified</span>
                                                    }
                                                </h6>
                                                <p class="mb-1 small">
                                                    <strong>Key ID:</strong> <span class="font-monospace">@key.LongKeyId</span>
                                                </p>
                                                <p class="mb-1 small">
                                                    <strong>Email:</strong> @key.PrimaryEmail
                                                    @if (key.Emails.Count > 1)
                                                    {
                                                        <span class="text-muted">(+@(key.Emails.Count - 1) more)</span>
                                                    }
                                                </p>
                                                <small class="text-muted">
                                                    Added @key.CreatedAt.ToString("MMM d, yyyy")
                                                    @if (key.ExpiresAt.HasValue)
                                                    {
                                                        <span> &middot; Expires @key.ExpiresAt.Value.ToString("MMM d, yyyy")</span>
                                                    }
                                                </small>
                                            </div>
                                            <button class="btn btn-danger btn-sm" @onclick="() => DeleteGpgKey(key.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
            else if (ActiveTab == "tokens")
            {
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Personal Access Tokens</h5>
                        <button class="btn btn-primary btn-sm" @onclick='() => ShowAddToken = true'>
                            <i class="bi bi-plus-lg"></i> Generate Token
                        </button>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(lastGeneratedToken))
                        {
                            <div class="alert alert-success d-flex align-items-center gap-2 mb-3">
                                <i class="bi bi-key-fill"></i>
                                <div class="flex-grow-1">
                                    <strong>Your new token:</strong>
                                    <code class="ms-2 user-select-all">@lastGeneratedToken</code>
                                </div>
                                <small class="text-muted">Copy it now — you won't see it again.</small>
                            </div>
                        }
                        @if (Tokens.Count == 0)
                        {
                            <p class="text-muted">No personal access tokens</p>
                        }
                        else
                        {
                            <div class="list-group">
                                @foreach (var token in Tokens)
                                {
                                    <div class="list-group-item">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="mb-1">@token.Name</h6>
                                                <p class="mb-1">
                                                    <span class="badge bg-secondary">@string.Join(", ", token.Scopes)</span>
                                                    @if (token.AllowedRoutes?.Length > 0)
                                                    {
                                                        <span class="badge bg-info ms-1" title="@string.Join(", ", token.AllowedRoutes)">
                                                            <i class="bi bi-shield-lock"></i> @token.AllowedRoutes.Length route(s)
                                                        </span>
                                                    }
                                                </p>
                                                <small class="text-muted">
                                                    Created @token.CreatedAt.ToString("MMM d, yyyy")
                                                    @if (token.ExpiresAt.HasValue)
                                                    {
                                                        <span> • Expires @token.ExpiresAt.Value.ToString("MMM d, yyyy")</span>
                                                    }
                                                    @if (token.LastUsed.HasValue)
                                                    {
                                                        <span> • Last used @token.LastUsed.Value.ToString("MMM d, yyyy")</span>
                                                    }
                                                </small>
                                            </div>
                                            <button class="btn btn-danger btn-sm" @onclick="() => DeleteToken(token.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
            else if (ActiveTab == "sessions")
            {
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Active Sessions</h5>
                    </div>
                    <div class="card-body">
                        @if (Sessions.Count == 0)
                        {
                            <p class="text-muted">No active sessions</p>
                        }
                        else
                        {
                            <div class="list-group">
                                @foreach (var session in Sessions)
                                {
                                    <div class="list-group-item">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="mb-1">
                                                    <i class="bi bi-laptop"></i> @session.UserAgent
                                                </h6>
                                                <p class="mb-1">
                                                    <i class="bi bi-geo-alt"></i> @session.IpAddress
                                                </p>
                                                <small class="text-muted">
                                                    Started @session.CreatedAt.ToString("g")
                                                    • Last activity @session.LastActivity.ToString("g")
                                                </small>
                                            </div>
                                            <button class="btn btn-danger btn-sm" @onclick="() => RevokeSession(session.Id)">
                                                <i class="bi bi-x-circle"></i> Revoke
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
            else if (ActiveTab == "notifications")
            {
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Notification Preferences</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" @bind="UserProfileData.PushNotificationsEnabled" id="pushEnabled" />
                                <label class="form-check-label" for="pushEnabled">
                                    <strong>Push notifications (ntfy/Gotify)</strong>
                                    <small class="text-muted d-block">Send notifications to external push services when configured by admin</small>
                                </label>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" @bind="UserProfileData.EmailNotificationsEnabled" id="emailEnabled" />
                                <label class="form-check-label" for="emailEnabled">
                                    <strong>Email notifications</strong>
                                    <small class="text-muted d-block">Receive email notifications when SMTP is configured by admin</small>
                                </label>
                            </div>
                        </div>
                        <hr />
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" @bind="UserProfileData.NotifyOnPullRequest" id="notifyPR" />
                                <label class="form-check-label" for="notifyPR">
                                    Pull request notifications
                                </label>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" @bind="UserProfileData.NotifyOnIssue" id="notifyIssue" />
                                <label class="form-check-label" for="notifyIssue">
                                    Issue notifications
                                </label>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" @bind="UserProfileData.NotifyOnMention" id="notifyMention" />
                                <label class="form-check-label" for="notifyMention">
                                    Mention notifications
                                </label>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" @bind="UserProfileData.NotifyOnComment" id="notifyComment" />
                                <label class="form-check-label" for="notifyComment">
                                    Comment notifications
                                </label>
                            </div>
                        </div>
                        <button class="btn btn-primary" @onclick="SaveNotificationSettings">
                            <i class="bi bi-check-lg"></i> Save Preferences
                        </button>
                    </div>
                </div>
            }
            else if (ActiveTab == "linked")
            {
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Linked Accounts</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Manage external accounts linked to your MyPersonalGit profile for single sign-on.</p>

                        @if (!string.IsNullOrEmpty(LinkedAccountMessage))
                        {
                            <div class="alert alert-info">@LinkedAccountMessage</div>
                        }

                        @if (externalLogins.Any())
                        {
                            <div class="list-group mb-3">
                                @foreach (var login in externalLogins)
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <i class="bi @MyPersonalGit.Data.OAuthService.GetProviderIcon(login.Provider) me-2"
                                               style="color: @MyPersonalGit.Data.OAuthService.GetProviderColor(login.Provider);"></i>
                                            <strong>@GetProviderDisplayName(login.Provider)</strong>
                                            @if (!string.IsNullOrEmpty(login.ProviderUsername))
                                            {
                                                <span class="text-muted ms-1">(@login.ProviderUsername)</span>
                                            }
                                            <br /><small class="text-muted">Linked @login.LinkedAt.ToString("MMM d, yyyy")</small>
                                        </div>
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => UnlinkAccount(login.Provider)">
                                            <i class="bi bi-x-lg me-1"></i> Unlink
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">No linked accounts.</p>
                        }

                        @if (enabledOAuthProviders.Any())
                        {
                            <h6 class="mt-3">Link a new account</h6>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var provider in enabledOAuthProviders.Where(p => !externalLogins.Any(l => l.Provider == p.ProviderName)))
                                {
                                    <a href="/oauth/login/@provider.ProviderName" class="btn btn-outline-secondary btn-sm">
                                        <i class="bi @MyPersonalGit.Data.OAuthService.GetProviderIcon(provider.ProviderName) me-1"
                                           style="color: @MyPersonalGit.Data.OAuthService.GetProviderColor(provider.ProviderName);"></i>
                                        Link @(provider.DisplayName ?? provider.ProviderName)
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@if (ShowAddSshKey)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add SSH Key</h5>
                    <button type="button" class="btn-close" @onclick='() => ShowAddSshKey = false'></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input type="text" class="form-control" @bind="NewSshKeyTitle" placeholder="My SSH Key" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Key</label>
                        <textarea class="form-control font-monospace" rows="5" @bind="NewSshKeyContent" 
                                  placeholder="ssh-rsa AAAAB3NzaC1yc2E..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick='() => ShowAddSshKey = false'>Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="AddSshKey">Add Key</button>
                </div>
            </div>
        </div>
    </div>
}

@if (ShowAddToken)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Generate Personal Access Token</h5>
                    <button type="button" class="btn-close" @onclick='() => ShowAddToken = false'></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Token Name</label>
                        <input type="text" class="form-control" @bind="NewTokenName" placeholder="My Token" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Scopes</label>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="TokenScopeRepo" id="scopeRepo" />
                            <label class="form-check-label" for="scopeRepo">repo - Full repository access</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="TokenScopeUser" id="scopeUser" />
                            <label class="form-check-label" for="scopeUser">user - User profile access</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="TokenScopeAdmin" id="scopeAdmin" />
                            <label class="form-check-label" for="scopeAdmin">admin - Administrative access</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Expiration (days)</label>
                        <input type="number" class="form-control" @bind="TokenExpirationDays" placeholder="30" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Route Restrictions <span class="badge bg-secondary">Optional</span></label>
                        <textarea class="form-control font-monospace" rows="3" @bind="TokenAllowedRoutes"
                                  placeholder="/api/packages/**&#10;/api/v1/repos/MyRepo/**"></textarea>
                        <div class="form-text">
                            One glob pattern per line. If empty, the token can access all routes matching its scopes.
                            Use <code>**</code> to match any sub-path (e.g. <code>/api/packages/**</code>).
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick='() => ShowAddToken = false'>Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="GenerateToken">Generate Token</button>
                </div>
            </div>
        </div>
    </div>
}
@if (ShowAddGpgKey)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add GPG Key</h5>
                    <button type="button" class="btn-close" @onclick='() => ShowAddGpgKey = false'></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">GPG Public Key</label>
                        <textarea class="form-control font-monospace" rows="10" @bind="NewGpgKeyContent"
                                  placeholder="-----BEGIN PGP PUBLIC KEY BLOCK-----&#10;&#10;...&#10;&#10;-----END PGP PUBLIC KEY BLOCK-----"></textarea>
                        <div class="form-text">Paste your ASCII-armored GPG public key.</div>
                    </div>
                    @if (!string.IsNullOrEmpty(GpgKeyError))
                    {
                        <div class="alert alert-danger small">@GpgKeyError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick='() => ShowAddGpgKey = false'>Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="AddGpgKey">Add Key</button>
                </div>
            </div>
        </div>
    </div>
}

} @* end else (IsLoggedIn) *@

@code {
    [Parameter]
    public string? Tab { get; set; }

    private string ActiveTab = "profile";

    private UserProfileModel UserProfileData = new();
    private TwoFactorAuth TwoFactor = new();
    private List<SshKey> SshKeys = new();
    private List<GpgKey> GpgKeys = new();
    private List<PersonalAccessToken> Tokens = new();
    private List<ActiveUserSession> Sessions = new();

    private string CurrentPassword = "";
    private string NewPassword = "";
    private string ConfirmPassword = "";

    // 2FA setup state
    private bool ShowTwoFactorSetup = false;
    private string TwoFactorSetupSecret = "";
    private string TwoFactorSetupUri = "";
    private string VerifySetupCode = "";
    private bool ShowRecoveryCodes = false;
    private string[] RecoveryCodes = Array.Empty<string>();
    private bool ShowDisable2FAConfirm = false;
    private string Disable2FACode = "";
    private string TwoFactorMessage = "";
    private bool TwoFactorMessageIsError = false;

    // Notification preferences now stored in UserProfileData

    private bool ShowAddSshKey = false;
    private string NewSshKeyTitle = "";
    private string NewSshKeyContent = "";

    private bool ShowAddGpgKey = false;
    private string NewGpgKeyContent = "";
    private string GpgKeyError = "";

    private bool ShowAddToken = false;
    private string NewTokenName = "";
    private string lastGeneratedToken = "";
    private bool TokenScopeRepo = false;
    private bool TokenScopeUser = false;
    private bool TokenScopeAdmin = false;
    private int TokenExpirationDays = 30;
    private string TokenAllowedRoutes = "";

    // Linked accounts
    private List<ExternalLogin> externalLogins = new();
    private List<OAuthProviderConfig> enabledOAuthProviders = new();
    private string? LinkedAccountMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(Tab))
        {
            ActiveTab = Tab;
        }
        await LoadData();
    }

    protected override Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(Tab))
        {
            ActiveTab = Tab;
        }
        return Task.CompletedTask;
    }

    private void SetTab(string tab)
    {
        ActiveTab = tab;
        Navigation.NavigateTo($"/settings/{tab}");
    }

    private async Task LoadData()
    {
        if (!UserService.IsLoggedIn) return;
        UserProfileData = await ProfileService.GetProfileAsync(UserService.Username);
        TwoFactor = await ProfileService.Get2FAAsync(UserService.Username) ?? new();
        SshKeys = await ProfileService.GetSshKeysAsync(UserService.Username);
        Tokens = await ProfileService.GetTokensAsync(UserService.Username);
        Sessions = await ProfileService.GetSessionsAsync(UserService.Username);

        var user = await AuthService.GetUserByUsernameAsync(UserService.Username);
        if (user != null)
        {
            GpgKeys = await GpgKeyService.GetUserGpgKeysAsync(user.Id);
            externalLogins = await OAuthService.GetExternalLoginsAsync(user.Id);
        }
        enabledOAuthProviders = await OAuthService.GetEnabledProvidersAsync();
    }

    private async Task SaveProfile()
    {
        await ProfileService.SaveProfileAsync(UserProfileData);
    }

    private Task ChangePassword()
    {
        if (NewPassword != ConfirmPassword)
        {
            return Task.CompletedTask;
        }
        return Task.CompletedTask;
    }

    private async Task Enable2FA()
    {
        TwoFactorMessage = "";
        var user = await AuthService.GetUserByUsernameAsync(UserService.Username);
        if (user == null) return;

        try
        {
            var setupInfo = await TwoFactorService.EnableTwoFactor(user.Id);
            TwoFactorSetupSecret = setupInfo.Secret;
            TwoFactorSetupUri = setupInfo.TotpUri;
            ShowTwoFactorSetup = true;
            ShowRecoveryCodes = false;
            VerifySetupCode = "";
        }
        catch (Exception)
        {
            TwoFactorMessage = "Failed to initiate 2FA setup. Please try again.";
            TwoFactorMessageIsError = true;
        }
    }

    private async Task VerifyAndActivate2FA()
    {
        TwoFactorMessage = "";
        var user = await AuthService.GetUserByUsernameAsync(UserService.Username);
        if (user == null) return;

        var success = await TwoFactorService.VerifyAndActivate(user.Id, VerifySetupCode);
        if (success)
        {
            TwoFactorMessage = "Two-factor authentication has been enabled successfully.";
            TwoFactorMessageIsError = false;

            // Reload the 2FA data to get the recovery codes
            await LoadData();
            var twoFa = await ProfileService.Get2FAAsync(UserService.Username);
            if (twoFa != null)
            {
                RecoveryCodes = twoFa.BackupCodes;
                ShowRecoveryCodes = true;
            }
            ShowTwoFactorSetup = true; // Keep showing setup page with recovery codes
        }
        else
        {
            TwoFactorMessage = "Invalid verification code. Please check the code and try again.";
            TwoFactorMessageIsError = true;
        }
    }

    private void Cancel2FASetup()
    {
        ShowTwoFactorSetup = false;
        TwoFactorSetupSecret = "";
        TwoFactorSetupUri = "";
        VerifySetupCode = "";
        ShowRecoveryCodes = false;
        RecoveryCodes = Array.Empty<string>();
    }

    private async Task Disable2FA()
    {
        TwoFactorMessage = "";
        var user = await AuthService.GetUserByUsernameAsync(UserService.Username);
        if (user == null) return;

        var success = await TwoFactorService.DisableTwoFactor(user.Id, Disable2FACode);
        if (success)
        {
            TwoFactorMessage = "Two-factor authentication has been disabled.";
            TwoFactorMessageIsError = false;
            ShowDisable2FAConfirm = false;
            Disable2FACode = "";
            ShowRecoveryCodes = false;
            RecoveryCodes = Array.Empty<string>();
            await LoadData();
        }
        else
        {
            TwoFactorMessage = "Invalid TOTP code. Please try again.";
            TwoFactorMessageIsError = true;
        }
    }

    private async Task RegenerateRecoveryCodes()
    {
        TwoFactorMessage = "";
        var user = await AuthService.GetUserByUsernameAsync(UserService.Username);
        if (user == null) return;

        RecoveryCodes = await TwoFactorService.GenerateRecoveryCodes(user.Id);
        if (RecoveryCodes.Length > 0)
        {
            ShowRecoveryCodes = true;
            TwoFactorMessage = "Recovery codes have been regenerated. Save them securely.";
            TwoFactorMessageIsError = false;
        }
        else
        {
            TwoFactorMessage = "Failed to regenerate recovery codes.";
            TwoFactorMessageIsError = true;
        }
    }

    private async Task AddSshKey()
    {
        await ProfileService.AddSshKeyAsync(UserService.Username, NewSshKeyTitle, NewSshKeyContent);
        ShowAddSshKey = false;
        NewSshKeyTitle = "";
        NewSshKeyContent = "";
        await LoadData();
    }

    private async Task DeleteSshKey(int id)
    {
        await ProfileService.DeleteSshKeyAsync(UserService.Username, id);
        await LoadData();
    }

    private async Task AddGpgKey()
    {
        GpgKeyError = "";
        var user = await AuthService.GetUserByUsernameAsync(UserService.Username);
        if (user == null) return;

        var key = await GpgKeyService.AddGpgKeyAsync(user.Id, NewGpgKeyContent);
        if (key == null)
        {
            GpgKeyError = "Invalid GPG public key or key already exists. Please paste a valid ASCII-armored PGP public key.";
            return;
        }

        ShowAddGpgKey = false;
        NewGpgKeyContent = "";
        await LoadData();
    }

    private async Task DeleteGpgKey(int id)
    {
        await GpgKeyService.DeleteGpgKeyAsync(id);
        await LoadData();
    }

    private async Task GenerateToken()
    {
        var scopes = new List<string>();
        if (TokenScopeRepo) scopes.Add("repo");
        if (TokenScopeUser) scopes.Add("user");
        if (TokenScopeAdmin) scopes.Add("admin");

        var allowedRoutes = TokenAllowedRoutes
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(r => !string.IsNullOrWhiteSpace(r))
            .ToArray();

        DateTime? expiresAt = TokenExpirationDays > 0 ? DateTime.UtcNow.AddDays(TokenExpirationDays) : null;
        lastGeneratedToken = await ProfileService.CreateTokenAsync(UserService.Username, NewTokenName, scopes.ToArray(), expiresAt, allowedRoutes);
        ShowAddToken = false;
        NewTokenName = "";
        TokenScopeRepo = false;
        TokenScopeUser = false;
        TokenScopeAdmin = false;
        TokenAllowedRoutes = "";
        await LoadData();
    }

    private async Task DeleteToken(int id)
    {
        await ProfileService.DeleteTokenAsync(UserService.Username, id);
        await LoadData();
    }

    private async Task RevokeSession(int id)
    {
        await ProfileService.RevokeSessionAsync(UserService.Username, id);
        await LoadData();
    }

    private async Task SaveNotificationSettings()
    {
        await ProfileService.SaveProfileAsync(UserProfileData);
    }

    private async Task UnlinkAccount(string provider)
    {
        var user = await AuthService.GetUserByUsernameAsync(UserService.Username);
        if (user != null)
        {
            await OAuthService.UnlinkExternalLoginAsync(user.Id, provider);
            LinkedAccountMessage = $"{GetProviderDisplayName(provider)} account unlinked.";
            await LoadData();
        }
    }

    private static string GetProviderDisplayName(string provider) => provider.ToLowerInvariant() switch
    {
        "github" => "GitHub",
        "google" => "Google",
        "microsoft" => "Microsoft",
        "gitlab" => "GitLab",
        "bitbucket" => "Bitbucket",
        "facebook" => "Facebook",
        "discord" => "Discord",
        "twitter" => "X (Twitter)",
        _ => provider
    };
}
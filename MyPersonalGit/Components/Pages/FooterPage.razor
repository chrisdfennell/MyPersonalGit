@page "/terms"
@page "/privacy"
@page "/docs"
@page "/contact"
@using MyPersonalGit.Data
@using MyPersonalGit.Models
@using Microsoft.Extensions.Localization
@using MyPersonalGit.Resources
@inject IAdminService AdminService
@inject IMarkdownService MarkdownService
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L
@rendermode InteractiveServer

<PageTitle>@pageTitle - MyPersonalGit</PageTitle>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body p-4 markdown-body">
                    @content
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private MarkupString content;
    private string pageTitle = "";
    private string lastPath = "";

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += async (_, _) => await LoadContent();
        await LoadContent();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var currentPath = new Uri(Navigation.Uri).AbsolutePath;
        if (currentPath != lastPath)
            await LoadContent();
    }

    private async Task LoadContent()
    {
        var uri = new Uri(Navigation.Uri);
        var path = uri.AbsolutePath.TrimStart('/').ToLowerInvariant();

        if (path == lastPath) return;
        lastPath = path;

        var settings = await AdminService.GetSystemSettingsAsync();

        var (title, markdown) = path switch
        {
            "terms" => ((string)L["Footer_TermsOfService"], settings.FooterTerms),
            "privacy" => ((string)L["Footer_PrivacyPolicy"], settings.FooterPrivacy),
            "docs" => ((string)L["Footer_Documentation"], settings.FooterDocs),
            "contact" => ((string)L["Footer_Contact"], settings.FooterContact),
            _ => ((string)L["Footer_Page"], (string?)L["Footer_PageNotFound"])
        };

        pageTitle = title;
        content = new MarkupString(MarkdownService.RenderToHtml(
            string.IsNullOrWhiteSpace(markdown) ? $"## {title}\n\n{L["Footer_NoContent"]}" : markdown));

        await InvokeAsync(StateHasChanged);
    }
}

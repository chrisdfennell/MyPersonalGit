                ShowToast($"{count} merge conflict{(count > 1 ? "s" : "")} detected", "warning");
            }
        }
        catch { }
    }

    [JSInvokable]
    public async Task OnConflictResolved()
    {
        // A conflict was resolved — refresh the content tracking
        if (editorId != null && activeTabPath != null)
        {
            try
            {
                var content = await JS.InvokeAsync<string>("monacoInterop.getFileContent", editorId, activeTabPath);
                if (content != null)
                {
                    fileContents[activeTabPath] = content;
                    var tab = openTabs.FirstOrDefault(t => t.FilePath == activeTabPath);
                    if (tab != null)
                    {
                        tab.IsDirty = content != tab.OriginalContent;
                        if (tab.IsDirty) modifiedFiles.Add(activeTabPath);
                    }
                    UpdatePendingChanges();
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch { }
        }
    }


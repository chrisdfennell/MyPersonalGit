    private async Task RestoreWorkspaceState()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", $"ide-workspace-{RepoName}");
            if (string.IsNullOrEmpty(json)) return;

            using var doc = System.Text.Json.JsonDocument.Parse(json);
            var root = doc.RootElement;

            // Only restore if same branch
            if (root.TryGetProperty("branch", out var branchEl) && branchEl.GetString() != currentBranch)
                return;

            if (root.TryGetProperty("sidebarMode", out var sidebarEl))
                sidebarMode = sidebarEl.GetString() ?? "files";

            if (root.TryGetProperty("bottomPanel", out var bottomEl))
                bottomPanelMode = bottomEl.GetString() ?? "commits";

            if (root.TryGetProperty("openFiles", out var filesEl))
            {
                var activeFile = root.TryGetProperty("activeFile", out var activeEl) ? activeEl.GetString() : null;

                foreach (var fileEl in filesEl.EnumerateArray())
                {
                    var filePath = fileEl.GetProperty("filePath").GetString();
                    if (string.IsNullOrEmpty(filePath)) continue;

                    var isPinned = fileEl.TryGetProperty("isPinned", out var pinnedEl) && pinnedEl.GetBoolean();

                    try
                    {
                        if (IsImageFile(filePath))
                        {
                            openTabs.Add(new OpenTab
                            {
                                FilePath = filePath,
                                FileName = System.IO.Path.GetFileName(filePath),
                                IsDirty = false,
                                OriginalContent = "",
                                IsPinned = isPinned
                            });
                        }
                        else
                        {
                            var fileContent = await WebIdeService.GetFileContentAsync(RepoName, currentBranch, filePath);
                            fileContents[filePath] = fileContent.Content;
                            openTabs.Add(new OpenTab
                            {
                                FilePath = filePath,
                                FileName = System.IO.Path.GetFileName(filePath),
                                IsDirty = false,
                                OriginalContent = fileContent.Content,
                                IsPinned = isPinned
                            });

                            if (editorId != null)
                            {
                                await JS.InvokeVoidAsync("monacoInterop.openFile", editorId, filePath, fileContent.Content, !UserService.IsLoggedIn);
                            }
                        }
                    }
                    catch { /* file may have been deleted */ }
                }

                // Switch to the previously active tab
                if (activeFile != null && openTabs.Any(t => t.FilePath == activeFile))
                {
                    await SwitchToTab(activeFile);
                }
                else if (openTabs.Count > 0)
                {
                    await SwitchToTab(openTabs[0].FilePath);
                }
            }

            workspaceRestored = true;
            StateHasChanged();
        }
        catch { }
    }


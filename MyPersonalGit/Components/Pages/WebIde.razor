    // ---- Breadcrumb Siblings ----

    private List<TreeNode>? breadcrumbSiblings;
    private string? breadcrumbDropdownPath;

    private void ShowBreadcrumbSiblings(string folderPath)
    {
        if (breadcrumbDropdownPath == folderPath)
        {
            breadcrumbDropdownPath = null;
            breadcrumbSiblings = null;
            return;
        }

        breadcrumbDropdownPath = folderPath;
        breadcrumbSiblings = FindSiblingsAtPath(treeNodes, folderPath);
        StateHasChanged();
    }

    private List<TreeNode>? FindSiblingsAtPath(List<TreeNode>? nodes, string path)
    {
        if (nodes == null) return null;

        // Root level
        if (string.IsNullOrEmpty(path)) return nodes;

        foreach (var node in nodes)
        {
            if (node.Type == "tree" && node.Path == path)
                return node.Children;

            if (node.Type == "tree" && node.Children != null && path.StartsWith(node.Path + "/"))
            {
                var result = FindSiblingsAtPath(node.Children, path);
                if (result != null) return result;
            }
        }

        // Return parent level siblings
        var parentPath = path.Contains('/') ? path[..path.LastIndexOf('/')] : "";
        return FindSiblingsAtPath(nodes, parentPath);
    }


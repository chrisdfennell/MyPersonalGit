            await JS.InvokeVoidAsync("ideDebugger.launch", activeTabPath);
            isDebugging = true;
            isDebugPaused = false;
            debugOutput.Clear();
            debugCallStack.Clear();
            debugVariables.Clear();
            StateHasChanged();

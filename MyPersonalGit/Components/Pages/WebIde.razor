@page "/repo/{RepoName}/ide"
@page "/repo/{RepoName}/ide/{*FilePath}"
@layout IdeLayout
@rendermode InteractiveServer
@using MyPersonalGit.Data
@using MyPersonalGit.Services
@using MyPersonalGit.Components.Shared
@using static MyPersonalGit.Components.Shared.IdeTabBar
@using static MyPersonalGit.Components.Shared.IdeSettingsPanel
@inject IWebIdeService WebIdeService
@inject IJSRuntime JS
@inject IConfiguration Config
@inject NavigationManager Navigation
@inject CurrentUserService UserService
@inject IAdminService AdminService
@implements IAsyncDisposable

<div class="ide-container" @onkeydown="HandleGlobalKeyDown" tabindex="0" @ref="ideContainerRef">
    <div class="ide-sidebar">
        <div class="ide-sidebar-tabs">
            <button class="ide-sidebar-tab @(sidebarMode == "files" ? "active" : "")" @onclick='() => sidebarMode = "files"' title="Explorer">
                <i class="bi bi-files"></i>
            </button>
            <button class="ide-sidebar-tab @(sidebarMode == "search" ? "active" : "")" @onclick='() => sidebarMode = "search"' title="Search">
                <i class="bi bi-search"></i>
            </button>
            <button class="ide-sidebar-tab @(sidebarMode == "sourcecontrol" ? "active" : "")" @onclick='() => sidebarMode = "sourcecontrol"' title="Source Control">
                <i class="bi bi-git"></i>
            </button>
            <button class="ide-sidebar-tab @(sidebarMode == "settings" ? "active" : "")" @onclick='() => sidebarMode = "settings"' title="Settings" style="margin-top: auto;">
                <i class="bi bi-gear"></i>
            </button>
        </div>
        <div class="ide-sidebar-content">
            @if (sidebarMode == "files")
            {
                <IdeFileTree Nodes="treeNodes"
                             ActiveFilePath="@activeTabPath"
                             ModifiedFiles="modifiedFiles"
                             OnFileSelected="HandleFileSelected"
                             OnNewFile="HandleNewFile"
                             OnNewFolder="HandleNewFolder"
                             OnDeletePath="HandleDeletePath"
                             OnRenamePath="HandleRenamePath" />
            }
            else if (sidebarMode == "search")
            {
                <IdeSearchPanel RepoName="@RepoName"
                                Branch="@currentBranch"
                                OnResultSelected="HandleSearchResultSelected"
                                OnReplace="HandleSearchReplace" />
            }
            else if (sidebarMode == "sourcecontrol")
            {
                <div class="ide-source-control">
                    <div class="ide-sc-header px-3 py-2">
                        <span class="small fw-semibold">Source Control</span>
                        @if (modifiedFiles.Count > 0)
                        {
                            <span class="badge bg-primary rounded-pill ms-2">@modifiedFiles.Count</span>
                        }
                    </div>
                    @if (modifiedFiles.Count == 0)
                    {
                        <div class="text-muted small px-3 py-2">
                            <i class="bi bi-check-circle me-1"></i>No changes
                        </div>
                    }
                    else
                    {
                        <div class="ide-sc-files">
                            @foreach (var filePath in modifiedFiles)
                            {
                                var fileName = System.IO.Path.GetFileName(filePath);
                                <div class="ide-sc-file" @onclick="() => OpenDiffView(filePath)" title="Click to view diff">
                                    <i class="bi bi-file-earmark-diff me-2 text-warning"></i>
                                    <span class="ide-sc-filename">@fileName</span>
                                    <span class="ide-sc-filepath text-muted ms-2">@filePath</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else if (sidebarMode == "settings")
            {
                <IdeSettingsPanel EditorId="@editorId"
                                  SplitEditorId="@splitEditorId"
                                  OnSettingsChanged="HandleSettingsChanged" />
            }
        </div>
    </div>

    <div class="ide-tabs">
        <div class="ide-tabs-row">
            <IdeTabBar Tabs="openTabs"
                       ActiveTabPath="@activeTabPath"
                       OnTabSelected="HandleTabSelected"
                       OnTabClosed="HandleTabClosed" />
            @if (openTabs.Count > 0)
            {
                <button class="ide-action-btn @(isBlameActive ? "active" : "")" @onclick="ToggleBlame" title="@(isBlameActive ? "Hide Git Blame" : "Show Git Blame")">
                    <i class="bi bi-person-lines-fill"></i>
                </button>
                <button class="ide-action-btn" @onclick="ShowFileHistory" title="File History">
                    <i class="bi bi-clock-history"></i>
                </button>
                <button class="ide-split-btn" @onclick="ToggleSplitEditor" title="@(isSplit ? "Close Split" : "Split Editor")">
                    <i class="bi @(isSplit ? "bi-layout-sidebar-reverse" : "bi-layout-split")"></i>
                </button>
            }
        </div>
    </div>

    @if (activeTabPath != null && !showDiffView)
    {
        <div class="ide-breadcrumbs">
            <span class="ide-breadcrumb" @onclick='() => sidebarMode = "files"'>@RepoName</span>
            @foreach (var segment in GetBreadcrumbSegments(activeTabPath))
            {
                <i class="bi bi-chevron-right ide-breadcrumb-sep"></i>
                <span class="ide-breadcrumb @(segment.IsLast ? "active" : "")"
                      @onclick="() => { if (!segment.IsLast) HandleBreadcrumbClick(segment.Path); }">@segment.Name</span>
            }
        </div>
    }

    <div class="ide-editor">
        @if (isLoading)
        {
            <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                <span class="spinner-border spinner-border-sm me-2"></span>Loading...
            </div>
        }
        else if (openTabs.Count == 0 && !showDiffView)
        {
            <div class="ide-welcome d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                <i class="bi bi-braces display-3 mb-3 opacity-25"></i>
                <h5 class="fw-light opacity-50">Web IDE</h5>
                <p class="small opacity-50">Open a file from the explorer or press <kbd>Ctrl+P</kbd> to get started</p>
                <div class="mt-3 small opacity-50">
                    <p class="mb-1"><kbd>Ctrl+Shift+P</kbd> Commands &middot; <kbd>Ctrl+P</kbd> Quick Open &middot; <kbd>Ctrl+`</kbd> Terminal &middot; <kbd>?</kbd> Shortcuts</p>
                </div>
            </div>
        }

        @if (showDiffView)
        {
            <div class="ide-diff-header px-3 py-1">
                <i class="bi bi-file-earmark-diff me-2"></i>
                <span class="small">Diff: @diffFilePath</span>
                <button class="btn btn-sm btn-link text-muted ms-auto p-0" @onclick="CloseDiffView">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div id="diff-editor-container" style="width: 100%; flex: 1;"></div>
        }
        else
        {
            <div class="ide-editor-panes @(isSplit ? "split" : "")" style="@(openTabs.Count == 0 ? "display: none;" : "")">
                <div id="monaco-container" class="ide-pane" @onclick="() => SetActivePane(1)"></div>
                @if (isSplit)
                {
                    <div class="ide-pane-divider"></div>
                    <div id="monaco-container-split" class="ide-pane" @onclick="() => SetActivePane(2)"></div>
                }
            </div>
        }
    </div>

    <div class="ide-bottom-panel @(showHistory ? "expanded" : "")">
        <div class="ide-bottom-tabs">
            <button class="ide-bottom-tab @(bottomPanelMode == "commits" ? "active" : "")" @onclick='() => bottomPanelMode = "commits"'>
                <i class="bi bi-git me-1"></i>Commits
            </button>
            <button class="ide-bottom-tab @(bottomPanelMode == "terminal" ? "active" : "")" @onclick="ToggleTerminal">
                <i class="bi bi-terminal me-1"></i>Terminal
            </button>
            @if (showHistory)
            {
                <button class="ide-bottom-tab @(bottomPanelMode == "history" ? "active" : "")" @onclick='() => bottomPanelMode = "history"'>
                    <i class="bi bi-clock-history me-1"></i>History
                    <button class="btn btn-sm btn-link text-muted p-0 ms-1" @onclick="CloseHistory" @onclick:stopPropagation="true">
                        <i class="bi bi-x"></i>
                    </button>
                </button>
            }
        </div>
        @if (bottomPanelMode == "commits")
        {
            <IdeCommitPanel Changes="pendingChanges"
                            OnCommit="HandleCommit"
                            IsCommitting="isCommitting" />
        }
        else if (bottomPanelMode == "terminal")
        {
            <div class="ide-terminal-wrapper" style="height: 200px;">
                <IdeTerminal RepoName="@RepoName" IsVisible="@(bottomPanelMode == "terminal")" />
            </div>
        }
        else if (bottomPanelMode == "history" && showHistory)
        {
            <div class="ide-history-panel">
                <div class="ide-history-header px-3 py-1">
                    <i class="bi bi-clock-history me-1"></i>
                    <span class="small fw-semibold">History: @(activeTabPath != null ? System.IO.Path.GetFileName(activeTabPath) : "")</span>
                </div>
                @if (isLoadingHistory)
                {
                    <div class="text-center py-3">
                        <span class="spinner-border spinner-border-sm text-muted"></span>
                    </div>
                }
                else if (fileHistory.Count == 0)
                {
                    <div class="text-muted small px-3 py-2">No history found</div>
                }
                else
                {
                    <div class="ide-history-list">
                        @foreach (var entry in fileHistory)
                        {
                            <div class="ide-history-entry px-3 py-2">
                                <div class="d-flex align-items-center">
                                    <code class="text-info me-2">@entry.ShortSha</code>
                                    <span class="small fw-semibold text-truncate">@entry.Message</span>
                                </div>
                                <div class="small text-muted mt-1">
                                    <i class="bi bi-person me-1"></i>@entry.Author
                                    <span class="ms-2"><i class="bi bi-calendar me-1"></i>@entry.Date.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <div class="ide-status-bar">
        <div class="ide-status-left">
            <span class="ide-status-item" title="Branch">
                <i class="bi bi-git me-1"></i>@currentBranch
            </span>
            @if (modifiedFiles.Count > 0)
            {
                <span class="ide-status-item text-warning" title="Unsaved changes">
                    <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>@modifiedFiles.Count change(s)
                </span>
            }
        </div>
        <div class="ide-status-right">
            @if (activeTabPath != null)
            {
                <span class="ide-status-item" title="Cursor position">
                    Ln @cursorLine, Col @cursorColumn
                </span>
                @if (selectionLength > 0)
                {
                    <span class="ide-status-item" title="Selection">
                        (@selectionLength selected)
                    </span>
                }
                <span class="ide-status-item" title="Language">
                    @GetLanguageDisplayName(activeTabPath)
                </span>
                <span class="ide-status-item" title="Encoding">
                    UTF-8
                </span>
            }
            <button class="ide-status-item ide-status-btn" @onclick="() => { showShortcutHelp = true; StateHasChanged(); }" title="Keyboard Shortcuts">
                <i class="bi bi-keyboard me-1"></i>Shortcuts
            </button>
        </div>
    </div>
</div>

@if (showQuickOpen)
{
    <IdeQuickOpen TreeNodes="treeNodes"
                  OnFileSelected="HandleFileSelected"
                  OnClose="() => { showQuickOpen = false; StateHasChanged(); }" />
}

@if (showCommandPalette)
{
    <IdeCommandPalette HasActiveFile="@(activeTabPath != null)"
                       IsBlameActive="@isBlameActive"
                       OnCommand="HandleCommand"
                       OnClose="() => { showCommandPalette = false; StateHasChanged(); }" />
}

@if (showShortcutHelp)
{
    <IdeShortcutHelp OnClose="() => { showShortcutHelp = false; StateHasChanged(); }" />
}

@code {
    [Parameter] public string RepoName { get; set; } = "";
    [Parameter] public string? FilePath { get; set; }

    private List<TreeNode>? treeNodes;
    private List<OpenTab> openTabs = new();
    private string? activeTabPath;
    private string currentBranch = "main";
    private List<string> branches = new();
    private HashSet<string> modifiedFiles = new();
    private Dictionary<string, string> fileContents = new();
    private bool isLoading = true;
    private bool isCommitting;
    private string sidebarMode = "files";
    private string? editorId;
    private List<FileChange> pendingChanges = new();
    private DotNetObjectReference<WebIde>? dotNetRef;

    // Split editor state
    private bool isSplit;
    private string? splitEditorId;
    private int activePane = 1;
    private string? splitActiveTabPath;

    // Bottom panel state
    private string bottomPanelMode = "commits";

    // Quick open state
    private bool showQuickOpen;

    // Command palette state
    private bool showCommandPalette;

    // Shortcut help state
    private bool showShortcutHelp;

    // Status bar cursor state
    private int cursorLine = 1;
    private int cursorColumn = 1;
    private int selectionLength;

    // Diff view state
    private bool showDiffView;
    private string? diffFilePath;
    private string? diffEditorId;

    // Blame state
    private bool isBlameActive;

    // File history state
    private bool showHistory;
    private bool isLoadingHistory;
    private List<FileHistoryEntry> fileHistory = new();

    // Settings
    private EditorSettings? currentSettings;

    // Element reference for keyboard events
    private ElementReference ideContainerRef;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var uri = new Uri(Navigation.Uri);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
            var branchParam = query["branch"];
            if (!string.IsNullOrEmpty(branchParam))
                currentBranch = branchParam;

            treeNodes = await WebIdeService.GetFullTreeAsync(RepoName, currentBranch);

            var systemSettings = await AdminService.GetSystemSettingsAsync();
            var projectRoot = !string.IsNullOrEmpty(systemSettings.ProjectRoot)
                ? systemSettings.ProjectRoot
                : Config["Git:ProjectRoot"] ?? Config["Git:ReposPath"] ?? "/repos";
            branches = await Task.Run(() =>
            {
                var repoPath = System.IO.Path.Combine(projectRoot, RepoName);
                if (!LibGit2Sharp.Repository.IsValid(repoPath))
                {
                    repoPath = repoPath + ".git";
                    if (!LibGit2Sharp.Repository.IsValid(repoPath))
                    {
                        repoPath = System.IO.Path.Combine(projectRoot, RepoName, RepoName + ".git");
                    }
                }
                try
                {
                    using var repo = new LibGit2Sharp.Repository(repoPath);
                    return repo.Branches
                        .Where(b => !b.IsRemote)
                        .Select(b => b.FriendlyName)
                        .OrderBy(b => b)
                        .ToList();
                }
                catch
                {
                    return new List<string> { "main" };
                }
            });

            if (!branches.Contains(currentBranch) && branches.Count > 0)
                currentBranch = branches[0];
        }
        catch
        {
            treeNodes = new();
            branches = new List<string> { "main" };
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                dotNetRef = DotNetObjectReference.Create(this);

                await JS.InvokeVoidAsync("monacoInterop.init");
                await LoadSavedSettings();

                var theme = await JS.InvokeAsync<string>("themeHelper.get");
                var monacoTheme = theme == "dark" ? "vs-dark" : "vs";

                var editorOptions = new Dictionary<string, object>
                {
                    { "theme", monacoTheme },
                    { "fontSize", currentSettings?.FontSize ?? 14 },
                    { "minimap", currentSettings?.MinimapEnabled ?? true }
                };

                editorId = await JS.InvokeAsync<string>("monacoInterop.createEditor", "monaco-container", editorOptions);

                if (currentSettings != null)
                {
                    await ApplySettingsToEditor(editorId);
                }

                await JS.InvokeVoidAsync("monacoInterop.onDidChangeContent", editorId, dotNetRef, "OnEditorContentChanged");
                await JS.InvokeVoidAsync("monacoInterop.onDidChangeCursorPosition", editorId, dotNetRef, "OnCursorPositionChanged");

                if (!string.IsNullOrEmpty(FilePath))
                {
                    await HandleFileSelected(FilePath);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Monaco init error: {ex.Message}");
            }
        }
    }

    private async Task LoadSavedSettings()
    {
        try
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "ide-settings");
            if (!string.IsNullOrEmpty(saved))
            {
                currentSettings = System.Text.Json.JsonSerializer.Deserialize<EditorSettings>(saved);
            }
        }
        catch { }
    }

    private async Task ApplySettingsToEditor(string targetEditorId)
    {
        if (currentSettings == null) return;
        try
        {
            var options = new
            {
                fontSize = currentSettings.FontSize,
                tabSize = currentSettings.TabSize,
                wordWrap = currentSettings.WordWrap,
                minimap = new { enabled = currentSettings.MinimapEnabled },
                lineNumbers = currentSettings.LineNumbers ? "on" : "off",
                renderWhitespace = currentSettings.RenderWhitespace
            };
            await JS.InvokeVoidAsync("monacoInterop.updateEditorOptions", targetEditorId, options);
        }
        catch { }
    }

    private async Task HandleFileSelected(string path)
    {
        if (showDiffView)
        {
            await CloseDiffView();
        }

        var existingTab = openTabs.FirstOrDefault(t => t.FilePath == path);
        if (existingTab != null)
        {
            await SwitchToTab(path);
            return;
        }

        try
        {
            var fileContent = await WebIdeService.GetFileContentAsync(RepoName, currentBranch, path);
            fileContents[path] = fileContent.Content;

            var tab = new OpenTab
            {
                FilePath = path,
                FileName = System.IO.Path.GetFileName(path),
                IsDirty = false,
                OriginalContent = fileContent.Content
            };
            openTabs.Add(tab);

            activeTabPath = path;
            StateHasChanged();
            await Task.Delay(50);

            if (editorId != null)
            {
                await JS.InvokeVoidAsync("monacoInterop.layout", editorId);
                var isReadOnly = !UserService.IsLoggedIn;
                await JS.InvokeVoidAsync("monacoInterop.openFile", editorId, path, fileContent.Content, isReadOnly);
                await JS.InvokeVoidAsync("monacoInterop.layout", editorId);

                // Re-apply blame if active
                if (isBlameActive)
                {
                    await LoadBlameForCurrentFile();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to open file: {ex.Message}");
        }
    }

    private async Task HandleTabSelected(string path)
    {
        await SwitchToTab(path);
    }

    private async Task SwitchToTab(string path)
    {
        var targetEditorId = activePane == 2 && isSplit ? splitEditorId : editorId;

        if (targetEditorId != null && fileContents.ContainsKey(path))
        {
            await JS.InvokeVoidAsync("monacoInterop.openFile", targetEditorId, path, fileContents[path], !UserService.IsLoggedIn);
        }

        if (activePane == 2 && isSplit)
            splitActiveTabPath = path;
        else
            activeTabPath = path;

        // Re-apply blame if active
        if (isBlameActive && editorId != null)
        {
            await LoadBlameForCurrentFile();
        }

        StateHasChanged();
    }

    private async Task HandleTabClosed(string path)
    {
        if (editorId != null && modifiedFiles.Contains(path))
        {
            try
            {
                var content = await JS.InvokeAsync<string>("monacoInterop.getFileContent", editorId, path);
                fileContents[path] = content;
            }
            catch { }
        }

        if (editorId != null)
        {
            try
            {
                await JS.InvokeVoidAsync("monacoInterop.closeFile", editorId, path);
            }
            catch { }
        }

        var tabIndex = openTabs.FindIndex(t => t.FilePath == path);
        openTabs.RemoveAll(t => t.FilePath == path);
        modifiedFiles.Remove(path);
        fileContents.Remove(path);

        if (activeTabPath == path)
        {
            if (openTabs.Count > 0)
            {
                var newIndex = Math.Min(tabIndex, openTabs.Count - 1);
                await SwitchToTab(openTabs[newIndex].FilePath);
            }
            else
            {
                activeTabPath = null;
                if (isBlameActive)
                {
                    isBlameActive = false;
                }
            }
        }

        UpdatePendingChanges();
        StateHasChanged();
    }

    private async Task HandleCommit((string message, List<FileChange> changes) args)
    {
        if (!UserService.IsLoggedIn) return;

        isCommitting = true;
        StateHasChanged();

        try
        {
            var commitChanges = new List<FileChange>();
            foreach (var change in args.changes)
            {
                string? content = null;
                if (change.Action != "delete" && editorId != null)
                {
                    try
                    {
                        content = await JS.InvokeAsync<string>("monacoInterop.getFileContent", editorId, change.Path);
                    }
                    catch
                    {
                        content = fileContents.GetValueOrDefault(change.Path);
                    }
                }
                commitChanges.Add(new FileChange(change.Path, content ?? change.Content, change.Action, change.OldPath));
            }

            await WebIdeService.CommitMultipleFilesAsync(
                RepoName,
                currentBranch,
                UserService.Username,
                $"{UserService.Username}@personalgit.local",
                args.message,
                commitChanges
            );

            foreach (var change in commitChanges)
            {
                modifiedFiles.Remove(change.Path);
                var tab = openTabs.FirstOrDefault(t => t.FilePath == change.Path);
                if (tab != null)
                {
                    tab.IsDirty = false;
                    tab.OriginalContent = fileContents.GetValueOrDefault(change.Path, "");
                }
            }

            treeNodes = await WebIdeService.GetFullTreeAsync(RepoName, currentBranch);
            UpdatePendingChanges();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Commit failed: {ex.Message}");
        }
        finally
        {
            isCommitting = false;
            StateHasChanged();
        }
    }

    private async Task HandleNewFile(string folderPath)
    {
        if (!UserService.IsLoggedIn) return;

        try
        {
            var fileName = await JS.InvokeAsync<string>("prompt", "Enter file name:");
            if (string.IsNullOrWhiteSpace(fileName)) return;

            var newPath = string.IsNullOrEmpty(folderPath) ? fileName : $"{folderPath}/{fileName}";

            await WebIdeService.CreateFileAsync(
                RepoName, currentBranch, newPath, "",
                UserService.Username, $"{UserService.Username}@personalgit.local"
            );

            treeNodes = await WebIdeService.GetFullTreeAsync(RepoName, currentBranch);
            StateHasChanged();
            await HandleFileSelected(newPath);
        }
        catch { }
    }

    private async Task HandleNewFolder(string folderPath)
    {
        if (!UserService.IsLoggedIn) return;

        try
        {
            var folderName = await JS.InvokeAsync<string>("prompt", "Enter folder name:");
            if (string.IsNullOrWhiteSpace(folderName)) return;

            var newPath = string.IsNullOrEmpty(folderPath) ? folderName : $"{folderPath}/{folderName}";
            var keepPath = $"{newPath}/.gitkeep";

            await WebIdeService.CreateFileAsync(
                RepoName, currentBranch, keepPath, "",
                UserService.Username, $"{UserService.Username}@personalgit.local"
            );

            treeNodes = await WebIdeService.GetFullTreeAsync(RepoName, currentBranch);
            StateHasChanged();
        }
        catch { }
    }

    private async Task HandleDeletePath(string path)
    {
        if (!UserService.IsLoggedIn) return;

        try
        {
            var confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete '{path}'?");
            if (!confirmed) return;

            await WebIdeService.DeletePathAsync(
                RepoName, currentBranch, path,
                UserService.Username, $"{UserService.Username}@personalgit.local"
            );

            var tab = openTabs.FirstOrDefault(t => t.FilePath == path);
            if (tab != null)
            {
                await HandleTabClosed(path);
            }

            treeNodes = await WebIdeService.GetFullTreeAsync(RepoName, currentBranch);
            StateHasChanged();
        }
        catch { }
    }

    private async Task HandleRenamePath((string oldPath, string newPath) args)
    {
        if (!UserService.IsLoggedIn) return;

        try
        {
            var newName = await JS.InvokeAsync<string>("prompt", "Enter new name:", System.IO.Path.GetFileName(args.oldPath));
            if (string.IsNullOrWhiteSpace(newName)) return;

            var directory = System.IO.Path.GetDirectoryName(args.oldPath)?.Replace("\\", "/");
            var newFullPath = string.IsNullOrEmpty(directory) ? newName : $"{directory}/{newName}";

            await WebIdeService.RenamePathAsync(
                RepoName, currentBranch, args.oldPath, newFullPath,
                UserService.Username, $"{UserService.Username}@personalgit.local"
            );

            var tab = openTabs.FirstOrDefault(t => t.FilePath == args.oldPath);
            if (tab != null)
            {
                tab.FilePath = newFullPath;
                tab.FileName = System.IO.Path.GetFileName(newFullPath);
                if (activeTabPath == args.oldPath)
                    activeTabPath = newFullPath;

                if (fileContents.TryGetValue(args.oldPath, out var content))
                {
                    fileContents.Remove(args.oldPath);
                    fileContents[newFullPath] = content;
                }

                if (modifiedFiles.Remove(args.oldPath))
                    modifiedFiles.Add(newFullPath);
            }

            treeNodes = await WebIdeService.GetFullTreeAsync(RepoName, currentBranch);
            StateHasChanged();
        }
        catch { }
    }

    private async Task HandleSearchResultSelected((string filePath, int lineNumber) args)
    {
        await HandleFileSelected(args.filePath);

        if (editorId != null)
        {
            try
            {
                await JS.InvokeVoidAsync("monacoInterop.revealLine", editorId, args.lineNumber);
            }
            catch { }
        }

        sidebarMode = "files";
        StateHasChanged();
    }

    private async Task HandleSearchReplace((string search, string replace, string? filePath) args)
    {
        if (!UserService.IsLoggedIn) return;

        var filesToReplace = new List<string>();
        if (args.filePath != null)
        {
            filesToReplace.Add(args.filePath);
        }
        else
        {
            // Collect all unique file paths from current search results (we need to load them)
            // The search panel will have triggered a search, so we need to get the affected files
            // Do a search to find all affected files
            var results = await WebIdeService.SearchFilesAsync(RepoName, currentBranch, args.search);
            filesToReplace = results.Select(r => r.FilePath).Distinct().ToList();
        }

        foreach (var file in filesToReplace)
        {
            // Ensure file is loaded
            if (!fileContents.ContainsKey(file))
            {
                try
                {
                    var fc = await WebIdeService.GetFileContentAsync(RepoName, currentBranch, file);
                    fileContents[file] = fc.Content;

                    // Add to open tabs if not already
                    if (!openTabs.Any(t => t.FilePath == file))
                    {
                        openTabs.Add(new OpenTab
                        {
                            FilePath = file,
                            FileName = System.IO.Path.GetFileName(file),
                            IsDirty = false,
                            OriginalContent = fc.Content
                        });
                    }
                }
                catch { continue; }
            }

            // Do the replacement
            var content = fileContents[file];
            var newContent = content.Replace(args.search, args.replace, StringComparison.OrdinalIgnoreCase);
            if (content != newContent)
            {
                fileContents[file] = newContent;
                modifiedFiles.Add(file);

                var tab = openTabs.FirstOrDefault(t => t.FilePath == file);
                if (tab != null) tab.IsDirty = true;

                // Update Monaco model if it exists
                try
                {
                    await JS.InvokeAsync<int>("monacoInterop.replaceInModel", file, args.search, args.replace);
                }
                catch { }
            }
        }

        UpdatePendingChanges();
        StateHasChanged();
    }

    private async Task HandleBranchChanged(string newBranch)
    {
        currentBranch = newBranch;

        if (editorId != null)
        {
            foreach (var tab in openTabs.ToList())
            {
                try { await JS.InvokeVoidAsync("monacoInterop.closeFile", editorId, tab.FilePath); }
                catch { }
            }
        }

        openTabs.Clear();
        activeTabPath = null;
        modifiedFiles.Clear();
        fileContents.Clear();
        pendingChanges.Clear();
        isBlameActive = false;

        isLoading = true;
        StateHasChanged();

        try
        {
            treeNodes = await WebIdeService.GetFullTreeAsync(RepoName, currentBranch);
        }
        catch
        {
            treeNodes = new();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public Task OnCursorPositionChanged(int line, int column, int selection)
    {
        cursorLine = line;
        cursorColumn = column;
        selectionLength = selection;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnEditorContentChanged(string filePath)
    {
        var tab = openTabs.FirstOrDefault(t => t.FilePath == filePath);
        if (tab == null) return;

        if (editorId != null)
        {
            try
            {
                var content = await JS.InvokeAsync<string>("monacoInterop.getFileContent", editorId, filePath);
                fileContents[filePath] = content;

                var isDirty = content != tab.OriginalContent;
                tab.IsDirty = isDirty;

                if (isDirty)
                    modifiedFiles.Add(filePath);
                else
                    modifiedFiles.Remove(filePath);

                UpdatePendingChanges();
                await InvokeAsync(StateHasChanged);
            }
            catch { }
        }
    }

    private void UpdatePendingChanges()
    {
        pendingChanges = modifiedFiles
            .Select(path =>
            {
                var tab = openTabs.FirstOrDefault(t => t.FilePath == path);
                var content = fileContents.GetValueOrDefault(path, "");
                var action = string.IsNullOrEmpty(tab?.OriginalContent) ? "add" : "modify";
                return new FileChange(path, content, action);
            })
            .ToList();
    }

    // ---- Command Palette ----

    private async Task HandleCommand(string commandId)
    {
        switch (commandId)
        {
            case "quickOpen":
                showQuickOpen = true;
                break;
            case "search":
                sidebarMode = "search";
                break;
            case "toggleTerminal":
                ToggleTerminal();
                break;
            case "splitEditor":
                await ToggleSplitEditor();
                break;
            case "toggleTheme":
                await JS.InvokeVoidAsync("themeHelper.toggle");
                break;
            case "toggleBlame":
                await ToggleBlame();
                break;
            case "fileHistory":
                await ShowFileHistory();
                break;
            case "findReplace":
                if (editorId != null)
                    await JS.InvokeVoidAsync("monacoInterop.triggerFindReplace", editorId);
                break;
            case "closeTab":
                if (activeTabPath != null)
                    await HandleTabClosed(activeTabPath);
                break;
            case "closeAllTabs":
                foreach (var tab in openTabs.ToList())
                    await HandleTabClosed(tab.FilePath);
                break;
            case "sourceControl":
                sidebarMode = "sourcecontrol";
                break;
            case "settings":
                sidebarMode = "settings";
                break;
            case "explorer":
                sidebarMode = "files";
                break;
            case "showShortcuts":
                showShortcutHelp = true;
                break;
        }
        StateHasChanged();
    }

    // ---- Blame ----

    private async Task ToggleBlame()
    {
        if (isBlameActive)
        {
            isBlameActive = false;
            if (editorId != null)
            {
                try { await JS.InvokeVoidAsync("monacoInterop.clearBlameDecorations", editorId); }
                catch { }
            }
        }
        else
        {
            isBlameActive = true;
            await LoadBlameForCurrentFile();
        }
        StateHasChanged();
    }

    private async Task LoadBlameForCurrentFile()
    {
        if (activeTabPath == null || editorId == null) return;

        try
        {
            var blameData = await WebIdeService.GetFileBlameAsync(RepoName, currentBranch, activeTabPath);
            var jsBlameData = blameData.Select(h => new
            {
                startLine = h.StartLine,
                endLine = h.EndLine,
                commitSha = h.CommitSha,
                author = h.Author,
                date = h.Date.ToString("o"),
                message = h.Message
            }).ToArray();

            await JS.InvokeVoidAsync("monacoInterop.setBlameDecorations", editorId, jsBlameData);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load blame: {ex.Message}");
        }
    }

    // ---- File History ----

    private async Task ShowFileHistory()
    {
        if (activeTabPath == null) return;

        showHistory = true;
        bottomPanelMode = "history";
        isLoadingHistory = true;
        StateHasChanged();

        try

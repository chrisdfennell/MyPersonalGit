    private async Task OpenSplitEditor()
    {
        if (isSplit || editorId == null) return;

        isSplit = true;
        StateHasChanged();
        await Task.Delay(50);

        try
        {
            var editorOptions = new Dictionary<string, object>
            {
                { "fontSize", currentSettings?.FontSize ?? 14 },
                { "minimap", currentSettings?.MinimapEnabled ?? true }
            };

            splitEditorId = await JS.InvokeAsync<string>("monacoInterop.createSplitEditor",
                "monaco-container", editorId, editorOptions);

            if (currentSettings != null && splitEditorId != null)
            {
                await ApplySettingsToEditor(splitEditorId);
            }

            if (splitEditorId != null && dotNetRef != null)
            {
                await JS.InvokeVoidAsync("monacoInterop.onDidChangeContent", splitEditorId, dotNetRef, "OnEditorContentChanged");
            }

            if (activeTabPath != null && fileContents.ContainsKey(activeTabPath))
            {
                splitActiveTabPath = activeTabPath;
                await JS.InvokeVoidAsync("monacoInterop.openFile", splitEditorId, activeTabPath, fileContents[activeTabPath], !UserService.IsLoggedIn);
            }

            await JS.InvokeVoidAsync("monacoInterop.layout", editorId);
            await JS.InvokeVoidAsync("monacoInterop.layout", splitEditorId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Split editor error: {ex.Message}");
            isSplit = false;
            splitEditorId = null;
        }
    }

    private async Task CloseSplitEditor()
    {
        if (!isSplit || splitEditorId == null) return;

        try
        {
            await JS.InvokeVoidAsync("monacoInterop.closeSplitEditor", splitEditorId, "monaco-container");
        }
        catch { }

        splitEditorId = null;
        splitActiveTabPath = null;
        isSplit = false;
        activePane = 1;
        StateHasChanged();

        if (editorId != null)

@page "/repo/{RepoName}/ide"
@page "/repo/{RepoName}/ide/{*FilePath}"
@layout IdeLayout
@rendermode InteractiveServer
@using MyPersonalGit.Data
@using MyPersonalGit.Services
@using MyPersonalGit.Components.Shared
@using static MyPersonalGit.Components.Shared.IdeTabBar
@using static MyPersonalGit.Components.Shared.IdeSettingsPanel
@inject IWebIdeService WebIdeService
@inject IJSRuntime JS
@inject IConfiguration Config
@inject NavigationManager Navigation
@inject CurrentUserService UserService
@inject IAdminService AdminService
@inject IAiCompletionService AiCompletionService
@inject IAiChatService AiChatService
@using Microsoft.Extensions.Localization
@using MyPersonalGit.Resources
@inject IStringLocalizer<SharedResource> L
@implements IAsyncDisposable

<div class="ide-container @(isZenMode ? "ide-zen-mode" : "")" @onkeydown="HandleGlobalKeyDown" tabindex="0" @ref="ideContainerRef">
    @if (isZenMode)
    {
        <button class="ide-zen-exit" @onclick="ToggleZenMode" title="Exit Zen Mode (Esc)">
            <i class="bi bi-fullscreen-exit"></i>
        </button>
    }
    <div class="ide-sidebar" style="@(sidebarWidth > 0 ? $"width:{sidebarWidth}px;" : "")">
        <div class="ide-sidebar-tabs">
            <button class="ide-sidebar-tab @(sidebarMode == "files" ? "active" : "")" @onclick='() => ToggleSidebarMode("files")' title="@L["Ide_Explorer"]">
                <i class="bi bi-files"></i>
            </button>
            <button class="ide-sidebar-tab @(sidebarMode == "search" ? "active" : "")" @onclick='() => ToggleSidebarMode("search")' title="@L["Ide_Search"]">
                <i class="bi bi-search"></i>
            </button>
            <button class="ide-sidebar-tab @(sidebarMode == "sourcecontrol" ? "active" : "")" @onclick='() => ToggleSidebarMode("sourcecontrol")' title="@L["Ide_SourceControl"]">
                <i class="bi bi-git"></i>
            </button>
            <button class="ide-sidebar-tab @(sidebarMode == "outline" ? "active" : "")" @onclick="OpenOutlinePanel" title="@L["Ide_Outline"]">
                <i class="bi bi-list-nested"></i>
            </button>
            <button class="ide-sidebar-tab @(sidebarMode == "debug" ? "active" : "")" @onclick='() => ToggleSidebarMode("debug")' title="Debug">
                <i class="bi bi-bug"></i>
            </button>
            @if (aiChatEnabled)
            {
                <button class="ide-sidebar-tab @(sidebarMode == "aichat" ? "active" : "")" @onclick='() => ToggleSidebarMode("aichat")' title="AI Assistant">
                    <i class="bi bi-stars" style="@(sidebarMode == "aichat" ? "color:#c084fc;" : "")"></i>
                </button>
            }
            <button class="ide-sidebar-tab @(sidebarMode == "branchdiff" ? "active" : "")" @onclick='() => ToggleSidebarMode("branchdiff")' title="Branch Diff">
                <i class="bi bi-arrow-left-right"></i>
            </button>
            <button class="ide-sidebar-tab @(sidebarMode == "settings" ? "active" : "")" @onclick='() => ToggleSidebarMode("settings")' title="@L["Ide_Settings"]" style="margin-top: auto;">
                <i class="bi bi-gear"></i>
            </button>
        </div>
        <div class="ide-sidebar-content">
            @if (sidebarMode == "files")
            {
                <IdeFileTree Nodes="treeNodes"
                             ActiveFilePath="@activeTabPath"
                             ModifiedFiles="modifiedFiles"
                             CanEdit="UserService.IsLoggedIn"
                             OnFileSelected="HandleFileSelected"
                             OnNewFile="HandleNewFile"
                             OnNewFolder="HandleNewFolder"
                             OnDeletePath="HandleDeletePath"
                             OnRenamePath="HandleRenamePath" />
            }
            else if (sidebarMode == "search")
            {
                <IdeSearchPanel RepoName="@RepoName"
                                Branch="@currentBranch"
                                OnResultSelected="HandleSearchResultSelected"
                                OnReplace="HandleSearchReplace" />
            }
            else if (sidebarMode == "sourcecontrol")
            {
                <div class="ide-source-control">
                    <div class="ide-sc-header px-3 py-2">
                        <span class="small fw-semibold">@L["Ide_SourceControl"]</span>
                        @if (modifiedFiles.Count > 0)
                        {
                            <span class="badge bg-primary rounded-pill ms-2">@modifiedFiles.Count</span>
                        }
                    </div>
                    @if (modifiedFiles.Count == 0)
                    {
                        <div class="text-muted small px-3 py-2">
                            <i class="bi bi-check-circle me-1"></i>@L["Ide_NoChanges"]
                        </div>
                    }
                    else
                    {
                        <div class="ide-sc-files">
                            @foreach (var filePath in modifiedFiles)
                            {
                                var fileName = System.IO.Path.GetFileName(filePath);
                                <div class="ide-sc-file" @onclick="() => OpenDiffView(filePath)" title="@L["Ide_ClickViewDiff"]">
                                    <i class="bi bi-file-earmark-diff me-2 text-warning"></i>
                                    <span class="ide-sc-filename">@fileName</span>
                                    <span class="ide-sc-filepath text-muted ms-2">@filePath</span>
                                </div>
                            }
                        </div>
                        @if (UserService.IsLoggedIn && modifiedFiles.Count > 0)
                        {
                            <div class="px-3 py-2 border-top" style="border-color: #3c3c3c !important;">
                                <div class="input-group input-group-sm">
                                    <input type="text" class="form-control" style="background:#3c3c3c;border-color:#555;color:#ccc;"
                                           @bind="stashMessage" placeholder="@L["Ide_StashMessage"]" />
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="StashChanges" title="@L["Ide_StashChanges"]">
                                        <i class="bi bi-archive"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    }

                    <!-- Stashes -->
                    <div class="ide-sc-header px-3 py-2" style="border-top: 1px solid #3c3c3c;">
                        <span class="small fw-semibold">@L["Ide_Stash"]</span>
                        <button class="btn btn-sm btn-link text-muted p-0 ms-auto" @onclick="LoadStashes" title="@L["Ide_Refresh"]">
                            <i class="bi bi-arrow-clockwise"></i>
                        </button>
                    </div>
                    @if (isLoadingStashes)
                    {
                        <div class="text-center py-2"><span class="spinner-border spinner-border-sm text-muted"></span></div>
                    }
                    else if (stashes.Count == 0)
                    {
                        <div class="text-muted small px-3 py-1"><i class="bi bi-archive me-1"></i>@L["Ide_NoStashes"]</div>
                    }
                    else
                    {
                        <div class="ide-sc-files">
                            @foreach (var stash in stashes)
                            {
                                <div class="ide-sc-file">
                                    <i class="bi bi-archive me-2 text-info"></i>
                                    <span class="ide-sc-filename" style="font-size:0.75rem;">@stash.Message</span>
                                    <span class="ms-auto d-flex gap-1">
                                        <button class="btn btn-link btn-sm text-muted p-0" @onclick="() => ApplyStash(stash.Index)" title="@L["Ide_ApplyStash"]">
                                            <i class="bi bi-box-arrow-down" style="font-size:0.7rem;"></i>
                                        </button>
                                        <button class="btn btn-link btn-sm text-muted p-0" @onclick="() => DropStash(stash.Index)" title="@L["Ide_DropStash"]">
                                            <i class="bi bi-trash" style="font-size:0.7rem;"></i>
                                        </button>
                                    </span>
                                </div>
                            }
                        </div>
                        <div class="px-3 py-1">
                            <button class="btn btn-outline-info btn-sm w-100" @onclick="PopStash">
                                <i class="bi bi-box-arrow-up me-1"></i>@L["Ide_PopStash"]
                            </button>
                        </div>
                    }
                </div>
            }
            else if (sidebarMode == "outline")
            {
                <div class="ide-source-control">
                    <div class="ide-sc-header px-3 py-2">
                        <span class="small fw-semibold">@L["Ide_Outline"]</span>
                        @if (activeTabPath != null)
                        {
                            <button class="btn btn-sm btn-link text-muted p-0 ms-auto" @onclick="RefreshOutline" title="@L["Ide_Refresh"]">
                                <i class="bi bi-arrow-clockwise"></i>
                            </button>
                        }
                    </div>
                    @if (activeTabPath == null)
                    {
                        <div class="text-muted small px-3 py-2">
                            <i class="bi bi-info-circle me-1"></i>@L["Ide_OpenFileOutline"]
                        </div>
                    }
                    else if (isLoadingOutline)
                    {
                        <div class="text-center py-3">
                            <span class="spinner-border spinner-border-sm text-muted"></span>
                        </div>
                    }
                    else if (outlineSymbols.Count == 0)
                    {
                        <div class="text-muted small px-3 py-2">
                            <i class="bi bi-info-circle me-1"></i>@L["Ide_NoSymbolsFound"]
                        </div>
                    }
                    else
                    {
                        <div class="ide-sc-files">
                            @foreach (var symbol in outlineSymbols)
                            {
                                <div class="ide-sc-file" @onclick="() => GoToSymbol(symbol)" title="@symbol.Name — Line @symbol.Line">
                                    <i class="bi @GetSymbolIcon(symbol.Kind) me-2" style="color: @GetSymbolColor(symbol.Kind);"></i>
                                    <span class="ide-sc-filename">@symbol.Name</span>
                                    <span class="ide-sc-filepath text-muted ms-2">Ln @symbol.Line</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else if (sidebarMode == "debug")
            {
                <div class="p-2">
                    <div class="small fw-semibold mb-2"><i class="bi bi-bug me-1"></i>Debug</div>
                    <div class="mb-2">
                        <select class="form-select form-select-sm" style="font-size:0.78rem;background:#3c3c3c;border-color:#555;color:#ccc;" @bind="selectedDebugLanguage">
                            <option value="">Auto-detect</option>
                            <option value="python">Python (debugpy)</option>
                            <option value="csharp">C# (netcoredbg)</option>
                            <option value="javascript">JavaScript (js-debug)</option>
                            <option value="typescript">TypeScript (js-debug)</option>
                            <option value="go">Go (Delve)</option>
                            <option value="rust">Rust (lldb-dap)</option>
                            <option value="java">Java (JDWP)</option>
                        </select>
                    </div>
                    <div class="d-flex gap-1 mb-2">
                        @if (!isDebugging)
                        {
                            <button class="btn btn-sm btn-success flex-fill" @onclick="StartDebugSession" disabled="@(activeTabPath == null)">
                                <i class="bi bi-play-fill me-1"></i>Start
                            </button>
                        }
                        else
                        {
                            @if (isDebugPaused)
                            {
                                <button class="btn btn-sm btn-primary" @onclick="DebugContinue" title="Continue (F5)"><i class="bi bi-play-fill"></i></button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="DebugStepOver" title="Step Over (F10)"><i class="bi bi-skip-forward"></i></button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="DebugStepIn" title="Step In (F11)"><i class="bi bi-box-arrow-in-down"></i></button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="DebugStepOut" title="Step Out"><i class="bi bi-box-arrow-up"></i></button>
                            }
                            <button class="btn btn-sm btn-danger ms-auto" @onclick="StopDebugSession"><i class="bi bi-stop-fill"></i></button>
                        }
                    </div>
                    @if (isDebugging && debugCallStack.Count > 0)
                    {
                        <div class="small fw-semibold mb-1">Call Stack</div>
                        <div class="mb-2" style="max-height: 200px; overflow-y: auto;">
                            @foreach (var frame in debugCallStack)
                            {
                                <div class="ide-problems-item" style="padding: 2px 4px;" @onclick="() => NavigateToDebugFrame(frame)">
                                    <span class="text-truncate">@frame.Name</span>
                                    <span class="text-muted small ms-auto">:@frame.Line</span>
                                </div>
                            }
                        </div>
                    }
                    @if (isDebugging && debugVariables.Count > 0)
                    {
                        <div class="small fw-semibold mb-1">Variables</div>
                        <div style="max-height: 300px; overflow-y: auto;">
                            @foreach (var v in debugVariables)
                            {
                                <div style="font-size: 0.75rem; padding: 1px 4px; display: flex; gap: 4px;">
                                    <span style="color: #4fc1ff;">@v.Name</span>
                                    <span class="text-muted">=</span>
                                    <span class="text-truncate" style="color: #ce9178;">@v.Value</span>
                                </div>
                            }
                        </div>
                    }
                    @if (debugOutput.Count > 0)
                    {
                        <div class="small fw-semibold mb-1 mt-2">Output</div>
                        <div style="max-height: 200px; overflow-y: auto; font-size: 0.72rem; font-family: monospace; background: #1e1e1e; padding: 4px; border-radius: 3px;">
                            @foreach (var o in debugOutput)
                            {
                                <div style="color: @(o.Category == "stderr" ? "#f85149" : "#ccc"); white-space: pre-wrap;">@o.Text</div>
                            }
                        </div>
                    }
                </div>
            }
            else if (sidebarMode == "branchdiff")
            {
                <div class="p-2">
                    <div class="small fw-semibold mb-2">Branch Diff</div>
                    <label class="form-label small mb-1">Base</label>
                    <select class="form-select form-select-sm mb-2" style="font-size:0.78rem;" @bind="branchDiffBase">
                        @foreach (var b in branches)
                        {
                            <option value="@b">@b</option>
                        }
                    </select>
                    <label class="form-label small mb-1">Compare</label>
                    <select class="form-select form-select-sm mb-2" style="font-size:0.78rem;" @bind="branchDiffCompare">
                        @foreach (var b in branches)
                        {
                            <option value="@b">@b</option>
                        }
                    </select>
                    <button class="btn btn-sm btn-primary w-100 mb-2" @onclick="LoadBranchDiff"
                            disabled="@(branchDiffBase == branchDiffCompare || isLoadingBranchDiff)">
                        <i class="bi bi-arrow-left-right me-1"></i>Compare
                    </button>
                    @if (isLoadingBranchDiff)
                    {
                        <div class="text-center py-2"><span class="spinner-border spinner-border-sm text-muted"></span></div>
                    }
                    @if (branchDiffFiles.Count > 0)
                    {
                        <div class="small text-muted mb-1">@branchDiffFiles.Count file(s) changed</div>
                        <div style="overflow-y:auto; max-height: calc(100vh - 300px);">
                            @foreach (var f in branchDiffFiles)
                            {
                                <div class="ide-sc-file @(f.Path == branchDiffSelectedFile ? "active" : "")" style="cursor:pointer; padding: 3px 6px; font-size: 0.78rem;"
                                     @onclick="() => ViewBranchDiffFile(f.Path, f.Status)">
                                    <span class="me-1 fw-bold" style="color: @(f.Status == "Added" ? "#2ea043" : f.Status == "Deleted" ? "#f85149" : f.Status == "Renamed" ? "#d29922" : "#0078d4")">
                                        @(f.Status == "Added" ? "A" : f.Status == "Deleted" ? "D" : f.Status == "Renamed" ? "R" : "M")
                                    </span>
                                    <span class="text-truncate">@f.Path</span>
                                </div>
                            }
                        </div>
                    }
                    @if (showBranchDiff)
                    {
                        <button class="btn btn-sm btn-outline-secondary w-100 mt-2" @onclick="CloseBranchDiffEditor">
                            <i class="bi bi-x me-1"></i>Close Diff
                        </button>
                    }
                </div>
            }
            else if (sidebarMode == "aichat" && aiChatEnabled)
            {
                <IdeAiChatPanel SelectedCode="@aiSelectedCode"
                                Language="@GetLanguageDisplayName(activeTabPath)"
                                FileName="@(activeTabPath != null ? System.IO.Path.GetFileName(activeTabPath) : null)"
                                FileContent="@GetCurrentFileContent()"
                                OnApplyCode="HandleAiApplyCode"
                                OnInsertNewFile="HandleAiInsertNewFile" />
            }
            else if (sidebarMode == "settings")
            {
                <IdeSettingsPanel EditorId="@editorId"
                                  SplitEditorId="@splitEditorId"
                                  OnSettingsChanged="HandleSettingsChanged" />
            }
        </div>
    </div>
    <div class="ide-resize-handle ide-resize-sidebar" style="left: @(sidebarWidth > 0 ? sidebarWidth : 280)px;" @onmousedown="StartSidebarResize"></div>

    <div class="ide-tabs">
        <div class="ide-tabs-row">
            <IdeTabBar Tabs="openTabs"
                       ActiveTabPath="@activeTabPath"
                       OnTabSelected="HandleTabSelected"
                       OnTabClosed="HandleTabClosed"
                       OnTabReordered="HandleTabReordered"
                       OnTabPinToggled="HandleTabPinToggled" />
            @if (openTabs.Count > 0)
            {
                @if (activeTabPath != null && IsMarkdownFile(activeTabPath))
                {
                    <button class="ide-action-btn @(showMarkdownPreview ? "active" : "")" @onclick="ToggleMarkdownPreview" title="@L["Ide_TogglePreview"]">
                        <i class="bi bi-eye"></i>
                    </button>
                }
                <button class="ide-action-btn @(isBlameActive ? "active" : "")" @onclick="ToggleBlame" title="@(isBlameActive ? L["Ide_HideGitBlame"] : L["Ide_ShowGitBlame"])">
                    <i class="bi bi-person-lines-fill"></i>
                </button>
                <button class="ide-action-btn" @onclick="ShowFileHistory" title="@L["Ide_FileHistory"]">
                    <i class="bi bi-clock-history"></i>
                </button>
                <button class="ide-action-btn" @onclick="HandleToggleMinimap" title="@L["Ide_ToggleMinimap"]">
                    <i class="bi bi-map"></i>
                </button>
                <button class="ide-split-btn" @onclick="ToggleSplitEditor" title="@(isSplit ? L["Ide_CloseSplit"] : L["Ide_SplitEditor"])">
                    <i class="bi @(isSplit ? "bi-layout-sidebar-reverse" : "bi-layout-split")"></i>
                </button>
            }
        </div>
    </div>

    @if (activeTabPath != null && !showDiffView)
    {
        <div class="ide-breadcrumbs">
            <span class="ide-breadcrumb" @onclick='() => sidebarMode = "files"'>@RepoName</span>
            @foreach (var segment in GetBreadcrumbSegments(activeTabPath))
            {
                <i class="bi bi-chevron-right ide-breadcrumb-sep"></i>
                <span class="ide-breadcrumb-wrapper">
                    <span class="ide-breadcrumb @(segment.IsLast ? "active" : "")"
                          @onclick="() => { if (!segment.IsLast) ShowBreadcrumbSiblings(segment.Path); else ShowBreadcrumbSiblings(GetParentBreadcrumbPath(segment.Path)); }">@segment.Name</span>
                    @if (breadcrumbDropdownPath != null && (breadcrumbDropdownPath == segment.Path || (segment.IsLast && breadcrumbDropdownPath == GetParentBreadcrumbPath(segment.Path))))
                    {
                        <div class="ide-breadcrumb-dropdown">
                            @if (breadcrumbSiblings != null)
                            {
                                @foreach (var sibling in breadcrumbSiblings.Take(20))
                                {
                                    var sibIsFolder = sibling.Type == "tree";
                                    <div class="ide-breadcrumb-item @(sibling.Path == activeTabPath ? "active" : "")"
                                         @onclick="() => BreadcrumbSiblingClicked(sibling)">
                                        <i class="bi @(sibIsFolder ? "bi-folder text-warning" : "bi-file-earmark text-muted") me-2" style="font-size:0.75rem;"></i>
                                        <span>@sibling.Name</span>
                                    </div>
                                }
                            }
                        </div>
                    }
                </span>
            }
            @if (breadcrumbDropdownPath != null)
            {
                <div class="ide-breadcrumb-backdrop" @onclick="() => breadcrumbDropdownPath = null"></div>
            }
        </div>
    }

    <div class="ide-editor">
        @if (isLoading)
        {
            <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                <span class="spinner-border spinner-border-sm me-2"></span>@L["Ide_Loading"]
            </div>
        }
        else if (openTabs.Count == 0 && !showDiffView)
        {
            <div class="ide-welcome d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                <i class="bi bi-braces display-3 mb-3 opacity-25"></i>
                <h5 class="fw-light opacity-50">@L["Ide_WebIde"]</h5>
                <p class="small opacity-50">@L["Ide_WelcomeMessage"] <kbd>Ctrl+P</kbd> @L["Ide_ToGetStarted"]</p>
                <div class="mt-3 small opacity-50">
                    <p class="mb-1"><kbd>Ctrl+Shift+P</kbd> @L["Ide_Commands"] &middot; <kbd>Ctrl+P</kbd> @L["Ide_QuickOpen"] &middot; <kbd>Ctrl+`</kbd> @L["Ide_Terminal"] &middot; <kbd>?</kbd> @L["Ide_Shortcuts"]</p>
                </div>
            </div>
        }

        @if (showDiffView)
        {
            <div class="ide-diff-header px-3 py-1">
                <i class="bi bi-file-earmark-diff me-2"></i>
                <span class="small">@L["Ide_Diff"]: @diffFilePath</span>
                <button class="btn btn-sm btn-link text-muted ms-auto p-0" @onclick="CloseDiffView">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div id="diff-editor-container" style="width: 100%; flex: 1;"></div>
        }
        else if (showBranchDiff)
        {
            <div class="ide-diff-header px-3 py-1">
                <i class="bi bi-arrow-left-right me-2"></i>
                <span class="small">@branchDiffBase ... @branchDiffCompare : @branchDiffSelectedFile</span>
                <button class="btn btn-sm btn-link text-muted ms-auto p-0" @onclick="CloseBranchDiffEditor">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div id="branch-diff-editor-container" style="width: 100%; flex: 1;"></div>
        }
        else if (activeTabPath != null && IsImageFile(activeTabPath))
        {
            <div class="ide-preview ide-image-preview">
                <img src="/api/v1/ide/@RepoName/raw/@activeTabPath?branch=@Uri.EscapeDataString(currentBranch)" alt="@System.IO.Path.GetFileName(activeTabPath)" />
            </div>
        }
        else
        {
            @if (activeTabPath != null && IsMarkdownFile(activeTabPath) && showMarkdownPreview)
            {
                <div class="ide-preview ide-markdown-preview">
                    <div class="ide-markdown-toolbar">
                        <button class="ide-action-btn active" title="@L["Ide_Preview"]">
                            <i class="bi bi-eye"></i>
                        </button>
                        <button class="ide-action-btn" @onclick="ExitMarkdownPreview" title="@L["Ide_Edit"]">
                            <i class="bi bi-pencil"></i>
                        </button>
                    </div>
                    <div class="ide-markdown-body" id="markdown-preview-container">
                        @((MarkupString)renderedMarkdown)
                    </div>
                </div>
            }
            @if (activeTabPath != null && IsMarkdownFile(activeTabPath) && !showMarkdownPreview)
            {
                <div class="ide-markdown-toolbar" style="position: absolute; top: 4px; right: 20px; z-index: 5;">
                    <button class="ide-action-btn" @onclick="ToggleMarkdownPreview" title="@L["Ide_Preview"]">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
            }
            <div class="ide-editor-panes @(isSplit ? "split" : "")" style="@(openTabs.Count == 0 || showMarkdownPreview ? "display: none;" : "")">
                <div id="monaco-container" class="ide-pane" @onclick="() => SetActivePane(1)"></div>
                @if (isSplit)
                {
                    <div class="ide-pane-divider"></div>
                    <div id="monaco-container-split" class="ide-pane" @onclick="() => SetActivePane(2)"></div>
                }
            </div>
        }
    </div>

    <div class="ide-bottom-panel @(showHistory ? "expanded" : "")" style="@(bottomPanelHeight > 0 ? $"max-height:{bottomPanelHeight}px;height:{bottomPanelHeight}px;" : "")">
        <div class="ide-resize-bottom" @onmousedown="StartBottomResize"></div>
        <div class="ide-bottom-tabs">
            <button class="ide-bottom-tab @(bottomPanelMode == "commits" ? "active" : "")" @onclick='() => bottomPanelMode = "commits"'>
                <i class="bi bi-git me-1"></i>@L["Ide_Commits"]
            </button>
            <button class="ide-bottom-tab @(bottomPanelMode == "graph" ? "active" : "")" @onclick="LoadCommitGraph">
                <i class="bi bi-diagram-3 me-1"></i>@L["Ide_Graph"]
            </button>
            <button class="ide-bottom-tab @(bottomPanelMode == "problems" ? "active" : "")" @onclick='() => bottomPanelMode = "problems"'>
                <i class="bi bi-exclamation-triangle me-1"></i>Problems
                @if (errorCount > 0)
                {
                    <span class="ide-problems-badge ide-badge-error">@errorCount</span>
                }
                @if (warningCount > 0)
                {
                    <span class="ide-problems-badge ide-badge-warning">@warningCount</span>
                }
            </button>
            <button class="ide-bottom-tab @(bottomPanelMode == "tasks" ? "active" : "")" @onclick='() => bottomPanelMode = "tasks"'>
                <i class="bi bi-play-circle me-1"></i>Tasks
            </button>
            <button class="ide-bottom-tab @(bottomPanelMode == "terminal" ? "active" : "")" @onclick="ToggleTerminal">
                <i class="bi bi-terminal me-1"></i>@L["Ide_Terminal"]
            </button>
            @if (bottomPanelMode == "terminal")
            {
                @foreach (var term in terminalTabs)
                {
                    <button class="ide-bottom-tab ide-term-tab @(term.Id == activeTerminalId ? "active" : "")"
                            @onclick="() => SwitchTerminal(term.Id)">
                        @term.Name
                        @if (terminalTabs.Count > 1)
                        {
                            <span class="ide-term-close" @onclick="() => CloseTerminal(term.Id)" @onclick:stopPropagation="true">
                                <i class="bi bi-x"></i>
                            </span>
                        }
                    </button>
                }
                <button class="ide-bottom-tab ide-term-add" @onclick="AddTerminal" title="@L["Ide_NewTerminal"]">
                    <i class="bi bi-plus"></i>
                </button>
            }
            @if (showHistory)
            {
                <button class="ide-bottom-tab @(bottomPanelMode == "history" ? "active" : "")" @onclick='() => bottomPanelMode = "history"'>
                    <i class="bi bi-clock-history me-1"></i>@L["Ide_History"]
                    <button class="btn btn-sm btn-link text-muted p-0 ms-1" @onclick="CloseHistory" @onclick:stopPropagation="true">
                        <i class="bi bi-x"></i>
                    </button>
                </button>
            }
        </div>
        @if (bottomPanelMode == "commits")
        {
            <IdeCommitPanel Changes="pendingChanges"
                            OnCommit="HandleCommit"
                            IsCommitting="isCommitting" />
        }
        else if (bottomPanelMode == "graph")
        {
            <div class="ide-graph-panel" style="flex: 1; overflow: auto;">
                @if (isLoadingGraph)
                {
                    <div class="text-center py-3"><span class="spinner-border spinner-border-sm text-muted"></span></div>
                }
                else if (commitGraph.Count == 0)
                {
                    <div class="text-muted small px-3 py-2">@L["Ide_NoCommits"]</div>
                }
                else
                {
                    <table class="ide-graph-table">
                        @foreach (var entry in commitGraph)
                        {
                            <tr class="ide-graph-row">
                                <td class="ide-graph-line" style="width: @((maxGraphColumn + 1) * 16 + 8)px;">
                                    <svg height="24" width="@((maxGraphColumn + 1) * 16 + 8)">
                                        <circle cx="@(entry.Column * 16 + 8)" cy="12" r="4" fill="@GetGraphColor(entry.Column)" />
                                        @foreach (var parentSha in entry.ParentShas)
                                        {
                                            var parentEntry = commitGraph.FirstOrDefault(e => e.Sha == parentSha);
                                            if (parentEntry != null)
                                            {
                                                var px = parentEntry.Column * 16 + 8;
                                                var cx = entry.Column * 16 + 8;
                                                <line x1="@cx" y1="12" x2="@px" y2="24" stroke="@GetGraphColor(Math.Min(entry.Column, parentEntry.Column))" stroke-width="1.5" />
                                            }
                                        }
                                    </svg>
                                </td>
                                <td class="ide-graph-sha"><code>@entry.ShortSha</code></td>
                                <td class="ide-graph-msg">
                                    @entry.Message
                                    @foreach (var b in entry.Branches)
                                    {
                                        <span class="ide-graph-branch">@b</span>
                                    }
                                </td>
                                <td class="ide-graph-author">@entry.Author</td>
                                <td class="ide-graph-date">@entry.Date.LocalDateTime.ToString("MMM dd")</td>
                            </tr>
                        }
                    </table>
                }
            </div>
        }
        else if (bottomPanelMode == "problems")
        {
            <div class="ide-problems-panel">
                @if (allDiagnostics.Count == 0)
                {
                    <div class="text-muted small px-3 py-2">No problems detected.</div>
                }
                else
                {
                    @foreach (var group in allDiagnostics.GroupBy(d => d.FilePath))
                    {
                        <div class="ide-problems-file">
                            <div class="ide-problems-file-header">
                                <i class="bi bi-file-earmark-code me-1"></i>
                                <span>@System.IO.Path.GetFileName(group.Key)</span>
                                <span class="text-muted ms-1 small">@group.Key</span>
                                <span class="ide-problems-count ms-auto">@group.Count()</span>
                            </div>
                            @foreach (var diag in group.OrderBy(d => d.StartLineNumber))
                            {
                                <div class="ide-problems-item" @onclick="() => NavigateToDiagnostic(diag)">
                                    <i class="bi @(diag.Severity == 8 ? "bi-x-circle-fill text-danger" : diag.Severity == 4 ? "bi-exclamation-triangle-fill text-warning" : "bi-info-circle-fill text-info") me-1"></i>
                                    <span class="ide-problems-msg">@diag.Message</span>
                                    <span class="text-muted small ms-auto">[@diag.StartLineNumber, @diag.StartColumn]</span>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        }
        else if (bottomPanelMode == "tasks")
        {
            <div class="ide-taskrunner">
                <div class="ide-taskrunner-toolbar">
                    <select @bind="selectedTask" class="ide-taskrunner-select">
                        @foreach (var task in availableTasks)
                        {
                            <option value="@task.Command">@task.Label</option>
                        }
                    </select>
                    <input @bind="customTaskCommand" class="ide-taskrunner-select" style="flex:1;" placeholder="or type a command..." />
                    <button class="ide-taskrunner-run" @onclick="RunTask" disabled="@isTaskRunning">
                        <i class="bi bi-play-fill"></i> Run
                    </button>
                    @if (isTaskRunning)
                    {
                        <button class="ide-taskrunner-stop" @onclick="StopTask">
                            <i class="bi bi-stop-fill"></i> Stop
                        </button>
                    }
                    <button class="ide-taskrunner-clear" @onclick="ClearTaskOutput">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
                <div class="ide-taskrunner-output">
                    @foreach (var line in taskOutputLines)
                    {
                        <div class="ide-taskrunner-line @(line.IsError ? "ide-taskrunner-stderr" : "")">
                            @if (line.FilePath != null)
                            {
                                <span class="ide-taskrunner-link" @onclick="() => NavigateToTaskError(line)">@line.Text</span>
                            }
                            else
                            {
                                @line.Text
                            }
                        </div>
                    }
                    @if (taskExitCode.HasValue)
                    {
                        <div class="ide-taskrunner-line" style="color: @(taskExitCode == 0 ? "#2ea043" : "#f85149"); font-weight: 600; margin-top: 4px;">
                            Process exited with code @taskExitCode
                        </div>
                    }
                </div>
            </div>
        }
        else if (bottomPanelMode == "terminal")
        {
            <div class="ide-terminal-wrapper">
                @foreach (var term in terminalTabs)
                {
                    <div style="@(term.Id == activeTerminalId ? "" : "display:none;") width:100%; height:100%;">
                        <IdeTerminal RepoName="@RepoName" IsVisible="@(bottomPanelMode == "terminal" && term.Id == activeTerminalId)" />
                    </div>
                }
            </div>
        }
        else if (bottomPanelMode == "history" && showHistory)
        {
            <div class="ide-history-panel">
                <div class="ide-history-header px-3 py-1">
                    <i class="bi bi-clock-history me-1"></i>
                    <span class="small fw-semibold">History: @(activeTabPath != null ? System.IO.Path.GetFileName(activeTabPath) : "")</span>
                </div>
                @if (isLoadingHistory)
                {
                    <div class="text-center py-3">
                        <span class="spinner-border spinner-border-sm text-muted"></span>
                    </div>
                }
                else if (fileHistory.Count == 0)
                {
                    <div class="text-muted small px-3 py-2">@L["Ide_NoHistoryFound"]</div>
                }
                else
                {
                    <div class="ide-history-list">
                        @foreach (var entry in fileHistory)
                        {
                            <div class="ide-history-entry px-3 py-2">
                                <div class="d-flex align-items-center">
                                    <code class="text-info me-2">@entry.ShortSha</code>
                                    <span class="small fw-semibold text-truncate">@entry.Message</span>
                                </div>
                                <div class="small text-muted mt-1">
                                    <i class="bi bi-person me-1"></i>@entry.Author
                                    <span class="ms-2"><i class="bi bi-calendar me-1"></i>@entry.Date.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <div class="ide-status-bar">
        <div class="ide-status-left">
            <span class="ide-status-item" title="@L["Ide_Branch"]">
                <i class="bi bi-git me-1"></i>@currentBranch
            </span>
            @if (modifiedFiles.Count > 0)
            {
                <span class="ide-status-item text-warning" title="@L["Ide_UnsavedChanges"]">
                    <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>@modifiedFiles.Count @L["Ide_Change"]
                </span>
            }
            @if (errorCount > 0 || warningCount > 0)
            {
                <button class="ide-status-item ide-status-btn" @onclick='() => bottomPanelMode = "problems"' title="Problems">
                    @if (errorCount > 0)
                    {
                        <i class="bi bi-x-circle-fill me-1" style="color:#f85149;font-size:0.6rem;"></i><span>@errorCount</span>
                    }
                    @if (warningCount > 0)
                    {
                        <i class="bi bi-exclamation-triangle-fill ms-1 me-1" style="color:#d29922;font-size:0.6rem;"></i><span>@warningCount</span>
                    }
                </button>
            }
        </div>
        <div class="ide-status-right">
            @if (activeTabPath != null)
            {
                <span class="ide-status-item" title="@L["Ide_CursorPosition"]">
                    Ln @cursorLine, Col @cursorColumn
                </span>
                @if (selectionLength > 0)
                {
                    <span class="ide-status-item" title="@L["Ide_Selection"]">
                        (@selectionLength @L["Ide_Selected"])
                    </span>
                }
                <button class="ide-status-item ide-status-btn" @onclick="HandleToggleWordWrap" title="@L["Ide_ToggleWordWrap"]">
                    <i class="bi bi-text-wrap me-1"></i>@(currentWordWrap == "on" ? L["Ide_WrapOn"] : L["Ide_WrapOff"])
                </button>
                <span class="ide-status-item" title="@L["Ide_Language"]">
                    @GetLanguageDisplayName(activeTabPath)
                </span>
                <span class="ide-status-item" title="@L["Ide_Encoding"]">
                    UTF-8
                </span>
            }
            @{ var lspLang = GetLspLanguage(activeTabPath); }
            @if (lspLang != null)
            {
                var status = lspStatus.GetValueOrDefault(lspLang, "inactive");
                var color = status == "running" ? "#3c3" : status == "error" ? "#c33" : "#888";
                <span class="ide-status-item" title="LSP: @lspLang (@status)">
                    <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem; color: @color;"></i>LSP
                </span>
            }
            @if (aiCompletionEnabled)
            {
                <span class="ide-status-item" title="AI Code Completion">
                    <i class="bi bi-stars me-1" style="color:#c084fc;"></i>AI
                </span>
            }
            @if (collabEnabled)
            {
                <button class="ide-status-item ide-status-btn" @onclick="ToggleCollaboration" title="@(collabActive ? "Leave collaboration" : "Start collaboration")">
                    <i class="bi bi-people-fill me-1" style="color: @(collabActive ? "#2ea043" : "#888");"></i>
                    @if (collabActive)
                    {
                        <span>@(collabParticipantCount + 1)</span>
                    }
                    else
                    {
                        <span>Collab</span>
                    }
                </button>
            }
            <button class="ide-status-item ide-status-btn" @onclick="ToggleZenMode" title="@L["Ide_ZenMode"]">
                <i class="bi bi-arrows-fullscreen"></i>
            </button>
            <button class="ide-status-item ide-status-btn" @onclick="() => { showShortcutHelp = true; StateHasChanged(); }" title="@L["Ide_KeyboardShortcuts"]">
                <i class="bi bi-keyboard me-1"></i>@L["Ide_Shortcuts"]
            </button>
        </div>
    </div>
</div>

@if (showQuickOpen)
{
    <IdeQuickOpen TreeNodes="treeNodes"
                  RecentFiles="recentFiles"
                  OnFileSelected="HandleFileSelected"
                  OnClose="() => { showQuickOpen = false; StateHasChanged(); }" />
}

@if (showCommandPalette)
{
    <IdeCommandPalette HasActiveFile="@(activeTabPath != null)"
                       IsBlameActive="@isBlameActive"
                       OnCommand="HandleCommand"
                       OnClose="() => { showCommandPalette = false; StateHasChanged(); }" />
}

@if (showShortcutHelp)
{
    <IdeShortcutHelp OnClose="() => { showShortcutHelp = false; StateHasChanged(); }" />
}

@* Toast notifications *@
@if (toasts.Count > 0)
{
    <div class="ide-toast-container">
        @foreach (var toast in toasts)
        {
            <div class="ide-toast ide-toast-@toast.Type">
                <i class="bi @GetToastIcon(toast.Type) me-2"></i>
                <span>@toast.Message</span>
                <button class="ide-toast-close" @onclick="() => DismissToast(toast.Id)">
                    <i class="bi bi-x"></i>
                </button>
            </div>
        }
    </div>
}

@code {
    [Parameter] public string RepoName { get; set; } = "";
    [Parameter] public string? FilePath { get; set; }

    private List<TreeNode>? treeNodes;
    private List<OpenTab> openTabs = new();
    private Stack<string> closedTabHistory = new();
    private string? activeTabPath;
    private string currentBranch = "main";
    private List<string> branches = new();
    private HashSet<string> modifiedFiles = new();
    private Dictionary<string, string> fileContents = new();
    private bool isLoading = true;
    private bool isCommitting;
    private string sidebarMode = "files";
    private string previousSidebarMode = "files";
    private string? editorId;
    private List<FileChange> pendingChanges = new();
    private DotNetObjectReference<WebIde>? dotNetRef;

    // Split editor state
    private bool isSplit;
    private string? splitEditorId;
    private int activePane = 1;
    private string? splitActiveTabPath;

    // Bottom panel state
    private string bottomPanelMode = "commits";

    // Terminal tabs
    private record TerminalTab(string Id, string Name);
    private List<TerminalTab> terminalTabs = new() { new("term-1", "bash") };
    private string activeTerminalId = "term-1";
    private int terminalCounter = 1;

    // Quick open state
    private bool showQuickOpen;

    // Command palette state
    private bool showCommandPalette;

    // Shortcut help state
    private bool showShortcutHelp;

    // Status bar cursor state
    private int cursorLine = 1;
    private int cursorColumn = 1;
    private int selectionLength;

    // Diff view state
    private bool showDiffView;
    private string? diffFilePath;
    private string? diffEditorId;

    // Branch diff state
    private bool showBranchDiff;
    private string? branchDiffBase;
    private string? branchDiffCompare;
    private List<BranchDiffFile> branchDiffFiles = new();
    private string? branchDiffSelectedFile;
    private string? branchDiffEditorId;
    private bool isLoadingBranchDiff;

    // Preview state
    private bool showMarkdownPreview;
    private string renderedMarkdown = "";

    // LSP state
    private Dictionary<string, string> lspStatus = new(); // language -> "running"|"error"|"disconnected"

    // Problems panel state
    private List<DiagnosticItem> allDiagnostics = new();
    private int errorCount;
    private int warningCount;
    private record DiagnosticItem(string FilePath, int StartLineNumber, int StartColumn, int EndLineNumber, int EndColumn, string Message, int Severity, string Source, string Code);

    // Task runner state
    private record TaskDef(string Label, string Command);
    private record TaskOutputLine(string Text, bool IsError, string? FilePath, int Line, int Column);
    private List<TaskDef> availableTasks = new()
    {
        new("dotnet build", "dotnet build"),
        new("dotnet test", "dotnet test"),
        new("npm install", "npm install"),
        new("npm run build", "npm run build"),
        new("npm test", "npm test"),
        new("go build ./...", "go build ./..."),
        new("go test ./...", "go test ./..."),
        new("make", "make"),
        new("python -m pytest", "python -m pytest"),
    };
    private string selectedTask = "dotnet build";
    private string customTaskCommand = "";
    private bool isTaskRunning;
    private List<TaskOutputLine> taskOutputLines = new();
    private int? taskExitCode;

    // Debugger state
    private bool isDebugging;
    private bool isDebugPaused;
    private record DebugStackFrame(int Id, string Name, string Source, int Line);
    private record DebugVariable(string Name, string Value, string Type);
    private record DebugOutputLine(string Text, string Category);
    private List<DebugStackFrame> debugCallStack = new();
    private List<DebugVariable> debugVariables = new();
    private List<DebugOutputLine> debugOutput = new();

    // AI completion state
    private bool aiCompletionEnabled;

    // AI chat state
    private bool aiChatEnabled;
    private string? aiSelectedCode;

    // Collaboration state
    private bool collabEnabled;
    private bool collabActive;
    private int collabParticipantCount;

    // Debug language selector
    private string selectedDebugLanguage = "";


    // ---- Task runner ----

    private async Task RunTask()
    {
        var command = !string.IsNullOrWhiteSpace(customTaskCommand) ? customTaskCommand : selectedTask;
        if (string.IsNullOrWhiteSpace(command)) return;

        isTaskRunning = true;
        taskExitCode = null;
        taskOutputLines.Clear();
        taskOutputLines.Add(new TaskOutputLine($"> {command}", false, null, 0, 0));
        StateHasChanged();

        try
        {
            var baseUri = new Uri(Navigation.BaseUri);
            var wsScheme = baseUri.Scheme == "https" ? "wss" : "ws";
            var sessionId = UserService.SessionId;
            if (string.IsNullOrEmpty(sessionId))
            {
                try { sessionId = await JS.InvokeAsync<string?>("localStorage.getItem", "sessionId"); }
                catch { }
            }
            if (string.IsNullOrEmpty(sessionId)) return;

            var wsUrl = $"{wsScheme}://{baseUri.Host}:{baseUri.Port}/ws/taskrunner/{RepoName}?session={Uri.EscapeDataString(sessionId)}";
            await JS.InvokeVoidAsync("ideTaskRunner.connect", wsUrl, dotNetRef);
            await JS.InvokeVoidAsync("ideTaskRunner.run", command);
        }
        catch (Exception ex)
        {
            taskOutputLines.Add(new TaskOutputLine($"Error: {ex.Message}", true, null, 0, 0));
            isTaskRunning = false;
            StateHasChanged();
        }
    }

    private async Task StopTask()
    {
        try { await JS.InvokeVoidAsync("ideTaskRunner.cancel"); }
        catch { }
    }

    private void ClearTaskOutput()
    {
        taskOutputLines.Clear();
        taskExitCode = null;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnTaskOutput(string type, string data, int code)
    {
        if (type == "exit")
        {
            taskExitCode = code;
            isTaskRunning = false;
        }
        else if (type == "stdout" || type == "stderr")
        {
            var lines = data.Split('\n', StringSplitOptions.None);
            foreach (var line in lines)
            {
                if (string.IsNullOrEmpty(line)) continue;
                var parsed = ParseErrorLocation(line);
                taskOutputLines.Add(new TaskOutputLine(line, type == "stderr", parsed.file, parsed.line, parsed.col));
            }
        }
        InvokeAsync(StateHasChanged);
    }

    private (string? file, int line, int col) ParseErrorLocation(string text)
    {
        // MSBuild style: path(line,col)
        var msbuild = System.Text.RegularExpressions.Regex.Match(text, @"(\S+)\((\d+),(\d+)\)");
        if (msbuild.Success)
            return (msbuild.Groups[1].Value, int.Parse(msbuild.Groups[2].Value), int.Parse(msbuild.Groups[3].Value));

        // GCC/Go/TS style: path:line:col
        var gcc = System.Text.RegularExpressions.Regex.Match(text, @"(\S+):(\d+):(\d+)");
        if (gcc.Success)
            return (gcc.Groups[1].Value, int.Parse(gcc.Groups[2].Value), int.Parse(gcc.Groups[3].Value));

        return (null, 0, 0);
    }


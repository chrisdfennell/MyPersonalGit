    private static string GetLanguageDisplayName(string path)
    {
        var ext = System.IO.Path.GetExtension(path).ToLowerInvariant();
        return ext switch
        {
            ".cs" => "C#",
            ".js" => "JavaScript",
            ".jsx" => "JavaScript (JSX)",
            ".ts" => "TypeScript",
            ".tsx" => "TypeScript (TSX)",
            ".py" => "Python",
            ".rb" => "Ruby",
            ".go" => "Go",
            ".rs" => "Rust",
            ".java" => "Java",
            ".kt" => "Kotlin",
            ".swift" => "Swift",
            ".c" => "C",
            ".cpp" or ".cc" or ".cxx" => "C++",
            ".h" or ".hpp" => "C/C++ Header",
            ".html" or ".htm" => "HTML",
            ".css" => "CSS",
            ".scss" => "SCSS",
            ".less" => "Less",
            ".json" => "JSON",
            ".xml" or ".csproj" or ".svg" => "XML",
            ".yaml" or ".yml" => "YAML",
            ".md" => "Markdown",
            ".sql" => "SQL",
            ".sh" or ".bash" => "Shell",
            ".ps1" => "PowerShell",
            ".dockerfile" => "Dockerfile",
            ".razor" or ".cshtml" => "Razor",
            ".php" => "PHP",
            ".lua" => "Lua",
            ".r" => "R",
            ".toml" => "TOML",
            ".ini" or ".cfg" => "INI",
            _ => ext.TrimStart('.').ToUpperInvariant()
        };
    }


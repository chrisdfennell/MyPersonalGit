    private async Task HandleAiInsertNewFile(string code)
    {
        // Create a new untitled file with the AI-generated code
        var ext = GuessExtensionFromLanguage(GetLanguageDisplayName(activeTabPath));
        var newPath = $"untitled{ext}";
        var counter = 1;
        while (openTabs.Any(t => t.FilePath == newPath))
        {
            newPath = $"untitled{counter}{ext}";
            counter++;
        }

        fileContents[newPath] = code;
        var newTab = new OpenTab { FilePath = newPath, FileName = System.IO.Path.GetFileName(newPath), IsDirty = true };
        openTabs.Add(newTab);
        activeTabPath = newPath;
        modifiedFiles.Add(newPath);

        if (editorId != null)
            await JS.InvokeVoidAsync("monacoInterop.openFile", editorId, newPath, code, false);

        StateHasChanged();
    }

    private static string GuessExtensionFromLanguage(string? lang)
    {
        return (lang?.ToLowerInvariant()) switch
        {
            "csharp" or "c#" => ".cs",
            "javascript" => ".js",
            "typescript" => ".ts",
            "python" => ".py",
            "go" => ".go",
            "rust" => ".rs",
            "java" => ".java",
            "html" => ".html",
            "css" => ".css",
            "json" => ".json",
            "yaml" => ".yml",
            "ruby" => ".rb",
            "php" => ".php",
            _ => ".txt"
        };
    }

    // ---- Collaboration ----

    private async Task ToggleCollaboration()
    {
        if (collabActive)
        {
            // Leave collaboration
            if (activeTabPath != null)
                try { await JS.InvokeVoidAsync("ideCollaboration.leaveSession", RepoName, activeTabPath); } catch { }
            try { await JS.InvokeVoidAsync("ideCollaboration.disconnect"); } catch { }
            collabActive = false;
            collabParticipantCount = 0;
            ShowToast("Left collaboration session", "info");
        }
        else
        {
            // Join collaboration
            try
            {
                await JS.InvokeVoidAsync("ideCollaboration.init", dotNetRef, null);
                if (activeTabPath != null)
                {
                    var username = UserService.Username ?? "anonymous";
                    var colors = new[] { "#ff6b6b", "#feca57", "#48dbfb", "#ff9ff3", "#54a0ff", "#5f27cd" };
                    var color = colors[Math.Abs(username.GetHashCode()) % colors.Length];
                    await JS.InvokeVoidAsync("ideCollaboration.joinSession", RepoName, activeTabPath, username, color);

                    // Attach to the current editor by ID
                    await JS.InvokeVoidAsync("ideCollaboration.attachEditorById", editorId);
                }
                collabActive = true;
                ShowToast("Joined collaboration session — share this URL for others to join", "success");
            }
            catch (Exception ex)
            {
                ShowToast($"Collaboration error: {ex.Message}", "error");
            }
        }
        StateHasChanged();
    }


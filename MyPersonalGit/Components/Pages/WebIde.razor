    private async Task CloseTerminal(string id)
    {
        var idx = terminalTabs.FindIndex(t => t.Id == id);

        // Dispose the terminal being closed
        try { await JS.InvokeVoidAsync("ideTerminal.dispose", $"ide-terminal-{id}"); } catch { }

        terminalTabs.RemoveAll(t => t.Id == id);
        if (activeTerminalId == id && terminalTabs.Count > 0)
        {
            activeTerminalId = terminalTabs[Math.Min(idx, terminalTabs.Count - 1)].Id;
        }
        if (terminalTabs.Count == 0)
        {
            terminalCounter++;
            var newId = $"term-{terminalCounter}";
            terminalTabs.Add(new TerminalTab(newId, "bash"));
            activeTerminalId = newId;
        }
        StateHasChanged();

        // Re-fit the active terminal after DOM settles
        await Task.Delay(100);
        try { await JS.InvokeVoidAsync("ideTerminal.fitAll"); } catch { }
    }


    // ---- Dispose ----

    public async ValueTask DisposeAsync()
    {
        autoSaveTimer?.Dispose();

        // Disconnect collaboration
        if (collabActive)
        {
            try { await JS.InvokeVoidAsync("ideCollaboration.disconnect"); }
            catch { }
        }

        // Dispose AI chat
        try { await JS.InvokeVoidAsync("ideAiChat.dispose"); }
        catch { }

        // Disconnect all LSP servers
        try { await JS.InvokeVoidAsync("ideLsp.disconnectAll"); }
        catch { }

        if (branchDiffEditorId != null)
        {
            try { await JS.InvokeVoidAsync("monacoInterop.disposeDiffEditor", branchDiffEditorId); }
            catch { }
        }

        if (diffEditorId != null)
        {
            try { await JS.InvokeVoidAsync("monacoInterop.disposeDiffEditor", diffEditorId); }
            catch { }
        }

        if (splitEditorId != null)
        {
            try { await JS.InvokeVoidAsync("monacoInterop.closeSplitEditor", splitEditorId, "monaco-container"); }
            catch { }
        }

        if (editorId != null)
        {
            try
            {
                await JS.InvokeVoidAsync("monacoInterop.dispose", editorId);
            }
            catch { }
        }
        dotNetRef?.Dispose();
    }

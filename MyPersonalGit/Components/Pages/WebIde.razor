    // ---- LSP helpers ----

    private static readonly Dictionary<string, string> LspLanguageMap = new()
    {
        ["csharp"] = "csharp",
        ["javascript"] = "typescript",
        ["typescript"] = "typescript",
        ["python"] = "python",
        ["go"] = "go",
        ["rust"] = "rust",
        ["html"] = "html",
        ["css"] = "css",
        ["scss"] = "css",
        ["less"] = "css",
        ["json"] = "json",
        ["yaml"] = "yaml",
        ["shell"] = "bash",
        ["dockerfile"] = "dockerfile",
        ["markdown"] = "markdown"
    };

    private string? GetLspLanguage(string? filePath)
    {
        if (string.IsNullOrEmpty(filePath)) return null;
        var ext = System.IO.Path.GetExtension(filePath)?.ToLowerInvariant();
        var fileName = System.IO.Path.GetFileName(filePath)?.ToLowerInvariant();
        var monacoLang = ext switch
        {
            ".cs" => "csharp",
            ".js" or ".jsx" => "javascript",
            ".ts" or ".tsx" => "typescript",
            ".py" => "python",
            ".go" => "go",
            ".rs" => "rust",
            ".html" or ".htm" => "html",
            ".css" => "css",
            ".scss" => "scss",
            ".less" => "less",
            ".json" => "json",
            ".yml" or ".yaml" => "yaml",
            ".sh" or ".bash" => "shell",
            ".md" => "markdown",
            _ => fileName == "dockerfile" ? "dockerfile" : null
        };
        if (monacoLang == null) return null;
        return LspLanguageMap.GetValueOrDefault(monacoLang);
    }

    private string GetMonacoLanguageId(string filePath)
    {
        var ext = System.IO.Path.GetExtension(filePath)?.ToLowerInvariant();
        var fileName = System.IO.Path.GetFileName(filePath)?.ToLowerInvariant();
        return ext switch
        {
            ".cs" => "csharp",
            ".js" or ".jsx" => "javascript",
            ".ts" or ".tsx" => "typescript",
            ".py" => "python",
            ".go" => "go",
            ".rs" => "rust",
            ".html" or ".htm" => "html",
            ".css" => "css",
            ".scss" => "scss",
            ".less" => "less",
            ".json" => "json",
            ".yml" or ".yaml" => "yaml",
            ".sh" or ".bash" => "shell",
            ".md" => "markdown",
            _ => fileName == "dockerfile" ? "dockerfile" : "plaintext"
        };
    }

    private async Task LspEnsureConnected(string lspLanguage)
    {
        if (lspStatus.GetValueOrDefault(lspLanguage) == "running") return;

        try
        {
            var baseUri = new Uri(Navigation.BaseUri);
            var wsScheme = baseUri.Scheme == "https" ? "wss" : "ws";

            var sessionId = UserService.SessionId;
            if (string.IsNullOrEmpty(sessionId))
            {
                try { sessionId = await JS.InvokeAsync<string?>("localStorage.getItem", "sessionId"); }
                catch { }
            }
            if (string.IsNullOrEmpty(sessionId))
            {
                Console.WriteLine("[LSP] No session ID available");
                return;
            }

            var wsUrl = $"{wsScheme}://{baseUri.Host}:{baseUri.Port}/ws/lsp/{RepoName}/{lspLanguage}?session={Uri.EscapeDataString(sessionId)}&branch={currentBranch}";
            Console.WriteLine($"[LSP] Connecting to {wsUrl}");

            var connected = await JS.InvokeAsync<bool>("ideLsp.connect", lspLanguage, wsUrl);
            Console.WriteLine($"[LSP] Connect result for {lspLanguage}: {connected}");
            if (connected)
            {
                lspStatus[lspLanguage] = "running";
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LSP] Failed to connect {lspLanguage}: {ex.Message}\n{ex.StackTrace}");
        }
    }

    private async Task LspDidOpen(string filePath, string content)
    {
        var lspLang = GetLspLanguage(filePath);
        if (lspLang == null) return;

        await LspEnsureConnected(lspLang);

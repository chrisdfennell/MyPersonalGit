    [JSInvokable]
    public async Task OnFilesDropped(string fileName, string base64Content)
    {
        if (!UserService.IsLoggedIn) return;

        try
        {
            var content = Convert.FromBase64String(base64Content);
            var contentStr = System.Text.Encoding.UTF8.GetString(content);

            // Check if it's a binary file (image, etc.)
            var ext = System.IO.Path.GetExtension(fileName).ToLowerInvariant();
            var isBinary = ext is ".png" or ".jpg" or ".jpeg" or ".gif" or ".webp" or ".ico" or ".bmp"
                or ".zip" or ".tar" or ".gz" or ".pdf" or ".woff" or ".woff2" or ".ttf" or ".eot";

            if (isBinary)
            {
                // For binary files, we need to commit them directly via the service
                // Store as base64 in a special commit
                await WebIdeService.CreateBinaryFileAsync(
                    RepoName, currentBranch, fileName, content,
                    UserService.Username, $"{UserService.Username}@personalgit.local"
                );
            }
            else
            {
                await WebIdeService.CreateFileAsync(
                    RepoName, currentBranch, fileName, contentStr,
                    UserService.Username, $"{UserService.Username}@personalgit.local"
                );
            }

            // Refresh tree and open the file
            treeNodes = await WebIdeService.GetFullTreeAsync(RepoName, currentBranch);
            await InvokeAsync(StateHasChanged);
            await HandleFileSelected(fileName);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"File upload error: {ex.Message}");
        }
    }

    [JSInvokable]
    public async Task OnEditorContentChanged(string filePath)
    {
        var tab = openTabs.FirstOrDefault(t => t.FilePath == filePath);
        if (tab == null) return;

        if (editorId != null)
        {
            try
            {
                var content = await JS.InvokeAsync<string>("monacoInterop.getFileContent", editorId, filePath);
                fileContents[filePath] = content;

                var isDirty = content != tab.OriginalContent;
                tab.IsDirty = isDirty;

                if (isDirty)
                    modifiedFiles.Add(filePath);
                else
                    modifiedFiles.Remove(filePath);

                // Auto-save: reset timer on each change
                if (autoSaveEnabled && isDirty)
                {
                    autoSaveTimer?.Dispose();
                    autoSaveTimer = new System.Threading.Timer(async _ =>
                    {
                        await InvokeAsync(async () =>
                        {
                            await AutoSaveFile(filePath);
                        });
                    }, null, autoSaveDelay, System.Threading.Timeout.Infinite);
                }

                UpdatePendingChanges();
                await InvokeAsync(StateHasChanged);
            }
            catch { }
        }
    }

    private void QueueWorkspaceSave()
    {
        _ = SaveWorkspaceState();
    }

    private void UpdatePendingChanges()
    {
        pendingChanges = modifiedFiles
            .Select(path =>
            {
                var tab = openTabs.FirstOrDefault(t => t.FilePath == path);
                var content = fileContents.GetValueOrDefault(path, "");
                var action = string.IsNullOrEmpty(tab?.OriginalContent) ? "add" : "modify";
                return new FileChange(path, content, action);
            })
            .ToList();

        // Update browser beforeunload warning
        _ = UpdateUnsavedWarning();
    }

    private async Task UpdateUnsavedWarning()
    {
        try
        {
            await JS.InvokeVoidAsync("ideUnsaved.setHasChanges", modifiedFiles.Count > 0);
        }
        catch { }
    }


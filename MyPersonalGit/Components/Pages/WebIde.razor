    private async Task HandleFileSelected(string path)
    {
        if (showDiffView)
        {
            await CloseDiffView();
        }

        // Reset markdown preview when switching files
        showMarkdownPreview = false;

        var existingTab = openTabs.FirstOrDefault(t => t.FilePath == path);
        if (existingTab != null)
        {
            await SwitchToTab(path);
            return;
        }

        try
        {
            // Image files don't need content loaded into Monaco
            if (IsImageFile(path))
            {
                var tab = new OpenTab
                {
                    FilePath = path,
                    FileName = System.IO.Path.GetFileName(path),
                    IsDirty = false,
                    OriginalContent = ""
                };
                openTabs.Add(tab);
                activeTabPath = path;
                QueueWorkspaceSave();
                StateHasChanged();
                return;
            }

            var fileContent = await WebIdeService.GetFileContentAsync(RepoName, currentBranch, path);
            fileContents[path] = fileContent.Content;

            var openTab = new OpenTab
            {
                FilePath = path,
                FileName = System.IO.Path.GetFileName(path),
                IsDirty = false,
                OriginalContent = fileContent.Content
            };
            openTabs.Add(openTab);

            activeTabPath = path;
            StateHasChanged();
            await Task.Delay(50);

            if (editorId != null)
            {
                await JS.InvokeVoidAsync("monacoInterop.layout", editorId);
                var isReadOnly = !UserService.IsLoggedIn;
                await JS.InvokeVoidAsync("monacoInterop.openFile", editorId, path, fileContent.Content, isReadOnly);
                await JS.InvokeVoidAsync("monacoInterop.layout", editorId);

                // Re-apply blame if active
                if (isBlameActive)
                {
                    await LoadBlameForCurrentFile();
                }

                // Detect merge conflicts
                await DetectConflicts();
            }

            QueueWorkspaceSave();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to open file: {ex.Message}");
        }
    }


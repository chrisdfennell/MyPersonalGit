    // ---- Split Editor ----

    private async Task ToggleSplitEditor()
    {
        if (isSplit)
        {
            await CloseSplitEditor();
        }
        else
        {
            await OpenSplitEditor();
        }
    }

    private async Task OpenSplitEditor()
    {
        if (isSplit || editorId == null) return;

        isSplit = true;
        StateHasChanged();
        await Task.Delay(50);

        try
        {
            var editorOptions = new Dictionary<string, object>
            {
                { "fontSize", currentSettings?.FontSize ?? 14 },
                { "minimap", currentSettings?.MinimapEnabled ?? true }
            };

            splitEditorId = await JS.InvokeAsync<string>("monacoInterop.createSplitEditor",
                "monaco-container", editorId, editorOptions);

            if (currentSettings != null && splitEditorId != null)
            {
                await ApplySettingsToEditor(splitEditorId);
            }

            if (splitEditorId != null && dotNetRef != null)
            {
                await JS.InvokeVoidAsync("monacoInterop.onDidChangeContent", splitEditorId, dotNetRef, "OnEditorContentChanged");
            }

            if (activeTabPath != null && fileContents.ContainsKey(activeTabPath))
            {
                splitActiveTabPath = activeTabPath;
                await JS.InvokeVoidAsync("monacoInterop.openFile", splitEditorId, activeTabPath, fileContents[activeTabPath], !UserService.IsLoggedIn);
            }

            await JS.InvokeVoidAsync("monacoInterop.layout", editorId);
            await JS.InvokeVoidAsync("monacoInterop.layout", splitEditorId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Split editor error: {ex.Message}");
            isSplit = false;
            splitEditorId = null;
        }
    }

    private async Task CloseSplitEditor()
    {
        if (!isSplit || splitEditorId == null) return;

        try
        {
            await JS.InvokeVoidAsync("monacoInterop.closeSplitEditor", splitEditorId, "monaco-container");
        }
        catch { }

        splitEditorId = null;
        splitActiveTabPath = null;
        isSplit = false;
        activePane = 1;
        StateHasChanged();

        if (editorId != null)
        {
            await Task.Delay(50);
            try { await JS.InvokeVoidAsync("monacoInterop.layout", editorId); }
            catch { }
        }
    }

    private void SetActivePane(int pane)
    {
        activePane = pane;
    }

    // ---- Diff View ----

    private async Task OpenDiffView(string filePath)
    {
        await CloseDiffView();

        diffFilePath = filePath;
        showDiffView = true;
        StateHasChanged();
        await Task.Delay(50);

        try
        {
            var originalContent = "";
            var tab = openTabs.FirstOrDefault(t => t.FilePath == filePath);
            if (tab != null)
            {
                originalContent = tab.OriginalContent ?? "";
            }
            else
            {
                try
                {
                    var fileData = await WebIdeService.GetFileContentAsync(RepoName, currentBranch, filePath);
                    originalContent = fileData.Content;
                }
                catch { }
            }

            var modifiedContent = fileContents.GetValueOrDefault(filePath, originalContent);

            diffEditorId = await JS.InvokeAsync<string>("monacoInterop.createDiffEditor",
                "diff-editor-container", originalContent, modifiedContent, filePath);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Diff editor error: {ex.Message}");
            showDiffView = false;
        }
    }

    private async Task CloseDiffView()
    {
        if (diffEditorId != null)
        {
            try
            {
                await JS.InvokeVoidAsync("monacoInterop.disposeDiffEditor", diffEditorId);
            }
            catch { }
            diffEditorId = null;
        }
        showDiffView = false;
        diffFilePath = null;
        StateHasChanged();
    }

    // ---- Terminal ----

    private void ToggleTerminal()
    {
        bottomPanelMode = bottomPanelMode == "terminal" ? "commits" : "terminal";
    }

    private void AddTerminal()
    {
        terminalCounter++;
        var id = $"term-{terminalCounter}";
        terminalTabs.Add(new TerminalTab(id, $"bash ({terminalCounter})"));
        activeTerminalId = id;
        StateHasChanged();
    }

    private void SwitchTerminal(string id)
    {
        activeTerminalId = id;
    }

    private void CloseTerminal(string id)
    {
        var idx = terminalTabs.FindIndex(t => t.Id == id);
        terminalTabs.RemoveAll(t => t.Id == id);
        if (activeTerminalId == id && terminalTabs.Count > 0)
        {
            activeTerminalId = terminalTabs[Math.Min(idx, terminalTabs.Count - 1)].Id;
        }
        if (terminalTabs.Count == 0)
        {
            terminalCounter++;
            var newId = $"term-{terminalCounter}";
            terminalTabs.Add(new TerminalTab(newId, "bash"));
            activeTerminalId = newId;
        }
        StateHasChanged();
    }

    // ---- Quick Open & Key Handling ----

    private void HandleGlobalKeyDown(KeyboardEventArgs e)
    {
        // Ctrl+Shift+P: Command Palette
        if (e.CtrlKey && e.ShiftKey && e.Key == "P")
        {
            showCommandPalette = !showCommandPalette;
            StateHasChanged();
        }
        // Ctrl+P: Quick Open
        else if (e.CtrlKey && !e.ShiftKey && e.Key == "p")
        {
            showQuickOpen = !showQuickOpen;
            StateHasChanged();
        }
        // Ctrl+` (backtick): Toggle Terminal
        else if (e.CtrlKey && e.Key == "`")
        {
            ToggleTerminal();
            StateHasChanged();
        }
        // Ctrl+Shift+F: Focus search
        else if (e.CtrlKey && e.ShiftKey && e.Key == "F")
        {
            sidebarMode = "search";
            StateHasChanged();
        }
        // Escape: Exit zen mode
        else if (e.Key == "Escape" && isZenMode)
        {
            isZenMode = false;
            StateHasChanged();
            _ = Task.Run(async () =>
            {
                await Task.Delay(50);
                await InvokeAsync(async () =>
                {
                    if (editorId != null)
                        try { await JS.InvokeVoidAsync("monacoInterop.layout", editorId); } catch { }
                });
            });
        }
        // ?: Show shortcut help (only when no modals open and not typing in editor)
        else if (e.Key == "?" && !e.CtrlKey && !e.AltKey && openTabs.Count == 0)
        {
            showShortcutHelp = !showShortcutHelp;
            StateHasChanged();
        }
    }


    private void HandleTabReordered((int from, int to) args)
    {
        if (args.from < 0 || args.from >= openTabs.Count || args.to < 0 || args.to >= openTabs.Count) return;
        var tab = openTabs[args.from];
        openTabs.RemoveAt(args.from);

    // ---- Preview Helpers ----

    private static bool IsImageFile(string path)
    {
        var ext = System.IO.Path.GetExtension(path).ToLowerInvariant();
        return ext is ".png" or ".jpg" or ".jpeg" or ".gif" or ".webp" or ".svg" or ".ico" or ".bmp";
    }

    private static bool IsMarkdownFile(string path)
    {
        var ext = System.IO.Path.GetExtension(path).ToLowerInvariant();
        return ext is ".md" or ".markdown" or ".mdx";
    }

    private async Task ToggleMarkdownPreview()
    {
        showMarkdownPreview = !showMarkdownPreview;
        if (showMarkdownPreview && activeTabPath != null)
        {
            await RenderMarkdown();
        }
        StateHasChanged();
    }

    private async Task RenderMarkdown()
    {
        if (activeTabPath == null) return;
        var content = fileContents.GetValueOrDefault(activeTabPath, "");
        try
        {
            renderedMarkdown = await JS.InvokeAsync<string>("idePreview.renderMarkdown", content);
        }
        catch
        {
            // Simple fallback - wrap in <pre> if JS rendering fails
            renderedMarkdown = $"<pre>{System.Net.WebUtility.HtmlEncode(content)}</pre>";
        }
    }

    // ---- Breadcrumbs ----

    private record BreadcrumbSegment(string Name, string Path, bool IsLast);

    private List<BreadcrumbSegment> GetBreadcrumbSegments(string filePath)
    {
        var parts = filePath.Replace("\\", "/").Split('/');
        var segments = new List<BreadcrumbSegment>();
        for (int i = 0; i < parts.Length; i++)
        {
            var path = string.Join("/", parts.Take(i + 1));
            segments.Add(new BreadcrumbSegment(parts[i], path, i == parts.Length - 1));
        }
        return segments;
    }


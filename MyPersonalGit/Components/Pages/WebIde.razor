    [JSInvokable]
    public async Task OnGoToDefinition(string symbol)
    {
        // Search repo for symbol definition when not found in loaded models
        try
        {
            var results = await WebIdeService.SearchFilesAsync(RepoName, currentBranch, symbol);
            var definitionPatterns = new[] { "class ", "interface ", "struct ", "enum ", "record ", "function ", "def ", "fn ", "func " };
            var match = results.FirstOrDefault(r =>
                definitionPatterns.Any(p => r.LineContent.Contains(p + symbol)));

            if (match != null)
            {
                await HandleFileSelected(match.FilePath);
                if (editorId != null)
                {
                    await Task.Delay(100);
                    await JS.InvokeVoidAsync("monacoInterop.revealLine", editorId, match.LineNumber);
                }

    private async Task HandleCommand(string commandId)
    {
        switch (commandId)
        {
            case "quickOpen":
                showQuickOpen = true;
                break;
            case "search":
                sidebarMode = "search";
                break;
            case "toggleTerminal":
                ToggleTerminal();
                break;
            case "splitEditor":
                await ToggleSplitEditor();
                break;
            case "toggleTheme":
                await JS.InvokeVoidAsync("themeHelper.toggle");
                break;
            case "toggleBlame":
                await ToggleBlame();
                break;
            case "fileHistory":
                await ShowFileHistory();
                break;
            case "findReplace":
                if (editorId != null)
                    await JS.InvokeVoidAsync("monacoInterop.triggerFindReplace", editorId);
                break;
            case "goToLine":
                if (editorId != null)
                    await JS.InvokeVoidAsync("monacoInterop.triggerGoToLine", editorId);
                break;
            case "toggleMinimap":
                if (editorId != null)
                    await JS.InvokeAsync<bool>("monacoInterop.toggleMinimap", editorId);
                break;
            case "closeTab":
                if (activeTabPath != null)
                    await HandleTabClosed(activeTabPath);
                break;
            case "closeAllTabs":
                foreach (var tab in openTabs.ToList())
                    await HandleTabClosed(tab.FilePath);
                break;
            case "sourceControl":
                sidebarMode = "sourcecontrol";
                break;
            case "settings":
                sidebarMode = "settings";
                break;
            case "explorer":
                sidebarMode = "files";
                break;
            case "outline":
                await OpenOutlinePanel();
                break;
            case "zenMode":
                await ToggleZenMode();
                break;
            case "toggleWordWrap":
                await HandleToggleWordWrap();
                break;
            case "foldAll":
                if (editorId != null)
                    await JS.InvokeVoidAsync("monacoInterop.foldAll", editorId);
                break;
            case "unfoldAll":
                if (editorId != null)
                    await JS.InvokeVoidAsync("monacoInterop.unfoldAll", editorId);
                break;
            case "showShortcuts":
                showShortcutHelp = true;
                break;
            case "toggleAutoSave":
                autoSaveEnabled = !autoSaveEnabled;
                if (currentSettings != null)
                {
                    currentSettings.AutoSaveEnabled = autoSaveEnabled;
                    try
                    {
                        var json = System.Text.Json.JsonSerializer.Serialize(currentSettings);
                        await JS.InvokeVoidAsync("localStorage.setItem", "ide-settings", json);
                    }
                    catch { }
                }
                ShowToast(autoSaveEnabled ? "Auto-save enabled" : "Auto-save disabled", "info");
                break;
        }
        StateHasChanged();
    }


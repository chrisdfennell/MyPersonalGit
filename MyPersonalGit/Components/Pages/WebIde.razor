    // ---- Debugger ----

    private async Task StartDebugSession()
    {
        if (activeTabPath == null) return;
        try
        {
            // Auto-detect language if not manually selected
            var debugLang = selectedDebugLanguage;
            if (string.IsNullOrEmpty(debugLang))
            {
                debugLang = DapSessionManager.GetDebugLanguageForFile(activeTabPath);
                if (string.IsNullOrEmpty(debugLang))
                {
                    ShowToast("Cannot auto-detect debug language for this file type", "warning");
                    return;
                }
            }

            var baseUri = new Uri(Navigation.BaseUri);
            var wsScheme = baseUri.Scheme == "https" ? "wss" : "ws";
            var sessionId = UserService.SessionId;
            if (string.IsNullOrEmpty(sessionId))
            {
                try { sessionId = await JS.InvokeAsync<string?>("localStorage.getItem", "sessionId"); }
                catch { }
            }
            if (string.IsNullOrEmpty(sessionId)) return;

            var wsUrl = $"{wsScheme}://{baseUri.Host}:{baseUri.Port}/ws/dap/{RepoName}?language={debugLang}&branch={currentBranch}&session={Uri.EscapeDataString(sessionId)}";
            var connected = await JS.InvokeAsync<bool>("ideDebugger.connect", wsUrl, dotNetRef);

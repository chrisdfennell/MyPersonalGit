    [JSInvokable]
    public async Task OnDebugStopped(string reason, string framesJson)
    {
        isDebugPaused = true;
        try
        {
            debugCallStack = System.Text.Json.JsonSerializer.Deserialize<List<DebugStackFrame>>(framesJson,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();

            // Highlight the top frame's line
            if (debugCallStack.Count > 0 && editorId != null)
            {
                var topFrame = debugCallStack[0];
                // Navigate to the file if needed (strip worktree prefix)
                var relativePath = topFrame.Source;
                if (relativePath.Contains("/lsp-workdir/") || relativePath.Contains("/dap-workdir/"))
                {
                    var parts = relativePath.Split(new[] { "/lsp-workdir/", "/dap-workdir/" }, StringSplitOptions.None);
                    if (parts.Length > 1)
                    {
                        var afterGuid = parts[1];
                        var slashIdx = afterGuid.IndexOf('/');
                        if (slashIdx >= 0) relativePath = afterGuid[(slashIdx + 1)..];
                    }
                }

                if (relativePath != activeTabPath)
                    await HandleFileSelected(relativePath);

                await JS.InvokeVoidAsync("ideDebugger.highlightLine", editorId, topFrame.Line);
            }
        }
        catch { }
        await InvokeAsync(StateHasChanged);
    }


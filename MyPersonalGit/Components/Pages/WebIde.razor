    private async Task SwitchToTab(string path)
    {
        var targetEditorId = activePane == 2 && isSplit ? splitEditorId : editorId;

        if (targetEditorId != null && fileContents.ContainsKey(path))
        {
            await JS.InvokeVoidAsync("monacoInterop.openFile", targetEditorId, path, fileContents[path], !UserService.IsLoggedIn);
        }

        if (activePane == 2 && isSplit)
            splitActiveTabPath = path;
        else
            activeTabPath = path;

        // Re-apply blame if active
        if (isBlameActive && editorId != null)
        {
            await LoadBlameForCurrentFile();
        }

        StateHasChanged();
    }

    private async Task HandleTabClosed(string path)
    {
        if (editorId != null && modifiedFiles.Contains(path))
        {
            try
            {
                var content = await JS.InvokeAsync<string>("monacoInterop.getFileContent", editorId, path);
                fileContents[path] = content;
            }
            catch { }
        }

        if (editorId != null)
        {
            try
            {
                await JS.InvokeVoidAsync("monacoInterop.closeFile", editorId, path);
            }
            catch { }
        }

        var tabIndex = openTabs.FindIndex(t => t.FilePath == path);
        openTabs.RemoveAll(t => t.FilePath == path);
        modifiedFiles.Remove(path);
        fileContents.Remove(path);

        if (activeTabPath == path)
        {
            if (openTabs.Count > 0)
            {
                var newIndex = Math.Min(tabIndex, openTabs.Count - 1);
                await SwitchToTab(openTabs[newIndex].FilePath);
            }
            else
            {
                activeTabPath = null;
                if (isBlameActive)
                {
                    isBlameActive = false;
                }
            }
        }

        UpdatePendingChanges();
        QueueWorkspaceSave();
        StateHasChanged();
    }

    private async Task HandleCommit((string message, List<FileChange> changes) args)
    {
        if (!UserService.IsLoggedIn) return;

        isCommitting = true;
        StateHasChanged();

        try
        {
            var commitChanges = new List<FileChange>();
            foreach (var change in args.changes)
            {
                string? content = null;
                if (change.Action != "delete" && editorId != null)
                {
                    try
                    {
                        content = await JS.InvokeAsync<string>("monacoInterop.getFileContent", editorId, change.Path);
                    }
                    catch
                    {
                        content = fileContents.GetValueOrDefault(change.Path);
                    }
                }
                commitChanges.Add(new FileChange(change.Path, content ?? change.Content, change.Action, change.OldPath));
            }

            await WebIdeService.CommitMultipleFilesAsync(
                RepoName,
                currentBranch,
                UserService.Username,
                $"{UserService.Username}@personalgit.local",
                args.message,
                commitChanges
            );

            foreach (var change in commitChanges)
            {
                modifiedFiles.Remove(change.Path);
                var tab = openTabs.FirstOrDefault(t => t.FilePath == change.Path);
                if (tab != null)
                {
                    tab.IsDirty = false;
                    tab.OriginalContent = fileContents.GetValueOrDefault(change.Path, "");
                }
            }

            treeNodes = await WebIdeService.GetFullTreeAsync(RepoName, currentBranch);
            UpdatePendingChanges();
            ShowToast("Commit successful", "success");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Commit failed: {ex.Message}");
            ShowToast($"Commit failed: {ex.Message}", "error");
        }
        finally
        {
            isCommitting = false;
            StateHasChanged();
        }
    }


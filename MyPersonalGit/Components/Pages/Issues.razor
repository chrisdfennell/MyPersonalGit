@page "/repo/{RepoName}/issues"
@page "/repo/{RepoName}/issues/{Number:int}"
@page "/repo/{RepoName}/milestones"
@using Markdig
@using MyPersonalGit.Models
@using MyPersonalGit.Data
@using LibGit2Sharp
@inject IIssueService IssueService
@inject IMilestoneService MilestoneService
@inject IIssueTemplateService TemplateService
@inject IReactionService ReactionService
@inject IConfiguration Config
@inject IAdminService AdminService
@inject NavigationManager Nav
@using MyPersonalGit.Services
@inject CurrentUserService UserService
@rendermode InteractiveServer

<PageTitle>Issues · @RepoName</PageTitle>

<div class="repo-header border-bottom bg-light-subtle mb-4 pt-3">
    <div class="container-xl px-3">
        <div class="d-flex align-items-center mb-3">
            <i class="bi bi-journal-bookmark text-muted me-2 h4 mb-0"></i>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 h4">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Repositories</a></li>
                    <li class="breadcrumb-item"><a href="/repo/@RepoName" class="text-decoration-none">@RepoName</a></li>
                    <li class="breadcrumb-item active fw-bold" aria-current="page">@(viewMode == "milestones" ? "Milestones" : "Issues")</li>
                </ol>
            </nav>
        </div>
        <ul class="nav nav-tabs mt-2">
            <li class="nav-item">
                <button class="nav-link @(viewMode == "issues" ? "active" : "")" @onclick='() => { viewMode = "issues"; }'>
                    <i class="bi bi-circle-fill me-1" style="font-size: 8px;"></i> Issues
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(viewMode == "milestones" ? "active" : "")" @onclick="SwitchToMilestones">
                    <i class="bi bi-signpost me-1"></i> Milestones
                    <span class="badge bg-secondary ms-1">@milestones.Count</span>
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(viewMode == "templates" ? "active" : "")" @onclick='() => viewMode = "templates"'>
                    <i class="bi bi-file-earmark-text me-1"></i> Templates
                    <span class="badge bg-secondary ms-1">@issueTemplates.Count</span>
                </button>
            </li>
        </ul>
    </div>
</div>

<div class="container-xl px-3">
    @if (viewMode == "templates")
    {
        <div class="d-flex justify-content-between align-items-center mb-3 mt-3">
            <h5 class="mb-0">Issue Templates</h5>
            @if (UserService.IsLoggedIn)
            {
                <button class="btn btn-success btn-sm" @onclick="() => showNewTemplateModal = true">
                    <i class="bi bi-plus-lg me-1"></i> New template
                </button>
            }
        </div>

        @if (issueTemplates.Any())
        {
            <div class="list-group">
                @foreach (var tmpl in issueTemplates)
                {
                    <div class="list-group-item py-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="mb-1 fw-bold"><i class="bi bi-file-earmark-text me-1"></i>@tmpl.Name</h6>
                                @if (!string.IsNullOrEmpty(tmpl.Description))
                                {
                                    <p class="text-muted small mb-1">@tmpl.Description</p>
                                }
                                @if (!string.IsNullOrEmpty(tmpl.Labels))
                                {
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var label in tmpl.Labels.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(l => l.Trim()))
                                        {
                                            <span class="badge bg-primary" style="font-size: 10px;">@label</span>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-outline-primary btn-sm" @onclick="() => UseTemplate(tmpl)">
                                    <i class="bi bi-plus-circle me-1"></i>Use
                                </button>
                                @if (UserService.IsLoggedIn)
                                {
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteTemplate(tmpl.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-file-earmark-text display-4 text-muted"></i>
                <p class="text-muted mt-3">No issue templates configured.</p>
            </div>
        }
    }
    else if (viewMode == "milestones")
    {
        <div class="d-flex justify-content-between align-items-center mb-3 mt-3">
            <div class="btn-group">
                <button class="btn @(milestoneFilter == "open" ? "btn-dark" : "btn-outline-secondary") btn-sm" @onclick='() => milestoneFilter = "open"'>
                    <i class="bi bi-signpost me-1"></i> @milestones.Count(m => m.State == MilestoneState.Open) Open
                </button>
                <button class="btn @(milestoneFilter == "closed" ? "btn-dark" : "btn-outline-secondary") btn-sm" @onclick='() => milestoneFilter = "closed"'>
                    <i class="bi bi-check-circle me-1"></i> @milestones.Count(m => m.State == MilestoneState.Closed) Closed
                </button>
            </div>
            @if (UserService.IsLoggedIn)
            {
                <button class="btn btn-gh-primary btn-sm" @onclick="() => showNewMilestoneModal = true">
                    <i class="bi bi-plus-lg me-1"></i> New milestone
                </button>
            }
        </div>

        @if (GetFilteredMilestones().Any())
        {
            <div class="list-group">
                @foreach (var ms in GetFilteredMilestones())
                {
                    var counts = milestoneCounts.ContainsKey(ms.Id) ? milestoneCounts[ms.Id] : (0, 0);
                    var total = counts.Item1 + counts.Item2;
                    var pct = total > 0 ? (int)(counts.Item2 * 100.0 / total) : 0;
                    <div class="list-group-item py-3">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <h6 class="mb-0 fw-bold">
                                    <i class="bi bi-signpost text-muted me-1"></i> @ms.Title
                                </h6>
                                @if (ms.DueDate.HasValue)
                                {
                                    <small class="text-muted"><i class="bi bi-calendar me-1"></i>Due @ms.DueDate.Value.ToString("MMM d, yyyy")</small>
                                }
                                @if (!string.IsNullOrEmpty(ms.Description))
                                {
                                    <p class="text-muted small mb-0 mt-1">@ms.Description</p>
                                }
                            </div>
                            <div class="d-flex gap-2">
                                @if (UserService.IsLoggedIn)
                                {
                                    @if (ms.State == MilestoneState.Open)
                                    {
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => CloseMilestone(ms.Number)">Close</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-success btn-sm" @onclick="() => ReopenMilestone(ms.Number)">Reopen</button>
                                    }
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteMilestone(ms.Number)"><i class="bi bi-trash"></i></button>
                                }
                            </div>
                        </div>
                        <div class="progress mb-1" style="height: 8px;">
                            <div class="progress-bar bg-success" style="width: @pct%"></div>
                        </div>
                        <small class="text-muted">@pct% complete · @counts.Item2 closed · @counts.Item1 open</small>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-signpost display-4 text-muted"></i>
                <p class="text-muted mt-3">No @milestoneFilter milestones.</p>
            </div>
        }
    }
    else if (Number.HasValue)
    {
        @if (currentIssue != null)
        {
            <div class="issue-detail">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="flex-grow-1">
                        <h1 class="h3 mb-2">
                            @currentIssue.Title
                            <span class="text-muted fw-normal">#@currentIssue.Number</span>
                        </h1>
                        <div class="d-flex gap-2 align-items-center">
                            @if (currentIssue.IsDraft)
                            {
                                <span class="badge bg-secondary d-flex align-items-center gap-1">
                                    <i class="bi bi-pencil"></i> Draft
                                </span>
                            }
                            else if (currentIssue.State == IssueState.Open)
                            {
                                <span class="badge bg-success d-flex align-items-center gap-1">
                                    <i class="bi bi-circle-fill" style="font-size: 8px;"></i> Open
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger d-flex align-items-center gap-1">
                                    <i class="bi bi-check-circle-fill"></i> Closed
                                </span>
                            }
                            <span class="text-muted small">
                                <strong>@currentIssue.Author</strong> opened this issue @FormatDate(currentIssue.CreatedAt)
                                @if (currentIssue.ClosedAt.HasValue)
                                {
                                    <span> · Closed @FormatDate(currentIssue.ClosedAt.Value)</span>
                                }
                            </span>
                        </div>
                    </div>
                    @if (UserService.IsLoggedIn)
                    {
                        <div class="btn-group">
                            @if (currentIssue.IsDraft)
                            {
                                <button class="btn btn-outline-success btn-sm" @onclick="ConvertDraftToIssue">
                                    <i class="bi bi-check-circle me-1"></i> Convert to issue
                                </button>
                            }
                            @if (currentIssue.State == IssueState.Open)
                            {
                                <button class="btn btn-outline-danger btn-sm" @onclick="CloseIssue">
                                    <i class="bi bi-check-circle me-1"></i> Close issue
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-outline-success btn-sm" @onclick="ReopenIssue">
                                    <i class="bi bi-arrow-counterclockwise me-1"></i> Reopen issue
                                </button>
                            }
                        </div>
                    }
                </div>

                @if (currentIssue.Labels.Any())
                {
                    <div class="mb-3">
                        @foreach (var label in currentIssue.Labels)
                        {
                            <span class="badge bg-primary me-1">@label</span>
                        }
                    </div>
                }
                @if (currentIssueMilestone != null)
                {
                    <div class="mb-3">
                        <span class="badge bg-info bg-opacity-10 text-info border border-info-subtle">
                            <i class="bi bi-signpost me-1"></i> @currentIssueMilestone.Title
                        </span>
                    </div>
                }

                <div class="card mb-3">
                    <div class="card-header bg-light d-flex align-items-center gap-2">
                        <i class="bi bi-person-circle"></i>
                        <strong>@currentIssue.Author</strong>
                        <span class="text-muted small">commented @FormatDate(currentIssue.CreatedAt)</span>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrWhiteSpace(currentIssue.Body))
                        {
                            <div class="markdown-body">@((MarkupString)RenderMarkdown(currentIssue.Body))</div>
                        }
                        else
                        {
                            <p class="text-muted fst-italic">No description provided.</p>
                        }
                    </div>
                </div>

                @foreach (var comment in currentIssue.Comments)
                {
                    @if (IsAutoCloseComment(comment.Body))
                    {
                        <div class="d-flex align-items-center gap-2 mb-3 ms-3 py-2">
                            <i class="bi bi-check-circle-fill text-danger"></i>
                            <span class="text-muted small">
                                <strong>@comment.Author</strong> @((MarkupString)RenderMarkdown(comment.Body)) @FormatDate(comment.CreatedAt)
                            </span>
                        </div>
                    }
                    else if (IsReferenceComment(comment.Body))
                    {
                        <div class="d-flex align-items-center gap-2 mb-3 ms-3 py-2">
                            <i class="bi bi-link-45deg text-primary"></i>
                            <span class="text-muted small">
                                <strong>@comment.Author</strong> @((MarkupString)RenderMarkdown(comment.Body)) @FormatDate(comment.CreatedAt)
                            </span>
                        </div>
                    }
                    else
                    {
                        <div class="card mb-3">
                            <div class="card-header bg-light d-flex align-items-center gap-2">
                                <i class="bi bi-person-circle"></i>
                                <strong>@comment.Author</strong>
                                <span class="text-muted small">commented @FormatDate(comment.CreatedAt)</span>
                            </div>
                            <div class="card-body">
                                <div class="markdown-body">@((MarkupString)RenderMarkdown(comment.Body))</div>
                            </div>
                        </div>
                    }
                }

                @if (UserService.IsLoggedIn)
                {
                    <div class="card">
                        <div class="card-header bg-light">
                            <strong>Add a comment</strong>
                        </div>
                        <div class="card-body">
                            <textarea class="form-control mb-2" rows="4" @bind="newCommentBody" placeholder="Leave a comment"></textarea>
                            <button class="btn btn-success" @onclick="AddComment" disabled="@string.IsNullOrWhiteSpace(newCommentBody)">
                                <i class="bi bi-chat-left-text me-1"></i> Comment
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-warning">Issue #@Number not found.</div>
        }
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="btn-group">
                <button class="btn @(filterState == "open" ? "btn-dark" : "btn-outline-secondary") btn-sm" @onclick='() => filterState = "open"'>
                    <i class="bi bi-circle-fill me-1" style="font-size: 8px;"></i> @openCount Open
                </button>
                <button class="btn @(filterState == "closed" ? "btn-dark" : "btn-outline-secondary") btn-sm" @onclick='() => filterState = "closed"'>
                    <i class="bi bi-check-circle me-1"></i> @closedCount Closed
                </button>
            </div>
            @if (milestones.Any(m => m.State == MilestoneState.Open))
            {
                <select class="form-select form-select-sm" style="width: auto; min-width: 150px;" @bind="filterMilestoneId">
                    <option value="0">All milestones</option>
                    @foreach (var ms in milestones.Where(m => m.State == MilestoneState.Open))
                    {
                        <option value="@ms.Id">@ms.Title</option>
                    }
                </select>
            }
            @if (UserService.IsLoggedIn)
            {
                <button class="btn btn-success btn-sm" @onclick="OpenNewIssueModal">
                    <i class="bi bi-plus-circle me-1"></i> New issue
                </button>
            }
        </div>

        @if (filteredIssues.Any())
        {
            <div class="list-group">
                @foreach (var issue in filteredIssues)
                {
                    <a href="/repo/@RepoName/issues/@issue.Number" class="list-group-item list-group-item-action">
                        <div class="d-flex w-100 justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    @if (issue.State == IssueState.Open)
                                    {
                                        <i class="bi bi-circle-fill text-success" style="font-size: 12px;"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-check-circle-fill text-danger"></i>
                                    }
                                    <h6 class="mb-0">@issue.Title</h6>
                                    @if (issue.IsDraft)
                                    {
                                        <span class="badge bg-secondary" style="font-size: 10px;">Draft</span>
                                    }
                                    @foreach (var label in issue.Labels)
                                    {
                                        <span class="badge bg-primary" style="font-size: 10px;">@label</span>
                                    }
                                </div>
                                <small class="text-muted">
                                    #@issue.Number opened @FormatDate(issue.CreatedAt) by @issue.Author
                                    @if (issue.Comments.Any())
                                    {
                                        <span> · <i class="bi bi-chat-left"></i> @issue.Comments.Count</span>
                                    }
                                </small>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="blankslate p-5 border rounded-3 bg-light text-center">
                <i class="bi bi-check-circle display-4 text-muted mb-3"></i>
                <h3 class="h5">No @filterState issues</h3>
                <p class="text-muted">There are no @filterState issues for this repository.</p>
            </div>
        }
    }
</div>

@if (showNewIssueModal)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">New Issue</h5>
                    <button type="button" class="btn-close" @onclick="() => showNewIssueModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Title</label>
                        <input type="text" class="form-control" @bind="newIssueTitle" placeholder="Issue title" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Description</label>
                        <textarea class="form-control" rows="6" @bind="newIssueBody" placeholder="Leave a comment"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Labels (comma-separated)</label>
                        <input type="text" class="form-control" @bind="newIssueLabels" placeholder="bug, enhancement, documentation" />
                    </div>
                    @if (issueTemplates.Any())
                    {
                        <div class="mb-3">
                            <label class="form-label fw-bold">Template</label>
                            <select class="form-select" @bind="selectedTemplateId" @bind:after="ApplyTemplate">
                                <option value="0">No template</option>
                                @foreach (var tmpl in issueTemplates)
                                {
                                    <option value="@tmpl.Id">@tmpl.Name</option>
                                }
                            </select>
                        </div>
                    }
                    @if (milestones.Any(m => m.State == MilestoneState.Open))
                    {
                        <div class="mb-3">
                            <label class="form-label fw-bold">Milestone</label>
                            <select class="form-select" @bind="newIssueMilestoneId">
                                <option value="0">No milestone</option>
                                @foreach (var ms in milestones.Where(m => m.State == MilestoneState.Open))
                                {
                                    <option value="@ms.Id">@ms.Title</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" @bind="newIssueIsDraft" id="issueDraftCheck">
                        <label class="form-check-label" for="issueDraftCheck">
                            Create as draft
                        </label>
                        <div class="form-text">Draft issues are visible but marked as work-in-progress.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showNewIssueModal = false">Cancel</button>
                    <button type="button" class="btn btn-success" @onclick="CreateIssue" disabled="@string.IsNullOrWhiteSpace(newIssueTitle)">
                        <i class="bi bi-plus-circle me-1"></i> @(newIssueIsDraft ? "Create draft" : "Create issue")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string RepoName { get; set; } = "";
    [Parameter] public int? Number { get; set; }

    private List<Issue> issues = new();
    private Issue? currentIssue;
    private Milestone? currentIssueMilestone;
    private string filterState = "open";
    private bool showNewIssueModal = false;
    private string viewMode = "issues";
    private string milestoneFilter = "open";

    private string newIssueTitle = "";
    private string newIssueBody = "";
    private string newIssueLabels = "";
    private string newCommentBody = "";
    private string? issueTemplate;
    private int newIssueMilestoneId;
    private int filterMilestoneId;
    private bool newIssueIsDraft;
    private int selectedTemplateId;

    // Issue Templates
    private List<IssueTemplate> issueTemplates = new();
    private bool showNewTemplateModal;
    private string newTemplateName = "";
    private string newTemplateBody = "";
    private string newTemplateDescription = "";
    private string newTemplateLabels = "";

    // Milestones
    private List<Milestone> milestones = new();
    private Dictionary<int, (int, int)> milestoneCounts = new();
    private bool showNewMilestoneModal;
    private string newMilestoneTitle = "";
    private string newMilestoneDescription = "";
    private string newMilestoneDueDate = "";

    private List<Issue> filteredIssues
    {
        get
        {
            var q = issues.Where(i => filterState == "open" ? i.State == IssueState.Open : i.State == IssueState.Closed);
            if (filterMilestoneId > 0)
                q = q.Where(i => i.MilestoneId == filterMilestoneId);
            return q.OrderByDescending(i => i.CreatedAt).ToList();
        }
    }

    private int openCount => issues.Count(i => i.State == IssueState.Open);
    private int closedCount => issues.Count(i => i.State == IssueState.Closed);

    protected override async Task OnParametersSetAsync()
    {
        // Detect milestones route
        var uri = Nav.ToBaseRelativePath(Nav.Uri);
        if (uri.EndsWith("/milestones", StringComparison.OrdinalIgnoreCase))
            viewMode = "milestones";

        await LoadIssues();
        await LoadMilestones();
        await LoadTemplates();
        LoadTemplate();
    }

    private async Task LoadIssues()
    {
        issues = await IssueService.GetIssuesAsync(RepoName);
        if (Number.HasValue)
        {
            currentIssue = await IssueService.GetIssueAsync(RepoName, Number.Value);
            if (currentIssue?.MilestoneId != null)
            {
                currentIssueMilestone = milestones.FirstOrDefault(m => m.Id == currentIssue.MilestoneId);
                if (currentIssueMilestone == null)
                {
                    // Milestones may not be loaded yet, load them
                    await LoadMilestones();
                    currentIssueMilestone = milestones.FirstOrDefault(m => m.Id == currentIssue.MilestoneId);
                }
            }
        }
    }

    private async Task LoadMilestones()
    {
        milestones = await MilestoneService.GetMilestonesAsync(RepoName);
        milestoneCounts.Clear();
        foreach (var ms in milestones)
        {
            var counts = await MilestoneService.GetIssueCountsAsync(ms.Id);
            milestoneCounts[ms.Id] = (counts.Open, counts.Closed);
        }
    }

    private void LoadTemplate()
    {
        try
        {
            var repoPath = GetRepoPathSync();
            if (repoPath == null || !LibGit2Sharp.Repository.IsValid(repoPath)) return;
            using var repo = new LibGit2Sharp.Repository(repoPath);
            var head = repo.Head;
            if (head?.Tip == null) return;
            var tree = head.Tip.Tree;
            var entry = tree[".github/ISSUE_TEMPLATE.md"];
            if (entry?.Target is Blob blob)
            {
                issueTemplate = blob.GetContentText();
            }
        }
        catch { }
    }

    private string? GetRepoPathSync()
    {
        var projectRoot = Config["Git:ProjectRoot"] ?? "/repos";
        var path = System.IO.Path.Combine(projectRoot, RepoName);
        if (LibGit2Sharp.Repository.IsValid(path)) return path;
        if (LibGit2Sharp.Repository.IsValid(path + ".git")) return path + ".git";
        return null;
    }

    private void OpenNewIssueModal()
    {
        newIssueBody = issueTemplate ?? "";
        showNewIssueModal = true;
    }

    private async Task CreateIssue()
    {
        if (!UserService.IsLoggedIn) return;
        var labels = newIssueLabels.Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(l => l.Trim())
            .Where(l => !string.IsNullOrWhiteSpace(l))
            .ToList();

        var issue = await IssueService.CreateIssueAsync(RepoName, newIssueTitle, newIssueBody, UserService.Username, labels);

        if (newIssueMilestoneId > 0)
        {
            await IssueService.UpdateIssueAsync(RepoName, issue.Number, i => i.MilestoneId = newIssueMilestoneId);
        }
        if (newIssueIsDraft)
        {
            await IssueService.UpdateIssueAsync(RepoName, issue.Number, i => i.IsDraft = true);
        }

        newIssueTitle = "";
        newIssueBody = "";
        newIssueLabels = "";
        newIssueMilestoneId = 0;
        newIssueIsDraft = false;
        selectedTemplateId = 0;
        showNewIssueModal = false;

        Nav.NavigateTo($"/repo/{RepoName}/issues/{issue.Number}");
    }

    private async Task AddComment()
    {
        if (!UserService.IsLoggedIn) return;
        if (Number.HasValue && !string.IsNullOrWhiteSpace(newCommentBody))
        {
            await IssueService.AddCommentAsync(RepoName, Number.Value, UserService.Username, newCommentBody);
            newCommentBody = "";
            await LoadIssues();
        }
    }

    private async Task CloseIssue()
    {
        if (!UserService.IsLoggedIn) return;
        if (Number.HasValue)
        {
            await IssueService.CloseIssueAsync(RepoName, Number.Value);
            await LoadIssues();
        }
    }

    private async Task ReopenIssue()
    {
        if (!UserService.IsLoggedIn) return;
        if (Number.HasValue)
        {
            await IssueService.ReopenIssueAsync(RepoName, Number.Value);
            await LoadIssues();
        }
    }

    private string FormatDate(DateTime date)
    {
        var diff = DateTime.UtcNow - date;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} minutes ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} hours ago";
        if (diff.TotalDays < 30) return $"{(int)diff.TotalDays} days ago";
        return date.ToString("MMM d, yyyy");
    }

    private static readonly MarkdownPipeline _mdPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    private string RenderMarkdown(string markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown)) return "";
        return Markdown.ToHtml(markdown, _mdPipeline);
    }

    private static bool IsAutoCloseComment(string body) =>
        body.StartsWith("Closed via commit") || body.StartsWith("Closed via pull request");

    private static bool IsReferenceComment(string body) =>
        body.StartsWith("Referenced in commit") || body.StartsWith("Referenced in pull request");

    private List<Milestone> GetFilteredMilestones() =>
        milestones.Where(m => milestoneFilter == "open" ? m.State == MilestoneState.Open : m.State == MilestoneState.Closed).ToList();

    private void SwitchToMilestones()
    {
        viewMode = "milestones";
    }

    private async Task CreateMilestone()
    {
        if (string.IsNullOrWhiteSpace(newMilestoneTitle) || !UserService.IsLoggedIn) return;
        DateTime? dueDate = DateTime.TryParse(newMilestoneDueDate, out var d) ? d : null;
        await MilestoneService.CreateMilestoneAsync(RepoName, newMilestoneTitle, newMilestoneDescription, dueDate, UserService.Username);
        showNewMilestoneModal = false;
        newMilestoneTitle = "";
        newMilestoneDescription = "";
        newMilestoneDueDate = "";
        await LoadMilestones();
    }

    private async Task CloseMilestone(int number)
    {
        await MilestoneService.CloseMilestoneAsync(RepoName, number);
        await LoadMilestones();
    }

    private async Task ReopenMilestone(int number)
    {
        await MilestoneService.ReopenMilestoneAsync(RepoName, number);
        await LoadMilestones();
    }

    private async Task DeleteMilestone(int number)
    {
        await MilestoneService.DeleteMilestoneAsync(RepoName, number);
        await LoadMilestones();
    }

    // Issue Templates
    private async Task LoadTemplates()
    {
        issueTemplates = await TemplateService.GetTemplatesAsync(RepoName);
    }

    private void ApplyTemplate()
    {
        if (selectedTemplateId <= 0) return;
        var tmpl = issueTemplates.FirstOrDefault(t => t.Id == selectedTemplateId);
        if (tmpl == null) return;
        newIssueBody = tmpl.Body;
        if (!string.IsNullOrEmpty(tmpl.Labels))
            newIssueLabels = tmpl.Labels;
    }

    private void UseTemplate(IssueTemplate tmpl)
    {
        selectedTemplateId = tmpl.Id;
        newIssueBody = tmpl.Body;
        if (!string.IsNullOrEmpty(tmpl.Labels))
            newIssueLabels = tmpl.Labels;
        viewMode = "issues";
        showNewIssueModal = true;
    }

    private async Task CreateTemplate()
    {
        if (!UserService.IsLoggedIn || string.IsNullOrWhiteSpace(newTemplateName)) return;
        await TemplateService.CreateTemplateAsync(RepoName, newTemplateName, newTemplateBody, newTemplateDescription, newTemplateLabels);
        newTemplateName = "";
        newTemplateBody = "";
        newTemplateDescription = "";
        newTemplateLabels = "";
        showNewTemplateModal = false;
        await LoadTemplates();
    }

    private async Task DeleteTemplate(int id)
    {
        await TemplateService.DeleteTemplateAsync(id);
        await LoadTemplates();
    }

    // Draft issue conversion
    private async Task ConvertDraftToIssue()
    {
        if (!UserService.IsLoggedIn || currentIssue == null) return;
        await IssueService.UpdateIssueAsync(RepoName, currentIssue.Number, i => i.IsDraft = false);
        await LoadIssues();
    }
}

@if (showNewMilestoneModal)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5); position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-bottom-0">
                    <h5 class="modal-title fw-bold">New milestone</h5>
                    <button type="button" class="btn-close" @onclick="() => showNewMilestoneModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Title</label>
                        <input type="text" class="form-control" @bind="newMilestoneTitle" placeholder="v1.0" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Due date (optional)</label>
                        <input type="text" class="form-control" @bind="newMilestoneDueDate" placeholder="YYYY-MM-DD" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Description</label>
                        <textarea class="form-control" rows="3" @bind="newMilestoneDescription" placeholder="Describe the milestone..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top-0">
                    <button class="btn btn-light border" @onclick="() => showNewMilestoneModal = false">Cancel</button>
                    <button class="btn btn-gh-primary" @onclick="CreateMilestone" disabled="@string.IsNullOrWhiteSpace(newMilestoneTitle)">Create milestone</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showNewTemplateModal)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5); position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1050;">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-bottom-0">
                    <h5 class="modal-title fw-bold">New Issue Template</h5>
                    <button type="button" class="btn-close" @onclick="() => showNewTemplateModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Template Name</label>
                        <input type="text" class="form-control" @bind="newTemplateName" placeholder="Bug Report" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Description</label>
                        <input type="text" class="form-control" @bind="newTemplateDescription" placeholder="File a bug report" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Default Labels (comma-separated)</label>
                        <input type="text" class="form-control" @bind="newTemplateLabels" placeholder="bug, triage" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Template Body (Markdown)</label>
                        <textarea class="form-control font-monospace" rows="10" @bind="newTemplateBody" placeholder="## Description&#10;&#10;## Steps to Reproduce&#10;&#10;## Expected Behavior&#10;&#10;## Actual Behavior"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top-0">
                    <button class="btn btn-light border" @onclick="() => showNewTemplateModal = false">Cancel</button>
                    <button class="btn btn-success" @onclick="CreateTemplate" disabled="@(string.IsNullOrWhiteSpace(newTemplateName) || string.IsNullOrWhiteSpace(newTemplateBody))">Create template</button>
                </div>
            </div>
        </div>
    </div>
}


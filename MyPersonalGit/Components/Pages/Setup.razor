@page "/setup"
@using MyPersonalGit.Data
@using MyPersonalGit.Models
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Logging
@using MyPersonalGit.Services
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IAdminService AdminService
@inject CurrentUserService UserService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<Setup> Logger
@* prerender disabled so the form runs on the interactive circuit (JS interop available) *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>First-run setup · MyPersonalGit</PageTitle>

<div class="container" style="max-width: 560px;">
    <div class="card shadow mt-5">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <i class="bi bi-rocket-takeoff text-primary" style="font-size: 2.5rem;" aria-hidden="true"></i>
                <h1 class="h3 fw-bold mt-2">Welcome to MyPersonalGit</h1>
                <p class="text-muted mb-0">First-run setup — create the administrator account to get started.</p>
            </div>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-danger" role="alert"><i class="bi bi-exclamation-triangle me-2" aria-hidden="true"></i>@ErrorMessage</div>
            }

            <EditForm Model="@model" OnValidSubmit="CompleteSetup">
                <div class="mb-3">
                    <label for="siteName" class="form-label">Site name</label>
                    <input id="siteName" class="form-control" @bind="model.SiteName" placeholder="MyPersonalGit" />
                </div>

                <hr class="my-3" />
                <h2 class="h6 fw-bold">Administrator account</h2>

                <div class="mb-3">
                    <label for="username" class="form-label">Admin username</label>
                    <input id="username" class="form-control" @bind="model.Username" placeholder="admin" autocomplete="username" autofocus />
                </div>
                <div class="mb-3">
                    <label for="email" class="form-label">Admin email <span class="text-muted fw-normal">(optional)</span></label>
                    <input id="email" type="email" class="form-control" @bind="model.Email" placeholder="you@example.com" autocomplete="email" />
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input id="password" type="password" class="form-control" @bind="model.Password" autocomplete="new-password" />
                    <div class="form-text">At least 8 characters.</div>
                </div>
                <div class="mb-3">
                    <label for="confirm" class="form-label">Confirm password</label>
                    <input id="confirm" type="password" class="form-control" @bind="model.ConfirmPassword" autocomplete="new-password" />
                </div>

                <button type="submit" class="btn btn-primary w-100" disabled="@IsBusy">
                    @if (IsBusy)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>Setting up…</span>
                    }
                    else
                    {
                        <span>Create admin &amp; finish setup</span>
                    }
                </button>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private SetupModel model = new();
    private string? ErrorMessage;
    private bool IsBusy;

    protected override async Task OnInitializedAsync()
    {
        // Setup is one-time: if an admin already exists, the wizard is closed.
        await using var db = await DbFactory.CreateDbContextAsync();
        if (await db.Users.AnyAsync(u => u.IsAdmin))
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        try
        {
            var settings = await AdminService.GetSystemSettingsAsync();
            if (!string.IsNullOrWhiteSpace(settings.SiteName)) model.SiteName = settings.SiteName;
        }
        catch { /* settings not ready yet — use defaults */ }
    }

    private async Task CompleteSetup()
    {
        ErrorMessage = null;

        if (string.IsNullOrWhiteSpace(model.Username)) { ErrorMessage = "Username is required."; return; }
        if (model.Password.Length < 8) { ErrorMessage = "Password must be at least 8 characters."; return; }
        if (model.Password != model.ConfirmPassword) { ErrorMessage = "Passwords do not match."; return; }

        IsBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            // Guard against double-submit / a race creating two admins.
            if (await db.Users.AnyAsync(u => u.IsAdmin))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            var admin = new User
            {
                Username = model.Username.Trim(),
                Email = string.IsNullOrWhiteSpace(model.Email) ? $"{model.Username.Trim()}@localhost" : model.Email.Trim(),
                PasswordHash = BCrypt.Net.BCrypt.HashPassword(model.Password, workFactor: 12),
                IsAdmin = true,
                IsActive = true,
                CreatedAt = DateTime.UtcNow
            };
            db.Users.Add(admin);

            if (!string.IsNullOrWhiteSpace(model.SiteName))
            {
                var settings = await db.SystemSettings.FirstOrDefaultAsync();
                if (settings != null) settings.SiteName = model.SiteName.Trim();
            }

            await db.SaveChangesAsync();

            // Log the new admin in and land on the dashboard.
            var sessionId = await UserService.CreateSessionForUserAsync(admin);
            if (!string.IsNullOrEmpty(sessionId))
            {
                try { await JS.InvokeVoidAsync("sessionHelper.set", "sessionId", sessionId); }
                catch (Exception jsEx) { Logger.LogError(jsEx, "Setup: storing session in browser failed"); }
            }

            Navigation.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "First-run setup failed");
            ErrorMessage = "Setup failed: " + ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private class SetupModel
    {
        public string SiteName { get; set; } = "MyPersonalGit";
        public string Username { get; set; } = "admin";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}

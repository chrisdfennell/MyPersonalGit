@page "/repo/{RepoName}/actions"
@page "/repo/{RepoName}/actions/runs/{RunId:int}"
@using MyPersonalGit.Data
@using MyPersonalGit.Models
@using MyPersonalGit.Services
@using LibGit2Sharp
@inject IWorkflowService WorkflowService
@inject IArtifactService ArtifactService
@inject WorkflowYamlParser YamlParser
@inject IAdminService AdminService
@inject IConfiguration Config
@inject CurrentUserService UserService
@inject NavigationManager Navigation
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Actions - @RepoName</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/">Repositories</a></li>
                    <li class="breadcrumb-item"><a href="/repo/@RepoName">@RepoName</a></li>
                    <li class="breadcrumb-item active">Actions</li>
                </ol>
            </nav>
            <h2 class="mt-2">Actions</h2>
        </div>
        @if (UserService.IsLoggedIn && !RunId.HasValue)
        {
            @if (detectedWorkflows.Any())
            {
                <div class="dropdown">
                    <button class="btn btn-primary dropdown-toggle" type="button" @onclick="() => showRunDropdown = !showRunDropdown">
                        <i class="bi bi-play-circle me-1"></i> Run workflow
                    </button>
                    @if (showRunDropdown)
                    {
                        <div class="dropdown-menu show shadow p-3" style="min-width: 350px; display: block; position: absolute; right: 0; z-index: 1000;">
                            @if (selectedDispatchWorkflow == null)
                            {
                                <h6 class="fw-bold small mb-2">Select workflow</h6>
                                @foreach (var wf in detectedWorkflows)
                                {
                                    <button class="dropdown-item py-2" @onclick="() => SelectWorkflowForDispatch(wf)">
                                        <i class="bi bi-file-earmark-code me-2"></i> @wf.Name
                                        <span class="text-muted small d-block">@wf.FileName</span>
                                    </button>
                                }
                            }
                            else
                            {
                                <h6 class="fw-bold small mb-2">@selectedDispatchWorkflow.Name</h6>
                                @if (selectedDispatchWorkflow.Inputs.Any())
                                {
                                    @foreach (var input in selectedDispatchWorkflow.Inputs)
                                    {
                                        <div class="mb-2">
                                            <label class="form-label small mb-1">
                                                @input.Name
                                                @if (input.Required) { <span class="text-danger">*</span> }
                                            </label>
                                            @if (!string.IsNullOrEmpty(input.Description))
                                            {
                                                <div class="text-muted" style="font-size: 0.75rem;">@input.Description</div>
                                            }
                                            @if (input.Type == "boolean")
                                            {
                                                <div class="form-check">
                                                    <input type="checkbox" class="form-check-input"
                                                           checked="@(string.Equals(GetDispatchInputValue(input.Name), "true", StringComparison.OrdinalIgnoreCase))"
                                                           @onchange="@(e => SetDispatchInputValue(input.Name, string.Equals(e.Value?.ToString(), "True") ? "true" : "false"))" />
                                                </div>
                                            }
                                            else if (input.Type == "choice" && input.Options.Any())
                                            {
                                                <select class="form-select form-select-sm" value="@GetDispatchInputValue(input.Name)"
                                                        @onchange="@(e => SetDispatchInputValue(input.Name, e.Value?.ToString() ?? string.Empty))">
                                                    @foreach (var opt in input.Options)
                                                    {
                                                        <option value="@opt">@opt</option>
                                                    }
                                                </select>
                                            }
                                            else
                                            {
                                                <input type="text" class="form-control form-control-sm" value="@GetDispatchInputValue(input.Name)"
                                                       @onchange="@(e => SetDispatchInputValue(input.Name, e.Value?.ToString() ?? string.Empty))" />
                                            }
                                        </div>
                                    }
                                }
                                <div class="d-flex gap-2 mt-3">
                                    <button class="btn btn-sm btn-secondary" @onclick="() => selectedDispatchWorkflow = null">Back</button>
                                    <button class="btn btn-sm btn-primary" @onclick="() => TriggerWorkflowWithInputs()">
                                        <i class="bi bi-play-fill me-1"></i>Run
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <button class="btn btn-primary" @onclick="ShowCreateWorkflowModal">
                    <i class="bi bi-plus-circle me-2"></i>Create workflow run
                </button>
            }
        }
    </div>

    @if (RunId.HasValue)
    {
        <!-- Run Detail View -->
        @if (selectedRun != null)
        {
            <div class="mb-3">
                <a href="/repo/@RepoName/actions" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Back to runs
                </a>
            </div>

            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1">
                            <i class="@GetStatusIcon(selectedRun.Status) me-2"></i>
                            @selectedRun.WorkflowName
                            <span class="badge @GetStatusBadgeClass(selectedRun.Status) ms-2">@selectedRun.Status</span>
                        </h5>
                        <small class="text-muted">
                            <i class="bi bi-git me-1"></i>@selectedRun.Branch
                            <span class="mx-1">·</span>
                            <code>@selectedRun.CommitSha[..Math.Min(7, selectedRun.CommitSha.Length)]</code>
                            <span class="mx-1">·</span>
                            @selectedRun.CommitMessage
                        </small>
                    </div>
                    <div class="text-end text-muted small">
                        <div>Triggered by <strong>@selectedRun.TriggeredBy</strong></div>
                        <div>Started: @selectedRun.CreatedAt.ToString("MMM dd, yyyy HH:mm:ss") UTC</div>
                        @if (selectedRun.CompletedAt.HasValue)
                        {
                            <div>Finished: @selectedRun.CompletedAt.Value.ToString("HH:mm:ss") UTC</div>
                        }
                        @if (selectedRun.CompletedAt.HasValue && selectedRun.StartedAt.HasValue)
                        {
                            <div><strong>Total: @FormatDuration(selectedRun.CompletedAt.Value - selectedRun.StartedAt.Value)</strong></div>
                        }
                        else if (selectedRun.StartedAt.HasValue)
                        {
                            <div><i class="bi bi-hourglass-split me-1"></i>Running: @FormatDuration(DateTime.UtcNow - selectedRun.StartedAt.Value)</div>
                        }
                        <div class="mt-2 d-flex gap-2">
                            @if (selectedRun.Status == WorkflowStatus.Queued || selectedRun.Status == WorkflowStatus.InProgress)
                            {
                                <button class="btn btn-outline-danger btn-sm" @onclick="CancelRun">
                                    <i class="bi bi-x-circle me-1"></i>Cancel
                                </button>
                            }
                            @if (selectedRun.Status == WorkflowStatus.Failure || selectedRun.Status == WorkflowStatus.Success || selectedRun.Status == WorkflowStatus.Cancelled)
                            {
                                <button class="btn btn-outline-primary btn-sm" @onclick="RerunWorkflow">
                                    <i class="bi bi-arrow-clockwise me-1"></i>Re-run
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @foreach (var job in selectedRun.Jobs)
            {
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center" style="cursor: pointer;" @onclick="() => ToggleJob(job.Id)">
                        <div>
                            <i class="@GetStatusIcon(job.Status) me-2"></i>
                            <strong>@job.Name</strong>
                            <span class="badge @GetStatusBadgeClass(job.Status) ms-2">@job.Status</span>
                            <span class="text-muted small ms-2">(@job.RunsOn)</span>
                            @if (job.StartedAt.HasValue && job.CompletedAt.HasValue)
                            {
                                <span class="text-muted small ms-2">@FormatDuration(job.CompletedAt.Value - job.StartedAt.Value)</span>
                            }
                        </div>
                        <i class="bi @(expandedJobs.Contains(job.Id) ? "bi-chevron-up" : "bi-chevron-down")"></i>
                    </div>
                    @if (expandedJobs.Contains(job.Id))
                    {
                        <div class="card-body p-0">
                            @foreach (var step in job.Steps)
                            {
                                <div class="border-bottom px-3 py-2">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div>
                                            <i class="@GetStatusIcon(step.Status) me-2"></i>
                                            <span class="small fw-semibold">@step.Name</span>
                                        </div>
                                        @if (step.StartedAt.HasValue && step.CompletedAt.HasValue)
                                        {
                                            <span class="text-muted" style="font-size: 11px;">
                                                @((step.CompletedAt.Value - step.StartedAt.Value).TotalSeconds.ToString("F1"))s
                                            </span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(step.Output))
                                    {
                                        <pre class="mt-2 p-2 bg-dark text-light rounded small mb-0" style="max-height: 400px; overflow: auto; font-size: 12px; white-space: pre-wrap;">@step.Output</pre>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            @if (runArtifacts.Any())
            {
                <div class="card mb-3">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-archive me-2"></i>Artifacts</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            @foreach (var artifact in runArtifacts)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <i class="bi bi-file-earmark-zip me-2"></i>
                                        <span class="fw-semibold">@artifact.Name</span>
                                        <span class="text-muted small ms-2">@FormatBytes(artifact.SizeBytes)</span>
                                    </div>
                                    <div class="btn-group btn-group-sm">
                                        <a href="/api/artifacts/@artifact.Id/download" class="btn btn-outline-primary" target="_blank">
                                            <i class="bi bi-download me-1"></i> Download
                                        </a>
                                        @if (UserService.IsLoggedIn)
                                        {
                                            <button class="btn btn-outline-danger" @onclick="() => DeleteArtifact(artifact.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-warning">Workflow run #@RunId not found.</div>
        }
    }
    else
    {
        <!-- Runs List -->
        <ul class="nav nav-tabs mb-4">
            <li class="nav-item">
                <button class="nav-link @(ActiveTab == "runs" ? "active" : "")" @onclick='() => ActiveTab = "runs"'>
                    <i class="bi bi-play-circle me-1"></i> Workflow Runs
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(ActiveTab == "webhooks" ? "active" : "")" @onclick='() => ActiveTab = "webhooks"'>
                    <i class="bi bi-webhook me-1"></i> Webhooks
                </button>
            </li>
        </ul>

        @if (ActiveTab == "runs")
        {
            @if (detectedWorkflows.Any())
            {
                <div class="alert alert-info small py-2 mb-3">
                    <i class="bi bi-info-circle me-1"></i>
                    Detected <strong>@detectedWorkflows.Count</strong> workflow@(detectedWorkflows.Count != 1 ? "s" : "") from <code>.github/workflows/</code>:
                    @string.Join(", ", detectedWorkflows.Select(w => w.FileName))
                </div>
            }

            @if (WorkflowRuns.Count == 0)
            {
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-play-circle" style="font-size: 4rem; color: #6c757d;"></i>
                        <h3 class="mt-3">No workflow runs yet</h3>
                        <p class="text-muted">
                            @if (detectedWorkflows.Any())
                            {
                                <span>Click "Run workflow" to trigger a workflow from <code>.github/workflows/</code></span>
                            }
                            else
                            {
                                <span>Add a <code>.github/workflows/*.yml</code> file to your repository, or create a manual run.</span>
                            }
                        </p>
                    </div>
                </div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var run in WorkflowRuns.OrderByDescending(r => r.CreatedAt))
                    {
                        <div class="list-group-item list-group-item-action" style="cursor: pointer;" @onclick="() => ViewWorkflowRun(run.Id)">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center mb-2">
                                        <i class="@GetStatusIcon(run.Status) me-2"></i>
                                        <h6 class="mb-0">@run.WorkflowName</h6>
                                        <span class="badge @GetStatusBadgeClass(run.Status) ms-2">@run.Status</span>
                                    </div>
                                    <p class="mb-1 text-muted small">@run.CommitMessage</p>
                                    <small class="text-muted">
                                        <i class="bi bi-git me-1"></i>@run.Branch
                                        <span class="mx-2">·</span>
                                        <code>@run.CommitSha[..Math.Min(7, run.CommitSha.Length)]</code>
                                        <span class="mx-2">·</span>
                                        <i class="bi bi-person me-1"></i>@run.TriggeredBy
                                        <span class="mx-2">·</span>
                                        @FormatDate(run.CreatedAt)
                                    </small>
                                </div>
                                @if (run.CompletedAt.HasValue && run.StartedAt.HasValue)
                                {
                                    <div class="text-end">
                                        <small class="text-muted">
                                            @FormatDuration(run.CompletedAt.Value - run.StartedAt.Value)
                                        </small>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else if (ActiveTab == "webhooks")
        {
            @if (selectedWebhook == null)
            {
                @if (UserService.IsLoggedIn)
                {
                    <div class="d-flex justify-content-end mb-3">
                        <button class="btn btn-primary" @onclick="ShowCreateWebhookModal">
                            <i class="bi bi-plus-circle me-2"></i>Add webhook
                        </button>
                    </div>
                }

                @if (Webhooks.Count == 0)
                {
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <i class="bi bi-webhook" style="font-size: 4rem; color: #6c757d;"></i>
                            <h3 class="mt-3">No webhooks configured</h3>
                            <p class="text-muted">Add webhooks to receive notifications about repository events</p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var webhook in Webhooks)
                        {
                            <div class="list-group-item list-group-item-action" style="cursor: pointer;" @onclick="() => ViewWebhookDetails(webhook)">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center mb-2">
                                            <h6 class="mb-0">@webhook.Url</h6>
                                            <span class="badge @(webhook.IsActive ? "bg-success" : "bg-secondary") ms-2">
                                                @(webhook.IsActive ? "Active" : "Inactive")
                                            </span>
                                        </div>
                                        <div class="mb-2">
                                            @foreach (var evt in webhook.Events)
                                            {
                                                <span class="badge bg-secondary me-1">@evt</span>
                                            }
                                        </div>
                                        <small class="text-muted">
                                            Created @FormatDate(webhook.CreatedAt)
                                            @if (webhook.LastTriggeredAt.HasValue)
                                            {
                                                <span class="mx-2">·</span>
                                                <span>Last triggered @FormatDate(webhook.LastTriggeredAt.Value)</span>
                                            }
                                        </small>
                                    </div>
                                    @if (UserService.IsLoggedIn)
                                    {
                                        <div class="btn-group" @onclick:stopPropagation="true">
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEditWebhook(webhook)" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => ToggleWebhook(webhook.Id)" title="@(webhook.IsActive ? "Disable" : "Enable")">
                                                <i class="bi bi-@(webhook.IsActive ? "pause" : "play")-circle"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteWebhook(webhook.Id)" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                @* Webhook detail view with delivery history *@
                <div class="mb-3">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => { selectedWebhook = null; webhookDeliveries.Clear(); }">
                        <i class="bi bi-arrow-left me-1"></i>Back to webhooks
                    </button>
                </div>

                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Webhook Details</h5>
                        <span class="badge @(selectedWebhook.IsActive ? "bg-success" : "bg-secondary")">
                            @(selectedWebhook.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-8">
                                <p class="mb-1"><strong>URL:</strong> <code>@selectedWebhook.Url</code></p>
                                <p class="mb-1"><strong>Events:</strong>
                                    @foreach (var evt in selectedWebhook.Events)
                                    {
                                        <span class="badge bg-secondary me-1">@evt</span>
                                    }
                                </p>
                                <p class="mb-1"><strong>Created:</strong> @FormatDate(selectedWebhook.CreatedAt)</p>
                                @if (selectedWebhook.LastTriggeredAt.HasValue)
                                {
                                    <p class="mb-0"><strong>Last triggered:</strong> @FormatDate(selectedWebhook.LastTriggeredAt.Value)</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <h5>Recent Deliveries</h5>
                @if (webhookDeliveries.Count == 0)
                {
                    <div class="text-muted py-3">No deliveries yet.</div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var delivery in webhookDeliveries)
                        {
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center mb-1">
                                            <i class="bi @(delivery.Success ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger") me-2"></i>
                                            <strong>@delivery.Event</strong>
                                            <span class="badge @(delivery.Success ? "bg-success" : "bg-danger") ms-2">@(delivery.StatusCode > 0 ? delivery.StatusCode.ToString() : "Error")</span>
                                        </div>
                                        <small class="text-muted">Delivered @FormatDate(delivery.DeliveredAt)</small>

                                        @if (expandedDeliveryId == delivery.Id)
                                        {
                                            <div class="mt-2">
                                                <div class="mb-2">
                                                    <strong class="small">Request Payload:</strong>
                                                    <pre class="bg-dark text-light p-2 rounded mt-1" style="max-height: 200px; overflow-y: auto; font-size: 12px;">@delivery.Payload</pre>
                                                </div>
                                                @if (!string.IsNullOrEmpty(delivery.Response))
                                                {
                                                    <div>
                                                        <strong class="small">Response:</strong>
                                                        <pre class="bg-dark text-light p-2 rounded mt-1" style="max-height: 200px; overflow-y: auto; font-size: 12px;">@delivery.Response</pre>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                    <div class="btn-group">
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleDeliveryDetails(delivery.Id)" title="@(expandedDeliveryId == delivery.Id ? "Collapse" : "Expand")">
                                            <i class="bi bi-@(expandedDeliveryId == delivery.Id ? "chevron-up" : "chevron-down")"></i>
                                        </button>
                                        @if (UserService.IsLoggedIn)
                                        {
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => RedeliverWebhook(delivery.Id)" title="Redeliver">
                                                <i class="bi bi-arrow-repeat"></i>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        }
    }
</div>

@if (ShowWorkflowModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create Workflow Run</h5>
                    <button type="button" class="btn-close" @onclick="() => ShowWorkflowModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Workflow Name</label>
                        <input type="text" class="form-control" @bind="NewWorkflowName" placeholder="e.g., Build and Test" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Branch</label>
                        <input type="text" class="form-control" @bind="NewWorkflowBranch" placeholder="e.g., main" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Commit SHA</label>
                        <input type="text" class="form-control" @bind="NewWorkflowCommitSha" placeholder="e.g., abc123" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Commit Message</label>
                        <input type="text" class="form-control" @bind="NewWorkflowCommitMessage" placeholder="e.g., Fix bug" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => ShowWorkflowModal = false">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="CreateWorkflowRun">Create</button>
                </div>
            </div>
        </div>
    </div>
}

@if (ShowWebhookModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingWebhookId.HasValue ? "Edit Webhook" : "Add Webhook")</h5>
                    <button type="button" class="btn-close" @onclick="() => ShowWebhookModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Payload URL</label>
                        <input type="url" class="form-control" @bind="NewWebhookUrl" placeholder="https://example.com/webhook" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Secret @(editingWebhookId.HasValue ? "(leave blank to keep current)" : "")</label>
                        <input type="password" class="form-control" @bind="NewWebhookSecret" placeholder="@(editingWebhookId.HasValue ? "Leave blank to keep current" : "Enter webhook secret")" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Events</label>
                        <div class="row">
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" checked="@SelectedEvents.Contains("push")" @onchange="@((e) => ToggleEvent(e, "push"))" />
                                    <label class="form-check-label">Push</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" checked="@SelectedEvents.Contains("pull_request")" @onchange="@((e) => ToggleEvent(e, "pull_request"))" />
                                    <label class="form-check-label">Pull Request</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" checked="@SelectedEvents.Contains("issues")" @onchange="@((e) => ToggleEvent(e, "issues"))" />
                                    <label class="form-check-label">Issues</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" checked="@SelectedEvents.Contains("release")" @onchange="@((e) => ToggleEvent(e, "release"))" />
                                    <label class="form-check-label">Release</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" checked="@SelectedEvents.Contains("workflow_run")" @onchange="@((e) => ToggleEvent(e, "workflow_run"))" />
                                    <label class="form-check-label">Workflow Run</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" checked="@SelectedEvents.Contains("create")" @onchange="@((e) => ToggleEvent(e, "create"))" />
                                    <label class="form-check-label">Branch/Tag Create</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" checked="@SelectedEvents.Contains("delete")" @onchange="@((e) => ToggleEvent(e, "delete"))" />
                                    <label class="form-check-label">Branch/Tag Delete</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" checked="@SelectedEvents.Contains("fork")" @onchange="@((e) => ToggleEvent(e, "fork"))" />
                                    <label class="form-check-label">Fork</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => ShowWebhookModal = false">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveWebhook">@(editingWebhookId.HasValue ? "Save changes" : "Add webhook")</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string RepoName { get; set; } = "";
    [Parameter] public int? RunId { get; set; }

    private List<WorkflowRun> WorkflowRuns { get; set; } = new();
    private List<Webhook> Webhooks { get; set; } = new();
    private List<WorkflowDefinition> detectedWorkflows = new();
    private WorkflowRun? selectedRun;
    private List<WorkflowArtifact> runArtifacts = new();
    private string ActiveTab { get; set; } = "runs";
    private bool showRunDropdown;
    private WorkflowDefinition? selectedDispatchWorkflow;
    private Dictionary<string, string> dispatchInputValues = new();
    private HashSet<int> expandedJobs = new();
    private System.Threading.Timer? _refreshTimer;

    private bool ShowWorkflowModal { get; set; }
    private string NewWorkflowName { get; set; } = "";
    private string NewWorkflowBranch { get; set; } = "main";
    private string NewWorkflowCommitSha { get; set; } = "";
    private string NewWorkflowCommitMessage { get; set; } = "";

    private bool ShowWebhookModal { get; set; }
    private string NewWebhookUrl { get; set; } = "";
    private string NewWebhookSecret { get; set; } = "";
    private List<string> SelectedEvents { get; set; } = new();
    private int? editingWebhookId;
    private Webhook? selectedWebhook;
    private List<WebhookDelivery> webhookDeliveries = new();
    private int? expandedDeliveryId;

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
        DetectWorkflows();

        if (RunId.HasValue)
        {
            selectedRun = await WorkflowService.GetWorkflowRunAsync(RepoName, RunId.Value);
            if (selectedRun != null)
            {
                // Load artifacts
                runArtifacts = await ArtifactService.GetArtifactsAsync(selectedRun.Id);

                // Auto-expand all jobs
                foreach (var job in selectedRun.Jobs)
                    expandedJobs.Add(job.Id);

                // Auto-refresh while in-progress
                if (selectedRun.Status == WorkflowStatus.InProgress || selectedRun.Status == WorkflowStatus.Queued)
                {
                    StartAutoRefresh();
                }
                else
                {
                    StopAutoRefresh();
                }
            }
        }
        else
        {
            selectedRun = null;
            // Auto-refresh list view to pick up new runs
            StartAutoRefresh();
        }
    }

    private void StartAutoRefresh()
    {
        StopAutoRefresh();
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                if (RunId.HasValue)
                {
                    selectedRun = await WorkflowService.GetWorkflowRunAsync(RepoName, RunId.Value);
                    if (selectedRun != null && selectedRun.Status != WorkflowStatus.InProgress && selectedRun.Status != WorkflowStatus.Queued)
                    {
                        StopAutoRefresh();
                    }
                    await InvokeAsync(StateHasChanged);
                }
                else
                {
                    // Refresh runs list to pick up new/updated runs
                    await LoadData();
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch { }
        }, null, 3000, 5000);
    }

    private void StopAutoRefresh()
    {
        _refreshTimer?.Dispose();
        _refreshTimer = null;
    }

    public void Dispose()
    {
        StopAutoRefresh();
    }

    private async Task LoadData()
    {
        WorkflowRuns = await WorkflowService.GetWorkflowRunsAsync(RepoName);
        Webhooks = await WorkflowService.GetWebhooksAsync(RepoName);
    }

    private void DetectWorkflows()
    {
        try
        {
            var repoPath = GetRepoPath();
            if (repoPath != null)
            {
                detectedWorkflows = YamlParser.ParseFromRepo(repoPath);
            }
        }
        catch { }
    }

    private string? GetRepoPath()
    {
        var projectRoot = Config["Git:ProjectRoot"] ?? "/repos";
        var path = System.IO.Path.Combine(projectRoot, RepoName);
        if (LibGit2Sharp.Repository.IsValid(path)) return path;
        if (LibGit2Sharp.Repository.IsValid(path + ".git")) return path + ".git";
        return null;
    }

    private void SelectWorkflowForDispatch(WorkflowDefinition wf)
    {
        if (!wf.Inputs.Any())
        {
            // No inputs — trigger immediately
            _ = TriggerWorkflow(wf);
            return;
        }
        selectedDispatchWorkflow = wf;
        dispatchInputValues = new Dictionary<string, string>();
        foreach (var input in wf.Inputs)
        {
            if (input.Default != null)
                dispatchInputValues[input.Name] = input.Default;
            else if (input.Type == "boolean")
                dispatchInputValues[input.Name] = "false";
            else if (input.Type == "choice" && input.Options.Any())
                dispatchInputValues[input.Name] = input.Options[0];
            else
                dispatchInputValues[input.Name] = "";
        }
    }

    private string GetDispatchInputValue(string name) =>
        dispatchInputValues.TryGetValue(name, out var v) ? v : "";

    private void SetDispatchInputValue(string name, string value) =>
        dispatchInputValues[name] = value;

    private async Task TriggerWorkflowWithInputs()
    {
        if (selectedDispatchWorkflow == null) return;
        await TriggerWorkflow(selectedDispatchWorkflow, dispatchInputValues);
        selectedDispatchWorkflow = null;
    }

    private async Task TriggerWorkflow(WorkflowDefinition workflow, Dictionary<string, string>? inputs = null)
    {
        if (!UserService.IsLoggedIn) return;
        showRunDropdown = false;

        var repoPath = GetRepoPath();
        var branch = "main";
        var sha = "HEAD";
        var message = "Manual trigger";

        if (repoPath != null && LibGit2Sharp.Repository.IsValid(repoPath))
        {
            try
            {
                using var repo = new LibGit2Sharp.Repository(repoPath);
                var head = repo.Head;
                if (head?.Tip != null)
                {
                    branch = head.FriendlyName;
                    sha = head.Tip.Sha;
                    message = head.Tip.MessageShort;
                }
            }
            catch { }
        }

        await WorkflowService.CreateWorkflowRunWithJobsAsync(
            RepoName, workflow, branch, sha, message, UserService.Username, inputs);
        await LoadData();
    }

    private void ToggleJob(int jobId)
    {
        if (!expandedJobs.Remove(jobId))
            expandedJobs.Add(jobId);
    }

    private void ShowCreateWorkflowModal()
    {
        ShowWorkflowModal = true;
    }

    private async Task CreateWorkflowRun()
    {
        if (!UserService.IsLoggedIn) return;
        if (string.IsNullOrWhiteSpace(NewWorkflowName) || string.IsNullOrWhiteSpace(NewWorkflowCommitSha))
            return;

        await WorkflowService.CreateWorkflowRunAsync(
            RepoName,
            NewWorkflowName,
            NewWorkflowBranch,
            NewWorkflowCommitSha,
            NewWorkflowCommitMessage,
            UserService.Username
        );

        ShowWorkflowModal = false;
        NewWorkflowName = "";
        NewWorkflowBranch = "main";
        NewWorkflowCommitSha = "";
        NewWorkflowCommitMessage = "";

        await LoadData();
    }

    private void ViewWorkflowRun(int runId)
    {
        Navigation.NavigateTo($"/repo/{RepoName}/actions/runs/{runId}");
    }

    private void ShowCreateWebhookModal()
    {
        ShowWebhookModal = true;
        SelectedEvents.Clear();
    }

    private async Task SaveWebhook()
    {
        if (!UserService.IsLoggedIn) return;
        if (string.IsNullOrWhiteSpace(NewWebhookUrl) || SelectedEvents.Count == 0)
            return;

        if (editingWebhookId.HasValue)
        {
            await WorkflowService.UpdateWebhookAsync(RepoName, editingWebhookId.Value, NewWebhookUrl, NewWebhookSecret, SelectedEvents);
        }
        else
        {
            await WorkflowService.CreateWebhookAsync(RepoName, NewWebhookUrl, NewWebhookSecret, SelectedEvents);
        }

        ShowWebhookModal = false;
        editingWebhookId = null;
        NewWebhookUrl = "";
        NewWebhookSecret = "";
        SelectedEvents.Clear();

        await LoadData();
    }

    private void StartEditWebhook(Webhook webhook)
    {
        editingWebhookId = webhook.Id;
        NewWebhookUrl = webhook.Url;
        NewWebhookSecret = "";
        SelectedEvents = new List<string>(webhook.Events);
        ShowWebhookModal = true;
    }

    private async Task ViewWebhookDetails(Webhook webhook)
    {
        selectedWebhook = webhook;
        webhookDeliveries = await WorkflowService.GetWebhookDeliveriesAsync(RepoName, webhook.Id);
    }

    private void ToggleDeliveryDetails(int deliveryId)
    {
        expandedDeliveryId = expandedDeliveryId == deliveryId ? null : deliveryId;
    }

    private async Task RedeliverWebhook(int deliveryId)
    {
        if (!UserService.IsLoggedIn) return;
        await WorkflowService.RedeliverWebhookAsync(RepoName, deliveryId);
        if (selectedWebhook != null)
            webhookDeliveries = await WorkflowService.GetWebhookDeliveriesAsync(RepoName, selectedWebhook.Id);
    }

    private async Task ToggleWebhook(int webhookId)
    {
        if (!UserService.IsLoggedIn) return;
        await WorkflowService.ToggleWebhookAsync(RepoName, webhookId);
        await LoadData();
    }

    private async Task DeleteWebhook(int webhookId)
    {
        if (!UserService.IsLoggedIn) return;
        await WorkflowService.DeleteWebhookAsync(RepoName, webhookId);
        await LoadData();
    }

    private void ToggleEvent(ChangeEventArgs e, string eventName)
    {
        if ((bool)e.Value!)
        {
            if (!SelectedEvents.Contains(eventName))
                SelectedEvents.Add(eventName);
        }
        else
        {
            SelectedEvents.Remove(eventName);
        }
    }

    private async Task DeleteArtifact(int artifactId)
    {
        if (!UserService.IsLoggedIn) return;
        await ArtifactService.DeleteArtifactAsync(artifactId);
        if (selectedRun != null)
            runArtifacts = await ArtifactService.GetArtifactsAsync(selectedRun.Id);
    }

    private string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1) { order++; len /= 1024; }
        return $"{len:0.##} {sizes[order]}";
    }

    private string GetStatusIcon(WorkflowStatus status) => status switch
    {
        WorkflowStatus.Queued => "bi bi-clock text-secondary",
        WorkflowStatus.InProgress => "bi bi-arrow-repeat text-primary",
        WorkflowStatus.Success => "bi bi-check-circle-fill text-success",
        WorkflowStatus.Failure => "bi bi-x-circle-fill text-danger",
        WorkflowStatus.Cancelled => "bi bi-dash-circle text-secondary",
        _ => "bi bi-circle"
    };

    private string GetStatusBadgeClass(WorkflowStatus status) => status switch
    {
        WorkflowStatus.Queued => "bg-secondary",
        WorkflowStatus.InProgress => "bg-primary",
        WorkflowStatus.Success => "bg-success",
        WorkflowStatus.Failure => "bg-danger",
        WorkflowStatus.Cancelled => "bg-secondary",
        _ => "bg-secondary"
    };

    private string FormatDate(DateTime date)
    {
        var timeAgo = DateTime.UtcNow - date;
        if (timeAgo.TotalMinutes < 1) return "just now";
        if (timeAgo.TotalMinutes < 60) return $"{(int)timeAgo.TotalMinutes} minutes ago";
        if (timeAgo.TotalHours < 24) return $"{(int)timeAgo.TotalHours} hours ago";
        if (timeAgo.TotalDays < 7) return $"{(int)timeAgo.TotalDays} days ago";
        return date.ToString("MMM dd, yyyy");
    }

    private static string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalSeconds < 60)
            return $"{duration.TotalSeconds:F1}s";
        if (duration.TotalMinutes < 60)
            return $"{(int)duration.TotalMinutes}m {duration.Seconds}s";
        return $"{(int)duration.TotalHours}h {duration.Minutes}m {duration.Seconds}s";
    }

    private async Task CancelRun()
    {
        if (selectedRun == null) return;
        await WorkflowService.CancelWorkflowRunAsync(RepoName, selectedRun.Id);
        await LoadData();
    }

    private async Task RerunWorkflow()
    {
        if (selectedRun == null) return;
        var newRun = await WorkflowService.RerunWorkflowRunAsync(RepoName, selectedRun.Id);
        if (newRun != null)
            Navigation.NavigateTo($"/repo/{RepoName}/actions/{newRun.Id}");
        else
            await LoadData();
    }
}

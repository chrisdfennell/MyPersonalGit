@page "/repo/{RepoName}/insights"
@using LibGit2Sharp
@using System.IO
@using MyPersonalGit.Data
@using MyPersonalGit.Models
@using GitRepository = LibGit2Sharp.Repository
@using Microsoft.Extensions.Localization
@using MyPersonalGit.Resources
@inject IConfiguration Config
@inject IAdminService AdminService
@inject IRepositoryTrafficService TrafficService
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> L
@rendermode InteractiveServer

<PageTitle>Insights · @RepoName</PageTitle>

<div class="repo-header border-bottom bg-light-subtle mb-4 pt-3">
    <div class="container-xl px-3">
        <div class="d-flex align-items-center mb-3">
            <i class="bi bi-journal-bookmark text-muted me-2 h4 mb-0"></i>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 h4">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none">@L["Insights_Repositories"]</a></li>
                    <li class="breadcrumb-item"><a href="/repo/@RepoName" class="text-decoration-none">@RepoName</a></li>
                    <li class="breadcrumb-item active fw-bold" aria-current="page">@L["Insights_Title"]</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<div class="container-xl px-3">
    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="list-group">
                <button class="list-group-item list-group-item-action @(activeTab == "contributors" ? "active" : "")" @onclick='() => activeTab = "contributors"'>
                    <i class="bi bi-people me-2"></i> @L["Insights_Contributors"]
                </button>
                <button class="list-group-item list-group-item-action @(activeTab == "commits" ? "active" : "")" @onclick='() => activeTab = "commits"'>
                    <i class="bi bi-graph-up me-2"></i> @L["Insights_CommitActivity"]
                </button>
                <button class="list-group-item list-group-item-action @(activeTab == "frequency" ? "active" : "")" @onclick='() => activeTab = "frequency"'>
                    <i class="bi bi-bar-chart me-2"></i> @L["Insights_CodeFrequency"]
                </button>
                <button class="list-group-item list-group-item-action @(activeTab == "network" ? "active" : "")" @onclick='() => activeTab = "network"'>
                    <i class="bi bi-diagram-3 me-2"></i> @L["Insights_Network"]
                </button>
                <button class="list-group-item list-group-item-action @(activeTab == "traffic" ? "active" : "")" @onclick='() => { activeTab = "traffic"; LoadTrafficData(); }'>
                    <i class="bi bi-graph-up-arrow me-2"></i> @L["Traffic_Title"]
                </button>
            </div>
        </div>

        <div class="col-md-9">
            @if (activeTab == "contributors")
            {
                <div class="contributors-view">
                    <h4 class="mb-4">@L["Insights_Contributors"]</h4>
                    
                    @if (contributors.Any())
                    {
                        <div class="list-group">
                            @foreach (var contributor in contributors.OrderByDescending(c => c.CommitCount))
                            {
                                <div class="list-group-item">
                                    <div class="d-flex align-items-center">
                                        <div class="me-3">
                                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                                <strong>@contributor.Name.Substring(0, Math.Min(2, contributor.Name.Length)).ToUpper()</strong>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1">
                                            <h6 class="mb-1">@contributor.Name</h6>
                                            <small class="text-muted">@contributor.Email</small>
                                        </div>
                                        <div class="text-end">
                                            <div class="h5 mb-0 text-primary">@contributor.CommitCount</div>
                                            <small class="text-muted">@L["Insights_Commits"]</small>
                                        </div>
                                    </div>
                                    <div class="mt-3">
                                        <div class="progress" style="height: 8px;">
                                            <div class="progress-bar bg-success" style="width: @GetContributionPercentage(contributor)%"></div>
                                        </div>
                                        <div class="d-flex justify-content-between mt-2 small text-muted">
                                            <span>@contributor.Additions @L["Insights_Additions"]</span>
                                            <span>@contributor.Deletions @L["Insights_Deletions"]</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            @L["Insights_NoContributors"]
                        </div>
                    }
                </div>
            }
            else if (activeTab == "commits")
            {
                <div class="commit-activity-view">
                    <h4 class="mb-4">@L["Insights_CommitActivity"]</h4>
                    
                    @if (commitActivity.Any())
                    {
                        <div class="card">
                            <div class="card-body">
                                <div class="mb-4">
                                    <h6 class="text-muted">@L["Insights_CommitsPerWeek"]</h6>
                                    <div class="d-flex align-items-end gap-1" style="height: 200px;">
                                        @{
                                            var maxCommits = commitActivity.Max(c => c.Count);
                                        }
                                        @foreach (var week in commitActivity)
                                        {
                                            var height = maxCommits > 0 ? (week.Count * 180.0 / maxCommits) : 0;
                                            <div class="flex-fill bg-primary rounded-top" 
                                                 style="height: @(height)px; min-height: 4px;"
                                                 title="Week of @week.WeekStart.ToString("MMM dd"): @week.Count commits">
                                            </div>
                                        }
                                    </div>
                                    <div class="d-flex justify-content-between mt-2 small text-muted">
                                        <span>@commitActivity.First().WeekStart.ToString("MMM dd")</span>
                                        <span>@commitActivity.Last().WeekStart.ToString("MMM dd")</span>
                                    </div>
                                </div>

                                <div class="row text-center">
                                    <div class="col-md-4">
                                        <div class="h3 text-primary mb-0">@totalCommits</div>
                                        <small class="text-muted">@L["Insights_TotalCommits"]</small>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="h3 text-success mb-0">@contributors.Count</div>
                                        <small class="text-muted">@L["Insights_Contributors"]</small>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="h3 text-info mb-0">@branches.Count</div>
                                        <small class="text-muted">@L["Insights_Branches"]</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            @L["Insights_NoCommitActivity"]
                        </div>
                    }
                </div>
            }
            else if (activeTab == "frequency")
            {
                <div class="code-frequency-view">
                    <h4 class="mb-4">@L["Insights_CodeFrequency"]</h4>
                    
                    <div class="card">
                        <div class="card-body">
                            <p class="text-muted">@L["Insights_CodeFrequencyDescription"]</p>
                            
                            @if (codeFrequency.Any())
                            {
                                <div class="mb-4">
                                    <div class="d-flex align-items-center gap-1" style="height: 200px;">
                                        @{
                                            var maxChanges = codeFrequency.Max(c => Math.Max(c.Additions, c.Deletions));
                                        }
                                        @foreach (var week in codeFrequency)
                                        {
                                            var addHeight = maxChanges > 0 ? (week.Additions * 90.0 / maxChanges) : 0;
                                            var delHeight = maxChanges > 0 ? (week.Deletions * 90.0 / maxChanges) : 0;
                                            <div class="flex-fill d-flex flex-column justify-content-center align-items-center gap-1">
                                                <div class="bg-success rounded" style="width: 100%; height: @(addHeight)px; min-height: 2px;"></div>
                                                <div class="bg-danger rounded" style="width: 100%; height: @(delHeight)px; min-height: 2px;"></div>
                                            </div>
                                        }
                                    </div>
                                    <div class="d-flex gap-3 mt-3">
                                        <span class="small"><span class="badge bg-success">+</span> @L["Insights_Additions"]</span>
                                        <span class="small"><span class="badge bg-danger">-</span> @L["Insights_Deletions"]</span>
                                    </div>
                                </div>

                                <div class="row text-center">
                                    <div class="col-md-6">
                                        <div class="h3 text-success mb-0">+@codeFrequency.Sum(c => c.Additions)</div>
                                        <small class="text-muted">@L["Insights_LinesAdded"]</small>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="h3 text-danger mb-0">-@codeFrequency.Sum(c => c.Deletions)</div>
                                        <small class="text-muted">@L["Insights_LinesDeleted"]</small>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info">
                                    <i class="bi bi-info-circle me-2"></i>
                                    @L["Insights_NoCodeFrequency"]
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
            else if (activeTab == "traffic")
            {
                <div class="traffic-view">
                    <h4 class="mb-4"><i class="bi bi-graph-up-arrow me-2"></i>@L["Traffic_Title"]</h4>

                    <div class="row mb-4">
                        <div class="col-md-3">
                            <div class="card text-center">
                                <div class="card-body">
                                    <div class="h3 text-primary mb-0">@trafficTotalClones</div>
                                    <small class="text-muted">@L["Traffic_Clones14Days"]</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card text-center">
                                <div class="card-body">
                                    <div class="h3 text-info mb-0">@trafficUniqueCloners</div>
                                    <small class="text-muted">@L["Traffic_UniqueCloners"]</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card text-center">
                                <div class="card-body">
                                    <div class="h3 text-success mb-0">@trafficTotalViews</div>
                                    <small class="text-muted">@L["Traffic_PageViews"]</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card text-center">
                                <div class="card-body">
                                    <div class="h3 text-warning mb-0">@trafficUniqueVisitors</div>
                                    <small class="text-muted">@L["Traffic_UniqueVisitors"]</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (trafficSummary.Any())
                    {
                        <div class="card mb-4">
                            <div class="card-header">@L["Traffic_Clones"]</div>
                            <div class="card-body">
                                <div class="d-flex align-items-end gap-1" style="height: 120px;">
                                    @{ var maxClones = trafficSummary.Any() ? Math.Max(trafficSummary.Max(s => s.Clones), 1) : 1; }
                                    @foreach (var day in trafficSummary)
                                    {
                                        var h = day.Clones * 110.0 / maxClones;
                                        <div class="flex-fill bg-primary rounded-top" style="height: @(h)px; min-height: 2px;" title="@day.Date.ToString("MMM dd"): @day.Clones clones"></div>
                                    }
                                </div>
                                <div class="d-flex justify-content-between mt-1 small text-muted">
                                    @if (trafficSummary.Any())
                                    {
                                        <span>@trafficSummary.First().Date.ToString("MMM dd")</span>
                                        <span>@trafficSummary.Last().Date.ToString("MMM dd")</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="card mb-4">
                            <div class="card-header">@L["Traffic_PageViews"]</div>
                            <div class="card-body">
                                <div class="d-flex align-items-end gap-1" style="height: 120px;">
                                    @{ var maxViews = trafficSummary.Any() ? Math.Max(trafficSummary.Max(s => s.PageViews), 1) : 1; }
                                    @foreach (var day in trafficSummary)
                                    {
                                        var h = day.PageViews * 110.0 / maxViews;
                                        <div class="flex-fill bg-success rounded-top" style="height: @(h)px; min-height: 2px;" title="@day.Date.ToString("MMM dd"): @day.PageViews views"></div>
                                    }
                                </div>
                                <div class="d-flex justify-content-between mt-1 small text-muted">
                                    @if (trafficSummary.Any())
                                    {
                                        <span>@trafficSummary.First().Date.ToString("MMM dd")</span>
                                        <span>@trafficSummary.Last().Date.ToString("MMM dd")</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            @L["Traffic_NoData"]
                        </div>
                    }

                    @if (topReferrers.Any())
                    {
                        <div class="card mb-4">
                            <div class="card-header">@L["Traffic_TopReferrers"]</div>
                            <div class="card-body p-0">
                                <table class="table table-sm mb-0">
                                    <thead><tr><th>@L["Traffic_Referrer"]</th><th class="text-end">@L["Traffic_Views"]</th></tr></thead>
                                    <tbody>
                                        @foreach (var (referrer, count) in topReferrers)
                                        {
                                            <tr><td>@referrer</td><td class="text-end">@count</td></tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                    @if (popularPages.Any())
                    {
                        <div class="card">
                            <div class="card-header">@L["Traffic_PopularContent"]</div>
                            <div class="card-body p-0">
                                <table class="table table-sm mb-0">
                                    <thead><tr><th>@L["Traffic_Path"]</th><th class="text-end">@L["Traffic_Views"]</th></tr></thead>
                                    <tbody>
                                        @foreach (var (path, count) in popularPages)
                                        {
                                            <tr><td>@path</td><td class="text-end">@count</td></tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
            }
            else if (activeTab == "network")
            {
                <div class="network-view">
                    <h4 class="mb-4">@L["Insights_NetworkGraph"]</h4>
                    
                    <div class="card">
                        <div class="card-body">
                            <p class="text-muted">@L["Insights_NetworkDescription"]</p>
                            
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle me-2"></i>
                                @L["Insights_NetworkInfo"]
                            </div>

                            @if (branches.Any())
                            {
                                <h6 class="mt-4">@L["Insights_ActiveBranches"]</h6>
                                <div class="list-group">
                                    @foreach (var branch in branches)
                                    {
                                        <div class="list-group-item d-flex justify-content-between align-items-center">
                                            <div>
                                                <i class="bi bi-git text-primary me-2"></i>
                                                <strong>@branch.Name</strong>
                                            </div>
                                            <span class="badge bg-secondary">@branch.CommitCount commits</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string RepoName { get; set; } = "";

    private string activeTab = "contributors";
    private List<Contributor> contributors = new();
    private List<CommitActivity> commitActivity = new();
    private List<CodeFrequency> codeFrequency = new();
    private List<BranchInfo> branches = new();
    private int totalCommits = 0;

    // Traffic data
    private List<RepositoryTrafficSummary> trafficSummary = new();
    private List<(string Referrer, int Count)> topReferrers = new();
    private List<(string Path, int Count)> popularPages = new();
    private int trafficTotalClones, trafficUniqueCloners, trafficTotalViews, trafficUniqueVisitors;

    private async void LoadTrafficData()
    {
        try
        {
            trafficSummary = await TrafficService.GetTrafficSummaryAsync(RepoName);
            topReferrers = await TrafficService.GetTopReferrersAsync(RepoName);
            popularPages = await TrafficService.GetPopularPagesAsync(RepoName);
            (trafficTotalClones, trafficUniqueCloners, trafficTotalViews, trafficUniqueVisitors) = await TrafficService.GetTotalsAsync(RepoName);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading traffic data: {ex.Message}");
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadInsights();
    }

    private async Task LoadInsights()
    {
        try
        {
            var projectRoot = "";
            var systemSettings = await AdminService.GetSystemSettingsAsync();
            if (!string.IsNullOrEmpty(systemSettings.ProjectRoot))
                projectRoot = systemSettings.ProjectRoot;
            if (string.IsNullOrEmpty(projectRoot))
                projectRoot = Config["Git:ProjectRoot"] ?? "/repos";

            var repoPath = Path.Combine(projectRoot, $"{RepoName}.git");

            if (!Directory.Exists(repoPath))
                return;

            using var repo = new GitRepository(repoPath);

            LoadContributors(repo);
            LoadCommitActivity(repo);
            LoadCodeFrequency(repo);
            LoadBranches(repo);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading insights: {ex.Message}");
        }
    }

    private void LoadContributors(GitRepository repo)
    {
        var contributorDict = new Dictionary<string, Contributor>();
        var filter = new CommitFilter { IncludeReachableFrom = repo.Refs };

        foreach (var commit in repo.Commits.QueryBy(filter))
        {
            var email = commit.Author.Email;
            if (!contributorDict.ContainsKey(email))
            {
                contributorDict[email] = new Contributor
                {
                    Name = commit.Author.Name,
                    Email = email
                };
            }

            contributorDict[email].CommitCount++;
            
            try
            {
                var parent = commit.Parents.FirstOrDefault();
                if (parent != null)
                {
                    var changes = repo.Diff.Compare<Patch>(parent.Tree, commit.Tree);
                    contributorDict[email].Additions += changes.Sum(c => c.LinesAdded);
                    contributorDict[email].Deletions += changes.Sum(c => c.LinesDeleted);
                }
            }
            catch { }
        }

        contributors = contributorDict.Values.ToList();
        totalCommits = repo.Commits.QueryBy(filter).Count();
    }

    private void LoadCommitActivity(GitRepository repo)
    {
        var now = DateTime.UtcNow;
        var weeks = new Dictionary<DateTime, int>();

        for (int i = 11; i >= 0; i--)
        {
            var weekStart = now.AddDays(-7 * i).Date;
            weekStart = weekStart.AddDays(-(int)weekStart.DayOfWeek);
            weeks[weekStart] = 0;
        }

        var filter = new CommitFilter { IncludeReachableFrom = repo.Refs };
        foreach (var commit in repo.Commits.QueryBy(filter))
        {
            var commitDate = commit.Author.When.UtcDateTime;
            var weekStart = commitDate.Date.AddDays(-(int)commitDate.DayOfWeek);

            if (weeks.ContainsKey(weekStart))
            {
                weeks[weekStart]++;
            }
        }

        commitActivity = weeks.Select(w => new CommitActivity
        {
            WeekStart = w.Key,
            Count = w.Value
        }).OrderBy(w => w.WeekStart).ToList();
    }

    private void LoadCodeFrequency(GitRepository repo)
    {
        var now = DateTime.UtcNow;
        var weeks = new Dictionary<DateTime, CodeFrequency>();

        for (int i = 11; i >= 0; i--)
        {
            var weekStart = now.AddDays(-7 * i).Date;
            weekStart = weekStart.AddDays(-(int)weekStart.DayOfWeek);
            weeks[weekStart] = new CodeFrequency { WeekStart = weekStart };
        }

        var filter = new CommitFilter { IncludeReachableFrom = repo.Refs };
        foreach (var commit in repo.Commits.QueryBy(filter).Take(100))
        {
            try
            {
                var parent = commit.Parents.FirstOrDefault();
                if (parent != null)
                {
                    var commitDate = commit.Author.When.UtcDateTime;
                    var weekStart = commitDate.Date.AddDays(-(int)commitDate.DayOfWeek);

                    if (weeks.ContainsKey(weekStart))
                    {
                        var changes = repo.Diff.Compare<Patch>(parent.Tree, commit.Tree);
                        weeks[weekStart].Additions += changes.Sum(c => c.LinesAdded);
                        weeks[weekStart].Deletions += changes.Sum(c => c.LinesDeleted);
                    }
                }
            }
            catch { }
        }

        codeFrequency = weeks.Values.OrderBy(w => w.WeekStart).ToList();
    }

    private void LoadBranches(GitRepository repo)
    {
        branches = repo.Branches.Select(b => new BranchInfo
        {
            Name = b.FriendlyName,
            CommitCount = b.Commits.Count()
        }).ToList();
    }

    private double GetContributionPercentage(Contributor contributor)
    {
        if (totalCommits == 0) return 0;
        return (contributor.CommitCount * 100.0 / totalCommits);
    }

    public class Contributor
    {
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public int CommitCount { get; set; }
        public int Additions { get; set; }
        public int Deletions { get; set; }
    }

    public class CommitActivity
    {
        public DateTime WeekStart { get; set; }
        public int Count { get; set; }
    }

    public class CodeFrequency
    {
        public DateTime WeekStart { get; set; }
        public int Additions { get; set; }
        public int Deletions { get; set; }
    }

    public class BranchInfo
    {
        public string Name { get; set; } = "";
        public int CommitCount { get; set; }
    }
}

@page "/repo/{RepoName}/discussions"
@page "/repo/{RepoName}/discussions/{Number:int}"
@using Markdig
@using MyPersonalGit.Models
@using MyPersonalGit.Data
@using Microsoft.Extensions.Localization
@using MyPersonalGit.Resources
@inject IDiscussionService DiscussionService
@inject IReactionService ReactionService
@inject NavigationManager Nav
@using MyPersonalGit.Services
@inject CurrentUserService UserService
@inject IStringLocalizer<SharedResource> L
@rendermode InteractiveServer

<PageTitle>Discussions · @RepoName</PageTitle>

<div class="repo-header border-bottom bg-light-subtle mb-4 pt-3">
    <div class="container-xl px-3">
        <div class="d-flex align-items-center mb-3">
            <i class="bi bi-journal-bookmark text-muted me-2 h4 mb-0"></i>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 h4">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none">@L["Nav_Repositories"]</a></li>
                    <li class="breadcrumb-item"><a href="/repo/@RepoName" class="text-decoration-none">@RepoName</a></li>
                    <li class="breadcrumb-item active fw-bold" aria-current="page">@L["Discussions_Title"]</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<div class="container-xl px-3">
    @if (Number.HasValue && currentDiscussion != null)
    {
        <!-- Discussion detail view -->
        <div class="mb-3">
            <a href="/repo/@RepoName/discussions" class="text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i> @L["Discussions_BackToList"]
            </a>
        </div>

        <div class="d-flex justify-content-between align-items-start mb-3">
            <div class="flex-grow-1">
                <h1 class="h3 mb-2">
                    @currentDiscussion.Title
                    <span class="text-muted fw-normal">#@currentDiscussion.Number</span>
                </h1>
                <div class="d-flex gap-2 align-items-center flex-wrap">
                    <span class="badge bg-info bg-opacity-10 text-info border border-info-subtle">
                        @GetCategoryIcon(currentDiscussion.Category) @GetCategoryName(currentDiscussion.Category)
                    </span>
                    @if (currentDiscussion.IsPinned)
                    {
                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning-subtle">
                            <i class="bi bi-pin-fill me-1"></i>@L["Discussions_Pinned"]
                        </span>
                    }
                    @if (currentDiscussion.IsLocked)
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle">
                            <i class="bi bi-lock-fill me-1"></i>@L["Discussions_Locked"]
                        </span>
                    }
                    @if (currentDiscussion.IsAnswered)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle">
                            <i class="bi bi-check-circle-fill me-1"></i>@L["Discussions_Answered"]
                        </span>
                    }
                    <span class="text-muted small">
                        @L["Discussion_StartedBy"] <strong>@currentDiscussion.Author</strong> @FormatDate(currentDiscussion.CreatedAt)
                    </span>
                </div>
            </div>
            @if (UserService.IsLoggedIn && UserService.Username == currentDiscussion.Author)
            {
                <div class="dropdown">
                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-gear"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><button class="dropdown-item" @onclick="TogglePin"><i class="bi bi-pin me-2"></i>@(currentDiscussion.IsPinned ? L["Discussions_Unpin"] : L["Discussions_Pin"])</button></li>
                        <li><button class="dropdown-item" @onclick="ToggleLock"><i class="bi bi-lock me-2"></i>@(currentDiscussion.IsLocked ? L["Discussions_Unlock"] : L["Discussions_Lock"])</button></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li><button class="dropdown-item text-danger" @onclick="DeleteDiscussion"><i class="bi bi-trash me-2"></i>@L["Discussions_Delete"]</button></li>
                    </ul>
                </div>
            }
        </div>

        <!-- Original post -->
        <div class="card mb-3">
            <div class="card-header bg-light d-flex align-items-center gap-2">
                <i class="bi bi-person-circle"></i>
                <strong>@currentDiscussion.Author</strong>
                <span class="text-muted small">@L["Discussion_Posted"] @FormatDate(currentDiscussion.CreatedAt)</span>
            </div>
            <div class="card-body">
                <div class="markdown-body">@((MarkupString)RenderMarkdown(currentDiscussion.Body))</div>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0">
                @{ RenderReactionBar(null, discussionId: currentDiscussion.Id); }
            </div>
        </div>

        <!-- Comments -->
        @foreach (var comment in currentDiscussion.Comments)
        {
            <div class="card mb-3 @(comment.IsAnswer ? "border-success" : "")">
                @if (comment.IsAnswer)
                {
                    <div class="card-header bg-success bg-opacity-10 text-success d-flex align-items-center gap-2">
                        <i class="bi bi-check-circle-fill"></i>
                        <span class="fw-bold">@L["Discussions_AcceptedAnswer"]</span>
                    </div>
                }
                <div class="card-header bg-light d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-person-circle"></i>
                        <strong>@comment.Author</strong>
                        <span class="text-muted small">@L["Discussion_Commented"] @FormatDate(comment.CreatedAt)</span>
                    </div>
                    <div class="d-flex gap-1">
                        @if (comment.UpvoteCount > 0)
                        {
                            <span class="badge bg-secondary bg-opacity-10 text-secondary">
                                <i class="bi bi-arrow-up me-1"></i>@comment.UpvoteCount
                            </span>
                        }
                        @if (UserService.IsLoggedIn)
                        {
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => UpvoteComment(comment.Id)" title="Upvote">
                                <i class="bi bi-arrow-up"></i>
                            </button>
                            @if (currentDiscussion.Category == DiscussionCategory.QAndA && UserService.Username == currentDiscussion.Author)
                            {
                                @if (comment.IsAnswer)
                                {
                                    <button class="btn btn-outline-success btn-sm" @onclick="() => UnmarkAnswer(comment.Id)">
                                        <i class="bi bi-x-circle me-1"></i>@L["Discussions_Unmark"]
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-outline-success btn-sm" @onclick="() => MarkAnswer(comment.Id)">
                                        <i class="bi bi-check-circle me-1"></i>@L["Discussions_MarkAsAnswer"]
                                    </button>
                                }
                            }
                            @if (UserService.Username == comment.Author)
                            {
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteComment(comment.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        }
                    </div>
                </div>
                <div class="card-body">
                    <div class="markdown-body">@((MarkupString)RenderMarkdown(comment.Body))</div>
                </div>
                <div class="card-footer bg-transparent border-top-0 pt-0">
                    @{ RenderReactionBar(null, discussionCommentId: comment.Id); }
                </div>

                <!-- Replies -->
                @if (comment.Replies.Any())
                {
                    <div class="border-top">
                        @foreach (var reply in comment.Replies)
                        {
                            <div class="px-4 py-2 border-bottom bg-light-subtle">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="bi bi-person-circle small"></i>
                                        <strong class="small">@reply.Author</strong>
                                        <span class="text-muted" style="font-size: 11px;">@FormatDate(reply.CreatedAt)</span>
                                    </div>
                                    @if (UserService.IsLoggedIn && UserService.Username == reply.Author)
                                    {
                                        <button class="btn btn-link btn-sm p-0 text-danger" @onclick="() => DeleteComment(reply.Id)">
                                            <i class="bi bi-trash" style="font-size: 11px;"></i>
                                        </button>
                                    }
                                </div>
                                <div class="small markdown-body">@((MarkupString)RenderMarkdown(reply.Body))</div>
                            </div>
                        }
                    </div>
                }

                <!-- Reply form -->
                @if (UserService.IsLoggedIn && !currentDiscussion.IsLocked && replyingToCommentId == comment.Id)
                {
                    <div class="card-footer">
                        <textarea class="form-control form-control-sm mb-2" rows="2" @bind="replyBody" placeholder="@L["Discussions_WriteReply"]"></textarea>
                        <div class="d-flex gap-1">
                            <button class="btn btn-primary btn-sm" @onclick="() => SubmitReply(comment.Id)" disabled="@string.IsNullOrWhiteSpace(replyBody)">@L["Discussions_Reply"]</button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => replyingToCommentId = null">@L["Discussions_Cancel"]</button>
                        </div>
                    </div>
                }
                else if (UserService.IsLoggedIn && !currentDiscussion.IsLocked)
                {
                    <div class="card-footer bg-transparent">
                        <button class="btn btn-link btn-sm text-muted p-0" @onclick="() => replyingToCommentId = comment.Id">
                            <i class="bi bi-reply me-1"></i>@L["Discussions_Reply"]
                        </button>
                    </div>
                }
            </div>
        }

        <!-- New comment -->
        @if (UserService.IsLoggedIn && !currentDiscussion.IsLocked)
        {
            <div class="card">
                <div class="card-header bg-light">
                    <strong>@L["Discussions_AddComment"]</strong>
                </div>
                <div class="card-body">
                    <textarea class="form-control mb-2" rows="4" @bind="newCommentBody" placeholder="@L["Discussions_LeaveComment"]"></textarea>
                    <button class="btn btn-success" @onclick="AddComment" disabled="@string.IsNullOrWhiteSpace(newCommentBody)">
                        <i class="bi bi-chat-left-text me-1"></i> @L["Discussions_Comment"]
                    </button>
                </div>
            </div>
        }
        else if (currentDiscussion.IsLocked)
        {
            <div class="alert alert-secondary text-center">
                <i class="bi bi-lock-fill me-1"></i> @L["Discussions_LockedMessage"]
            </div>
        }
    }
    else if (Number.HasValue)
    {
        <div class="alert alert-warning">Discussion #@Number not found.</div>
    }
    else
    {
        <!-- Discussion list view -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="d-flex gap-2 align-items-center">
                <h4 class="h5 mb-0"><i class="bi bi-chat-square-text me-2"></i>@L["Discussions_Title"]</h4>
                <span class="badge bg-secondary">@discussions.Count</span>
            </div>
            @if (UserService.IsLoggedIn)
            {
                <button class="btn btn-success btn-sm" @onclick="() => showNewModal = true">
                    <i class="bi bi-plus-circle me-1"></i> @L["Discussions_NewDiscussion"]
                </button>
            }
        </div>

        <!-- Category filter -->
        <div class="d-flex flex-wrap gap-2 mb-3">
            <button class="btn btn-sm @(filterCategory == null ? "btn-dark" : "btn-outline-secondary")" @onclick="() => filterCategory = null">
                @L["Discussions_All"]
            </button>
            <button class="btn btn-sm @(filterCategory == DiscussionCategory.General ? "btn-dark" : "btn-outline-secondary")" @onclick="() => filterCategory = DiscussionCategory.General">
                <i class="bi bi-chat-left me-1"></i>@L["Discussions_General"]
            </button>
            <button class="btn btn-sm @(filterCategory == DiscussionCategory.QAndA ? "btn-dark" : "btn-outline-secondary")" @onclick="() => filterCategory = DiscussionCategory.QAndA">
                <i class="bi bi-question-circle me-1"></i>@L["Discussions_QAndA"]
            </button>
            <button class="btn btn-sm @(filterCategory == DiscussionCategory.Announcements ? "btn-dark" : "btn-outline-secondary")" @onclick="() => filterCategory = DiscussionCategory.Announcements">
                <i class="bi bi-megaphone me-1"></i>@L["Discussions_Announcements"]
            </button>
            <button class="btn btn-sm @(filterCategory == DiscussionCategory.Ideas ? "btn-dark" : "btn-outline-secondary")" @onclick="() => filterCategory = DiscussionCategory.Ideas">
                <i class="bi bi-lightbulb me-1"></i>@L["Discussions_Ideas"]
            </button>
            <button class="btn btn-sm @(filterCategory == DiscussionCategory.ShowAndTell ? "btn-dark" : "btn-outline-secondary")" @onclick="() => filterCategory = DiscussionCategory.ShowAndTell">
                <i class="bi bi-stars me-1"></i>@L["Discussions_ShowAndTell"]
            </button>
            <button class="btn btn-sm @(filterCategory == DiscussionCategory.Polls ? "btn-dark" : "btn-outline-secondary")" @onclick="() => filterCategory = DiscussionCategory.Polls">
                <i class="bi bi-bar-chart me-1"></i>@L["Discussions_Polls"]
            </button>
        </div>

        @if (GetFilteredDiscussions().Any())
        {
            <div class="list-group">
                @foreach (var d in GetFilteredDiscussions())
                {
                    <a href="/repo/@RepoName/discussions/@d.Number" class="list-group-item list-group-item-action py-3">
                        <div class="d-flex w-100 justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    @if (d.IsPinned)
                                    {
                                        <i class="bi bi-pin-fill text-warning"></i>
                                    }
                                    @if (d.IsAnswered)
                                    {
                                        <i class="bi bi-check-circle-fill text-success"></i>
                                    }
                                    else if (d.Category == DiscussionCategory.QAndA)
                                    {
                                        <i class="bi bi-question-circle text-info"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-chat-left text-muted"></i>
                                    }
                                    <h6 class="mb-0">@d.Title</h6>
                                    <span class="badge bg-info bg-opacity-10 text-info border border-info-subtle" style="font-size: 10px;">
                                        @GetCategoryName(d.Category)
                                    </span>
                                    @if (d.IsLocked)
                                    {
                                        <i class="bi bi-lock-fill text-muted small"></i>
                                    }
                                </div>
                                <small class="text-muted">
                                    #@d.Number started @FormatDate(d.CreatedAt) by @d.Author
                                    @if (d.Comments.Any())
                                    {
                                        <span> · <i class="bi bi-chat-left"></i> @d.Comments.Count</span>
                                    }
                                </small>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-chat-square-text display-4 text-muted"></i>
                <p class="text-muted mt-3">@L["Discussions_Empty"]</p>
            </div>
        }
    }
</div>

@if (showNewModal)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@L["Discussions_NewDiscussion"]</h5>
                    <button type="button" class="btn-close" @onclick="() => showNewModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">@L["Discussions_Category"]</label>
                        <select class="form-select" @bind="newCategory">
                            <option value="@DiscussionCategory.General">@L["Discussions_General"]</option>
                            <option value="@DiscussionCategory.QAndA">@L["Discussions_QAndA"]</option>
                            <option value="@DiscussionCategory.Announcements">@L["Discussions_Announcements"]</option>
                            <option value="@DiscussionCategory.Ideas">@L["Discussions_Ideas"]</option>
                            <option value="@DiscussionCategory.ShowAndTell">@L["Discussions_ShowAndTell"]</option>
                            <option value="@DiscussionCategory.Polls">@L["Discussions_Polls"]</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">@L["Discussions_TitleLabel"]</label>
                        <input type="text" class="form-control" @bind="newTitle" placeholder="@L["Discussions_TitlePlaceholder"]" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">@L["Discussions_Body"]</label>
                        <textarea class="form-control" rows="8" @bind="newBody" placeholder="@L["Discussions_BodyPlaceholder"]"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showNewModal = false">@L["Discussions_Cancel"]</button>
                    <button type="button" class="btn btn-success" @onclick="CreateDiscussion" disabled="@(string.IsNullOrWhiteSpace(newTitle) || string.IsNullOrWhiteSpace(newBody))">
                        <i class="bi bi-plus-circle me-1"></i> @L["Discussions_StartDiscussion"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string RepoName { get; set; } = "";
    [Parameter] public int? Number { get; set; }

    private List<Discussion> discussions = new();
    private Discussion? currentDiscussion;
    private DiscussionCategory? filterCategory;
    private bool showNewModal;

    private string newTitle = "";
    private string newBody = "";
    private DiscussionCategory newCategory = DiscussionCategory.General;
    private string newCommentBody = "";
    private string replyBody = "";
    private int? replyingToCommentId;

    // Reactions state
    private Dictionary<string, Dictionary<string, List<string>>> reactionSummaries = new();

    private static readonly MarkdownPipeline _mdPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .UseEmojiAndSmiley()
        .Build();

    protected override async Task OnParametersSetAsync()
    {
        if (Number.HasValue)
        {
            currentDiscussion = await DiscussionService.GetDiscussionAsync(RepoName, Number.Value);
            if (currentDiscussion != null)
            {
                await LoadReactions();
            }
        }
        else
        {
            discussions = await DiscussionService.GetDiscussionsAsync(RepoName);
        }
    }

    private async Task LoadReactions()
    {
        if (currentDiscussion == null) return;
        reactionSummaries.Clear();

        var key = $"discussion_{currentDiscussion.Id}";
        reactionSummaries[key] = await ReactionService.GetReactionSummaryAsync(discussionId: currentDiscussion.Id);

        foreach (var comment in currentDiscussion.Comments)
        {
            var ckey = $"dc_{comment.Id}";
            reactionSummaries[ckey] = await ReactionService.GetReactionSummaryAsync(discussionCommentId: comment.Id);
        }
    }

    private List<Discussion> GetFilteredDiscussions()
    {
        if (filterCategory == null) return discussions;
        return discussions.Where(d => d.Category == filterCategory).ToList();
    }

    private async Task CreateDiscussion()
    {
        if (!UserService.IsLoggedIn) return;
        var discussion = await DiscussionService.CreateDiscussionAsync(RepoName, newTitle, newBody, UserService.Username, newCategory);
        newTitle = "";
        newBody = "";
        newCategory = DiscussionCategory.General;
        showNewModal = false;
        Nav.NavigateTo($"/repo/{RepoName}/discussions/{discussion.Number}");
    }

    private async Task AddComment()
    {
        if (!UserService.IsLoggedIn || currentDiscussion == null) return;
        await DiscussionService.AddCommentAsync(currentDiscussion.Id, UserService.Username, newCommentBody);
        newCommentBody = "";
        currentDiscussion = await DiscussionService.GetDiscussionAsync(RepoName, Number!.Value);
        await LoadReactions();
    }

    private async Task SubmitReply(int parentId)
    {
        if (!UserService.IsLoggedIn || currentDiscussion == null) return;
        await DiscussionService.AddCommentAsync(currentDiscussion.Id, UserService.Username, replyBody, parentId);
        replyBody = "";
        replyingToCommentId = null;
        currentDiscussion = await DiscussionService.GetDiscussionAsync(RepoName, Number!.Value);
        await LoadReactions();
    }

    private async Task DeleteComment(int commentId)
    {
        if (!UserService.IsLoggedIn) return;
        await DiscussionService.DeleteCommentAsync(commentId, UserService.Username);
        currentDiscussion = await DiscussionService.GetDiscussionAsync(RepoName, Number!.Value);
        await LoadReactions();
    }

    private async Task TogglePin()
    {
        await DiscussionService.TogglePinAsync(RepoName, Number!.Value);
        currentDiscussion = await DiscussionService.GetDiscussionAsync(RepoName, Number!.Value);
    }

    private async Task ToggleLock()
    {
        await DiscussionService.ToggleLockAsync(RepoName, Number!.Value);
        currentDiscussion = await DiscussionService.GetDiscussionAsync(RepoName, Number!.Value);
    }

    private async Task MarkAnswer(int commentId)
    {
        await DiscussionService.MarkAsAnswerAsync(commentId);
        currentDiscussion = await DiscussionService.GetDiscussionAsync(RepoName, Number!.Value);
    }

    private async Task UnmarkAnswer(int commentId)
    {
        await DiscussionService.UnmarkAsAnswerAsync(commentId);
        currentDiscussion = await DiscussionService.GetDiscussionAsync(RepoName, Number!.Value);
    }

    private async Task UpvoteComment(int commentId)
    {
        await DiscussionService.UpvoteCommentAsync(commentId, UserService.Username);
        currentDiscussion = await DiscussionService.GetDiscussionAsync(RepoName, Number!.Value);
    }

    private async Task DeleteDiscussion()
    {
        if (!UserService.IsLoggedIn || currentDiscussion == null) return;
        await DiscussionService.DeleteDiscussionAsync(RepoName, Number!.Value, UserService.Username);
        Nav.NavigateTo($"/repo/{RepoName}/discussions");
    }

    private async Task ToggleReaction(string emoji, int? discussionId = null, int? discussionCommentId = null)
    {
        if (!UserService.IsLoggedIn) return;
        await ReactionService.ToggleReactionAsync(UserService.Username, emoji,
            discussionId: discussionId, discussionCommentId: discussionCommentId);
        await LoadReactions();
    }

    private void RenderReactionBar(int? _ignored, int? discussionId = null, int? discussionCommentId = null)
    {
        // This is a placeholder — the actual rendering is done inline in the markup
        // We use this method signature for the @{ } call pattern
    }

    private Dictionary<string, List<string>> GetReactions(string key)
    {
        return reactionSummaries.TryGetValue(key, out var summary) ? summary : new();
    }

    private string GetCategoryName(DiscussionCategory category) => category switch
    {
        DiscussionCategory.General => L["Discussions_General"],
        DiscussionCategory.QAndA => L["Discussions_QAndA"],
        DiscussionCategory.Announcements => L["Discussions_Announcements"],
        DiscussionCategory.Ideas => L["Discussions_Ideas"],
        DiscussionCategory.ShowAndTell => L["Discussions_ShowAndTell"],
        DiscussionCategory.Polls => L["Discussions_Polls"],
        _ => L["Discussions_General"]
    };

    private string GetCategoryIcon(DiscussionCategory category) => category switch
    {
        DiscussionCategory.QAndA => "\u2753",
        DiscussionCategory.Announcements => "\ud83d\udce2",
        DiscussionCategory.Ideas => "\ud83d\udca1",
        DiscussionCategory.ShowAndTell => "\u2728",
        DiscussionCategory.Polls => "\ud83d\udcca",
        _ => "\ud83d\udcac"
    };

    private string RenderMarkdown(string content)
    {
        return Markdig.Markdown.ToHtml(content, _mdPipeline);
    }

    private string FormatDate(DateTime date)
    {
        var diff = DateTime.UtcNow - date;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} minutes ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} hours ago";
        if (diff.TotalDays < 30) return $"{(int)diff.TotalDays} days ago";
        return date.ToString("MMM d, yyyy");
    }
}

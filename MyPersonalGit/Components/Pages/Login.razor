@page "/login"
@using MyPersonalGit.Data
@using MyPersonalGit.Models
@using MyPersonalGit.Services
@inject CurrentUserService UserService
@inject IOAuthService OAuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Login - MyPersonalGit</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold">MyPersonalGit</h2>
                        <p class="text-muted">
                            @if (ShowTwoFactorStep)
                            {
                                <span>Two-factor authentication</span>
                            }
                            else
                            {
                                <span>Sign in to your account</span>
                            }
                        </p>
                    </div>

                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>@ErrorMessage
                        </div>
                    }

                    @if (!ShowTwoFactorStep)
                    {
                        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                            <DataAnnotationsValidator />

                            <div class="mb-3">
                                <label for="usernameOrEmail" class="form-label">Username or Email</label>
                                <InputText id="usernameOrEmail" class="form-control" @bind-Value="loginModel.UsernameOrEmail" placeholder="Enter username or email" />
                                <ValidationMessage For="@(() => loginModel.UsernameOrEmail)" />
                            </div>

                            <div class="mb-3">
                                <label for="password" class="form-label">Password</label>
                                <InputText id="password" type="password" class="form-control" @bind-Value="loginModel.Password" placeholder="Enter password" />
                                <ValidationMessage For="@(() => loginModel.Password)" />
                            </div>

                            <button type="submit" class="btn btn-primary w-100 mb-3" disabled="@IsLoading">
                                @if (IsLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Signing in...</span>
                                }
                                else
                                {
                                    <span>Sign in</span>
                                }
                            </button>
                        </EditForm>

                        @if (oauthProviders.Any())
                        {
                            <div class="d-flex align-items-center my-3">
                                <hr class="flex-grow-1" />
                                <span class="px-3 text-muted small">or continue with</span>
                                <hr class="flex-grow-1" />
                            </div>

                            <div class="d-grid gap-2">
                                @foreach (var provider in oauthProviders)
                                {
                                    <a href="/oauth/login/@provider.ProviderName" class="btn btn-outline-secondary d-flex align-items-center justify-content-center"
                                       style="border-color: @MyPersonalGit.Data.OAuthService.GetProviderColor(provider.ProviderName); color: @MyPersonalGit.Data.OAuthService.GetProviderColor(provider.ProviderName);">
                                        <i class="bi @MyPersonalGit.Data.OAuthService.GetProviderIcon(provider.ProviderName) me-2"></i>
                                        Sign in with @(provider.DisplayName ?? provider.ProviderName)
                                    </a>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="mb-3">
                            @if (UseRecoveryCode)
                            {
                                <label for="recoveryCode" class="form-label">Recovery Code</label>
                                <input id="recoveryCode" type="text" class="form-control font-monospace" @bind="TwoFactorCode" placeholder="Enter 8-digit recovery code" />
                                <div class="form-text">Enter one of your recovery codes.</div>
                            }
                            else
                            {
                                <label for="totpCode" class="form-label">Authentication Code</label>
                                <input id="totpCode" type="text" class="form-control font-monospace text-center" @bind="TwoFactorCode"
                                       placeholder="000000" maxlength="6" inputmode="numeric" />
                                <div class="form-text">Enter the 6-digit code from your authenticator app.</div>
                            }
                        </div>

                        <button class="btn btn-primary w-100 mb-3" @onclick="HandleTwoFactorLogin" disabled="@IsLoading">
                            @if (IsLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Verifying...</span>
                            }
                            else
                            {
                                <span>Verify</span>
                            }
                        </button>

                        <div class="text-center mb-2">
                            @if (UseRecoveryCode)
                            {
                                <a href="javascript:void(0)" class="text-decoration-none" @onclick="ToggleRecoveryCode">
                                    Use authenticator code instead
                                </a>
                            }
                            else
                            {
                                <a href="javascript:void(0)" class="text-decoration-none" @onclick="ToggleRecoveryCode">
                                    Use a recovery code
                                </a>
                            }
                        </div>

                        <div class="text-center">
                            <a href="javascript:void(0)" class="text-decoration-none text-muted" @onclick="BackToLogin">
                                <i class="bi bi-arrow-left me-1"></i>Back to login
                            </a>
                        </div>
                    }

                    @if (!ShowTwoFactorStep)
                    {
                        <div class="text-center mt-3">
                            <p class="text-muted mb-0">
                                Don't have an account? <a href="/register" class="text-decoration-none">Sign up</a>
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private string? ErrorMessage { get; set; }
    private bool IsLoading { get; set; }
    private bool ShowTwoFactorStep { get; set; }
    private bool UseRecoveryCode { get; set; }
    private string TwoFactorCode { get; set; } = "";
    private User? _pendingUser;
    private List<OAuthProviderConfig> oauthProviders = new();

    protected override async Task OnInitializedAsync()
    {
        oauthProviders = await OAuthService.GetEnabledProvidersAsync();

        // Check for OAuth error in query string
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var error = query["error"];
        if (!string.IsNullOrEmpty(error))
            ErrorMessage = error.Replace('+', ' ');
    }

    private async Task HandleLogin()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            var (user, requires2FA) = await UserService.ValidatePasswordAsync(loginModel.UsernameOrEmail, loginModel.Password);

            if (user == null)
            {
                ErrorMessage = "Invalid username/email or password";
                return;
            }

            if (requires2FA)
            {
                _pendingUser = user;
                ShowTwoFactorStep = true;
                TwoFactorCode = "";
                UseRecoveryCode = false;
                return;
            }

            // No 2FA — create session directly
            var sessionId = await UserService.CreateSessionForUserAsync(user);
            if (sessionId != null)
            {
                await JS.InvokeVoidAsync("sessionHelper.set", "sessionId", sessionId);
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else
            {
                ErrorMessage = "An error occurred during login. Please try again.";
            }
        }
        catch
        {
            ErrorMessage = "An error occurred during login. Please try again.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task HandleTwoFactorLogin()
    {
        if (_pendingUser == null)
        {
            BackToLogin();
            return;
        }

        IsLoading = true;
        ErrorMessage = null;

        try
        {
            var sessionId = await UserService.CompleteTwoFactorLoginAsync(_pendingUser, TwoFactorCode, UseRecoveryCode);

            if (sessionId != null)
            {
                await JS.InvokeVoidAsync("sessionHelper.set", "sessionId", sessionId);
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else
            {
                ErrorMessage = UseRecoveryCode
                    ? "Invalid recovery code. Please try again."
                    : "Invalid authentication code. Please try again.";
            }
        }
        catch
        {
            ErrorMessage = "An error occurred during verification. Please try again.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void ToggleRecoveryCode()
    {
        UseRecoveryCode = !UseRecoveryCode;
        TwoFactorCode = "";
        ErrorMessage = null;
    }

    private void BackToLogin()
    {
        ShowTwoFactorStep = false;
        UseRecoveryCode = false;
        TwoFactorCode = "";
        _pendingUser = null;
        ErrorMessage = null;
    }

    private class LoginModel
    {
        public string UsernameOrEmail { get; set; } = "";
        public string Password { get; set; } = "";
    }
}

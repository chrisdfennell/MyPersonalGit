@page "/login"
@using MyPersonalGit.Data
@using MyPersonalGit.Models
@using MyPersonalGit.Services
@using Microsoft.Extensions.Localization
@using MyPersonalGit.Resources
@inject CurrentUserService UserService
@inject IOAuthService OAuthService
@inject IWebAuthnService WebAuthnService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResource> L
@rendermode InteractiveServer

<PageTitle>Login - MyPersonalGit</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold">MyPersonalGit</h2>
                        <p class="text-muted">
                            @if (ShowTwoFactorStep)
                            {
                                <span>@L["Login_TwoFactor"]</span>
                            }
                            else
                            {
                                <span>@L["Login_Title"]</span>
                            }
                        </p>
                    </div>

                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>@ErrorMessage
                        </div>
                    }

                    @if (!ShowTwoFactorStep)
                    {
                        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                            <DataAnnotationsValidator />

                            <div class="mb-3">
                                <label for="usernameOrEmail" class="form-label">@L["Login_Username"]</label>
                                <InputText id="usernameOrEmail" class="form-control" @bind-Value="loginModel.UsernameOrEmail" placeholder="@L["Login_UsernamePlaceholder"]" />
                                <ValidationMessage For="@(() => loginModel.UsernameOrEmail)" />
                            </div>

                            <div class="mb-3">
                                <label for="password" class="form-label">@L["Login_Password"]</label>
                                <InputText id="password" type="password" class="form-control" @bind-Value="loginModel.Password" placeholder="@L["Login_PasswordPlaceholder"]" />
                                <ValidationMessage For="@(() => loginModel.Password)" />
                            </div>

                            <button type="submit" class="btn btn-primary w-100 mb-3" disabled="@IsLoading">
                                @if (IsLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>@L["Common_Loading"]</span>
                                }
                                else
                                {
                                    <span>@L["Login_SignIn"]</span>
                                }
                            </button>
                        </EditForm>

                        @if (oauthProviders.Any())
                        {
                            <div class="d-flex align-items-center my-3">
                                <hr class="flex-grow-1" />
                                <span class="px-3 text-muted small">@L["Login_OrSignInWith"]</span>
                                <hr class="flex-grow-1" />
                            </div>

                            <div class="d-grid gap-2">
                                @foreach (var provider in oauthProviders)
                                {
                                    <a href="/oauth/login/@provider.ProviderName" class="btn btn-outline-secondary d-flex align-items-center justify-content-center"
                                       style="border-color: @MyPersonalGit.Data.OAuthService.GetProviderColor(provider.ProviderName); color: @MyPersonalGit.Data.OAuthService.GetProviderColor(provider.ProviderName);">
                                        <i class="bi @MyPersonalGit.Data.OAuthService.GetProviderIcon(provider.ProviderName) me-2"></i>
                                        @L["Login_SignInWith", provider.DisplayName ?? provider.ProviderName]
                                    </a>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="mb-3">
                            @if (UseRecoveryCode)
                            {
                                <label for="recoveryCode" class="form-label">@L["Login_RecoveryCode"]</label>
                                <input id="recoveryCode" type="text" class="form-control font-monospace" @bind="TwoFactorCode" placeholder="@L["Login_RecoveryCodePlaceholder"]" />
                                <div class="form-text">@L["Login_RecoveryCodeHelp"]</div>
                            }
                            else
                            {
                                <label for="totpCode" class="form-label">@L["Login_AuthenticationCode"]</label>
                                <input id="totpCode" type="text" class="form-control font-monospace text-center" @bind="TwoFactorCode"
                                       placeholder="000000" maxlength="6" inputmode="numeric" />
                                <div class="form-text">@L["Login_AuthCodeHelp"]</div>
                            }
                        </div>

                        <button class="btn btn-primary w-100 mb-3" @onclick="HandleTwoFactorLogin" disabled="@IsLoading">
                            @if (IsLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>@L["Common_Loading"]</span>
                            }
                            else
                            {
                                <span>@L["Login_Verify"]</span>
                            }
                        </button>

                        @if (hasPasskeys)
                        {
                            <button class="btn btn-outline-secondary w-100 mb-3" @onclick="HandlePasskeyLogin" disabled="@IsLoading">
                                <i class="bi bi-fingerprint me-2"></i>@L["Login_UsePasskey"]
                            </button>
                        }

                        <div class="text-center mb-2">
                            @if (UseRecoveryCode)
                            {
                                <a href="javascript:void(0)" class="text-decoration-none" @onclick="ToggleRecoveryCode">
                                    @L["Login_UseAuthenticatorInstead"]
                                </a>
                            }
                            else
                            {
                                <a href="javascript:void(0)" class="text-decoration-none" @onclick="ToggleRecoveryCode">
                                    @L["Login_UseRecoveryCode"]
                                </a>
                            }
                        </div>

                        <div class="text-center">
                            <a href="javascript:void(0)" class="text-decoration-none text-muted" @onclick="BackToLogin">
                                <i class="bi bi-arrow-left me-1"></i>@L["Login_BackToLogin"]
                            </a>
                        </div>
                    }

                    @if (!ShowTwoFactorStep)
                    {
                        <div class="text-center mt-3">
                            <p class="text-muted mb-0">
                                @L["Login_NoAccount"] <a href="/register" class="text-decoration-none">@L["Nav_Register"]</a>
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private string? ErrorMessage { get; set; }
    private bool IsLoading { get; set; }
    private bool ShowTwoFactorStep { get; set; }
    private bool UseRecoveryCode { get; set; }
    private string TwoFactorCode { get; set; } = "";
    private User? _pendingUser;
    private bool hasPasskeys = false;
    private List<OAuthProviderConfig> oauthProviders = new();

    protected override async Task OnInitializedAsync()
    {
        oauthProviders = await OAuthService.GetEnabledProvidersAsync();

        // Check for OAuth error in query string
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var error = query["error"];
        if (!string.IsNullOrEmpty(error))
            ErrorMessage = error.Replace('+', ' ');
    }

    private async Task HandleLogin()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            var (user, requires2FA) = await UserService.ValidatePasswordAsync(loginModel.UsernameOrEmail, loginModel.Password);

            if (user == null)
            {
                ErrorMessage = L["Login_InvalidCredentials"];
                return;
            }

            if (requires2FA)
            {
                _pendingUser = user;
                ShowTwoFactorStep = true;
                TwoFactorCode = "";
                UseRecoveryCode = false;
                // Check if user has passkeys registered
                var creds = await WebAuthnService.GetCredentialsAsync(user.Username);
                hasPasskeys = creds.Count > 0;
                return;
            }

            // No 2FA — create session directly
            var sessionId = await UserService.CreateSessionForUserAsync(user);
            if (sessionId != null)
            {
                await JS.InvokeVoidAsync("sessionHelper.set", "sessionId", sessionId);
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else
            {
                ErrorMessage = L["Login_Error"];
            }
        }
        catch
        {
            ErrorMessage = L["Login_Error"];
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task HandleTwoFactorLogin()
    {
        if (_pendingUser == null)
        {
            BackToLogin();
            return;
        }

        IsLoading = true;
        ErrorMessage = null;

        try
        {
            var sessionId = await UserService.CompleteTwoFactorLoginAsync(_pendingUser, TwoFactorCode, UseRecoveryCode);

            if (sessionId != null)
            {
                await JS.InvokeVoidAsync("sessionHelper.set", "sessionId", sessionId);
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else
            {
                ErrorMessage = UseRecoveryCode
                    ? L["Login_InvalidRecoveryCode"]
                    : L["Login_InvalidAuthCode"];
            }
        }
        catch
        {
            ErrorMessage = L["Login_VerificationError"];
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void ToggleRecoveryCode()
    {
        UseRecoveryCode = !UseRecoveryCode;
        TwoFactorCode = "";
        ErrorMessage = null;
    }

    private void BackToLogin()
    {
        ShowTwoFactorStep = false;
        UseRecoveryCode = false;
        TwoFactorCode = "";
        _pendingUser = null;
        ErrorMessage = null;
    }

    private async Task HandlePasskeyLogin()
    {
        if (_pendingUser == null) { BackToLogin(); return; }
        IsLoading = true;
        ErrorMessage = null;
        try
        {
            var options = await WebAuthnService.GenerateAssertionOptionsAsync(_pendingUser.Username);
            var assertionJson = await JS.InvokeAsync<string>("webAuthn.authenticate", options);
            var verified = await WebAuthnService.VerifyAssertionAsync(_pendingUser.Username, assertionJson);
            if (verified)
            {
                var sessionId = await UserService.CreateSessionForUserAsync(_pendingUser);
                if (sessionId != null)
                {
                    await JS.InvokeVoidAsync("sessionHelper.set", "sessionId", sessionId);
                    Navigation.NavigateTo("/", forceLoad: true);
                }
                else { ErrorMessage = L["Login_SessionError"]; }
            }
            else { ErrorMessage = L["Login_PasskeyFailed"]; }
        }
        catch (Exception ex)
        {
            ErrorMessage = L["Login_PasskeyAuthFailed", ex.Message];
        }
        finally { IsLoading = false; }
    }

    private class LoginModel
    {
        public string UsernameOrEmail { get; set; } = "";
        public string Password { get; set; } = "";
    }
}

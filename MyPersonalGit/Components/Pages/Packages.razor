@page "/packages"
@page "/packages/{Type}"
@page "/packages/{Type}/{PackageName}"
@using MyPersonalGit.Data
@using MyPersonalGit.Models
@using MyPersonalGit.Services
@using Microsoft.Extensions.Localization
@using MyPersonalGit.Resources
@inject IPackageService PackageService
@inject CurrentUserService UserService
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> L
@rendermode InteractiveServer

<PageTitle>@L["Packages_Title"] · Personal Git</PageTitle>

<div class="container-xl py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0"><i class="bi bi-box-seam me-2"></i>@L["Packages_Title"]</h3>
    </div>

    @if (SelectedPackage != null)
    {
        <!-- Package detail view -->
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/packages">@L["Packages_Title"]</a></li>
                <li class="breadcrumb-item"><a href="/packages/@SelectedPackage.Type">@SelectedPackage.Type</a></li>
                <li class="breadcrumb-item active">@SelectedPackage.Name</li>
            </ol>
        </nav>

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-0">@SelectedPackage.Name</h5>
                    <span class="badge bg-primary">@SelectedPackage.Type</span>
                    <span class="text-muted small ms-2">by @SelectedPackage.Owner</span>
                </div>
                <span class="text-muted small"><i class="bi bi-download me-1"></i>@SelectedPackage.Downloads downloads</span>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(SelectedPackage.Description))
                {
                    <p>@SelectedPackage.Description</p>
                }

                <h6 class="fw-bold mt-3">@L["Packages_Install"]</h6>
                @if (SelectedPackage.Type == "nuget")
                {
                    <code class="d-block bg-light p-2 rounded small mb-3">dotnet add package @SelectedPackage.Name --source @(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/nuget/v3/index.json</code>
                }
                else if (SelectedPackage.Type == "npm")
                {
                    <code class="d-block bg-light p-2 rounded small mb-3">npm install @SelectedPackage.Name --registry=@(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/npm</code>
                }
                else if (SelectedPackage.Type == "pypi")
                {
                    <code class="d-block bg-light p-2 rounded small mb-3">pip install @SelectedPackage.Name --index-url @(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/pypi/simple/</code>
                }
                else if (SelectedPackage.Type == "cargo")
                {
                    <pre class="bg-light p-2 rounded small mb-3"><code>[registries.mygit]
index = "sparse+@(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/cargo/"</code></pre>
                    <code class="d-block bg-light p-2 rounded small mb-3">cargo add @SelectedPackage.Name --registry mygit</code>
                }
                else if (SelectedPackage.Type == "rubygems")
                {
                    <code class="d-block bg-light p-2 rounded small mb-3">gem install @SelectedPackage.Name --source @(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/rubygems</code>
                }
                else if (SelectedPackage.Type == "composer")
                {
                    <code class="d-block bg-light p-2 rounded small mb-3">composer require @SelectedPackage.Name</code>
                    <p class="small text-muted">Repository URL: <code>@(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/composer</code></p>
                }
                else if (SelectedPackage.Type == "helm")
                {
                    <code class="d-block bg-light p-2 rounded small mb-3">helm repo add mygit @(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/helm</code>
                    <code class="d-block bg-light p-2 rounded small mb-3">helm install @SelectedPackage.Name mygit/@SelectedPackage.Name</code>
                }
                else if (SelectedPackage.Type == "conda")
                {
                    <code class="d-block bg-light p-2 rounded small mb-3">conda install -c @(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/conda/main @SelectedPackage.Name</code>
                }
                else if (SelectedPackage.Type == "conan")
                {
                    <code class="d-block bg-light p-2 rounded small mb-3">conan remote add mygit @(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/conan</code>
                    <code class="d-block bg-light p-2 rounded small mb-3">conan install --requires @SelectedPackage.Name</code>
                }
                else if (SelectedPackage.Type == "vagrant")
                {
                    <code class="d-block bg-light p-2 rounded small mb-3">vagrant box add @(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/vagrant/@SelectedPackage.Name</code>
                }
                else if (SelectedPackage.Type == "pub")
                {
                    <code class="d-block bg-light p-2 rounded small mb-3">dart pub add @SelectedPackage.Name --hosted-url=@(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/pub</code>
                }
                else if (SelectedPackage.Type == "swift")
                {
                    <code class="d-block bg-light p-2 rounded small mb-3">.package(url: "@(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/swift/@SelectedPackage.Name", from: "1.0.0")</code>
                }
                else if (SelectedPackage.Type == "debian")
                {
                    <pre class="bg-light p-2 rounded small mb-3"><code>echo "deb @(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/debian stable main" | sudo tee /etc/apt/sources.list.d/mygit.list
sudo apt update
sudo apt install @SelectedPackage.Name</code></pre>
                }
                else if (SelectedPackage.Type == "alpine")
                {
                    <pre class="bg-light p-2 rounded small mb-3"><code># Add repository
echo "@(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/alpine/main" >> /etc/apk/repositories
# Install package
apk add @SelectedPackage.Name</code></pre>
                }
                else if (SelectedPackage.Type == "rpm")
                {
                    <pre class="bg-light p-2 rounded small mb-3"><code># Add repo file to /etc/yum.repos.d/mygit.repo
[mygit]
name=MyPersonalGit RPM Repository
baseurl=@(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/rpm/main
enabled=1
gpgcheck=0</code></pre>
                    <code class="d-block bg-light p-2 rounded small mb-3">dnf install @SelectedPackage.Name</code>
                }
                else if (SelectedPackage.Type == "chef")
                {
                    <code class="d-block bg-light p-2 rounded small mb-3">knife cookbook download @SelectedPackage.Name -s @(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/chef</code>
                }
                else if (SelectedPackage.Type == "cran")
                {
                    <code class="d-block bg-light p-2 rounded small mb-3">install.packages("@SelectedPackage.Name", repos = "@(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/cran")</code>
                }
                else if (SelectedPackage.Type == "maven")
                {
                    var parts = SelectedPackage.Name.Split(':');
                    var mavenGroupId = parts.Length > 1 ? parts[0] : SelectedPackage.Name;
                    var mavenArtifactId = parts.Length > 1 ? parts[1] : SelectedPackage.Name;
                    var mavenLatestVer = SelectedPackage.Versions.OrderByDescending(v => v.CreatedAt).FirstOrDefault()?.Version ?? "LATEST";
                    <pre class="bg-light p-2 rounded small mb-3"><code>&lt;dependency&gt;
  &lt;groupId&gt;@mavenGroupId&lt;/groupId&gt;
  &lt;artifactId&gt;@mavenArtifactId&lt;/artifactId&gt;
  &lt;version&gt;@mavenLatestVer&lt;/version&gt;
&lt;/dependency&gt;</code></pre>
                    <p class="small text-muted">Repository URL: <code>@(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/maven</code></p>
                }
                else
                {
                    var latest = SelectedPackage.Versions.OrderByDescending(v => v.CreatedAt).FirstOrDefault();
                    if (latest != null)
                    {
                        var firstFile = latest.Files.FirstOrDefault();
                        if (firstFile != null)
                        {
                            <code class="d-block bg-light p-2 rounded small mb-3">curl -O @(new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority))/api/packages/generic/@SelectedPackage.Name/@latest.Version/@firstFile.Filename</code>
                        }
                    }
                }

                <h6 class="fw-bold mt-3">@L["Packages_Versions"]</h6>
                <div class="list-group">
                    @foreach (var ver in SelectedPackage.Versions.OrderByDescending(v => v.CreatedAt))
                    {
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@ver.Version</strong>
                                    @if (ver.Size > 0)
                                    {
                                        <span class="text-muted small ms-2">@FormatBytes(ver.Size)</span>
                                    }
                                </div>
                                <div class="text-muted small">
                                    <i class="bi bi-download me-1"></i>@ver.Downloads
                                    <span class="ms-2">@ver.CreatedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>
                            @if (ver.Files.Any())
                            {
                                <div class="mt-1">
                                    @foreach (var f in ver.Files)
                                    {
                                        <span class="badge bg-light text-dark border me-1 small">@f.Filename</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Package list view -->
        <ul class="nav nav-tabs mb-4">
            <li class="nav-item">
                <a class="nav-link @(string.IsNullOrEmpty(Type) ? "active" : "")" href="/packages">@L["Packages_All"]</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Type == "nuget" ? "active" : "")" href="/packages/nuget">
                    <i class="bi bi-box me-1"></i>NuGet
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Type == "npm" ? "active" : "")" href="/packages/npm">
                    <i class="bi bi-box me-1"></i>npm
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Type == "pypi" ? "active" : "")" href="/packages/pypi">
                    <i class="bi bi-box me-1"></i>PyPI
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Type == "maven" ? "active" : "")" href="/packages/maven">
                    <i class="bi bi-box me-1"></i>Maven
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Type == "cargo" ? "active" : "")" href="/packages/cargo">
                    <i class="bi bi-box me-1"></i>Cargo
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Type == "rubygems" ? "active" : "")" href="/packages/rubygems">
                    <i class="bi bi-gem me-1"></i>RubyGems
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Type == "composer" ? "active" : "")" href="/packages/composer">
                    <i class="bi bi-box me-1"></i>Composer
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Type == "helm" ? "active" : "")" href="/packages/helm">
                    <i class="bi bi-box me-1"></i>Helm
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Type == "conda" ? "active" : "")" href="/packages/conda">
                    <i class="bi bi-box me-1"></i>Conda
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Type == "conan" ? "active" : "")" href="/packages/conan">
                    <i class="bi bi-box me-1"></i>Conan
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Type == "alpine" ? "active" : "")" href="/packages/alpine">
                    <i class="bi bi-box me-1"></i>Alpine
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Type == "rpm" ? "active" : "")" href="/packages/rpm">
                    <i class="bi bi-box me-1"></i>RPM
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Type == "chef" ? "active" : "")" href="/packages/chef">
                    <i class="bi bi-box me-1"></i>Chef
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Type == "generic" ? "active" : "")" href="/packages/generic">
                    <i class="bi bi-file-earmark-zip me-1"></i>Generic
                </a>
            </li>
        </ul>

        <div class="mb-3">
            <input type="text" class="form-control" placeholder="@L["Packages_SearchPlaceholder"]" @bind="searchTerm" @bind:event="oninput" />
        </div>

        @if (FilteredPackages.Any())
        {
            <div class="list-group">
                @foreach (var pkg in FilteredPackages)
                {
                    <a href="/packages/@pkg.Type/@pkg.Name" class="list-group-item list-group-item-action">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0 fw-bold">@pkg.Name</h6>
                                <span class="badge bg-primary me-2">@pkg.Type</span>
                                <span class="text-muted small">by @pkg.Owner</span>
                                @if (!string.IsNullOrEmpty(pkg.Description))
                                {
                                    <p class="text-muted small mb-0 mt-1">@pkg.Description</p>
                                }
                            </div>
                            <div class="text-end">
                                <div class="text-muted small"><i class="bi bi-download me-1"></i>@pkg.Downloads</div>
                                <div class="text-muted small">@pkg.Versions.Count version(s)</div>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-box-seam" style="font-size: 3rem;"></i>
                <p class="mt-3">@L["Packages_NoPackages"]</p>
                <p class="small">@L["Packages_NoPackagesDescription"]</p>
            </div>
        }
    }
</div>

@code {
    [Parameter] public string? Type { get; set; }
    [Parameter] public string? PackageName { get; set; }

    private List<Package> PackageList = new();
    private Package? SelectedPackage;
    private string searchTerm = "";

    private IEnumerable<Package> FilteredPackages =>
        PackageList.Where(p =>
            string.IsNullOrEmpty(searchTerm) ||
            p.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            (p.Description?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(PackageName) && !string.IsNullOrEmpty(Type))
        {
            SelectedPackage = await PackageService.GetPackageAsync(PackageName, Type);
        }
        else
        {
            SelectedPackage = null;
            PackageList = await PackageService.GetPackagesAsync(Type);
        }
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024 * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F1} GB";
    }
}

@page "/repo/{RepoName}/security"
@using MyPersonalGit.Data
@using MyPersonalGit.Models
@using MyPersonalGit.Services
@using Microsoft.Extensions.Localization
@using MyPersonalGit.Resources
@inject ISecurityService SecurityService
@inject ISecretScanService SecretScanService
@inject IConfiguration Config
@inject IAdminService AdminService
@inject CurrentUserService UserService
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L
@rendermode InteractiveServer

<PageTitle>Security - @RepoName</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/">@L["Security_Repositories"]</a></li>
                    <li class="breadcrumb-item"><a href="/repo/@RepoName">@RepoName</a></li>
                    <li class="breadcrumb-item active">@L["Security_Title"]</li>
                </ol>
            </nav>
            <h2 class="mt-2">@L["Security_Title"]</h2>
        </div>
    </div>

    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <button class="nav-link @(ActiveTab == "overview" ? "active" : "")" @onclick='() => ActiveTab = "overview"'>
                <i class="bi bi-shield-check me-1"></i> @L["Security_Overview"]
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(ActiveTab == "advisories" ? "active" : "")" @onclick='() => ActiveTab = "advisories"'>
                <i class="bi bi-exclamation-triangle me-1"></i> @L["Security_Advisories"]
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(ActiveTab == "dependencies" ? "active" : "")" @onclick='() => ActiveTab = "dependencies"'>
                <i class="bi bi-box-seam me-1"></i> @L["Security_Dependencies"]
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(ActiveTab == "secrets" ? "active" : "")" @onclick='() => { ActiveTab = "secrets"; LoadSecretScanResults(); }'>
                <i class="bi bi-key me-1"></i> @L["SecretScan_Title"]
                @if (secretAlerts.Count(a => a.State == SecretScanResultState.Open) > 0)
                {
                    <span class="badge bg-danger ms-1">@secretAlerts.Count(a => a.State == SecretScanResultState.Open)</span>
                }
            </button>
        </li>
    </ul>

    @if (ActiveTab == "overview")
    {
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="bi bi-shield-check me-2"></i>@L["Security_SecurityOverview"]
                        </h5>
                        @if (LatestScan != null)
                        {
                            <div class="mt-3">
                                <p class="text-muted mb-2">Last scanned: @FormatDate(LatestScan.ScannedAt)</p>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span>@L["Security_TotalVulnerabilities"]</span>
                                    <span class="badge bg-secondary">@LatestScan.VulnerabilitiesFound</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span>@L["Security_Critical"]</span>
                                    <span class="badge bg-danger">@LatestScan.CriticalCount</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span>@L["Security_High"]</span>
                                    <span class="badge bg-warning">@LatestScan.HighCount</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span>@L["Security_Medium"]</span>
                                    <span class="badge bg-info">@LatestScan.MediumCount</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>@L["Security_Low"]</span>
                                    <span class="badge bg-secondary">@LatestScan.LowCount</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mt-3">@L["Security_NoScansYet"]</p>
                        }
                        <button class="btn btn-primary mt-3 w-100" @onclick="RunSecurityScan" disabled="@isScanning">
                            @if (isScanning) { <span class="spinner-border spinner-border-sm me-2"></span> <text>Scanning...</text> }
                            else { <i class="bi bi-shield-check me-2"></i> <text>@L["Security_RunSecurityScan"]</text> }
                        </button>
                        @if (!string.IsNullOrEmpty(scanError)) { <div class="alert alert-danger mt-2 small">@scanError</div> }
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="bi bi-exclamation-triangle me-2"></i>@L["Security_SecurityAdvisories"]
                        </h5>
                        <div class="mt-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span>@L["Security_Published"]</span>
                                <span class="badge bg-danger">@Advisories.Count(a => a.State == SecurityAdvisoryState.Published)</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span>@L["Security_Draft"]</span>
                                <span class="badge bg-secondary">@Advisories.Count(a => a.State == SecurityAdvisoryState.Draft)</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span>@L["Security_Closed"]</span>
                                <span class="badge bg-success">@Advisories.Count(a => a.State == SecurityAdvisoryState.Closed)</span>
                            </div>
                        </div>
                        <button class="btn btn-primary mt-3 w-100" @onclick="ShowCreateAdvisoryModal">
                            <i class="bi bi-plus-circle me-2"></i>@L["Security_CreateAdvisory"]
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (ActiveTab == "advisories")
    {
        <div class="d-flex justify-content-end mb-3">
            <button class="btn btn-primary" @onclick="ShowCreateAdvisoryModal">
                <i class="bi bi-plus-circle me-2"></i>@L["Security_CreateAdvisory"]
            </button>
        </div>

        @if (Advisories.Count == 0)
        {
            <div class="card">
                <div class="card-body text-center py-5">
                    <i class="bi bi-exclamation-triangle" style="font-size: 4rem; color: #6c757d;"></i>
                    <h3 class="mt-3">@L["Security_NoAdvisories"]</h3>
                    <p class="text-muted">@L["Security_NoAdvisoriesDescription"]</p>
                </div>
            </div>
        }
        else
        {
            <div class="list-group">
                @foreach (var advisory in Advisories)
                {
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center mb-2">
                                    <h6 class="mb-0">@advisory.Title</h6>
                                    <span class="badge @GetSeverityBadgeClass(advisory.Severity) ms-2">@advisory.Severity</span>
                                    <span class="badge @GetStateBadgeClass(advisory.State) ms-2">@advisory.State</span>
                                </div>
                                <p class="mb-1 text-muted">@advisory.Description</p>
                                <small class="text-muted">
                                    Affected: @advisory.AffectedVersions
                                    @if (!string.IsNullOrEmpty(advisory.PatchedVersions))
                                    {
                                        <span class="mx-2">•</span>
                                        <span>Patched: @advisory.PatchedVersions</span>
                                    }
                                    <span class="mx-2">•</span>
                                    Reported by @advisory.Reporter
                                    <span class="mx-2">•</span>
                                    @FormatDate(advisory.CreatedAt)
                                </small>
                            </div>
                            <div class="btn-group">
                                @if (advisory.State == SecurityAdvisoryState.Draft)
                                {
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => PublishAdvisory(advisory.Id)">
                                        <i class="bi bi-send"></i> @L["Security_Publish"]
                                    </button>
                                }
                                @if (advisory.State == SecurityAdvisoryState.Published)
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => CloseAdvisory(advisory.Id)">
                                        <i class="bi bi-check-circle"></i> @L["Security_Close"]
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
    else if (ActiveTab == "secrets")
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="btn-group">
                <button class="btn btn-sm @(secretFilter == null ? "btn-primary" : "btn-outline-secondary")" @onclick='() => { secretFilter = null; LoadSecretScanResults(); }'>@L["SecretScan_All"]</button>
                <button class="btn btn-sm @(secretFilter == SecretScanResultState.Open ? "btn-primary" : "btn-outline-secondary")" @onclick='() => { secretFilter = SecretScanResultState.Open; LoadSecretScanResults(); }'>@L["SecretScan_Open"]</button>
                <button class="btn btn-sm @(secretFilter == SecretScanResultState.Resolved ? "btn-primary" : "btn-outline-secondary")" @onclick='() => { secretFilter = SecretScanResultState.Resolved; LoadSecretScanResults(); }'>@L["SecretScan_Resolved"]</button>
            </div>
            <button class="btn btn-warning btn-sm" @onclick="RunSecretScan" disabled="@isSecretScanning">
                @if (isSecretScanning) { <span class="spinner-border spinner-border-sm me-1"></span> <text>@L["SecretScan_Scanning"]</text> }
                else { <i class="bi bi-search me-1"></i> <text>@L["SecretScan_FullScan"]</text> }
            </button>
        </div>

        @if (!secretAlerts.Any())
        {
            <div class="card">
                <div class="card-body text-center py-5">
                    <i class="bi bi-shield-check" style="font-size: 4rem; color: #198754;"></i>
                    <h3 class="mt-3">@L["SecretScan_NoSecrets"]</h3>
                    <p class="text-muted">@L["SecretScan_NoSecretsDescription"]</p>
                </div>
            </div>
        }
        else
        {
            <div class="list-group">
                @foreach (var alert in secretAlerts)
                {
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center mb-1">
                                    <i class="bi bi-key-fill text-warning me-2"></i>
                                    <h6 class="mb-0">@alert.SecretType</h6>
                                    <span class="badge @(alert.State == SecretScanResultState.Open ? "bg-danger" : "bg-success") ms-2">@alert.State</span>
                                </div>
                                <p class="mb-1 small text-muted">
                                    <code>@alert.FilePath</code> @L["SecretScan_Line"] @alert.LineNumber
                                    <span class="mx-1">·</span>
                                    @L["SecretScan_Commit"] <code>@alert.CommitSha[..7]</code>
                                </p>
                                <pre class="bg-light p-2 rounded small mb-0" style="max-width: 600px; overflow-x: auto;">@alert.MatchSnippet</pre>
                                @if (alert.ResolvedBy != null)
                                {
                                    <small class="text-muted">@L["SecretScan_ResolvedBy"] @alert.ResolvedBy @L["SecretScan_On"] @alert.ResolvedAt?.ToString("g")</small>
                                }
                            </div>
                            @if (alert.State == SecretScanResultState.Open)
                            {
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => ResolveSecret(alert.Id, SecretScanResultState.Resolved)" title="@L["SecretScan_MarkResolved"]">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ResolveSecret(alert.Id, SecretScanResultState.FalsePositive)" title="@L["SecretScan_MarkFalsePositive"]">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }
    else if (ActiveTab == "dependencies")
    {
        @if (LatestScan == null || LatestScan.Dependencies.Count == 0)
        {
            <div class="card">
                <div class="card-body text-center py-5">
                    <i class="bi bi-box-seam" style="font-size: 4rem; color: #6c757d;"></i>
                    <h3 class="mt-3">@L["Security_NoDependenciesScanned"]</h3>
                    <p class="text-muted">@L["Security_NoDependenciesDescription"]</p>
                    <button class="btn btn-primary" @onclick="RunSecurityScan" disabled="@isScanning">
                        @if (isScanning) { <span class="spinner-border spinner-border-sm me-2"></span> <text>Scanning...</text> }
                        else { <i class="bi bi-shield-check me-2"></i> <text>@L["Security_RunSecurityScan"]</text> }
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="mb-3">
                <p class="text-muted">Last scanned: @FormatDate(LatestScan.ScannedAt)</p>
            </div>

            <div class="list-group">
                @foreach (var dependency in LatestScan.Dependencies)
                {
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <h6 class="mb-1">@dependency.Name <span class="text-muted">@dependency.Version</span></h6>
                                <small class="text-muted">Type: @dependency.Type</small>
                                
                                @if (dependency.Vulnerabilities.Count > 0)
                                {
                                    <div class="mt-2">
                                        <span class="badge bg-danger">@dependency.Vulnerabilities.Count vulnerabilities</span>
                                        @foreach (var vuln in dependency.Vulnerabilities)
                                        {
                                            <div class="alert alert-@GetSeverityAlertClass(vuln.Severity) mt-2 mb-0">
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <div>
                                                        <strong>@vuln.Title</strong>
                                                        <p class="mb-1">@vuln.Description</p>
                                                        @if (!string.IsNullOrEmpty(vuln.FixedVersion))
                                                        {
                                                            <small>Fixed in version: @vuln.FixedVersion</small>
                                                        }
                                                    </div>
                                                    <span class="badge @GetSeverityBadgeClass(vuln.Severity)">@vuln.Severity</span>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="mt-2">
                                        <span class="badge bg-success">@L["Security_NoKnownVulnerabilities"]</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@if (ShowAdvisoryModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@L["Security_CreateSecurityAdvisory"]</h5>
                    <button type="button" class="btn-close" @onclick="() => ShowAdvisoryModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">@L["Security_AdvisoryTitle"]</label>
                        <input type="text" class="form-control" @bind="NewAdvisoryTitle" placeholder="@L["Security_AdvisoryTitlePlaceholder"]" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@L["Security_AdvisoryDescription"]</label>
                        <textarea class="form-control" rows="3" @bind="NewAdvisoryDescription" placeholder="@L["Security_AdvisoryDescriptionPlaceholder"]"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@L["Security_Severity"]</label>
                        <select class="form-select" @bind="NewAdvisorySeverity">
                            <option value="@SecuritySeverity.Low">Low</option>
                            <option value="@SecuritySeverity.Medium">Medium</option>
                            <option value="@SecuritySeverity.High">High</option>
                            <option value="@SecuritySeverity.Critical">Critical</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@L["Security_AffectedVersions"]</label>
                        <input type="text" class="form-control" @bind="NewAdvisoryAffectedVersions" placeholder="e.g., < 1.2.3" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => ShowAdvisoryModal = false">@L["Security_Cancel"]</button>
                    <button type="button" class="btn btn-primary" @onclick="CreateAdvisory">@L["Security_Create"]</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string RepoName { get; set; } = "";
    
    private List<SecurityAdvisory> Advisories { get; set; } = new();
    private SecurityScan? LatestScan { get; set; }
    private string ActiveTab { get; set; } = "overview";
    
    private bool ShowAdvisoryModal { get; set; }
    private string NewAdvisoryTitle { get; set; } = "";
    private string NewAdvisoryDescription { get; set; } = "";
    private SecuritySeverity NewAdvisorySeverity { get; set; } = SecuritySeverity.Medium;
    private string NewAdvisoryAffectedVersions { get; set; } = "";

    private List<SecretScanResult> secretAlerts = new();
    private SecretScanResultState? secretFilter = null;
    private bool isSecretScanning = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        secretAlerts = await SecretScanService.GetResultsAsync(RepoName, secretFilter);
    }

    private async Task LoadData()
    {
        Advisories = await SecurityService.GetAdvisoriesAsync(RepoName);
        LatestScan = await SecurityService.GetLatestScanAsync(RepoName);
    }

    private async void LoadSecretScanResults()
    {
        secretAlerts = await SecretScanService.GetResultsAsync(RepoName, secretFilter);
        StateHasChanged();
    }

    private async Task RunSecretScan()
    {
        isSecretScanning = true;
        StateHasChanged();
        try
        {
            var systemSettings = await AdminService.GetSystemSettingsAsync();
            var projectRoot = !string.IsNullOrEmpty(systemSettings.ProjectRoot) ? systemSettings.ProjectRoot : Config["Git:ProjectRoot"] ?? "/repos";
            var repoPath = Path.Combine(projectRoot, RepoName);
            if (!Directory.Exists(repoPath)) repoPath = Path.Combine(projectRoot, RepoName + ".git");
            await SecretScanService.FullScanAsync(RepoName, repoPath);
            secretAlerts = await SecretScanService.GetResultsAsync(RepoName, secretFilter);
        }
        catch (Exception ex) { scanError = $"Secret scan failed: {ex.Message}"; }
        finally { isSecretScanning = false; StateHasChanged(); }
    }

    private async Task ResolveSecret(int alertId, SecretScanResultState state)
    {
        await SecretScanService.ResolveResultAsync(alertId, UserService.Username, state);
        secretAlerts = await SecretScanService.GetResultsAsync(RepoName, secretFilter);
        StateHasChanged();
    }

    private bool isScanning = false;
    private string scanError = "";

    private async Task RunSecurityScan()
    {
        isScanning = true;
        scanError = "";
        StateHasChanged();

        try
        {
            var projectRoot = Config["Git:ProjectRoot"] ?? "/repos";
            var repoPath = Path.Combine(projectRoot, RepoName);
            if (!Directory.Exists(repoPath))
                repoPath = Path.Combine(projectRoot, RepoName + ".git");

            await SecurityService.ScanRepositoryAsync(RepoName, repoPath);
            await LoadData();
        }
        catch (Exception ex)
        {
            scanError = $"Scan failed: {ex.Message}";
        }
        finally
        {
            isScanning = false;
            StateHasChanged();
        }
    }

    private void ShowCreateAdvisoryModal()
    {
        ShowAdvisoryModal = true;
    }

    private async Task CreateAdvisory()
    {
        if (string.IsNullOrWhiteSpace(NewAdvisoryTitle))
            return;

        await SecurityService.CreateAdvisoryAsync(
            RepoName,
            NewAdvisoryTitle,
            NewAdvisoryDescription,
            NewAdvisorySeverity,
            NewAdvisoryAffectedVersions,
            UserService.Username
        );

        ShowAdvisoryModal = false;
        NewAdvisoryTitle = "";
        NewAdvisoryDescription = "";
        NewAdvisorySeverity = SecuritySeverity.Medium;
        NewAdvisoryAffectedVersions = "";
        
        await LoadData();
    }

    private async Task PublishAdvisory(int advisoryId)
    {
        await SecurityService.PublishAdvisoryAsync(RepoName, advisoryId);
        await LoadData();
    }

    private async Task CloseAdvisory(int advisoryId)
    {
        await SecurityService.CloseAdvisoryAsync(RepoName, advisoryId);
        await LoadData();
    }

    private string GetSeverityBadgeClass(SecuritySeverity severity)
    {
        return severity switch
        {
            SecuritySeverity.Critical => "bg-danger",
            SecuritySeverity.High => "bg-warning",
            SecuritySeverity.Medium => "bg-info",
            SecuritySeverity.Low => "bg-secondary",
            _ => "bg-secondary"
        };
    }

    private string GetSeverityAlertClass(SecuritySeverity severity)
    {
        return severity switch
        {
            SecuritySeverity.Critical => "danger",
            SecuritySeverity.High => "warning",
            SecuritySeverity.Medium => "info",
            SecuritySeverity.Low => "secondary",
            _ => "secondary"
        };
    }

    private string GetStateBadgeClass(SecurityAdvisoryState state)
    {
        return state switch
        {
            SecurityAdvisoryState.Draft => "bg-secondary",
            SecurityAdvisoryState.Published => "bg-danger",
            SecurityAdvisoryState.Closed => "bg-success",
            _ => "bg-secondary"
        };
    }

    private string FormatDate(DateTime date)
    {
        var timeAgo = DateTime.UtcNow - date;
        if (timeAgo.TotalMinutes < 1) return "just now";
        if (timeAgo.TotalMinutes < 60) return $"{(int)timeAgo.TotalMinutes} minutes ago";
        if (timeAgo.TotalHours < 24) return $"{(int)timeAgo.TotalHours} hours ago";
        if (timeAgo.TotalDays < 7) return $"{(int)timeAgo.TotalDays} days ago";
        return date.ToString("MMM dd, yyyy");
    }
}

    // Commit graph state
    private List<GraphEntry> graphEntries = new();
    private int graphMaxLane = 0;
    private static readonly string[] GraphColors = new[] { "#0969da", "#cf222e", "#1a7f37", "#8250df", "#bf8700", "#0550ae", "#e16f24", "#6639ba" };

    private class GraphEntry
    {
        public int Row { get; set; }
        public int Lane { get; set; }
        public string Sha { get; set; } = "";
        public string ShortSha { get; set; } = "";
        public string Message { get; set; } = "";
        public string Author { get; set; } = "";
        public DateTime Date { get; set; }
        public string Color { get; set; } = "";
        public List<(int ParentRow, int ParentLane, string Color)> ParentLinks { get; set; } = new();
    }

    private void LoadGraph()
    {
        graphEntries.Clear();
        graphMaxLane = 0;
        try
        {
            using var repo = new Repository(RepoFullPath);
            var allTips = repo.Branches.Select(b => b.Tip).Where(t => t != null).ToList();
            if (!allTips.Any()) return;

            var filter = new CommitFilter { IncludeReachableFrom = allTips, SortBy = CommitSortStrategies.Topological | CommitSortStrategies.Time };
            var commits = repo.Commits.QueryBy(filter).Take(150).ToList();

            // activeLanes[i] = SHA expected at that lane slot, or null if free
            var activeLanes = new List<string?>();
            var shaToEntry = new Dictionary<string, GraphEntry>();

            int FindOrAddFreeLane(string sha)
            {
                for (int i = 0; i < activeLanes.Count; i++)
                    if (activeLanes[i] == null) { activeLanes[i] = sha; return i; }
                activeLanes.Add(sha);
                return activeLanes.Count - 1;
            }

            int row = 0;
            foreach (var commit in commits)
            {
                // Find which lane this commit occupies
                int lane = activeLanes.IndexOf(commit.Sha);
                if (lane == -1)
                    lane = FindOrAddFreeLane(commit.Sha);

                // Clear this lane
                activeLanes[lane] = null;

                var color = GraphColors[lane % GraphColors.Length];
                var entry = new GraphEntry
                {
                    Row = row,
                    Lane = lane,
                    Sha = commit.Sha,
                    ShortSha = commit.Sha[..7],
                    Message = commit.MessageShort,
                    Author = commit.Author.Name,
                    Date = commit.Author.When.UtcDateTime,
                    Color = color
                };

                // Assign parents to lanes
                var parents = commit.Parents.ToList();
                if (parents.Count > 0)
                {
                    // First parent inherits this commit's lane (straight line down)
                    if (activeLanes[lane] == null)
                        activeLanes[lane] = parents[0].Sha;
                    else
                        FindOrAddFreeLane(parents[0].Sha);

                    // Additional parents (merge) get free lanes
                    for (int i = 1; i < parents.Count; i++)
                    {
                        // Only assign if not already reserved
                        if (!activeLanes.Contains(parents[i].Sha))
                            FindOrAddFreeLane(parents[i].Sha);
                    }
                }

                shaToEntry[commit.Sha] = entry;
                graphEntries.Add(entry);
                if (lane > graphMaxLane) graphMaxLane = lane;
                row++;
            }

            // Resolve parent links now that all entries are placed
            foreach (var entry in graphEntries)
            {
                var commit = commits[entry.Row];
                foreach (var parent in commit.Parents)
                {
                    if (shaToEntry.TryGetValue(parent.Sha, out var parentEntry))
                    {
                        entry.ParentLinks.Add((parentEntry.Row, parentEntry.Lane, entry.Color));
                    }
                }
            }
        }
        catch { }
    }

    private string TruncateMessage(string msg, int max)
    {
        return msg.Length <= max ? msg : msg[..max] + "...";
    }

    private void ToggleBlameView()
    {
        if (activeTab == "blame")
        {
            activeTab = "code";
            LoadRepoData();
            return;
        }
        activeTab = "blame";
        LoadBlame();
    }

    private void LoadBlame()
    {
        blameLines.Clear();
        if (string.IsNullOrEmpty(Path)) return;
        try
        {
            using var repo = new Repository(RepoFullPath);
            var result = repo.Blame(Path);
            var allLines = fileContent.Split('\n');
            int hunkIndex = 0;
            foreach (var hunk in result)
            {
                var lineCount = hunk.LineCount;
                for (int i = 0; i < lineCount; i++)
                {
                    var globalLine = hunk.FinalStartLineNumber + i;
                    blameLines.Add(new BlameLine
                    {
                        HunkIndex = hunkIndex,
                        HunkLineCount = lineCount,
                        IsFirstInHunk = i == 0,
                        CommitSha = hunk.FinalCommit.Sha,
                        ShortSha = hunk.FinalCommit.Sha[..7],
                        Author = hunk.FinalCommit.Author.Name,
                        Date = hunk.FinalCommit.Author.When.UtcDateTime,
                        LineNumber = globalLine + 1,
                        Content = globalLine < allLines.Length ? allLines[globalLine] : ""
                    });
                }
                hunkIndex++;
            }
        }
        catch { }
    }


                                <a href="javascript:void(0)" class="list-group-item list-group-item-action border-0 py-1 px-2 @(settingsSection == "general" ? "active" : "")" @onclick='() => settingsSection = "general"'>
                                    <i class="bi bi-gear me-2"></i>@L["Repo_General"]
                                </a>
                                <a href="javascript:void(0)" class="list-group-item list-group-item-action border-0 py-1 px-2 @(settingsSection == "default-branch" ? "active" : "")" @onclick='() => settingsSection = "default-branch"'>
                                    <i class="bi bi-signpost-split me-2"></i>@L["Repo_DefaultBranch"]
                                </a>

                                <span class="list-group-item fw-bold text-muted bg-transparent border-0 py-1 px-2 mt-2" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;">Access</span>
                                <a href="javascript:void(0)" class="list-group-item list-group-item-action border-0 py-1 px-2 @(settingsSection == "collaborators" ? "active" : "")" @onclick='() => settingsSection = "collaborators"'>
                                    <i class="bi bi-people me-2"></i>Collaborators
                                </a>
                                <a href="javascript:void(0)" class="list-group-item list-group-item-action border-0 py-1 px-2 @(settingsSection == "deploy-keys" ? "active" : "")" @onclick='() => settingsSection = "deploy-keys"'>
                                    <i class="bi bi-key me-2"></i>Deploy Keys
                                </a>
                                <a href="javascript:void(0)" class="list-group-item list-group-item-action border-0 py-1 px-2 @(settingsSection == "secrets" ? "active" : "")" @onclick='() => settingsSection = "secrets"'>
                                    <i class="bi bi-key-fill me-2"></i>Secrets
                                </a>

                                <span class="list-group-item fw-bold text-muted bg-transparent border-0 py-1 px-2 mt-2" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;">Code & automation</span>
                                <a href="javascript:void(0)" class="list-group-item list-group-item-action border-0 py-1 px-2 @(settingsSection == "branches" ? "active" : "")" @onclick='() => settingsSection = "branches"'>
                                    <i class="bi bi-shield-lock me-2"></i>Branch Protection
                                </a>
                                <a href="javascript:void(0)" class="list-group-item list-group-item-action border-0 py-1 px-2 @(settingsSection == "tags" ? "active" : "")" @onclick='() => settingsSection = "tags"'>
                                    <i class="bi bi-shield-check me-2"></i>Tag Protection
                                </a>
                                <a href="javascript:void(0)" class="list-group-item list-group-item-action border-0 py-1 px-2 @(settingsSection == "hooks" ? "active" : "")" @onclick='() => settingsSection = "hooks"'>
                                    <i class="bi bi-terminal me-2"></i>@L["Repo_GitHooks"]
                                </a>
                                <a href="javascript:void(0)" class="list-group-item list-group-item-action border-0 py-1 px-2 @(settingsSection == "labels" ? "active" : "")" @onclick='() => settingsSection = "labels"'>
                                    <i class="bi bi-tags me-2"></i>Labels
                                </a>
                                <a href="javascript:void(0)" class="list-group-item list-group-item-action border-0 py-1 px-2 @(settingsSection == "pages" ? "active" : "")" @onclick='() => settingsSection = "pages"'>
                                    <i class="bi bi-globe me-2"></i>Pages
                                </a>
                                <a href="javascript:void(0)" class="list-group-item list-group-item-action border-0 py-1 px-2 @(settingsSection == "autolinks" ? "active" : "")" @onclick='() => settingsSection = "autolinks"'>
                                    <i class="bi bi-link-45deg me-2"></i>Autolinks
                                </a>
                                <a href="javascript:void(0)" class="list-group-item list-group-item-action border-0 py-1 px-2 @(settingsSection == "external-tracker" ? "active" : "")" @onclick='() => settingsSection = "external-tracker"'>
                                    <i class="bi bi-box-arrow-up-right me-2"></i>External Tracker
                                </a>
                                <a href="javascript:void(0)" class="list-group-item list-group-item-action border-0 py-1 px-2 @(settingsSection == "mirrors" ? "active" : "")" @onclick='() => settingsSection = "mirrors"'>
                                    <i class="bi bi-arrow-repeat me-2"></i>Mirrors
                                </a>
                                <a href="javascript:void(0)" class="list-group-item list-group-item-action border-0 py-1 px-2 @(settingsSection == "dependabot" ? "active" : "")" @onclick='() => { settingsSection = "dependabot"; LoadDependabotConfigs(); }'>
                                    <i class="bi bi-arrow-up-circle me-2"></i>Dependabot
                                </a>

                                <span class="list-group-item fw-bold text-muted bg-transparent border-0 py-1 px-2 mt-2" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;">Danger</span>
                                <a href="javascript:void(0)" class="list-group-item list-group-item-action border-0 py-1 px-2 @(settingsSection == "transfer" ? "active" : "")" @onclick='() => settingsSection = "transfer"'>
                                    <i class="bi bi-arrow-left-right me-2"></i>@L["Repo_TransferRepo"]
                                </a>
                                <a href="javascript:void(0)" class="list-group-item list-group-item-action border-0 py-1 px-2 @(settingsSection == "archive" ? "active" : "")" @onclick='() => settingsSection = "archive"'>
                                    <i class="bi bi-archive me-2"></i>Archive
                                </a>
                                <a href="javascript:void(0)" class="list-group-item list-group-item-action border-0 py-1 px-2 text-danger @(settingsSection == "danger" ? "active" : "")" @onclick='() => settingsSection = "danger"'>
                                    <i class="bi bi-exclamation-triangle me-2"></i>Danger Zone
                                </a>
                            </div>
                        </nav>
                    </div>
                    <div class="col-md-9">

                @if (UserService.IsLoggedIn && (settingsSection == "general" || settingsSection == ""))
                {
                    <div class="card border shadow-sm mb-4">
                        <div class="card-header bg-light-subtle py-2 small fw-bold">
                            <i class="bi bi-info-circle me-1"></i> @L["Repo_General"]
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label small fw-bold">@L["Repo_Description"]</label>
                                <input type="text" class="form-control form-control-sm" @bind="settingsDescription" placeholder="@L["Repo_DescriptionPlaceholder"]" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold">@L["Repo_Website"]</label>
                                <input type="url" class="form-control form-control-sm" @bind="settingsWebsiteUrl" placeholder="https://example.com" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold">@L["Repo_Visibility"]</label>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="settingsVisibility" id="settingsPublic" checked="@(!settingsIsPrivate)" @onchange="() => settingsIsPrivate = false" />
                                    <label class="form-check-label small" for="settingsPublic">
                                        <i class="bi bi-journal-bookmark me-1"></i> @L["Repo_PublicDesc"]
                                    </label>
                                </div>
                                <div class="form-check mt-1">
                                    <input class="form-check-input" type="radio" name="settingsVisibility" id="settingsPrivate" checked="@settingsIsPrivate" @onchange="() => settingsIsPrivate = true" />
                                    <label class="form-check-label small" for="settingsPrivate">
                                        <i class="bi bi-lock me-1"></i> @L["Repo_PrivateDesc"]
                                    </label>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold">@L["Repo_Topics"]</label>
                                <div class="d-flex flex-wrap gap-1 mb-2">
                                    @foreach (var topic in settingsTopics)
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle rounded-pill d-flex align-items-center gap-1 py-1 px-2">
                                            @topic
                                            <button type="button" class="btn-close" style="font-size: 8px;" @onclick="() => RemoveTopic(topic)"></button>
                                        </span>
                                    }
                                </div>
                                <div class="input-group input-group-sm" style="max-width: 300px;">
                                    <input type="text" class="form-control" @bind="newTopicInput" @bind:event="oninput" @onkeyup="HandleTopicKeyPress" placeholder="@L["Repo_AddTopicPlaceholder"]" />
                                    <button class="btn btn-outline-primary" type="button" @onclick="AddTopic" disabled="@string.IsNullOrWhiteSpace(newTopicInput)">@L["Repo_AddTopic"]</button>
                                </div>
                                <div class="form-text">@L["Repo_TopicsHelp"]</div>
                            </div>
                            <div class="mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" @bind="settingsIsTemplate" id="settingsIsTemplate" />
                                    <label class="form-check-label small" for="settingsIsTemplate">
                                        <i class="bi bi-copy me-1"></i> <strong>@L["Repo_TemplateRepo"]</strong> — @L["Repo_TemplateRepoDesc"]
                                    </label>
                                </div>
                            </div>
                            <button class="btn btn-gh-primary btn-sm" @onclick="SaveGeneralSettings">@L["Repo_SaveChanges"]</button>
                            @if (!string.IsNullOrEmpty(settingsSaveMessage))
                            {
                                <span class="text-success small ms-2"><i class="bi bi-check-circle me-1"></i>@settingsSaveMessage</span>
                            }
                        </div>
                    </div>

                    <div class="card border shadow-sm mb-4">
                        <div class="card-header bg-warning bg-opacity-10 py-2 small fw-bold">
                            <i class="bi bi-pencil-square me-1"></i> Rename Repository
                        </div>
                        <div class="card-body">
                            <div class="mb-2">
                                <label class="form-label small fw-bold">New repository name</label>
                                <div class="d-flex align-items-center gap-2">
                                    <input type="text" class="form-control form-control-sm" style="max-width: 300px;" @bind="settingsNewName" placeholder="new-name" />
                                    <button class="btn btn-warning btn-sm" @onclick="RenameRepository" disabled="@string.IsNullOrWhiteSpace(settingsNewName)">Rename</button>
                                </div>
                            </div>
                            <div class="form-text text-warning">
                                <i class="bi bi-exclamation-triangle me-1"></i> Renaming may break existing clones and links
                            </div>
                            @if (!string.IsNullOrEmpty(renameMessage))
                            {
                                <div class="mt-2 small @(renameSuccess ? "text-success" : "text-danger")">
                                    <i class="bi @(renameSuccess ? "bi-check-circle" : "bi-x-circle") me-1"></i>@renameMessage
                                </div>
                            }
                        </div>
                    </div>

                }

                @if (UserService.IsLoggedIn && (settingsSection == "default-branch" || settingsSection == "general"))
                {
                    <div class="card border shadow-sm mb-4">
                        <div class="card-header bg-light-subtle py-2 small fw-bold">
                            <i class="bi bi-signpost-split me-1"></i> @L["Repo_DefaultBranch"]
                        </div>
                        <div class="card-body">
                            <div class="d-flex align-items-center gap-2">
                                <select class="form-select form-select-sm" style="max-width: 250px;" @bind="selectedDefaultBranch">
                                    @foreach (var b in availableBranches)
                                    {
                                        <option value="@b">@b</option>
                                    }
                                </select>
                                <button class="btn btn-gh-primary btn-sm" @onclick="ChangeDefaultBranch">@L["Repo_Update"]</button>
                                @if (!string.IsNullOrEmpty(defaultBranchMessage))
                                {
                                    <span class="small text-success"><i class="bi bi-check-circle me-1"></i>@defaultBranchMessage</span>
                                }
                            </div>
                            <div class="form-text">@L["Repo_DefaultBranchHelp"]</div>
                        </div>
                    </div>
                }

                @if (UserService.IsLoggedIn && settingsSection == "transfer")
                {
                    <div class="card border border-warning shadow-sm mb-4">
                        <div class="card-header bg-warning-subtle py-2 small fw-bold text-warning-emphasis">
                            <i class="bi bi-arrow-left-right me-1"></i> @L["Repo_TransferRepo"]
                        </div>
                        <div class="card-body">
                            <p class="small text-muted mb-2">@L["Repo_TransferDesc"]</p>
                            <div class="d-flex align-items-center gap-2">
                                <input type="text" class="form-control form-control-sm" style="max-width: 250px;" @bind="transferTargetOwner" placeholder="@L["Repo_TransferPlaceholder"]" />
                                <button class="btn btn-warning btn-sm" @onclick="TransferRepository" disabled="@string.IsNullOrWhiteSpace(transferTargetOwner)">@L["Repo_Transfer"]</button>
                            </div>
                            @if (!string.IsNullOrEmpty(transferMessage))
                            {
                                <div class="small mt-2 @(transferSuccess ? "text-success" : "text-danger")">@transferMessage</div>
                            }
                        </div>
                    </div>
                }

                @if (settingsSection == "branches")
                {
                <div class="card border shadow-sm mb-4">
                    <div class="card-header bg-light-subtle py-2 small fw-bold">
                        <i class="bi bi-shield-lock me-1"></i> Branch protection rules
                    </div>
                    <div class="card-body">
                        @if (branchProtectionRules.Any())
                        {
                            <div class="list-group list-group-flush mb-3">
                                @foreach (var rule in branchProtectionRules)
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                                        <div>
                                            <span class="fw-bold font-monospace">@rule.BranchPattern</span>
                                            <div class="small text-muted mt-1">
                                                @if (rule.RequirePullRequest) { <span class="badge bg-info bg-opacity-10 text-info border border-info-subtle me-1">Require PR</span> }
                                                @if (rule.RequiredApprovals > 0) { <span class="badge bg-info bg-opacity-10 text-info border border-info-subtle me-1">@rule.RequiredApprovals approval(s)</span> }
                                                @if (rule.PreventForcePush) { <span class="badge bg-warning bg-opacity-10 text-warning border border-warning-subtle me-1">No force push</span> }
                                                @if (rule.PreventDeletion) { <span class="badge bg-warning bg-opacity-10 text-warning border border-warning-subtle me-1">No deletion</span> }
                                                @if (rule.RequireLinearHistory) { <span class="badge bg-secondary bg-opacity-10 text-secondary border me-1">Linear history</span> }
                                                @if (rule.RequireCodeOwnersApproval) { <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle me-1">CODEOWNERS</span> }
                                                @if (rule.RequireSignedCommits) { <span class="badge bg-info bg-opacity-10 text-info border border-info-subtle me-1">@L["Repo_SignedCommits"]</span> }
                                                @if (rule.ProtectedFilePatterns.Any())
                                                {
                                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning-subtle me-1">@rule.ProtectedFilePatterns.Count file pattern(s)</span>
                                                }
                                            </div>
                                        </div>
                                        @if (UserService.IsLoggedIn)
                                        {
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteBranchProtectionRule(rule.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small mb-3">No branch protection rules configured yet.</p>
                        }

                        @if (showAddProtectionRule)
                        {
                            <div class="border rounded p-3 bg-light-subtle">
                                <h6 class="fw-bold small mb-3">Add branch protection rule</h6>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">Branch name pattern</label>
                                    <input type="text" class="form-control form-control-sm" @bind="newProtectionRule.BranchPattern" placeholder="main, release/*, etc." />
                                    <div class="form-text">Use * as wildcard. Example: release/* matches release/v1, release/v2, etc.</div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <div class="form-check mb-2">
                                            <input type="checkbox" class="form-check-input" id="requirePR" @bind="newProtectionRule.RequirePullRequest" />
                                            <label class="form-check-label small" for="requirePR">Require pull request before merging</label>
                                        </div>
                                        <div class="form-check mb-2">
                                            <input type="checkbox" class="form-check-input" id="preventForce" @bind="newProtectionRule.PreventForcePush" />
                                            <label class="form-check-label small" for="preventForce">Prevent force pushes</label>
                                        </div>
                                        <div class="form-check mb-2">
                                            <input type="checkbox" class="form-check-input" id="preventDelete" @bind="newProtectionRule.PreventDeletion" />
                                            <label class="form-check-label small" for="preventDelete">Prevent branch deletion</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check mb-2">
                                            <input type="checkbox" class="form-check-input" id="linearHistory" @bind="newProtectionRule.RequireLinearHistory" />
                                            <label class="form-check-label small" for="linearHistory">Require linear history</label>
                                        </div>
                                        <div class="form-check mb-2">
                                            <input type="checkbox" class="form-check-input" id="requireChecks" @bind="newProtectionRule.RequireStatusChecks" />
                                            <label class="form-check-label small" for="requireChecks">Require status checks</label>
                                        </div>
                                        <div class="form-check mb-2">
                                            <input type="checkbox" class="form-check-input" id="requireCodeOwners" @bind="newProtectionRule.RequireCodeOwnersApproval" />
                                            <label class="form-check-label small" for="requireCodeOwners">Require CODEOWNERS approval</label>
                                        </div>
                                        <div class="form-check mb-2">
                                            <input type="checkbox" class="form-check-input" id="bpRequireSignedCommits" @bind="newProtectionRule.RequireSignedCommits" />
                                            <label class="form-check-label small" for="bpRequireSignedCommits">@L["Repo_RequireSignedCommits"]</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">Protected file patterns</label>
                                    <input type="text" class="form-control form-control-sm" @bind="newProtectedFilePatterns" placeholder="*.lock, migrations/**, .github/workflows/*" />
                                    <div class="form-text">Comma-separated glob patterns. Changes to matching files require review approval.</div>
                                </div>
                                @if (newProtectionRule.RequirePullRequest)
                                {
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold">Required approvals</label>
                                        <input type="number" class="form-control form-control-sm" style="width: 100px;" @bind="newProtectionRule.RequiredApprovals" min="0" max="10" />
                                    </div>
                                }
                                <div class="d-flex gap-2">
                                    @if (UserService.IsLoggedIn)
                                    {
                                        <button class="btn btn-gh-primary btn-sm" @onclick="SaveBranchProtectionRule" disabled="@string.IsNullOrWhiteSpace(newProtectionRule.BranchPattern)">Save rule</button>
                                    }
                                    <button class="btn btn-light btn-sm border" @onclick="() => showAddProtectionRule = false">Cancel</button>
                                </div>
                            </div>
                        }
                        else
                        {
                            @if (UserService.IsLoggedIn)
                            {
                                <button class="btn btn-outline-primary btn-sm" @onclick="() => showAddProtectionRule = true">
                                    <i class="bi bi-plus-lg me-1"></i>Add rule
                                </button>
                            }
                        }
                    </div>
                </div>
                }

                @* Tag Protection Rules *@
                @if (settingsSection == "tags")
                {
                <div class="card border shadow-sm mb-4">
                    <div class="card-header bg-light-subtle py-2 small fw-bold">
                        <i class="bi bi-tag me-1"></i> Tag protection rules
                    </div>
                    <div class="card-body">
                        @if (tagProtectionRules.Any())
                        {
                            <div class="list-group list-group-flush mb-3">
                                @foreach (var rule in tagProtectionRules)
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                                        <div>
                                            <span class="fw-bold font-monospace">@rule.TagPattern</span>
                                            <div class="small text-muted mt-1">
                                                @if (rule.PreventDeletion) { <span class="badge bg-warning bg-opacity-10 text-warning border border-warning-subtle me-1">No deletion</span> }
                                                @if (rule.PreventForcePush) { <span class="badge bg-warning bg-opacity-10 text-warning border border-warning-subtle me-1">No force push</span> }
                                                @if (rule.RestrictCreation) { <span class="badge bg-info bg-opacity-10 text-info border border-info-subtle me-1">Restrict creation</span> }
                                                @if (rule.RequireSignedTags) { <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle me-1">Require signed</span> }
                                            </div>
                                        </div>
                                        @if (UserService.IsLoggedIn)
                                        {
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteTagProtectionRule(rule.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small mb-3">No tag protection rules configured yet.</p>
                        }

                        @if (showAddTagProtectionRule)
                        {
                            <div class="border rounded p-3 bg-light-subtle">
                                <h6 class="fw-bold small mb-3">Add tag protection rule</h6>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">Tag name pattern</label>
                                    <input type="text" class="form-control form-control-sm" @bind="newTagProtectionRule.TagPattern" placeholder="v*, release-*, etc." />
                                    <div class="form-text">Use * as wildcard. Example: v* matches v1.0, v2.0, etc.</div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <div class="form-check mb-2">
                                            <input type="checkbox" class="form-check-input" id="tagPreventDelete" @bind="newTagProtectionRule.PreventDeletion" />
                                            <label class="form-check-label small" for="tagPreventDelete">Prevent tag deletion</label>
                                        </div>
                                        <div class="form-check mb-2">
                                            <input type="checkbox" class="form-check-input" id="tagPreventForce" @bind="newTagProtectionRule.PreventForcePush" />
                                            <label class="form-check-label small" for="tagPreventForce">Prevent tag force update</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check mb-2">
                                            <input type="checkbox" class="form-check-input" id="tagRestrictCreate" @bind="newTagProtectionRule.RestrictCreation" />
                                            <label class="form-check-label small" for="tagRestrictCreate">Restrict tag creation</label>
                                        </div>
                                        <div class="form-check mb-2">
                                            <input type="checkbox" class="form-check-input" id="tagRequireSigned" @bind="newTagProtectionRule.RequireSignedTags" />
                                            <label class="form-check-label small" for="tagRequireSigned">Require signed tags</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex gap-2">
                                    @if (UserService.IsLoggedIn)
                                    {
                                        <button class="btn btn-gh-primary btn-sm" @onclick="SaveTagProtectionRule" disabled="@string.IsNullOrWhiteSpace(newTagProtectionRule.TagPattern)">Save rule</button>
                                    }
                                    <button class="btn btn-light btn-sm border" @onclick="() => showAddTagProtectionRule = false">Cancel</button>
                                </div>
                            </div>
                        }
                        else
                        {
                            @if (UserService.IsLoggedIn)
                            {
                                <button class="btn btn-outline-primary btn-sm" @onclick="() => showAddTagProtectionRule = true">
                                    <i class="bi bi-plus-lg me-1"></i>Add rule
                                </button>
                            }
                        }
                    </div>
                </div>
                }

                @* Git Hooks *@
                @if (settingsSection == "hooks")
                {
                <div class="card border shadow-sm mb-4">
                    <div class="card-header bg-light-subtle py-2 small fw-bold">
                        <i class="bi bi-terminal me-1"></i> Git Hooks
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Hook type</label>
                            <select class="form-select form-select-sm" style="width: 220px;" value="@selectedHookName"
                                    @onchange="HandleHookSelectionChanged">
                                <option value="pre-receive">pre-receive</option>
                                <option value="update">update</option>
                                <option value="post-receive">post-receive</option>
                                <option value="post-update">post-update</option>
                                <option value="pre-push">pre-push</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Script content</label>
                            <textarea class="form-control form-control-sm font-monospace" rows="12"
                                      @bind="hookContent" placeholder="#!/bin/bash&#10;# Enter hook script here..."></textarea>
                        </div>
                        @if (!string.IsNullOrEmpty(hookStatusMessage))
                        {
                            <div class="alert alert-info alert-dismissible py-2 small mb-3">
                                @hookStatusMessage
                                <button type="button" class="btn-close btn-close-sm" @onclick="() => hookStatusMessage = string.Empty"></button>
                            </div>
                        }
                        @if (UserService.IsLoggedIn)
                        {
                            <div class="d-flex gap-2">
                                <button class="btn btn-gh-primary btn-sm" @onclick="SaveGitHook" disabled="@string.IsNullOrWhiteSpace(hookContent)">
                                    <i class="bi bi-save me-1"></i>Save hook
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="DeleteGitHook" disabled="@string.IsNullOrWhiteSpace(hookContent)">
                                    <i class="bi bi-trash me-1"></i>Delete hook
                                </button>
                            </div>
                        }
                    </div>
                </div>
                }

                @* Repository Labels *@
                @if (settingsSection == "labels")
                {
                <div class="card border shadow-sm mb-4">
                    <div class="card-header bg-light-subtle py-2 small fw-bold">
                        <i class="bi bi-tags me-1"></i> Labels
                    </div>
                    <div class="card-body">
                        @if (repoLabels.Any())
                        {
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @foreach (var label in repoLabels)
                                {
                                    <div class="d-inline-flex align-items-center gap-1">
                                        <span class="badge rounded-pill" style="background-color: @label.Color; color: @GetContrastColor(label.Color);">@label.Name</span>
                                        @if (UserService.IsLoggedIn)
                                        {
                                            <button class="btn btn-link btn-sm text-danger p-0 ms-1" style="font-size: 0.7rem;" @onclick="() => DeleteRepoLabel(label.Id)">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small mb-3">No labels defined yet.</p>
                        }

                        @if (showAddLabel)
                        {
                            <div class="border rounded p-3 bg-light-subtle">
                                <h6 class="fw-bold small mb-3">Add label</h6>
                                <div class="row mb-2">
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold">Name</label>
                                        <input type="text" class="form-control form-control-sm" @bind="newLabelName" placeholder="bug, feature, etc." />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label small fw-bold">Color</label>
                                        <input type="color" class="form-control form-control-sm form-control-color" @bind="newLabelColor" />
                                    </div>
                                    <div class="col-md-5">
                                        <label class="form-label small fw-bold">Description</label>
                                        <input type="text" class="form-control form-control-sm" @bind="newLabelDescription" placeholder="Optional description" />
                                    </div>
                                </div>
                                <div class="d-flex gap-2 mt-2">
                                    @if (UserService.IsLoggedIn)
                                    {
                                        <button class="btn btn-gh-primary btn-sm" @onclick="SaveRepoLabel" disabled="@string.IsNullOrWhiteSpace(newLabelName)">Save label</button>
                                    }
                                    <button class="btn btn-light btn-sm border" @onclick="() => showAddLabel = false">Cancel</button>
                                </div>
                            </div>
                        }
                        else
                        {
                            @if (UserService.IsLoggedIn)
                            {
                                <button class="btn btn-outline-primary btn-sm" @onclick="() => showAddLabel = true">
                                    <i class="bi bi-plus-lg me-1"></i>Add label
                                </button>
                            }
                        }
                    </div>
                </div>
                }

                @if (UserService.IsLoggedIn && settingsSection == "collaborators")
                {
                    <div class="card border shadow-sm mb-4">
                        <div class="card-header bg-light-subtle py-2 small fw-bold">
                            <i class="bi bi-people me-1"></i> Collaborators
                        </div>
                        <div class="card-body">
                            @if (collaborators.Any())
                            {
                                <div class="list-group list-group-flush mb-3">
                                    @foreach (var collab in collaborators)
                                    {
                                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                                            <div>
                                                <a href="/profile/@collab.Username" class="text-decoration-none fw-bold">@collab.Username</a>
                                                <span class="badge bg-secondary bg-opacity-10 text-secondary ms-2">@collab.Permission</span>
                                            </div>
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveCollaborator(collab.Username)">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted small mb-3">No collaborators yet.</p>
                            }
                            <div class="d-flex gap-2">
                                <input type="text" class="form-control form-control-sm" @bind="newCollaboratorUsername" placeholder="Username" style="max-width: 200px;" />
                                <select class="form-select form-select-sm" @bind="newCollaboratorPermission" style="max-width: 140px;">
                                    <option value="Read">Read</option>
                                    <option value="Triage">Triage</option>
                                    <option value="Write">Write</option>
                                    <option value="Maintain">Maintain</option>
                                    <option value="Admin">Admin</option>
                                </select>
                                <button class="btn btn-gh-primary btn-sm" @onclick="AddCollaborator" disabled="@string.IsNullOrWhiteSpace(newCollaboratorUsername)">
                                    <i class="bi bi-plus-lg me-1"></i>Add
                                </button>
                            </div>
                        </div>
                    </div>
                }

                @if (UserService.IsLoggedIn && settingsSection == "pages")
                {
                    <div class="card border shadow-sm mb-4">
                        <div class="card-header bg-light-subtle py-2 small fw-bold">
                            <i class="bi bi-globe me-1"></i> Pages
                        </div>
                        <div class="card-body">
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" @bind="settingsHasPages" id="hasPages" />
                                <label class="form-check-label small" for="hasPages">
                                    Enable Pages (serve static site from a branch)
                                </label>
                            </div>
                            @if (settingsHasPages)
                            {
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">Source branch</label>
                                    <input type="text" class="form-control form-control-sm" @bind="settingsPagesBranch" placeholder="gh-pages" style="max-width: 200px;" />
                                </div>
                                <div class="alert alert-info py-2 small mb-3">
                                    <i class="bi bi-info-circle me-1"></i>
                                    Your site will be available at <code>/pages/@repoOwner/@RepoName/</code>
                                </div>
                            }
                            <button class="btn btn-gh-primary btn-sm" @onclick="SavePagesSettings">Save</button>
                        </div>
                    </div>
                }

                @if (UserService.IsLoggedIn && settingsSection == "autolinks")
                {
                    <div class="card border shadow-sm mb-4">
                        <div class="card-header bg-light-subtle py-2 small fw-bold">
                            <i class="bi bi-link-45deg me-1"></i> Autolink References
                        </div>
                        <div class="card-body">
                            <p class="text-muted small mb-3">Autolink references automatically turn text like <code>JIRA-123</code> into links. Issue references like <code>#123</code> are always linked automatically.</p>
                            @if (autolinkPatterns.Any())
                            {
                                <div class="list-group list-group-flush mb-3">
                                    @foreach (var pattern in autolinkPatterns)
                                    {
                                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                                            <div>
                                                <span class="fw-bold font-monospace">@pattern.Prefix</span><span class="text-muted">&lt;number&gt;</span>
                                                <span class="text-muted small ms-2">→ @pattern.UrlTemplate</span>
                                            </div>
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteAutolinkPattern(pattern.Id)" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted small mb-3">No custom autolink patterns configured.</p>
                            }
                            <div class="row g-2 align-items-end">
                                <div class="col-auto">
                                    <label class="form-label small fw-bold mb-1">Prefix</label>
                                    <input type="text" class="form-control form-control-sm" @bind="newAutolinkPrefix" placeholder="JIRA-" style="max-width:140px;" />
                                </div>
                                <div class="col">
                                    <label class="form-label small fw-bold mb-1">URL template (use <code>{0}</code> for number)</label>
                                    <input type="text" class="form-control form-control-sm" @bind="newAutolinkUrlTemplate" placeholder="https://jira.example.com/browse/JIRA-{0}" />
                                </div>
                                <div class="col-auto">
                                    <button class="btn btn-gh-primary btn-sm" @onclick="AddAutolinkPattern">Add</button>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(autolinkErrorMessage))
                            {
                                <div class="text-danger small mt-2">@autolinkErrorMessage</div>
                            }
                        </div>
                    </div>
                }

                @if (UserService.IsLoggedIn && settingsSection == "external-tracker")
                {
                    <div class="card border shadow-sm mb-4">
                        <div class="card-header bg-light-subtle py-2 small fw-bold">
                            <i class="bi bi-box-arrow-up-right me-1"></i> External Issue Tracker
                        </div>
                        <div class="card-body">
                            <p class="text-muted small mb-3">Redirect issue links to an external issue tracker instead of the built-in issue system.</p>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" @bind="settingsUseExternalTracker" id="useExternalTracker" />
                                <label class="form-check-label small" for="useExternalTracker">
                                    Enable external issue tracker
                                </label>
                            </div>
                            @if (settingsUseExternalTracker)
                            {
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">Tracker URL</label>
                                    <input type="text" class="form-control form-control-sm" @bind="settingsExternalTrackerUrl" placeholder="https://jira.example.com/browse/" />
                                    <div class="form-text small">Base URL for your external issue tracker.</div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">Issue pattern</label>
                                    <input type="text" class="form-control form-control-sm" @bind="settingsExternalTrackerPattern" placeholder="PROJ-{id}" />
                                    <div class="form-text small">Pattern for issue references. Use <code>{id}</code> as the placeholder for the issue number.</div>
                                </div>
                            }
                            <button class="btn btn-gh-primary btn-sm" @onclick="SaveExternalTrackerSettings">Save</button>
                            @if (!string.IsNullOrEmpty(externalTrackerSaveMessage))
                            {
                                <span class="text-success small ms-2">@externalTrackerSaveMessage</span>
                            }
                        </div>
                    </div>
                }

                @if (UserService.IsLoggedIn && settingsSection == "secrets")
                {
                    <div class="card border shadow-sm mb-4">
                        <div class="card-header bg-light-subtle py-2 small fw-bold">
                            <i class="bi bi-key-fill me-1"></i> Secrets
                        </div>
                        <div class="card-body">
                            <p class="text-muted small mb-3">Encrypted environment variables injected into CI/CD workflow runs.</p>
                            @if (repoSecrets.Any())
                            {
                                <div class="list-group list-group-flush mb-3">
                                    @foreach (var secret in repoSecrets)
                                    {
                                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                                            <div>
                                                <span class="fw-bold font-monospace">@secret.Name</span>
                                                <span class="text-muted small ms-2">Updated @secret.UpdatedAt.ToString("yyyy-MM-dd")</span>
                                            </div>
                                            <div class="d-flex gap-1">
                                                <button class="btn btn-outline-secondary btn-sm" @onclick="() => StartEditSecret(secret.Name)" title="Update value">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteSecret(secret.Name)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted small mb-3">No secrets configured yet.</p>
                            }

                            @if (showAddSecret)
                            {
                                <div class="border rounded p-3 bg-light-subtle">
                                    <h6 class="fw-bold small mb-3">@(editingSecretName != null ? "Update secret" : "Add secret")</h6>
                                    <div class="mb-2">
                                        <label class="form-label small fw-bold">Name</label>
                                        <input type="text" class="form-control form-control-sm font-monospace" @bind="newSecretName"
                                               placeholder="MY_SECRET" disabled="@(editingSecretName != null)" style="max-width: 300px;" />
                                        <div class="form-text">Uppercase letters, numbers, and underscores only.</div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold">Value</label>
                                        <input type="password" class="form-control form-control-sm" @bind="newSecretValue"
                                               placeholder="Enter secret value" style="max-width: 400px;" />
                                    </div>
                                    @if (!string.IsNullOrEmpty(secretErrorMessage))
                                    {
                                        <div class="alert alert-danger py-1 small mb-2">@secretErrorMessage</div>
                                    }
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-gh-primary btn-sm" @onclick="SaveSecret"
                                                disabled="@(string.IsNullOrWhiteSpace(newSecretName) || string.IsNullOrWhiteSpace(newSecretValue))">
                                            Save secret
                                        </button>
                                        <button class="btn btn-light btn-sm border" @onclick="CancelAddSecret">Cancel</button>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-outline-primary btn-sm" @onclick="() => { showAddSecret = true; editingSecretName = null; newSecretName = string.Empty; newSecretValue = string.Empty; }">
                                    <i class="bi bi-plus-lg me-1"></i>Add secret
                                </button>
                            }
                        </div>
                    </div>
                }

                @if (UserService.IsLoggedIn && settingsSection == "deploy-keys")
                {
                    <div class="card border shadow-sm mb-4">
                        <div class="card-header bg-light-subtle py-2 small fw-bold">
                            <i class="bi bi-key me-1"></i> Deploy Keys
                        </div>
                        <div class="card-body">
                            <p class="text-muted small mb-3">Deploy keys grant read-only or read-write access to this repository for automated systems.</p>
                            @if (deployKeys.Any())
                            {
                                <div class="list-group list-group-flush mb-3">
                                    @foreach (var dk in deployKeys)
                                    {
                                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                                            <div>
                                                <span class="fw-bold">@dk.Title</span>
                                                <span class="badge @(dk.ReadOnly ? "bg-info bg-opacity-10 text-info border border-info-subtle" : "bg-warning bg-opacity-10 text-warning border border-warning-subtle") ms-2">@(dk.ReadOnly ? "Read-only" : "Read-write")</span>
                                                <div class="small text-muted mt-1">
                                                    <code class="me-2">@dk.KeyFingerprint</code>
                                                    Added @dk.CreatedAt.ToString("yyyy-MM-dd")
                                                    @if (dk.LastUsedAt.HasValue)
                                                    {
                                                        <span class="ms-2">· Last used @dk.LastUsedAt.Value.ToString("yyyy-MM-dd")</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="ms-2">· Never used</span>
                                                    }
                                                </div>
                                            </div>
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteDeployKey(dk.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted small mb-3">No deploy keys configured yet.</p>
                            }

                            @if (showAddDeployKey)
                            {
                                <div class="border rounded p-3 bg-light-subtle">
                                    <h6 class="fw-bold small mb-3">Add deploy key</h6>
                                    <div class="mb-2">
                                        <label class="form-label small fw-bold">Title</label>
                                        <input type="text" class="form-control form-control-sm" @bind="newDeployKeyTitle"
                                               placeholder="e.g. CI Server" style="max-width: 300px;" />
                                    </div>
                                    <div class="mb-2">
                                        <label class="form-label small fw-bold">Public Key</label>
                                        <textarea class="form-control form-control-sm font-monospace" @bind="newDeployKeyPublicKey"
                                                  rows="4" placeholder="ssh-rsa AAAA... or ssh-ed25519 AAAA..."></textarea>
                                    </div>
                                    <div class="form-check mb-3">
                                        <input type="checkbox" class="form-check-input" id="deployKeyReadOnly" @bind="newDeployKeyReadOnly" />
                                        <label class="form-check-label small" for="deployKeyReadOnly">
                                            Allow read access only (uncheck for read-write)
                                        </label>
                                    </div>
                                    @if (!string.IsNullOrEmpty(deployKeyErrorMessage))
                                    {
                                        <div class="alert alert-danger py-1 small mb-2">@deployKeyErrorMessage</div>
                                    }
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-gh-primary btn-sm" @onclick="SaveDeployKey"
                                                disabled="@(string.IsNullOrWhiteSpace(newDeployKeyTitle) || string.IsNullOrWhiteSpace(newDeployKeyPublicKey))">
                                            Add key
                                        </button>
                                        <button class="btn btn-light btn-sm border" @onclick="() => { showAddDeployKey = false; deployKeyErrorMessage = string.Empty; }">Cancel</button>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-outline-primary btn-sm" @onclick="() => { showAddDeployKey = true; newDeployKeyTitle = string.Empty; newDeployKeyPublicKey = string.Empty; newDeployKeyReadOnly = true; deployKeyErrorMessage = string.Empty; }">
                                    <i class="bi bi-plus-lg me-1"></i>Add deploy key
                                </button>
                            }
                        </div>
                    </div>
                }

                @if (UserService.IsLoggedIn && settingsSection == "mirrors")
                {
                    <div class="card shadow-sm mb-4">
                        <div class="card-header py-2 small fw-bold">
                            <i class="bi bi-arrow-repeat me-1"></i> Mirrors
                        </div>
                        <div class="card-body">
                            @if (mirrors.Count > 0)
                            {
                                <div class="list-group list-group-flush mb-3">
                                    @foreach (var mirror in mirrors)
                                    {
                                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                                            <div>
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="badge @(mirror.Direction == MyPersonalGit.Models.MirrorDirection.Pull ? "bg-info" : "bg-warning")">
                                                        @(mirror.Direction == MyPersonalGit.Models.MirrorDirection.Pull ? "Pull" : "Push")
                                                    </span>
                                                    <span class="small fw-semibold">@mirror.RemoteUrl</span>
                                                    @if (!mirror.IsEnabled)
                                                    {
                                                        <span class="badge bg-secondary">Disabled</span>
                                                    }
                                                </div>
                                                <small class="text-muted">
                                                    Every @mirror.IntervalMinutes min ·
                                                    @if (mirror.LastSyncAt.HasValue)
                                                    {
                                                        <span>Last sync: @mirror.LastSyncAt.Value.ToString("g")
                                                            @if (mirror.LastSyncStatus == "success")
                                                            {
                                                                <i class="bi bi-check-circle text-success"></i>
                                                            }
                                                            else if (mirror.LastSyncStatus == "error")
                                                            {
                                                                <i class="bi bi-x-circle text-danger" title="@mirror.LastSyncError"></i>
                                                            }
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span>Never synced</span>
                                                    }
                                                </small>
                                            </div>
                                            <div class="d-flex gap-1">
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleMirror(mirror.Id)" title="@(mirror.IsEnabled ? "Disable" : "Enable")">
                                                    <i class="bi @(mirror.IsEnabled ? "bi-pause" : "bi-play")"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteMirror(mirror.Id)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted small mb-3">No mirrors configured.</p>
                            }
                            <div class="d-flex gap-2 flex-wrap align-items-end">
                                <div>
                                    <label class="form-label small mb-0">Remote URL</label>
                                    <input type="text" class="form-control form-control-sm" @bind="newMirrorUrl" placeholder="https://github.com/user/repo.git" style="min-width: 280px;" />
                                </div>
                                <div>
                                    <label class="form-label small mb-0">Direction</label>
                                    <select class="form-select form-select-sm" @bind="newMirrorDirection">
                                        <option value="Pull">Pull</option>
                                        <option value="Push">Push</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="form-label small mb-0">Interval (min)</label>
                                    <input type="number" class="form-control form-control-sm" @bind="newMirrorInterval" min="5" style="width: 80px;" />
                                </div>
                                <div>
                                    <label class="form-label small mb-0">Auth Token <span class="text-muted">(optional)</span></label>
                                    <input type="password" class="form-control form-control-sm" @bind="newMirrorToken" placeholder="token" style="width: 150px;" />
                                </div>
                                <button class="btn btn-gh-primary btn-sm" @onclick="AddMirror" disabled="@string.IsNullOrWhiteSpace(newMirrorUrl)">
                                    <i class="bi bi-plus-lg me-1"></i>Add Mirror
                                </button>
                            </div>
                        </div>
                    </div>
                }

                @if (UserService.IsLoggedIn && settingsSection == "archive")
                {
                    <div class="card border shadow-sm mb-4">
                        <div class="card-header bg-light-subtle py-2 small fw-bold">
                            <i class="bi bi-archive me-1"></i> Archive
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="fw-bold mb-0">@(repoIsArchived ? "Unarchive this repository" : "Archive this repository")</h6>
                                    <p class="text-muted small mb-0">@(repoIsArchived ? "Unarchiving will re-enable pushes, issues, and PRs." : "Archiving makes the repo read-only. No new pushes, issues, or PRs.")</p>
                                </div>
                                <button class="btn @(repoIsArchived ? "btn-outline-success" : "btn-outline-warning") btn-sm px-3" @onclick="ToggleArchive">
                                    @(repoIsArchived ? "Unarchive" : "Archive")
                                </button>
                            </div>
                        </div>
                    </div>
                }

                @if (UserService.IsLoggedIn && settingsSection == "dependabot")
                {
                    <div class="card border shadow-sm mb-4">
                        <div class="card-header bg-light-subtle py-2 small fw-bold">
                            <i class="bi bi-arrow-up-circle me-1"></i> @L["Depbot_Title"]
                        </div>
                        <div class="card-body">
                            <p class="text-muted small">@L["Depbot_Description"]</p>

                            @if (depbotConfigs.Any())
                            {
                                <table class="table table-sm mb-3">
                                    <thead><tr><th>@L["Depbot_Ecosystem"]</th><th>@L["Depbot_Schedule"]</th><th>@L["Depbot_Enabled"]</th><th>@L["Depbot_LastRun"]</th><th></th></tr></thead>
                                    <tbody>
                                        @foreach (var cfg in depbotConfigs)
                                        {
                                            <tr>
                                                <td><strong>@cfg.Ecosystem</strong></td>
                                                <td>@cfg.Schedule</td>
                                                <td><span class="badge @(cfg.IsEnabled ? "bg-success" : "bg-secondary")">@(cfg.IsEnabled ? L["Depbot_Active"] : L["Depbot_Disabled"])</span></td>
                                                <td class="small text-muted">@(cfg.LastRunAt?.ToString("g") ?? L["Depbot_Never"])</td>
                                                <td>
                                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DisableDependabot(cfg.Id)">
                                                        <i class="bi bi-x"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }

                            <div class="d-flex gap-2 align-items-end">
                                <div>
                                    <label class="form-label small mb-1">@L["Depbot_Ecosystem"]</label>
                                    <select class="form-select form-select-sm" @bind="newDepbotEcosystem">
                                        <option value="NuGet">NuGet (.NET)</option>
                                        <option value="npm">npm (Node.js)</option>
                                        <option value="pip">pip (Python)</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="form-label small mb-1">@L["Depbot_Schedule"]</label>
                                    <select class="form-select form-select-sm" @bind="newDepbotSchedule">
                                        <option value="daily">@L["Depbot_Daily"]</option>
                                        <option value="weekly">@L["Depbot_Weekly"]</option>
                                        <option value="monthly">@L["Depbot_Monthly"]</option>
                                    </select>
                                </div>
                                <button class="btn btn-primary btn-sm" @onclick="EnableDependabot">
                                    <i class="bi bi-plus me-1"></i> @L["Depbot_Enable"]
                                </button>
                            </div>
                        </div>
                    </div>
                }

                @if (UserService.IsLoggedIn && settingsSection == "danger")
                {
                    <div class="card border-danger shadow-sm">
                        <div class="card-header bg-danger bg-opacity-10 text-danger py-2 small fw-bold border-danger border-opacity-25">Danger Zone</div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="fw-bold mb-0">Delete this repository</h6>
                                    <p class="text-muted small mb-0">Once you delete a repository, there is no going back.</p>
                                </div>
                                <button class="btn btn-outline-danger btn-sm px-3" @onclick="() => showDeleteRepoModal = true">Delete this repository</button>
                            </div>
                        </div>
                    </div>
                }
                    </div> <!-- end col-md-9 -->
                </div> <!-- end row -->
            </div> <!-- end settings-view -->
        }
        else if (activeTab == "blame")
        {
            <div class="mb-3">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0 small">
                        <li class="breadcrumb-item"><a href="/repo/@RepoName" class="text-decoration-none">@RepoName</a></li>
                        <li class="breadcrumb-item active">@Path</li>
                    </ol>
                </nav>
            </div>
            <div class="card shadow-sm overflow-hidden">
                <div class="card-header bg-light-subtle py-2 px-3">
                    <span class="small fw-bold"><i class="bi bi-person-lines-fill me-1"></i> Blame</span>
                    <button class="btn btn-link btn-sm text-decoration-none float-end" @onclick="ExitBlameView">
                        <i class="bi bi-arrow-left me-1"></i>Back to code
                    </button>
                </div>
                <div class="card-body p-0">
                    @if (blameLines.Any())
                    {
                        <table class="table table-sm table-borderless mb-0 font-monospace" style="font-size: 12px;">
                            @foreach (var line in blameLines)
                            {
                                <tr class="@(line.HunkIndex % 2 == 0 ? "" : "bg-light")">
                                    @if (line.IsFirstInHunk)
                                    {
                                        <td class="text-muted border-end px-2 py-0 text-nowrap align-top" style="width: 200px; max-width: 200px; overflow: hidden; text-overflow: ellipsis;" rowspan="@line.HunkLineCount">
                                            <div class="d-flex flex-column">
                                                <a href="/repo/@RepoName/commit/@line.CommitSha" class="text-decoration-none text-primary" style="font-size: 11px;">@line.ShortSha</a>
                                                <span class="text-truncate" style="font-size: 11px;">@line.Author</span>
                                                <span style="font-size: 10px;" class="text-muted">@line.Date.ToString("yyyy-MM-dd")</span>
                                            </div>
                                        </td>
                                    }
                                    <td class="text-muted text-end border-end px-2 py-0 select-none" style="width: 40px;">@line.LineNumber</td>
                                    <td class="px-2 py-0"><pre class="m-0 d-inline" style="white-space: pre-wrap;">@line.Content</pre></td>
                                </tr>
                            }
                        </table>
                    }
                    else
                    {
                        <p class="text-muted p-3">Unable to load blame information.</p>
                    }
                </div>
            </div>
        }
        else if (activeTab == "edit" || activeTab == "add-file")
        {
            @if (UserService.IsLoggedIn)
            {
                <div class="editor-view mb-5">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold mb-0">
                            @(activeTab == "edit" ? "Editing " : "Adding file to ")
                            <span class="text-muted">@(activeTab == "edit" ? Path : (string.IsNullOrEmpty(Path) ? "/" : Path))</span>
                        </h5>
                        <button class="btn btn-link text-danger text-decoration-none btn-sm" @onclick='() => SetTab("code")'>Cancel</button>
                    </div>

                    @if (activeTab == "add-file")
                    {
                        <div class="mb-3">
                            <input type="text" class="form-control form-control-sm font-monospace" @bind="newFileName" @bind:event="oninput" placeholder="Name your file (e.g. README.md)..." />
                        </div>
                    }

                    <div class="card border shadow-sm mb-4">
                        @{
                            var editingFilePath = activeTab == "edit" ? Path : newFileName;
                            var isEditingMarkdown = editingFilePath?.EndsWith(".md", StringComparison.OrdinalIgnoreCase) == true;
                        }
                        <div class="card-header bg-light-subtle py-1 d-flex align-items-center gap-2">
                            <button class="btn btn-sm @(editorMode == "edit" ? "btn-secondary" : "btn-light border") px-3" @onclick='() => editorMode = "edit"'>
                                <i class="bi bi-code-slash me-1"></i>Edit file
                            </button>
                            @if (isEditingMarkdown)
                            {
                                <button class="btn btn-sm @(editorMode == "preview" ? "btn-secondary" : "btn-light border") px-3" @onclick='() => editorMode = "preview"'>
                                    <i class="bi bi-eye me-1"></i>Preview
                                </button>
                            }
                            <span class="ms-auto small text-muted">
                                @if (!string.IsNullOrEmpty(editingContent))
                                {
                                    @($"{editingContent.Split('\n').Length} lines · {Encoding.UTF8.GetByteCount(editingContent)} bytes")
                                }
                            </span>
                        </div>
                        <div class="card-body p-0">
                            @if (editorMode == "preview" && isEditingMarkdown)
                            {
                                <div class="p-4 markdown-body" style="min-height: 400px;">
                                    @ConvertMarkdownToHtml(editingContent)
                                </div>
                            }
                            else
                            {
                                <div class="editor-wrapper border rounded overflow-hidden">
                                    <div style="max-height: 600px; overflow: auto; display: flex; align-items: stretch;">
                                        <div id="editorGutter" class="editor-gutter text-end pe-2 user-select-none flex-shrink-0"
                                             style="width: 50px; font-size: 12px; line-height: 20px; padding-top: 6px; padding-bottom: 6px; font-family: ui-monospace,SFMono-Regular,SF Mono,Menlo,Consolas,Liberation Mono,monospace;">
                                            @{
                                                var editorLineCount = string.IsNullOrEmpty(editingContent) ? 1 : editingContent.Split(new[] { "\r\n", "\n", "\r" }, StringSplitOptions.None).Length;
                                            }
                                            @for (int ln = 1; ln <= editorLineCount; ln++)
                                            {
                                                <div>@ln</div>
                                            }
                                        </div>
                                        <textarea id="codeEditor" class="editor-textarea border-0 font-monospace flex-grow-1"
                                                  wrap="off"
                                                  style="resize: none; overflow: hidden; font-size: 13px; line-height: 20px; padding: 6px 12px; outline: none; min-width: 0;"
                                                  @bind="editingContent" @bind:event="oninput"></textarea>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="card border shadow-sm">
                        <div class="card-header bg-light-subtle py-2">
                            <span class="fw-bold small">Commit changes</span>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-8">
                                    <div class="mb-3">
                                        <input type="text" class="form-control form-control-sm fw-semibold" @bind="commitMessage" @bind:event="oninput" placeholder="Commit message" />
                                    </div>
                                    <div class="mb-3">
                                        <textarea class="form-control form-control-sm" rows="3" @bind="commitDescription" @bind:event="oninput" placeholder="Add description..."></textarea>
                                    </div>
                                    <button class="btn btn-gh-primary btn-sm px-4" @onclick="CommitChanges" disabled="@(activeTab == "add-file" && string.IsNullOrWhiteSpace(newFileName))">Commit changes</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning">You must be logged in to edit files.</div>
            }
        }
        else if (activeTab == "commits")
        {
            <div class="timeline border-start ms-3 ps-4 mt-3">
                @if (!string.IsNullOrEmpty(Path))
                {
                    <div class="mb-3">
                        <span class="badge bg-light text-body border fw-normal">History for: <code>@Path</code></span>
                        <button class="btn btn-link btn-sm text-decoration-none" @onclick="ClearFileFilter">Clear filter</button>
                    </div>
                }
                @foreach (var commit in commitHistory)
                {
                    <div class="commit-item mb-4 position-relative">
                        <div class="commit-dot position-absolute border border-2 border-secondary" style="width: 12px; height: 12px; left: -31px; top: 6px; border-radius: 50%; background-color: var(--bs-body-bg);"></div>
                        <div class="card border shadow-sm">
                            <div class="card-body py-2 px-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h6 class="mb-1 fw-bold">@((MarkupString)IssueAutoCloseService.RenderIssueLinks(commit.Message, dirName))</h6>
                                    <div class="d-flex align-items-center gap-2">
                                        @if (HasClosingKeywords(commit.Message))
                                        {
                                            <span class="badge text-white" title="This commit closes an issue" style="background-color: #8957e5;">
                                                <i class="bi bi-check2-circle"></i>
                                            </span>
                                        }
                                        @if (commit.IsSigned)
                                        {
                                            @if (commit.IsVerified)
                                            {
                                                <span class="badge bg-success" title="Verified: signed with a trusted GPG key (@commit.SignerKeyId)">
                                                    <i class="bi bi-shield-fill-check"></i> Verified
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark" title="Signed with GPG key @commit.SignerKeyId">
                                                    <i class="bi bi-shield-fill-exclamation"></i> Signed
                                                </span>
                                            }
                                        }
                                        <a href="/repo/@RepoName/commit/@commit.Sha" class="badge bg-light text-primary border border-primary-subtle font-monospace text-decoration-none">@commit.ShortSha</a>
                                    </div>
                                </div>
                                <div class="text-muted small">
                                    <strong>@commit.AuthorName</strong> committed @GetRelativeTime(commit.Date)
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (activeTab == "graph")
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light-subtle py-2">
                    <h6 class="fw-bold mb-0 small"><i class="bi bi-diagram-3 me-1"></i> @L["Repo_CommitGraph"]</h6>
                </div>
                <div class="card-body p-0" style="overflow-x: auto;">
                    @if (graphEntries.Any())
                    {
                        <div class="d-flex">
                            <svg width="@(graphMaxLane * 30 + 40)" height="@(graphEntries.Count * 32 + 20)" style="flex-shrink: 0;">
                                @foreach (var entry in graphEntries)
                                {
                                    var cx = entry.Lane * 30 + 20;
                                    var cy = entry.Row * 32 + 26;
                                    @foreach (var link in entry.ParentLinks)
                                    {
                                        var px = link.ParentLane * 30 + 20;
                                        var py = link.ParentRow * 32 + 26;
                                        var linkColor = link.Color;
                                        @if (cx == px)
                                        {
                                            <!-- Straight vertical line -->
                                            <line x1="@cx" y1="@cy" x2="@px" y2="@py" stroke="@linkColor" stroke-width="2" opacity="0.7" />
                                        }
                                        else
                                        {
                                            <!-- Curved path: bezier from child down to parent lane, then vertical to parent -->
                                            var midY = cy + 16;
                                            var pathD = $"M {cx} {cy} C {cx} {midY} {px} {midY} {px} {midY}";
                                            <path d="@pathD" stroke="@linkColor" stroke-width="2" fill="none" opacity="0.7" />
                                            @if (midY < py)
                                            {
                                                <line x1="@px" y1="@midY" x2="@px" y2="@py" stroke="@linkColor" stroke-width="2" opacity="0.7" />
                                            }
                                        }
                                    }
                                }
                                @foreach (var entry in graphEntries)
                                {
                                    var cx = entry.Lane * 30 + 20;
                                    var cy = entry.Row * 32 + 26;
                                    <circle cx="@cx" cy="@cy" r="5" fill="@entry.Color" stroke="var(--bs-body-bg, white)" stroke-width="2" />
                                }
                            </svg>
                            <div class="flex-grow-1" style="font-size: 12px; font-family: monospace;">
                                @foreach (var entry in graphEntries)
                                {
                                    <div style="height: 32px; line-height: 32px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding: 0 8px;">
                                        <a href="/repo/@RepoName/commit/@entry.Sha" class="text-decoration-none" style="color: #0969da;">@entry.ShortSha</a>
                                        <span class="ms-2">@TruncateMessage(entry.Message, 60)</span>
                                        <span class="ms-2 text-muted">@entry.Author · @GetRelativeTime(entry.Date)</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted p-3">@L["Repo_NoCommits"]</p>
                    }
                </div>
            </div>
        }
        else if (activeTab == "commit-detail" && selectedCommit != null)
        {
            <div class="commit-detail mb-5">
                @{
                    var commitTitle = selectedCommit.Message;
                    var commitBody = "";
                    var fullMsg = selectedCommit.FullMessage ?? selectedCommit.Message;
                    var firstNewline = fullMsg.IndexOf('\n');
                    if (firstNewline > 0)
                    {
                        commitTitle = fullMsg.Substring(0, firstNewline).Trim();
                        commitBody = fullMsg.Substring(firstNewline + 1).Trim();
                    }
                }
                <div class="card border shadow-sm mb-4">
                    <div class="card-body bg-light-subtle">
                        <h4 class="fw-bold mb-1">@((MarkupString)IssueAutoCloseService.RenderIssueLinks(commitTitle, dirName))</h4>
                        @if (!string.IsNullOrEmpty(commitBody))
                        {
                            <div class="mt-2 small" style="white-space: pre-wrap;">@((MarkupString)IssueAutoCloseService.RenderIssueLinks(commitBody, dirName))</div>
                        }
                        <div class="text-muted small mt-2">
                            <strong>@selectedCommit.AuthorName</strong> authored @selectedCommit.Date.ToString("f")
                            @if (selectedCommit.IsSigned)
                            {
                                @if (selectedCommit.IsVerified)
                                {
                                    <span class="badge bg-success ms-2" title="Verified: signed with a trusted GPG key (@selectedCommit.SignerKeyId)">
                                        <i class="bi bi-shield-fill-check"></i> Verified
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark ms-2" title="Signed with GPG key @selectedCommit.SignerKeyId">
                                        <i class="bi bi-shield-fill-exclamation"></i> Signed
                                    </span>
                                }
                            }
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex gap-3 small text-muted">
                                <span>commit <code>@selectedCommit.Sha</code></span>
                            </div>
                            <div class="d-flex gap-2 align-items-center">
                                @if (UserService.IsLoggedIn)
                                {
                                    <div class="dropdown">
                                        <button class="btn btn-outline-primary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                            <i class="bi bi-signpost-split me-1"></i> @L["CherryPick_Title"]
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            @foreach (var b in branches.Where(b => b.Name != currentBranch))
                                            {
                                                var branchName = b.Name;
                                                <li><button class="dropdown-item small" @onclick="() => CherryPickCommit(selectedCommit.Sha, branchName)">@branchName</button></li>
                                            }
                                        </ul>
                                    </div>
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => RevertCommit(selectedCommit.Sha)" disabled="@isReverting">
                                        @if (isReverting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        <i class="bi bi-arrow-counterclockwise me-1"></i> @L["Revert_Title"]
                                    </button>
                                }
                                <div class="btn-group btn-group-sm border rounded shadow-sm">
                                    <button type="button" class="btn btn-light @(diffViewMode == "unified" ? "active border-primary" : "")" @onclick='() => diffViewMode = "unified"'>Unified</button>
                                    <button type="button" class="btn btn-light @(diffViewMode == "split" ? "active border-primary" : "")" @onclick='() => diffViewMode = "split"'>Split</button>
                                </div>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(cherryPickRevertMessage))
                        {
                            <div class="alert @(cherryPickRevertSuccess ? "alert-success" : "alert-danger") mt-2 mb-0 small py-2">@cherryPickRevertMessage</div>
                        }
                    </div>
                </div>

                <div class="d-flex gap-3">
                    <!-- File browser sidebar -->
                    <div class="commit-file-sidebar" style="width: 260px; min-width: 260px; max-height: calc(100vh - 200px); overflow-y: auto; position: sticky; top: 80px;">
                        <div class="card border shadow-sm">
                            <div class="card-header bg-light-subtle py-2 d-flex justify-content-between align-items-center">
                                <span class="fw-bold small">Changed files</span>
                                <span class="badge bg-secondary">@commitPatches.Count</span>
                            </div>
                            <div class="list-group list-group-flush" style="font-size: 12px;">
                                @foreach (var patch in commitPatches)
                                {
                                    var fileName = System.IO.Path.GetFileName(patch.Path);
                                    var dirPath = System.IO.Path.GetDirectoryName(patch.Path)?.Replace("\\", "/");
                                    <a href="javascript:void(0)" @onclick='() => ScrollToDiff(patch.Path)' @onclick:preventDefault class="list-group-item list-group-item-action py-1 px-2">
                                        <div class="d-flex align-items-center gap-1">
                                            <span class="text-success fw-bold" style="min-width: 28px; font-size: 11px;">+@patch.LinesAdded</span>
                                            <span class="text-danger fw-bold" style="min-width: 28px; font-size: 11px;">-@patch.LinesDeleted</span>
                                            <div class="text-truncate">
                                                @if (!string.IsNullOrEmpty(dirPath))
                                                {
                                                    <span class="text-muted">@dirPath/</span>
                                                }
                                                <span class="fw-semibold">@fileName</span>
                                            </div>
                                        </div>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Diff content -->
                    <div class="flex-grow-1" style="min-width: 0;">
                        <h6 class="fw-bold text-muted small text-uppercase mb-3">Showing @commitPatches.Count changed files</h6>
                @foreach (var patch in commitPatches)
                {
                    <div id="diff-@patch.Path.Replace("/", "-").Replace(".", "-").Replace(" ", "-")" class="card border shadow-sm mb-3">
                        <div class="card-header py-2 bg-light-subtle d-flex justify-content-between">
                            <span class="fw-bold small font-monospace">@patch.Path</span>
                            <span class="badge border fw-normal">@patch.LinesAdded additions / @patch.LinesDeleted deletions</span>
                        </div>
                        <div class="card-body p-0">
                            @if (diffViewMode == "unified")
                            {
                                <div class="diff-container font-monospace" data-diff-lang="@GetDiffLanguage(patch.Path)" style="font-size: 12px; line-height: 1.4; overflow-x: auto;">
                                    @foreach (var row in GetUnifiedDiffRows(patch.DiffLines))
                                    {
                                        <div class="diff-line d-flex @row.CssClass">
                                            <div class="diff-linenum text-end border-end user-select-none" style="width: 45px; min-width: 45px; padding: 0 6px; color: #8b949e;">@row.OldNum</div>
                                            <div class="diff-linenum text-end border-end user-select-none" style="width: 45px; min-width: 45px; padding: 0 6px; color: #8b949e;">@row.NewNum</div>
                                            <div class="diff-sign px-1 text-center user-select-none" style="width: 20px; min-width: 20px;">@row.Sign</div>
                                            <div class="diff-text px-2 text-wrap flex-grow-1" style="white-space: pre-wrap;">@row.Content</div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="diff-container font-monospace border-top" data-diff-lang="@GetDiffLanguage(patch.Path)" style="font-size: 12px; line-height: 1.4; overflow-x: auto;">
                                    @foreach (var pair in GetSplitDiffWithLineNumbers(patch.DiffLines))
                                    {
                                        <div class="d-flex border-bottom">
                                            <div class="col-6 diff-line border-end @(pair.Left?.StartsWith("-") == true ? "diff-removed" : pair.Left == null && pair.Right?.StartsWith("+") == true ? "diff-empty" : "diff-context")">
                                                <div class="d-flex h-100">
                                                    <div class="diff-linenum text-end border-end user-select-none" style="width: 40px; min-width: 40px; padding: 0 4px; color: #8b949e;">@(pair.LeftLineNum > 0 ? pair.LeftLineNum.ToString() : "")</div>
                                                    <div class="diff-sign px-1 text-center user-select-none" style="width: 20px; min-width: 20px;">@(pair.Left?.Length > 0 ? pair.Left[0] : ' ')</div>
                                                    <div class="diff-text px-2 text-wrap flex-grow-1" style="white-space: pre-wrap;">@(pair.Left?.Length > 0 ? pair.Left.Substring(1) : "")</div>
                                                </div>
                                            </div>
                                            <div class="col-6 diff-line @(pair.Right?.StartsWith("+") == true ? "diff-added" : pair.Right == null && pair.Left?.StartsWith("-") == true ? "diff-empty" : "diff-context")">
                                                <div class="d-flex h-100">
                                                    <div class="diff-linenum text-end border-end user-select-none" style="width: 40px; min-width: 40px; padding: 0 4px; color: #8b949e;">@(pair.RightLineNum > 0 ? pair.RightLineNum.ToString() : "")</div>
                                                    <div class="diff-sign px-1 text-center user-select-none" style="width: 20px; min-width: 20px;">@(pair.Right?.Length > 0 ? pair.Right[0] : ' ')</div>
                                                    <div class="diff-text px-2 text-wrap flex-grow-1" style="white-space: pre-wrap;">@(pair.Right?.Length > 0 ? pair.Right.Substring(1) : "")</div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
                    </div> <!-- end diff content -->
                </div> <!-- end flex container -->

                <!-- Commit Comments Section -->
                <div class="mt-4">
                    <h6 class="fw-bold text-muted small text-uppercase mb-3">
                        <i class="bi bi-chat-left-text me-1"></i> Discussion
                        @if (commitComments.Any())
                        {
                            <span class="badge bg-secondary ms-1">@commitComments.Count</span>
                        }
                    </h6>

                    @foreach (var comment in commitComments)
                    {
                        <div class="card mb-3">
                            <div class="card-header bg-light-subtle d-flex justify-content-between align-items-center py-2">
                                <div>
                                    <strong class="small">@comment.Author</strong>
                                    <span class="text-muted small ms-2">@GetRelativeTime(comment.CreatedAt)</span>
                                    @if (!string.IsNullOrEmpty(comment.FilePath))
                                    {
                                        <span class="text-muted small ms-2">on <code>@comment.FilePath</code>@(comment.LineNumber.HasValue ? $" line {comment.LineNumber}" : "")</span>
                                    }
                                </div>
                                @if (UserService.IsLoggedIn && comment.Author == UserService.Username)
                                {
                                    <button class="btn btn-outline-danger btn-sm" style="padding: 0 6px; font-size: 11px;" @onclick="() => DeleteCommitComment(comment.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </div>
                            <div class="card-body py-2">
                                <div class="markdown-body small">@ConvertMarkdownToHtml(comment.Body)</div>
                            </div>
                        </div>
                    }

                    @if (UserService.IsLoggedIn)
                    {
                        <div class="card">
                            <div class="card-header bg-light-subtle py-2">
                                <strong class="small">Add a comment</strong>
                            </div>
                            <div class="card-body py-2">
                                <textarea class="form-control form-control-sm mb-2" rows="3" @bind="newCommitCommentBody" placeholder="Leave a comment on this commit..."></textarea>
                                <button class="btn btn-gh-primary btn-sm" @onclick="AddCommitComment" disabled="@string.IsNullOrWhiteSpace(newCommitCommentBody)">
                                    <i class="bi bi-chat-left-text me-1"></i> Comment
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}


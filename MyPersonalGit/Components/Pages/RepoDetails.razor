    private void LoadRepoData()
    {
        var fullPath = RepoFullPath;
        if (!Repository.IsValid(fullPath)) { notFound = true; return; }

        try
        {
            using var repo = new Repository(fullPath);
            isEmpty = !repo.Refs.Any() && !repo.Commits.Any();
            notFound = false;

            branches = repo.Branches.Select(b => new BranchSummary { Name = b.FriendlyName, IsCurrent = b.IsCurrentRepositoryHead }).ToList();
            tags = repo.Tags.Select(t => new TagSummary { Name = t.FriendlyName, TargetSha = t.Target.Sha }).ToList();

            // Check tag signatures asynchronously
            var tagRepoPath = fullPath;
            _ = Task.Run(async () =>
            {
                try
                {
                    foreach (var tag in tags)
                    {
                        var sig = await GpgKeyService.VerifyTagSignatureAsync(tag.Name, tagRepoPath);
                        tag.IsSigned = sig.IsSigned;
                        tag.IsVerified = sig.IsVerified;
                    }
                    await InvokeAsync(StateHasChanged);
                }
                catch { }
            });

            var branch = repo.Branches[currentBranch] ?? repo.Branches["main"] ?? repo.Branches["master"] ?? repo.Head;
            currentBranch = branch.FriendlyName;

            if (branch.Tip != null)
            {
                latestCommit = MapCommit(branch.Tip, repo);
                isEmpty = false;

                {
                    var filter = new CommitFilter { IncludeReachableFrom = branch.Tip };
                    // Always count commits for the badge
                    commitCount = isFile && !string.IsNullOrEmpty(Path)
                        ? repo.Commits.QueryBy(Path, filter).Count()
                        : repo.Commits.QueryBy(filter).Count();

                    if (activeTab == "commits")
                    {
                        if (isFile && !string.IsNullOrEmpty(Path))
                            commitHistory = repo.Commits.QueryBy(Path, filter).Select(c => MapCommit(c.Commit, repo)).Take(20).ToList();
                        else
                            commitHistory = repo.Commits.QueryBy(filter).Select(c => MapCommit(c, repo)).Take(20).ToList();
                    }
                }

                if (!string.IsNullOrEmpty(CommitHash))
                {
                    activeTab = "commit-detail";
                    var rawCommit = repo.Lookup<Commit>(CommitHash);
                    if (rawCommit != null)
                    {
                        selectedCommit = MapCommit(rawCommit, repo);
                        LoadCommitDetail(repo, rawCommit);
                        LoadCommitComments();
                    }
                }
                else if (string.IsNullOrEmpty(Path))
                {
                    isFile = false;
                    LoadTree(branch.Tip.Tree, repo);
                    LoadReadme(branch.Tip.Tree);
                    LoadLicense(branch.Tip.Tree);
                    LoadLanguageStats(branch.Tip.Tree);

                    // Load health score async
                    _ = Task.Run(async () => {
                        healthReport = await RepoHealthService.GetHealthReportAsync(RepoName);
                        await InvokeAsync(StateHasChanged);
                    });
                }
                else
                {
                    var entry = branch.Tip[Path];
                    if (entry == null) { notFound = true; return; }
                    if (entry.TargetType == TreeEntryTargetType.Tree)
                    {
                        isFile = false;
                        LoadTree((Tree)entry.Target, repo);
                        LoadReadme((Tree)entry.Target);
                        LoadLicense((Tree)entry.Target);
                    }
                    else
                    {
                        isFile = true;
                        var blob = (Blob)entry.Target;
                        fileSize = blob.Size;
                        using var reader = new StreamReader(blob.GetContentStream(), Encoding.UTF8);
                        fileContent = reader.ReadToEnd();
                        lineCount = fileContent.Split('\n').Length;

                        // Load CODEOWNERS for this file
                        try
                        {
                            fileCodeOwners = CodeOwnersService.GetCodeOwnersForFile(RepoFullPath, currentBranch, Path);
                        }
                        catch { fileCodeOwners = new(); }
                    }
                }
            }
            else
            {
                commitCount = 0;
                commitHistory.Clear();
            }
        }
        catch { notFound = true; }
    }

    private GitCommit MapCommit(Commit c, LibGit2Sharp.Repository? repo = null)
    {
        var gc = new GitCommit
        {
            Sha = c.Sha,
            ShortSha = c.Id.ToString(7),
            AuthorName = c.Author.Name,
            Message = c.MessageShort,
            FullMessage = c.Message?.Trim() ?? c.MessageShort,
            Date = c.Author.When.UtcDateTime
        };

        // Check for GPG signature using raw commit object parsing
        if (repo != null)
        {
            try
            {
                gc.IsSigned = MyPersonalGit.Data.GpgKeyService.CommitHasSignature(c.Sha, RepoFullPath);
            }
            catch { /* No signature */ }
        }

        return gc;
    }

    private async Task VerifyCommitSignatures()
    {
        var signedCommits = commitHistory.Where(c => c.IsSigned).ToList();
        if (selectedCommit?.IsSigned == true)
            signedCommits.Add(selectedCommit);

        if (!signedCommits.Any()) return;

        foreach (var commit in signedCommits)
        {
            try
            {
                var result = await GpgKeyService.VerifyCommitSignatureAsync(commit.Sha, RepoFullPath);
                commit.IsVerified = result.IsVerified;
                commit.SignerKeyId = result.SignerKeyId;
            }
            catch { /* ignore verification errors */ }
        }
    }

    private static readonly MarkdownPipeline _markdownPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    private MarkupString RenderCsvTable(string content, char delimiter)
    {
        if (string.IsNullOrWhiteSpace(content)) return new MarkupString("<p class='text-muted'>Empty file</p>");
        var lines = content.Split('\n', StringSplitOptions.RemoveEmptyEntries);
        if (lines.Length == 0) return new MarkupString("");
        var sb = new System.Text.StringBuilder();
        sb.Append("<table class=\"table table-sm table-striped table-bordered mb-0\" style=\"font-size: 13px;\">");
        for (int i = 0; i < lines.Length && i < 1000; i++)
        {
            var cells = ParseCsvLine(lines[i].TrimEnd('\r'), delimiter);
            var tag = i == 0 ? "th" : "td";
            sb.Append(i == 0 ? "<thead><tr>" : "<tr>");
            foreach (var cell in cells)
                sb.Append($"<{tag} class=\"px-2 py-1\">{System.Net.WebUtility.HtmlEncode(cell)}</{tag}>");
            sb.Append(i == 0 ? "</tr></thead><tbody>" : "</tr>");
        }
        sb.Append("</tbody></table>");
        if (lines.Length > 1000) sb.Append("<p class='text-muted small mt-2'>Showing first 1,000 rows.</p>");
        return new MarkupString(sb.ToString());
    }

    private static List<string> ParseCsvLine(string line, char delimiter)
    {
        var fields = new List<string>();
        bool inQuotes = false;
        var current = new System.Text.StringBuilder();
        for (int i = 0; i < line.Length; i++)
        {
            if (inQuotes)
            {
                if (line[i] == '"' && i + 1 < line.Length && line[i + 1] == '"') { current.Append('"'); i++; }
                else if (line[i] == '"') inQuotes = false;
                else current.Append(line[i]);
            }
            else if (line[i] == '"') inQuotes = true;
            else if (line[i] == delimiter) { fields.Add(current.ToString()); current.Clear(); }
            else current.Append(line[i]);
        }
        fields.Add(current.ToString());
        return fields;
    }

    private MarkupString RenderNotebook(string json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return new MarkupString("<p class='text-muted'>Empty notebook</p>");

        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            var root = doc.RootElement;

            // Determine kernel language from metadata
            var language = "python";
            if (root.TryGetProperty("metadata", out var metadata) &&
                metadata.TryGetProperty("kernelspec", out var kernelspec) &&
                kernelspec.TryGetProperty("language", out var lang))
            {
                language = lang.GetString() ?? "python";
            }
            else if (root.TryGetProperty("metadata", out var meta2) &&
                     meta2.TryGetProperty("language_info", out var langInfo) &&
                     langInfo.TryGetProperty("name", out var langName))
            {
                language = langName.GetString() ?? "python";
            }

            if (!root.TryGetProperty("cells", out var cells))
                return new MarkupString("<p class='text-muted'>No cells found in notebook</p>");

            var sb = new System.Text.StringBuilder();
            sb.Append("<style>");
            sb.Append(".nb-cell { margin-bottom: 16px; }");
            sb.Append(".nb-code-cell { background: #f8f9fa; border: 1px solid #e1e4e8; border-radius: 6px; overflow: hidden; }");
            sb.Append(".nb-label { font-family: monospace; font-size: 12px; color: #6a737d; padding: 8px 12px 0 12px; user-select: none; }");
            sb.Append(".nb-source pre { margin: 0; padding: 8px 12px; font-size: 13px; line-height: 1.5; overflow-x: auto; background: transparent; }");
            sb.Append(".nb-output { border-top: 1px solid #e1e4e8; padding: 8px 12px; background: #fff; }");
            sb.Append(".nb-output pre { margin: 0; font-size: 13px; line-height: 1.5; white-space: pre-wrap; word-wrap: break-word; }");
            sb.Append(".nb-output img { max-width: 100%; }");
            sb.Append(".nb-markdown { padding: 12px 16px; }");
            sb.Append(".nb-raw pre { margin: 0; padding: 8px 12px; font-size: 13px; line-height: 1.5; background: #f8f9fa; border: 1px solid #e1e4e8; border-radius: 6px; }");
            sb.Append("</style>");

            int codeIndex = 1;
            foreach (var cell in cells.EnumerateArray())
            {
                var cellType = cell.TryGetProperty("cell_type", out var ct) ? ct.GetString() : "code";

                // Get source text (array of lines or single string)
                var source = "";
                if (cell.TryGetProperty("source", out var srcProp))
                {
                    if (srcProp.ValueKind == System.Text.Json.JsonValueKind.Array)
                    {
                        var srcSb = new System.Text.StringBuilder();
                        foreach (var line in srcProp.EnumerateArray())
                            srcSb.Append(line.GetString());
                        source = srcSb.ToString();
                    }
                    else if (srcProp.ValueKind == System.Text.Json.JsonValueKind.String)
                    {
                        source = srcProp.GetString() ?? "";
                    }
                }

                if (cellType == "markdown")
                {
                    sb.Append("<div class=\"nb-cell nb-markdown markdown-body\">");
                    var mdHtml = ConvertMarkdownToHtml(source);
                    sb.Append(mdHtml.Value);
                    sb.Append("</div>");
                }
                else if (cellType == "code")
                {
                    int execCount = 0;
                    if (cell.TryGetProperty("execution_count", out var ec) && ec.ValueKind == System.Text.Json.JsonValueKind.Number)
                        execCount = ec.GetInt32();
                    else
                        execCount = codeIndex;

                    sb.Append("<div class=\"nb-cell nb-code-cell\">");
                    sb.Append($"<div class=\"nb-label\">In [{execCount}]:</div>");
                    sb.Append("<div class=\"nb-source\"><pre><code class=\"language-");
                    sb.Append(System.Net.WebUtility.HtmlEncode(language));
                    sb.Append("\">");
                    sb.Append(System.Net.WebUtility.HtmlEncode(source));
                    sb.Append("</code></pre></div>");

                    // Render outputs
                    if (cell.TryGetProperty("outputs", out var outputs))
                    {
                        foreach (var output in outputs.EnumerateArray())
                        {
                            var outputType = output.TryGetProperty("output_type", out var ot) ? ot.GetString() : "";

                            if (outputType == "stream")
                            {
                                var text = GetNotebookOutputText(output, "text");
                                if (!string.IsNullOrEmpty(text))
                                {
                                    sb.Append("<div class=\"nb-output\">");
                                    sb.Append("<pre>");
                                    sb.Append(System.Net.WebUtility.HtmlEncode(text));
                                    sb.Append("</pre></div>");
                                }
                            }
                            else if (outputType == "execute_result" || outputType == "display_data")
                            {
                                sb.Append("<div class=\"nb-output\">");
                                sb.Append($"<div class=\"nb-label\">Out [{execCount}]:</div>");

                                if (output.TryGetProperty("data", out var data))
                                {
                                    // Prefer HTML, then image, then plain text
                                    if (data.TryGetProperty("text/html", out var htmlData))
                                    {
                                        sb.Append(GetNotebookMultilineString(htmlData));
                                    }
                                    else if (data.TryGetProperty("image/png", out var imgData))
                                    {
                                        var imgStr = imgData.ValueKind == System.Text.Json.JsonValueKind.Array
                                            ? string.Join("", NotebookEnumerateStrings(imgData))
                                            : imgData.GetString() ?? "";
                                        sb.Append($"<img src=\"data:image/png;base64,{imgStr.Trim()}\" />");
                                    }
                                    else if (data.TryGetProperty("text/plain", out var plainData))
                                    {
                                        sb.Append("<pre>");
                                        sb.Append(System.Net.WebUtility.HtmlEncode(GetNotebookMultilineString(plainData)));
                                        sb.Append("</pre>");
                                    }
                                }
                                sb.Append("</div>");
                            }
                            else if (outputType == "error")
                            {
                                var traceback = "";
                                if (output.TryGetProperty("traceback", out var tb) && tb.ValueKind == System.Text.Json.JsonValueKind.Array)
                                {
                                    var tbSb = new System.Text.StringBuilder();
                                    foreach (var tbLine in tb.EnumerateArray())
                                        tbSb.AppendLine(tbLine.GetString());
                                    traceback = tbSb.ToString();
                                }
                                if (!string.IsNullOrEmpty(traceback))
                                {
                                    // Strip ANSI escape codes
                                    traceback = System.Text.RegularExpressions.Regex.Replace(traceback, @"\x1B\[[0-9;]*m", "");
                                    sb.Append("<div class=\"nb-output\" style=\"background: #fff5f5;\">");
                                    sb.Append("<pre style=\"color: #d32f2f;\">");
                                    sb.Append(System.Net.WebUtility.HtmlEncode(traceback));
                                    sb.Append("</pre></div>");
                                }
                            }
                        }
                    }
                    sb.Append("</div>");
                    codeIndex++;
                }
                else if (cellType == "raw")
                {
                    sb.Append("<div class=\"nb-cell\"><div class=\"nb-raw\"><pre>");
                    sb.Append(System.Net.WebUtility.HtmlEncode(source));
                    sb.Append("</pre></div></div>");
                }
            }
            return new MarkupString(sb.ToString());
        }
        catch (System.Text.Json.JsonException ex)
        {
            return new MarkupString($"<p class='text-danger'>Failed to parse notebook: {System.Net.WebUtility.HtmlEncode(ex.Message)}</p>");
        }
    }

    private static string GetNotebookOutputText(System.Text.Json.JsonElement output, string property)
    {
        if (!output.TryGetProperty(property, out var prop)) return "";
        return GetNotebookMultilineString(prop);
    }

    private static string GetNotebookMultilineString(System.Text.Json.JsonElement element)
    {
        if (element.ValueKind == System.Text.Json.JsonValueKind.Array)
        {
            var sb = new System.Text.StringBuilder();
            foreach (var line in element.EnumerateArray())
                sb.Append(line.GetString());
            return sb.ToString();
        }
        return element.GetString() ?? "";
    }

    private static IEnumerable<string> NotebookEnumerateStrings(System.Text.Json.JsonElement array)
    {
        foreach (var item in array.EnumerateArray())
            yield return item.GetString() ?? "";
    }

    private MarkupString ConvertMarkdownToHtml(string markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown)) return new MarkupString("");

        var document = Markdown.Parse(markdown, _markdownPipeline);
        RewriteRelativeUrls(document);

        var writer = new StringWriter();
        var renderer = new Markdig.Renderers.HtmlRenderer(writer);
        _markdownPipeline.Setup(renderer);
        renderer.Render(document);
        writer.Flush();

        // Wrap standalone <img> tags in clickable <a> links to view full-size
        var html = Regex.Replace(writer.ToString(),
            @"(?<!<a[^>]*>)\s*<img\s+([^>]*?)src=""([^""]+)""([^>]*?)/?>",
            @"<a href=""$2"" target=""_blank"" rel=""noopener""><img src=""$2"" $1$3 /></a>");

        // Add GitHub-style IDs to all headings based on their text content.
        // Markdig's AutoIdentifiers strips leading numbers, so we do it ourselves.
        html = Regex.Replace(html, @"<(h[1-6])(?:\s+id=""[^""]*"")?>(.*?)</\1>", m =>
        {
            var tag = m.Groups[1].Value;
            var innerHtml = m.Groups[2].Value;
            // Strip HTML tags to get plain text
            var plainText = Regex.Replace(innerHtml, @"<[^>]+>", "").Trim();
            var id = GitHubSlugify(System.Net.WebUtility.HtmlDecode(plainText));
            return $"<{tag} id=\"{id}\">{innerHtml}</{tag}>";
        });

        return new MarkupString(html);
    }

    private static string GitHubSlugify(string heading)
    {
        // GitHub's heading anchor algorithm:
        // 1. Lowercase
        // 2. Remove everything except alphanumeric, spaces, hyphens
        // 3. Replace spaces with hyphens
        var sb = new System.Text.StringBuilder();
        foreach (var c in heading.ToLowerInvariant())
        {
            if (char.IsLetterOrDigit(c) || c == '-')
                sb.Append(c);
            else if (c == ' ')
                sb.Append('-');
        }
        return sb.ToString();
    }

    private void RewriteRelativeUrls(MarkdownDocument document)
    {
        // Determine directory context: README at root → "", file like "docs/guide.md" → "docs"
        var currentDir = string.IsNullOrEmpty(Path)
            ? ""
            : (isFile ? GetParentPath() : Path);

        foreach (var node in document.Descendants())
        {
            if (node is LinkInline link && !string.IsNullOrEmpty(link.Url))
            {
                if (IsAbsoluteUrl(link.Url)) continue;

                // Split off fragment/query
                var url = link.Url;
                var fragment = "";
                var hashIdx = url.IndexOf('#');
                if (hashIdx >= 0) { fragment = url[hashIdx..]; url = url[..hashIdx]; }
                var queryIdx = url.IndexOf('?');
                var query = "";
                if (queryIdx >= 0) { query = url[queryIdx..]; url = url[..queryIdx]; }

                if (string.IsNullOrEmpty(url) && !string.IsNullOrEmpty(fragment))
                {
                    // Rewrite pure anchor links to include the full page path
                    // so Blazor's router doesn't navigate away from the current page
                    var basePath = string.IsNullOrEmpty(Path) ? "" : $"/{Path}";
                    link.Url = $"/repo/{RepoName}{basePath}{fragment}";
                    continue;
                }

                var resolvedPath = ResolveRelativePath(currentDir, url);

                if (link.IsImage)
                {
                    link.Url = $"/raw/{RepoName}/{resolvedPath}?branch={Uri.EscapeDataString(currentBranch)}";
                }
                else
                {
                    link.Url = $"/repo/{RepoName}/{resolvedPath}{fragment}";
                }
            }
        }
    }

    private static bool IsAbsoluteUrl(string url) =>
        url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
        url.StartsWith("https://", StringComparison.OrdinalIgnoreCase) ||
        url.StartsWith("//") ||
        url.StartsWith("mailto:", StringComparison.OrdinalIgnoreCase) ||
        url.StartsWith("data:", StringComparison.OrdinalIgnoreCase);

    private static string ResolveRelativePath(string currentDir, string relativePath)
    {
        if (relativePath.StartsWith("/"))
            return relativePath.TrimStart('/');

        var combined = string.IsNullOrEmpty(currentDir)
            ? relativePath
            : currentDir.TrimEnd('/') + "/" + relativePath;

        var segments = combined.Split('/', StringSplitOptions.RemoveEmptyEntries);
        var result = new Stack<string>();
        foreach (var seg in segments)
        {
            if (seg == ".") continue;
            if (seg == "..") { if (result.Count > 0) result.Pop(); }
            else result.Push(seg);
        }
        return string.Join("/", result.Reverse());
    }

    private void LoadCommitDetail(Repository repo, Commit c)
    {
        commitPatches.Clear();
        var parent = c.Parents.FirstOrDefault();
        var changes = repo.Diff.Compare<Patch>(parent?.Tree, c.Tree);
        foreach (var change in changes)
        {
            commitPatches.Add(new FilePatch
            {
                Path = change.Path,
                LinesAdded = change.LinesAdded,
                LinesDeleted = change.LinesDeleted,
                DiffLines = change.Patch.Split('\n').ToList()
            });
        }
    }


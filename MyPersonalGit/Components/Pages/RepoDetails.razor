    // Default ignored patterns (common build artifacts, VCS dirs, etc.)
    private static readonly string[] DefaultIgnorePatterns = new[]
    {
        ".git/", ".git\\",
        "bin/", "bin\\",
        "obj/", "obj\\",
        "node_modules/", "node_modules\\",
        ".vs/", ".vs\\",
        ".idea/", ".idea\\",

    private static readonly System.Text.RegularExpressions.Regex ClosingKeywordRegex = new(
        @"\b(?:close[sd]?|fix(?:e[sd])?|resolve[sd]?)\s+#\d+",
        System.Text.RegularExpressions.RegexOptions.IgnoreCase | System.Text.RegularExpressions.RegexOptions.Compiled);

    private bool HasClosingKeywords(string message) =>
        !string.IsNullOrEmpty(message) && ClosingKeywordRegex.IsMatch(message);

    private string GetRepoFullPath()
    {
        var path = System.IO.Path.Combine(RootPath, RepoName);
        if (Repository.IsValid(path)) return path;
        if (Repository.IsValid(path + ".git")) return path + ".git";
        // Check for nested repo (e.g., /repos/RepoName/RepoName.git)
        var nested = System.IO.Path.Combine(path, RepoName + ".git");
        if (Repository.IsValid(nested)) return nested;
        return path;
    }

    private string CloneUrl => $"{Nav.BaseUri.TrimEnd('/')}/git/{RepoName}.git";

    protected override async Task OnParametersSetAsync()
    {
        // Priority: 1) Admin UI saved setting, 2) appsettings config, 3) auto-detection
        var systemSettings = await AdminService.GetSystemSettingsAsync();
        if (!string.IsNullOrEmpty(systemSettings.ProjectRoot))
        {
            try
            {
                if (!Directory.Exists(systemSettings.ProjectRoot))
                    Directory.CreateDirectory(systemSettings.ProjectRoot);
                RootPath = systemSettings.ProjectRoot;
            }
            catch { /* path invalid or drive missing — fall through */ }
        }

        if (string.IsNullOrEmpty(RootPath))
        {
            var configuredPath = Config["Git:ProjectRoot"];
            if (!string.IsNullOrEmpty(configuredPath))
            {
                try
                {
                    if (!Directory.Exists(configuredPath))
                        Directory.CreateDirectory(configuredPath);
                    RootPath = configuredPath;
                }
                catch { /* fall through */ }
            }
        }

        LoadRepoData();
        await VerifyCommitSignatures();
        await LoadRepoMetadata();
        await LoadReleases();
    }

    private async Task LoadRepoMetadata()
    {
        var repoName = RepoFullPath;
        var dirName = System.IO.Path.GetFileName(repoName);
        var meta = await RepoService.GetRepositoryAsync(dirName);
        if (meta != null)
        {
            repoIsPrivate = meta.IsPrivate;
            repoIsArchived = meta.IsArchived;
            repoIsTemplate = meta.IsTemplate;
            repoDescription = meta.Description ?? "";
            repoOwner = !string.IsNullOrEmpty(meta.Owner) ? meta.Owner : "anonymous";
            repoForkedFrom = meta.ForkedFrom ?? "";
            repoForkCount = meta.Forks;
            repoStarCount = meta.Stars;
            repoWatchCount = meta.Watchers;
            repoWebsiteUrl = meta.WebsiteUrl ?? "";
            settingsWebsiteUrl = meta.WebsiteUrl ?? "";
            settingsIsPrivate = meta.IsPrivate;
            settingsIsTemplate = meta.IsTemplate;
            settingsDescription = meta.Description ?? "";
            settingsHasPages = meta.HasPages;
            settingsPagesBranch = meta.PagesBranch ?? "gh-pages";
            settingsTopics = new List<string>(meta.Topics ?? new());
            settingsUseExternalTracker = meta.UseExternalIssueTracker;
            settingsExternalTrackerUrl = meta.ExternalIssueTrackerUrl ?? "";
            settingsExternalTrackerPattern = meta.ExternalIssueTrackerPattern ?? "";

            // Populate branch list for default branch selector
            try
            {
                using var branchRepo = new LibGit2Sharp.Repository(RepoFullPath);
                availableBranches = branchRepo.Branches.Where(b => !b.IsRemote).Select(b => b.FriendlyName).ToList();
                selectedDefaultBranch = meta.DefaultBranch ?? currentBranch;
            }
            catch { availableBranches = new() { currentBranch }; selectedDefaultBranch = currentBranch; }

            // Look up template source name
            repoTemplateFromName = "";
            if (meta.TemplateRepositoryId.HasValue)
            {
                using var db = DbFactory.CreateDbContext();
                var templateRepo = await db.Repositories.FirstOrDefaultAsync(r => r.Id == meta.TemplateRepositoryId.Value);
                if (templateRepo != null)
                {
                    repoTemplateFromName = templateRepo.Name.EndsWith(".git") ? templateRepo.Name[..^4] : templateRepo.Name;
                }
            }
        }
        else
        {
            repoIsPrivate = false;
            repoIsArchived = false;
            repoIsTemplate = false;
            repoTemplateFromName = "";
            repoDescription = "";
            repoOwner = "anonymous";
            repoForkedFrom = "";
            repoForkCount = 0;
            settingsIsPrivate = false;
            settingsIsTemplate = false;
            settingsDescription = "";
        }

        // Check if current user already forked/starred/watched this repo
        if (UserService.IsLoggedIn)
        {
            repoIsForked = await RepoService.IsForkedAsync(dirName, UserService.Username);
            repoIsStarred = await RepoService.IsStarredAsync(dirName, UserService.Username);
            repoIsWatched = await RepoService.IsWatchingAsync(dirName, UserService.Username);
        }

        // Load contributors from git history
        try { repoContributors = await RepoService.GetContributorsAsync(RepoFullPath); } catch { }

        // Enforce private repo access: if private and user is not owner or collaborator, block
        if (repoIsPrivate)
        {
            var hasAccess = UserService.IsLoggedIn && (
                repoOwner.Equals(UserService.Username, StringComparison.OrdinalIgnoreCase) ||
                await CollaboratorService.IsCollaboratorAsync(dirName, UserService.Username));
            if (!hasAccess)
                notFound = true;
        }

        // Load repository secrets (metadata only — values are encrypted)
        if (UserService.IsLoggedIn)
        {
            try { repoSecrets = await SecretsService.GetSecretsAsync(dirName); }
            catch { repoSecrets = new(); }
        }

        // Load deploy keys
        if (UserService.IsLoggedIn && meta != null)
        {
            try { deployKeys = await DeployKeyService.GetDeployKeysAsync(meta.Id); }
            catch { deployKeys = new(); }
        }
    }


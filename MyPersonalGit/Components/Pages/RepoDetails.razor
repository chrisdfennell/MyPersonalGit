    public class FilePatch { public string Path { get; set; } = ""; public int LinesAdded { get; set; } public int LinesDeleted { get; set; } public List<string> DiffLines { get; set; } = new(); }
    public class DiffPair { public string? Left { get; set; } public string? Right { get; set; } public int LeftLineNum { get; set; } public int RightLineNum { get; set; } }
    public class UnifiedDiffRow { public string OldNum { get; set; } = ""; public string NewNum { get; set; } = ""; public char Sign { get; set; } public string Content { get; set; } = ""; public string CssClass { get; set; } = ""; }
    public class LanguageStat { public string Name { get; set; } = ""; public double Percentage { get; set; } public string Color { get; set; } = ""; }

    // Dependabot
    private List<MyPersonalGit.Models.DependencyUpdateConfig> depbotConfigs = new();
    private string newDepbotEcosystem = "NuGet";
    private string newDepbotSchedule = "weekly";

    private async void LoadDependabotConfigs()
    {
        depbotConfigs = await DependencyUpdateService.GetConfigsAsync(RepoName);
        StateHasChanged();
    }

    private async Task EnableDependabot()
    {
        await DependencyUpdateService.EnableUpdatesAsync(RepoName, newDepbotEcosystem, newDepbotSchedule);
        depbotConfigs = await DependencyUpdateService.GetConfigsAsync(RepoName);
        StateHasChanged();
    }

    private async Task DisableDependabot(int configId)
    {
        await DependencyUpdateService.DisableUpdatesAsync(RepoName, configId);
        depbotConfigs = await DependencyUpdateService.GetConfigsAsync(RepoName);
        StateHasChanged();
    }

    // Cherry-pick / Revert
    private bool isReverting;
    private string? cherryPickRevertMessage;
    private bool cherryPickRevertSuccess;

    private async Task CherryPickCommit(string sha, string targetBranch)
    {
        cherryPickRevertMessage = null;
        var (success, error, prNumber) = await CherryPickRevertService.CherryPickAsPullRequestAsync(RepoName, sha, targetBranch, UserService.Username);
        cherryPickRevertSuccess = success;
        cherryPickRevertMessage = success ? $"PR #{prNumber} created for cherry-pick to {targetBranch}" : error;
        StateHasChanged();
    }

    private async Task RevertCommit(string sha)
    {
        isReverting = true;
        cherryPickRevertMessage = null;
        StateHasChanged();
        var (success, error, prNumber) = await CherryPickRevertService.RevertAsPullRequestAsync(RepoName, sha, currentBranch, UserService.Username);
        cherryPickRevertSuccess = success;
        cherryPickRevertMessage = success ? $"PR #{prNumber} created to revert {sha[..7]}" : error;
        isReverting = false;
        StateHasChanged();
    }
}
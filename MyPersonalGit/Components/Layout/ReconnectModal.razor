<div id="components-reconnect-modal" class="components-reconnect-hide">
    <div class="show">
        <p>Attempting to reconnect to the server...</p>
    </div>
    <div class="failed">
        <p>Reconnection failed. <a href="javascript:location.reload()">Reload</a> the page.</p>
    </div>
    <div class="rejected">
        <p>Reconnection rejected. <a href="javascript:location.reload()">Reload</a> the page.</p>
    </div>
</div>

<style>
    #components-reconnect-modal {
        display: none;
        position: fixed;
        top: 0px;
        right: 0px;
        bottom: 0px;
        left: 0px;
        z-index: 1000;
        overflow: hidden;
        background-color: rgba(0, 0, 0, 0.5);
        opacity: 0.9;
        text-align: center;
        font-weight: bold;
    }

    #components-reconnect-modal.components-reconnect-show {
        display: block;
    }
</style>

<style>
    /* Dark mode for the framework's <dialog> reconnect modal.
       This MUST be unscoped (not in .razor.css) to reach the top-layer dialog. */
    [data-bs-theme="dark"] dialog#components-reconnect-modal {
        background-color: #1e1e2e !important;
        color: #c9d1d9 !important;
        border-color: #444 !important;
    }

    [data-bs-theme="dark"] dialog#components-reconnect-modal p {
        color: #8b949e !important;
    }

    [data-bs-theme="dark"] dialog#components-reconnect-modal .components-rejoining-animation div {
        border-color: #58a6ff !important;
    }

    [data-bs-theme="dark"] dialog#components-reconnect-modal::backdrop {
        background-color: rgba(0, 0, 0, 0.7) !important;
    }

    [data-bs-theme="dark"] dialog#components-reconnect-modal button {
        background-color: #388bfd;
    }
</style>
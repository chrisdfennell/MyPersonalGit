@inherits LayoutComponentBase
@using MyPersonalGit.Data
@using MyPersonalGit.Services
@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject CurrentUserService UserService
@inject IWebIdeService WebIdeService
@inject IAdminService AdminService
@inject IConfiguration Config

<div class="ide-layout">
    <div class="ide-topbar">
        <a href="@BackUrl" class="ide-topbar-back" title="Back to repository">
            <i class="bi bi-arrow-left"></i>
        </a>
        <span class="ide-topbar-repo fw-semibold">@RepoName</span>
        <div class="ide-topbar-branch dropdown">
            <button class="btn btn-sm btn-outline-secondary dropdown-toggle py-0 px-2" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-git me-1"></i>@CurrentBranch
            </button>
            <ul class="dropdown-menu dropdown-menu-start">
                @foreach (var branch in Branches)
                {
                    <li>
                        <button class="dropdown-item small @(branch == CurrentBranch ? "active" : "")" @onclick="() => OnBranchChanged(branch)">
                            @branch
                        </button>
                    </li>
                }
            </ul>
        </div>
        <div class="ms-auto d-flex align-items-center gap-2">
            @if (UserService.IsLoggedIn)
            {
                <span class="text-muted small">@UserService.Username</span>
            }
            <button class="btn btn-sm btn-link text-muted p-0" @onclick="ToggleTheme" title="Toggle theme">
                <i class="bi @(currentTheme == "dark" ? "bi-sun-fill" : "bi-moon-fill")"></i>
            </button>
        </div>
    </div>
    <div class="ide-body">
        @Body
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string RepoName = "";
    private string CurrentBranch = "main";
    private List<string> Branches = new();
    private string currentTheme = "light";

    private string BackUrl => $"/repo/{RepoName}";

    protected override void OnInitialized()
    {
        // Extract repo name from the current URL
        var uri = new Uri(Navigation.Uri);
        var segments = uri.AbsolutePath.Split('/', StringSplitOptions.RemoveEmptyEntries);
        // URL pattern: /repo/{RepoName}/ide/...
        if (segments.Length >= 2 && segments[0] == "repo")
        {
            RepoName = segments[1];
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Initialize user session from localStorage (same as MainLayout)
                if (!UserService.IsLoggedIn)
                {
                    var sessionId = await JS.InvokeAsync<string>("sessionHelper.get", "sessionId");
                    if (!string.IsNullOrEmpty(sessionId))
                    {
                        await UserService.InitializeFromSessionAsync(sessionId);
                    }
                }

                currentTheme = await JS.InvokeAsync<string>("themeHelper.get");

                // Parse current branch from query string
                var uri = new Uri(Navigation.Uri);
                var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
                var branchParam = query["branch"];
                if (!string.IsNullOrEmpty(branchParam))
                    CurrentBranch = branchParam;

                // Load branch list
                if (!string.IsNullOrEmpty(RepoName))
                {
                    await LoadBranches();
                }

                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task LoadBranches()
    {
        var systemSettings = await AdminService.GetSystemSettingsAsync();
        var projectRoot = !string.IsNullOrEmpty(systemSettings.ProjectRoot)
            ? systemSettings.ProjectRoot
            : Config["Git:ProjectRoot"] ?? Config["Git:ReposPath"] ?? "/repos";

        Branches = await Task.Run(() =>
        {
            var repoPath = System.IO.Path.Combine(projectRoot, RepoName);
            if (!LibGit2Sharp.Repository.IsValid(repoPath))
            {
                repoPath = repoPath + ".git";
                if (!LibGit2Sharp.Repository.IsValid(repoPath))
                    repoPath = System.IO.Path.Combine(projectRoot, RepoName, RepoName + ".git");
            }
            try
            {
                using var repo = new LibGit2Sharp.Repository(repoPath);
                return repo.Branches
                    .Where(b => !b.IsRemote)
                    .Select(b => b.FriendlyName)
                    .OrderBy(b => b)
                    .ToList();
            }
            catch
            {
                return new List<string> { "main" };
            }
        });

        if (!Branches.Contains(CurrentBranch) && Branches.Count > 0)
            CurrentBranch = Branches[0];
    }

    private void OnBranchChanged(string branch)
    {
        CurrentBranch = branch;
        Navigation.NavigateTo($"/repo/{RepoName}/ide?branch={branch}", forceLoad: true);
    }

    private async Task ToggleTheme()
    {
        currentTheme = currentTheme == "dark" ? "light" : "dark";
        await JS.InvokeVoidAsync("themeHelper.set", currentTheme);
    }
}

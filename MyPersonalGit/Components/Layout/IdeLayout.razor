@inherits LayoutComponentBase
@using MyPersonalGit.Data
@using MyPersonalGit.Services
@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject CurrentUserService UserService
@inject IWebIdeService WebIdeService
@inject IAdminService AdminService
@inject IConfiguration Config
@using Microsoft.Extensions.Localization
@using MyPersonalGit.Resources
@inject IStringLocalizer<SharedResource> L

<div class="ide-layout">
    <div class="ide-topbar">
        <a href="@BackUrl" class="ide-topbar-back" title="@L["Ide_BackToRepo"]">
            <i class="bi bi-arrow-left"></i>
        </a>
        <span class="ide-topbar-repo fw-semibold">@RepoName</span>
        <div class="ide-topbar-branch dropdown">
            <button class="btn btn-sm btn-outline-secondary dropdown-toggle py-0 px-2" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-git me-1"></i>@CurrentBranch
            </button>
            <ul class="dropdown-menu dropdown-menu-start">
                @foreach (var branch in Branches)
                {
                    <li>
                        <button class="dropdown-item small @(branch == CurrentBranch ? "active" : "")" @onclick="() => OnBranchChanged(branch)">
                            @branch
                        </button>
                    </li>
                }
                @if (UserService.IsLoggedIn)
                {
                    <li><hr class="dropdown-divider" /></li>
                    <li>
                        <button class="dropdown-item small text-primary" @onclick="ShowCreateBranch">
                            <i class="bi bi-plus-circle me-1"></i>@L["Ide_NewBranch"]
                        </button>
                    </li>
                }
            </ul>
        </div>
        <div class="ms-auto d-flex align-items-center gap-2">
            @if (UserService.IsLoggedIn)
            {
                <span class="text-muted small">@UserService.Username</span>
            }
            <button class="btn btn-sm btn-link text-muted p-0" @onclick="ToggleTheme" title="@L["Ide_ToggleTheme"]">
                <i class="bi @(currentTheme == "dark" ? "bi-sun-fill" : "bi-moon-fill")"></i>
            </button>
        </div>
    </div>
    <div class="ide-body">
        @Body
    </div>
</div>

@if (showCreateBranch)
{
    <div class="ide-branch-overlay" @onclick="() => showCreateBranch = false">
        <div class="ide-branch-dialog" @onclick:stopPropagation="true">
            <div class="ide-branch-header">
                <span class="fw-semibold"><i class="bi bi-git me-2"></i>@L["Ide_CreateNewBranch"]</span>
                <button class="btn btn-sm btn-link text-muted p-0" @onclick="() => showCreateBranch = false">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="ide-branch-body">
                <div class="mb-3">
                    <label class="form-label small">@L["Ide_BranchFrom"]</label>
                    <select class="form-select form-select-sm" @bind="newBranchSource">
                        @foreach (var branch in Branches)
                        {
                            <option value="@branch">@branch</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label small">@L["Ide_NewBranchName"]</label>
                    <input type="text" class="form-control form-control-sm" @bind="newBranchName" placeholder="feature/my-branch"
                           @onkeydown="HandleBranchKeyDown" />
                </div>
                @if (!string.IsNullOrEmpty(createBranchError))
                {
                    <div class="alert alert-danger py-1 small">@createBranchError</div>
                }
                <button class="btn btn-primary btn-sm w-100" @onclick="CreateBranch" disabled="@creatingBranch">
                    @if (creatingBranch)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    @L["Ide_CreateBranch"]
                </button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string RepoName = "";
    private string CurrentBranch = "main";
    private List<string> Branches = new();
    private string currentTheme = "light";

    private string BackUrl => $"/repo/{RepoName}";

    protected override void OnInitialized()
    {
        // Extract repo name from the current URL
        var uri = new Uri(Navigation.Uri);
        var segments = uri.AbsolutePath.Split('/', StringSplitOptions.RemoveEmptyEntries);
        // URL pattern: /repo/{RepoName}/ide/...
        if (segments.Length >= 2 && segments[0] == "repo")
        {
            RepoName = segments[1];
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Initialize user session from localStorage (same as MainLayout)
                if (!UserService.IsLoggedIn)
                {
                    var sessionId = await JS.InvokeAsync<string>("sessionHelper.get", "sessionId");
                    if (!string.IsNullOrEmpty(sessionId))
                    {
                        await UserService.InitializeFromSessionAsync(sessionId);
                    }
                }

                currentTheme = await JS.InvokeAsync<string>("themeHelper.get");

                // Parse current branch from query string
                var uri = new Uri(Navigation.Uri);
                var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
                var branchParam = query["branch"];
                if (!string.IsNullOrEmpty(branchParam))
                    CurrentBranch = branchParam;

                // Load branch list
                if (!string.IsNullOrEmpty(RepoName))
                {
                    await LoadBranches();
                }

                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task LoadBranches()
    {
        var systemSettings = await AdminService.GetSystemSettingsAsync();
        var projectRoot = !string.IsNullOrEmpty(systemSettings.ProjectRoot)
            ? systemSettings.ProjectRoot
            : Config["Git:ProjectRoot"] ?? Config["Git:ReposPath"] ?? "/repos";

        Branches = await Task.Run(() =>
        {
            var repoPath = System.IO.Path.Combine(projectRoot, RepoName);
            if (!LibGit2Sharp.Repository.IsValid(repoPath))
            {
                repoPath = repoPath + ".git";
                if (!LibGit2Sharp.Repository.IsValid(repoPath))
                    repoPath = System.IO.Path.Combine(projectRoot, RepoName, RepoName + ".git");
            }
            try
            {
                using var repo = new LibGit2Sharp.Repository(repoPath);
                return repo.Branches
                    .Where(b => !b.IsRemote)
                    .Select(b => b.FriendlyName)
                    .OrderBy(b => b)
                    .ToList();
            }
            catch
            {
                return new List<string> { "main" };
            }
        });

        if (!Branches.Contains(CurrentBranch) && Branches.Count > 0)
            CurrentBranch = Branches[0];
    }

    // Branch creation state
    private bool showCreateBranch;
    private string newBranchName = "";
    private string newBranchSource = "";
    private string? createBranchError;
    private bool creatingBranch;

    private void ShowCreateBranch()
    {
        newBranchName = "";
        newBranchSource = CurrentBranch;
        createBranchError = null;
        showCreateBranch = true;
    }

    private async Task HandleBranchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await CreateBranch();
        else if (e.Key == "Escape") showCreateBranch = false;
    }

    private async Task CreateBranch()
    {
        if (string.IsNullOrWhiteSpace(newBranchName))
        {
            createBranchError = L["Ide_BranchNameRequired"];
            return;
        }

        creatingBranch = true;
        createBranchError = null;
        StateHasChanged();

        try
        {
            await WebIdeService.CreateBranchAsync(RepoName, newBranchSource, newBranchName.Trim());
            showCreateBranch = false;
            Navigation.NavigateTo($"/repo/{RepoName}/ide?branch={Uri.EscapeDataString(newBranchName.Trim())}", forceLoad: true);
        }
        catch (Exception ex)
        {
            createBranchError = ex.Message;
        }
        finally
        {
            creatingBranch = false;
            StateHasChanged();
        }
    }

    private void OnBranchChanged(string branch)
    {
        CurrentBranch = branch;
        Navigation.NavigateTo($"/repo/{RepoName}/ide?branch={branch}", forceLoad: true);
    }

    private async Task ToggleTheme()
    {
        currentTheme = currentTheme == "dark" ? "light" : "dark";
        await JS.InvokeVoidAsync("themeHelper.set", currentTheme);
    }
}

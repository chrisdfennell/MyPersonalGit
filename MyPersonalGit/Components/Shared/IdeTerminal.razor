@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject MyPersonalGit.Services.CurrentUserService UserService
@implements IAsyncDisposable

<div class="ide-terminal-container">
    <div id="@_containerId" class="ide-terminal-xterm"></div>
</div>

@code {
    [Parameter] public string RepoName { get; set; } = "";
    [Parameter] public bool IsVisible { get; set; }

    private string _containerId = "ide-terminal-" + Guid.NewGuid().ToString("N")[..8];
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Load xterm.js from CDN
            await JS.InvokeVoidAsync("ideTerminal.loadXterm");
        }

        if (IsVisible && !_initialized)
        {
            await InitTerminal();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !_initialized)
        {
            // Will be handled in OnAfterRenderAsync
        }
        else if (IsVisible && _initialized)
        {
            // Delay to let the container reach its final size, then fit
            await Task.Delay(50);
            try { await JS.InvokeVoidAsync("ideTerminal.fit", _containerId); } catch { }
            await Task.Delay(200);
            try { await JS.InvokeVoidAsync("ideTerminal.fit", _containerId); } catch { }
        }
    }

    private async Task InitTerminal()
    {
        try
        {
            // Build WebSocket URL
            var baseUri = new Uri(Navigation.BaseUri);
            var wsScheme = baseUri.Scheme == "https" ? "wss" : "ws";

            // Get session from CurrentUserService first, fallback to reading localStorage directly
            var sessionId = UserService.SessionId;
            if (string.IsNullOrEmpty(sessionId))
            {
                try
                {
                    sessionId = await JS.InvokeAsync<string?>("localStorage.getItem", "sessionId");
                }
                catch { }
            }

            if (string.IsNullOrEmpty(sessionId))
            {
                Console.WriteLine("Terminal: No session ID available");
                return;
            }

            var wsUrl = $"{wsScheme}://{baseUri.Host}:{baseUri.Port}/ws/terminal/{RepoName}?session={Uri.EscapeDataString(sessionId)}";

            await JS.InvokeVoidAsync("ideTerminal.init", _containerId, wsUrl);
            _initialized = true;

            // Fit after init and again after a delay to handle late container sizing
            await Task.Delay(100);
            try { await JS.InvokeVoidAsync("ideTerminal.fit", _containerId); } catch { }
            await Task.Delay(300);
            try { await JS.InvokeVoidAsync("ideTerminal.fit", _containerId); } catch { }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Terminal init error: {ex.Message}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_initialized)
        {
            try
            {
                await JS.InvokeVoidAsync("ideTerminal.dispose", _containerId);
            }
            catch { }
        }
    }
}

@using Microsoft.Extensions.Localization
@using MyPersonalGit.Resources
@inject IStringLocalizer<SharedResource> L

<div class="ide-command-palette-overlay" @onclick="HandleOverlayClick" @onkeydown="HandleKeyDown">
    <div class="ide-command-palette-dialog" @onclick:stopPropagation="true">
        <div class="ide-command-palette-input-wrapper">
            <i class="bi bi-chevron-right me-2 text-muted"></i>
            <input type="text" class="ide-command-palette-input" placeholder="@L["Ide_TypeCommand"]"
                   @ref="inputRef" @bind="filter" @bind:event="oninput" @onkeydown="HandleKeyDown" />
        </div>
        <div class="ide-command-palette-results">
            @if (FilteredCommands.Count == 0)
            {
                <div class="ide-command-palette-empty">@L["Ide_NoMatchingCommands"]</div>
            }
            else
            {
                @for (int i = 0; i < FilteredCommands.Count; i++)
                {
                    var cmd = FilteredCommands[i];
                    var idx = i;
                    <div class="ide-command-palette-item @(idx == selectedIndex ? "selected" : "")"
                         @onclick="() => ExecuteCommand(cmd)">
                        <i class="bi @cmd.Icon me-2"></i>
                        <span>@cmd.Label</span>
                        @if (!string.IsNullOrEmpty(cmd.Shortcut))
                        {
                            <span class="ide-command-palette-shortcut ms-auto">@cmd.Shortcut</span>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<string> OnCommand { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public bool HasActiveFile { get; set; }
    [Parameter] public bool IsBlameActive { get; set; }

    private ElementReference inputRef;
    private string filter = "";
    private int selectedIndex;

    public record CommandItem(string Id, string Label, string Icon, string? Shortcut = null, bool RequiresFile = false);

    private List<CommandItem> AllCommands => new()
    {
        new("quickOpen", L["Ide_CmdQuickOpen"], "bi-folder2-open", "Ctrl+P"),
        new("search", L["Ide_CmdSearchFiles"], "bi-search", "Ctrl+Shift+F"),
        new("toggleTerminal", L["Ide_CmdToggleTerminal"], "bi-terminal", "Ctrl+`"),
        new("splitEditor", L["Ide_CmdToggleSplit"], "bi-layout-split", null, true),
        new("toggleTheme", L["Ide_CmdToggleTheme"], "bi-circle-half"),
        new("toggleBlame", IsBlameActive ? L["Ide_CmdHideBlame"] : L["Ide_CmdShowBlame"], "bi-person-lines-fill", null, true),
        new("fileHistory", L["Ide_CmdFileHistory"], "bi-clock-history", null, true),
        new("findReplace", L["Ide_CmdFindReplace"], "bi-arrow-left-right", "Ctrl+H", true),
        new("goToLine", L["Ide_CmdGoToLine"], "bi-hash", "Ctrl+G", true),
        new("toggleMinimap", L["Ide_CmdToggleMinimap"], "bi-layout-sidebar-reverse", null, true),
        new("closeTab", L["Ide_CmdCloseTab"], "bi-x-lg", null, true),
        new("closeAllTabs", L["Ide_CmdCloseAllTabs"], "bi-x-square"),
        new("sourceControl", L["Ide_CmdSourceControl"], "bi-git"),
        new("outline", L["Ide_CmdOutline"], "bi-list-nested"),
        new("settings", L["Ide_CmdSettings"], "bi-gear"),
        new("explorer", L["Ide_CmdExplorer"], "bi-files"),
        new("zenMode", L["Ide_CmdZenMode"], "bi-arrows-fullscreen"),
        new("toggleWordWrap", L["Ide_CmdWordWrap"], "bi-text-wrap", null, true),
        new("foldAll", L["Ide_CmdFoldAll"], "bi-chevron-bar-contract", null, true),
        new("unfoldAll", L["Ide_CmdUnfoldAll"], "bi-chevron-bar-expand", null, true),
        new("showShortcuts", L["Ide_CmdShortcuts"], "bi-keyboard", "?"),
        new("toggleAutoSave", L["Ide_CmdToggleAutoSave"], "bi-save"),
    };

    private List<CommandItem> FilteredCommands
    {
        get
        {
            var available = AllCommands.Where(c => !c.RequiresFile || HasActiveFile).ToList();
            if (string.IsNullOrWhiteSpace(filter)) return available;
            return available
                .Where(c => c.Label.Contains(filter, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await inputRef.FocusAsync(); } catch { }
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        var cmds = FilteredCommands;
        if (e.Key == "ArrowDown")
        {
            selectedIndex = (selectedIndex + 1) % Math.Max(cmds.Count, 1);
        }
        else if (e.Key == "ArrowUp")
        {
            selectedIndex = selectedIndex <= 0 ? Math.Max(cmds.Count - 1, 0) : selectedIndex - 1;
        }
        else if (e.Key == "Enter" && cmds.Count > 0 && selectedIndex < cmds.Count)
        {
            _ = ExecuteCommand(cmds[selectedIndex]);
        }
        else if (e.Key == "Escape")
        {
            _ = OnClose.InvokeAsync();
        }
        else
        {
            // Reset selection on filter change
            selectedIndex = 0;
        }
    }

    private async Task ExecuteCommand(CommandItem cmd)
    {
        await OnClose.InvokeAsync();
        await OnCommand.InvokeAsync(cmd.Id);
    }

    private async Task HandleOverlayClick()
    {
        await OnClose.InvokeAsync();
    }
}

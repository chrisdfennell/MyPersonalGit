<div class="ide-tab-bar" @ref="tabBarRef">
    @if (Tabs == null || Tabs.Count == 0)
    {
        <div class="ide-tab-empty text-muted small px-3 py-1">
            <i class="bi bi-window-stack me-1"></i>@L["Ide_NoFilesOpen"]
        </div>
    }
    else
    {
        @if (showScrollLeft)
        {
            <button class="ide-tab-scroll-btn ide-tab-scroll-left" @onclick="ScrollLeft" title="@L["Ide_ScrollLeft"]">
                <i class="bi bi-chevron-left"></i>
            </button>
        }
        <div class="ide-tab-scroll" @ref="scrollRef">
            @foreach (var tab in SortedTabs)
            {
                var isActive = tab.FilePath == ActiveTabPath;
                <div class="ide-tab @(isActive ? "active" : "") @(tab.IsPinned ? "pinned" : "") @(dragOverTab == tab.FilePath ? "drag-over" : "")"
                     title="@tab.FilePath"
                     draggable="true"
                     @onclick="() => OnTabSelected.InvokeAsync(tab.FilePath)"
                     @ondragstart="() => OnDragStart(tab.FilePath)"
                     @ondragover:preventDefault="true"
                     @ondragover="() => OnDragOver(tab.FilePath)"
                     @ondragleave="() => dragOverTab = null"
                     @ondrop="() => OnDrop(tab.FilePath)"
                     @oncontextmenu="(e) => HandleContextMenu(e, tab.FilePath)"
                     @oncontextmenu:preventDefault="true">
                    @if (tab.IsPinned)
                    {
                        <i class="bi bi-pin-fill me-1" style="font-size: 0.65rem; color: #0078d4;"></i>
                    }
                    @{ var tabIcon = GetFileIconAndColor(tab.FileName); }
                    <i class="bi @tabIcon.icon me-1" style="font-size: 0.75rem; color: @tabIcon.color;"></i>
                    @if (!tab.IsPinned)
                    {
                        <span class="ide-tab-name">@tab.FileName</span>
                    }
                    @if (tab.IsDirty)
                    {
                        <span class="ide-tab-dirty" title="@L["Ide_UnsavedChanges"]"></span>
                    }
                    @if (!tab.IsPinned)
                    {
                        <button class="ide-tab-close" @onclick="() => CloseTab(tab.FilePath)" @onclick:stopPropagation="true" title="@L["Ide_Close"]">
                            <i class="bi bi-x"></i>
                        </button>
                    }
                </div>
            }
        </div>
        @if (showScrollRight)
        {
            <button class="ide-tab-scroll-btn ide-tab-scroll-right" @onclick="ScrollRight" title="@L["Ide_ScrollRight"]">
                <i class="bi bi-chevron-right"></i>
            </button>
        }
    }
</div>

@if (showContextMenu)
{
    <div class="ide-tab-context-overlay" @onclick="CloseContextMenu">
        <div class="ide-tab-context-menu" style="left: @(contextMenuX)px; top: @(contextMenuY)px;" @onclick:stopPropagation="true">
            @{ var ctxTab = Tabs?.FirstOrDefault(t => t.FilePath == contextMenuTab); }
            @if (ctxTab != null)
            {
                <div class="ide-tab-context-item" @onclick="() => TogglePin(ctxTab)">
                    <i class="bi @(ctxTab.IsPinned ? "bi-pin-angle" : "bi-pin-fill") me-2"></i>
                    @(ctxTab.IsPinned ? L["Ide_UnpinTab"] : L["Ide_PinTab"])
                </div>
                <div class="ide-tab-context-item" @onclick="async () => { CloseContextMenu(); await CloseTab(ctxTab.FilePath); }">
                    <i class="bi bi-x-lg me-2"></i>@L["Ide_CloseTab"]
                </div>
                <div class="ide-tab-context-item" @onclick="CloseOtherTabs">
                    <i class="bi bi-x-square me-2"></i>@L["Ide_CloseOtherTabs"]
                </div>
                <div class="ide-tab-context-item" @onclick="CloseTabsToRight">
                    <i class="bi bi-chevron-bar-right me-2"></i>@L["Ide_CloseTabsToRight"]
                </div>
                <div class="ide-tab-context-item" @onclick="CloseSavedTabs">
                    <i class="bi bi-check2-square me-2"></i>@L["Ide_CloseSavedTabs"]
                </div>
            }
        </div>
    </div>
}

@inject IJSRuntime JS
@using Microsoft.Extensions.Localization
@using MyPersonalGit.Resources
@inject IStringLocalizer<SharedResource> L

@code {
    [Parameter] public List<OpenTab>? Tabs { get; set; }
    [Parameter] public string? ActiveTabPath { get; set; }
    [Parameter] public EventCallback<string> OnTabSelected { get; set; }
    [Parameter] public EventCallback<string> OnTabClosed { get; set; }
    [Parameter] public EventCallback<(int from, int to)> OnTabReordered { get; set; }
    [Parameter] public EventCallback<string> OnTabPinToggled { get; set; }

    private string? draggedTab;
    private string? dragOverTab;
    private ElementReference tabBarRef;
    private ElementReference scrollRef;
    private bool showScrollLeft;
    private bool showScrollRight;

    // Context menu state
    private bool showContextMenu;
    private double contextMenuX;
    private double contextMenuY;
    private string? contextMenuTab;

    private List<OpenTab> SortedTabs => Tabs?.OrderByDescending(t => t.IsPinned).ToList() ?? new();

    private int lastTabCount;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Only check scroll overflow when tab count changes or on first render
        var tabCount = Tabs?.Count ?? 0;
        if (firstRender || tabCount != lastTabCount)
        {
            lastTabCount = tabCount;
            await UpdateScrollButtons();
        }
    }

    private async Task UpdateScrollButtons()
    {
        try
        {
            var state = await JS.InvokeAsync<ScrollState>("ideTabScroll.getScrollState", scrollRef);
            var newLeft = state.ScrollLeft > 0;
            var newRight = state.ScrollLeft + state.ClientWidth < state.ScrollWidth - 1;
            if (newLeft != showScrollLeft || newRight != showScrollRight)
            {
                showScrollLeft = newLeft;
                showScrollRight = newRight;
                StateHasChanged();
            }
        }
        catch { }
    }

    private async Task ScrollLeft()
    {
        try
        {
            await JS.InvokeVoidAsync("ideTabScroll.scroll", scrollRef, -200);
            await Task.Delay(200);
            await UpdateScrollButtons();
        }
        catch { }
    }

    private async Task ScrollRight()
    {
        try
        {
            await JS.InvokeVoidAsync("ideTabScroll.scroll", scrollRef, 200);
            await Task.Delay(200);
            await UpdateScrollButtons();
        }
        catch { }
    }

    private record ScrollState(double ScrollLeft, double ClientWidth, double ScrollWidth);

    private void OnDragStart(string filePath)
    {
        draggedTab = filePath;
    }

    private void OnDragOver(string filePath)
    {
        if (draggedTab != null && draggedTab != filePath)
        {
            dragOverTab = filePath;
        }
    }

    private async Task OnDrop(string targetPath)
    {
        dragOverTab = null;
        if (draggedTab == null || Tabs == null || draggedTab == targetPath) return;

        var fromIndex = Tabs.FindIndex(t => t.FilePath == draggedTab);
        var toIndex = Tabs.FindIndex(t => t.FilePath == targetPath);
        draggedTab = null;

        if (fromIndex >= 0 && toIndex >= 0)
        {
            await OnTabReordered.InvokeAsync((fromIndex, toIndex));
        }
    }

    private async Task CloseTab(string filePath)
    {
        var tab = Tabs?.FirstOrDefault(t => t.FilePath == filePath);
        if (tab?.IsDirty == true)
        {
            var confirmed = await JS.InvokeAsync<bool>("confirm", $"'{tab.FileName}' has unsaved changes. Close anyway?");
            if (!confirmed) return;
        }
        await OnTabClosed.InvokeAsync(filePath);
    }

    private void HandleContextMenu(MouseEventArgs e, string filePath)
    {
        contextMenuTab = filePath;
        contextMenuX = e.ClientX;
        contextMenuY = e.ClientY;
        showContextMenu = true;
    }

    private void CloseContextMenu()
    {
        showContextMenu = false;
        contextMenuTab = null;
    }

    private async Task TogglePin(OpenTab tab)
    {
        tab.IsPinned = !tab.IsPinned;
        CloseContextMenu();
        await OnTabPinToggled.InvokeAsync(tab.FilePath);
    }

    private async Task CloseOtherTabs()
    {
        if (Tabs == null || contextMenuTab == null) return;
        CloseContextMenu();
        var toClose = Tabs.Where(t => t.FilePath != contextMenuTab && !t.IsPinned).Select(t => t.FilePath).ToList();
        foreach (var path in toClose)
        {
            await OnTabClosed.InvokeAsync(path);
        }
    }

    private async Task CloseTabsToRight()
    {
        if (Tabs == null || contextMenuTab == null) return;
        CloseContextMenu();
        var sorted = SortedTabs;
        var idx = sorted.FindIndex(t => t.FilePath == contextMenuTab);
        if (idx < 0) return;
        var toClose = sorted.Skip(idx + 1).Where(t => !t.IsPinned).Select(t => t.FilePath).ToList();
        foreach (var path in toClose)
        {
            await OnTabClosed.InvokeAsync(path);
        }
    }

    private async Task CloseSavedTabs()
    {
        if (Tabs == null) return;
        CloseContextMenu();
        var toClose = Tabs.Where(t => !t.IsDirty && !t.IsPinned).Select(t => t.FilePath).ToList();
        foreach (var path in toClose)
        {
            await OnTabClosed.InvokeAsync(path);
        }
    }

    private (string icon, string color) GetFileIconAndColor(string name)
    {
        var ext = System.IO.Path.GetExtension(name).ToLowerInvariant();
        var fileName = System.IO.Path.GetFileName(name).ToLowerInvariant();
        if (fileName == "dockerfile") return ("bi-filetype-yml", "#2496ED");
        if (fileName == ".gitignore") return ("bi-git", "#F05032");
        return ext switch
        {
            ".cs" => ("bi-filetype-cs", "#68217A"),
            ".csproj" or ".sln" => ("bi-filetype-cs", "#512BD4"),
            ".js" => ("bi-filetype-js", "#F7DF1E"),
            ".jsx" => ("bi-filetype-jsx", "#61DAFB"),
            ".ts" => ("bi-filetype-tsx", "#3178C6"),
            ".tsx" => ("bi-filetype-tsx", "#3178C6"),
            ".py" => ("bi-filetype-py", "#3572A5"),
            ".go" => ("bi-file-earmark-code", "#00ADD8"),
            ".rs" => ("bi-file-earmark-code", "#DEA584"),
            ".java" => ("bi-filetype-java", "#B07219"),
            ".rb" => ("bi-filetype-rb", "#CC342D"),
            ".php" => ("bi-filetype-php", "#4F5D95"),
            ".cpp" or ".cc" or ".c" or ".h" => ("bi-file-earmark-code", "#555"),
            ".html" or ".htm" => ("bi-filetype-html", "#E34F26"),
            ".css" => ("bi-filetype-css", "#1572B6"),
            ".scss" => ("bi-filetype-scss", "#CC6699"),
            ".json" => ("bi-filetype-json", "#292929"),
            ".md" => ("bi-filetype-md", "#083fa1"),
            ".yml" or ".yaml" => ("bi-filetype-yml", "#cb171e"),
            ".xml" or ".svg" => ("bi-filetype-xml", "#e37933"),
            ".sh" or ".bash" => ("bi-terminal", "#4EAA25"),
            ".sql" => ("bi-filetype-sql", "#e38c00"),
            ".png" or ".jpg" or ".jpeg" or ".gif" or ".webp" => ("bi-file-earmark-image", "#a074c4"),
            ".pdf" => ("bi-filetype-pdf", "#FA0F00"),
            ".zip" or ".tar" or ".gz" => ("bi-file-earmark-zip", "#e8a917"),
            _ => ("bi-file-earmark", "#888")
        };
    }

    public class OpenTab
    {
        public string FilePath { get; set; } = "";
        public string FileName { get; set; } = "";
        public bool IsDirty { get; set; }
        public string OriginalContent { get; set; } = "";
        public bool IsPinned { get; set; }
    }
}

<style>
    .ide-tab-bar {
        display: flex;
        align-items: stretch;
        background: #252526;
        min-height: 35px;
        overflow: hidden;
        position: relative;
    }

    .ide-tab-empty {
        display: flex;
        align-items: center;
        color: #858585;
        font-size: 13px;
    }

    .ide-tab-scroll {
        display: flex;
        overflow-x: auto;
        overflow-y: hidden;
        scrollbar-width: none;
        flex: 1;
        min-width: 0;
    }

    .ide-tab-scroll::-webkit-scrollbar {
        height: 0;
        display: none;
    }

    /* Scroll chevron buttons */
    .ide-tab-scroll-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        min-width: 24px;
        border: none;
        background: #333333;
        color: #cccccc;
        cursor: pointer;
        font-size: 0.7rem;
        z-index: 2;
        flex-shrink: 0;
        transition: background 0.15s;
    }

    .ide-tab-scroll-btn:hover {
        background: #3c3c3c;
        color: #ffffff;
    }

    .ide-tab {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 0 12px;
        height: 35px;
        font-size: 13px;
        cursor: pointer;
        white-space: nowrap;
        border-right: 1px solid #1e1e1e;
        color: #969696;
        min-width: 0;
        flex-shrink: 0;
        background: #2d2d2d;
        border-top: 2px solid transparent;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        transition: border-left-color 0.1s;
    }

    .ide-tab:hover {
        color: #cccccc;
        background: #2d2d2d;
    }

    .ide-tab.active {
        color: #ffffff;
        background: #1e1e1e;
        border-top-color: #0078d4;
    }

    .ide-tab.pinned {
        padding: 0 8px;
        border-right: 1px solid #333333;
    }

    .ide-tab.pinned.active {
        border-top-color: #0078d4;
    }

    .ide-tab.drag-over {
        border-left: 2px solid #0078d4;
    }

    .ide-tab-name {
        max-width: 150px;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .ide-tab-dirty {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #e2b93d;
        flex-shrink: 0;
    }

    .ide-tab-close {
        background: none;
        border: none;
        padding: 0;
        margin: 0;
        font-size: 16px;
        line-height: 1;
        color: #969696;
        opacity: 0;
        cursor: pointer;
        border-radius: 3px;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 20px;
        height: 20px;
    }

    .ide-tab:hover .ide-tab-close,
    .ide-tab.active .ide-tab-close {
        opacity: 1;
    }

    .ide-tab-close:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #ffffff;
    }

    /* Context menu */
    .ide-tab-context-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 10000;
    }

    .ide-tab-context-menu {
        position: fixed;
        background: #252526;
        border: 1px solid #3c3c3c;
        border-radius: 4px;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.5);
        min-width: 160px;
        padding: 4px 0;
        z-index: 10001;
    }

    .ide-tab-context-item {
        display: flex;
        align-items: center;
        padding: 6px 12px;
        font-size: 0.8rem;
        color: #cccccc;
        cursor: pointer;
        transition: background 0.1s;
    }

    .ide-tab-context-item:hover {
        background: #04395e;
    }

    /* Light mode */
    [data-bs-theme="light"] .ide-tab-bar {
        background: #ececec;
    }

    [data-bs-theme="light"] .ide-tab {
        background: #d9d9d9;
        border-right-color: #e0e0e0;
        color: #666666;
    }

    [data-bs-theme="light"] .ide-tab.active {
        background: #ffffff;
        color: #333333;
    }

    [data-bs-theme="light"] .ide-tab:hover {
        color: #333333;
    }

    [data-bs-theme="light"] .ide-tab-scroll-btn {
        background: #e0e0e0;
        color: #555555;
    }

    [data-bs-theme="light"] .ide-tab-scroll-btn:hover {
        background: #d0d0d0;
        color: #333333;
    }

    [data-bs-theme="light"] .ide-tab-context-menu {
        background: #ffffff;
        border-color: #d0d0d0;
    }

    [data-bs-theme="light"] .ide-tab-context-item {
        color: #333333;
    }

    [data-bs-theme="light"] .ide-tab-context-item:hover {
        background: #e0e8f0;
    }
</style>

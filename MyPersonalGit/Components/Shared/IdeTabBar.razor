<div class="ide-tab-bar" @ref="tabBarRef">
    @if (Tabs == null || Tabs.Count == 0)
    {
        <div class="ide-tab-empty text-muted small px-3 py-1">
            <i class="bi bi-window-stack me-1"></i>No files open
        </div>
    }
    else
    {
        @if (showScrollLeft)
        {
            <button class="ide-tab-scroll-btn ide-tab-scroll-left" @onclick="ScrollLeft" title="Scroll left">
                <i class="bi bi-chevron-left"></i>
            </button>
        }
        <div class="ide-tab-scroll" @ref="scrollRef">
            @foreach (var tab in SortedTabs)
            {
                var isActive = tab.FilePath == ActiveTabPath;
                <div class="ide-tab @(isActive ? "active" : "") @(tab.IsPinned ? "pinned" : "") @(dragOverTab == tab.FilePath ? "drag-over" : "")"
                     title="@tab.FilePath"
                     draggable="true"
                     @onclick="() => OnTabSelected.InvokeAsync(tab.FilePath)"
                     @ondragstart="() => OnDragStart(tab.FilePath)"
                     @ondragover:preventDefault="true"
                     @ondragover="() => OnDragOver(tab.FilePath)"
                     @ondragleave="() => dragOverTab = null"
                     @ondrop="() => OnDrop(tab.FilePath)"
                     @oncontextmenu="(e) => HandleContextMenu(e, tab.FilePath)"
                     @oncontextmenu:preventDefault="true">
                    @if (tab.IsPinned)
                    {
                        <i class="bi bi-pin-fill me-1" style="font-size: 0.65rem; color: #0078d4;"></i>
                    }
                    <i class="bi @GetFileIcon(tab.FileName) me-1" style="font-size: 0.75rem;"></i>
                    @if (!tab.IsPinned)
                    {
                        <span class="ide-tab-name">@tab.FileName</span>
                    }
                    @if (tab.IsDirty)
                    {
                        <span class="ide-tab-dirty" title="Unsaved changes"></span>
                    }
                    @if (!tab.IsPinned)
                    {
                        <button class="ide-tab-close" @onclick="() => CloseTab(tab.FilePath)" @onclick:stopPropagation="true" title="Close">
                            <i class="bi bi-x"></i>
                        </button>
                    }
                </div>
            }
        </div>
        @if (showScrollRight)
        {
            <button class="ide-tab-scroll-btn ide-tab-scroll-right" @onclick="ScrollRight" title="Scroll right">
                <i class="bi bi-chevron-right"></i>
            </button>
        }
    }
</div>

@if (showContextMenu)
{
    <div class="ide-tab-context-overlay" @onclick="CloseContextMenu">
        <div class="ide-tab-context-menu" style="left: @(contextMenuX)px; top: @(contextMenuY)px;" @onclick:stopPropagation="true">
            @{ var ctxTab = Tabs?.FirstOrDefault(t => t.FilePath == contextMenuTab); }
            @if (ctxTab != null)
            {
                <div class="ide-tab-context-item" @onclick="() => TogglePin(ctxTab)">
                    <i class="bi @(ctxTab.IsPinned ? "bi-pin-angle" : "bi-pin-fill") me-2"></i>
                    @(ctxTab.IsPinned ? "Unpin Tab" : "Pin Tab")
                </div>
                <div class="ide-tab-context-item" @onclick="async () => { CloseContextMenu(); await CloseTab(ctxTab.FilePath); }">
                    <i class="bi bi-x-lg me-2"></i>Close Tab
                </div>
                <div class="ide-tab-context-item" @onclick="CloseOtherTabs">
                    <i class="bi bi-x-square me-2"></i>Close Other Tabs
                </div>
            }
        </div>
    </div>
}

@inject IJSRuntime JS

@code {
    [Parameter] public List<OpenTab>? Tabs { get; set; }
    [Parameter] public string? ActiveTabPath { get; set; }
    [Parameter] public EventCallback<string> OnTabSelected { get; set; }
    [Parameter] public EventCallback<string> OnTabClosed { get; set; }
    [Parameter] public EventCallback<(int from, int to)> OnTabReordered { get; set; }
    [Parameter] public EventCallback<string> OnTabPinToggled { get; set; }

    private string? draggedTab;
    private string? dragOverTab;
    private ElementReference tabBarRef;
    private ElementReference scrollRef;
    private bool showScrollLeft;
    private bool showScrollRight;

    // Context menu state
    private bool showContextMenu;
    private double contextMenuX;
    private double contextMenuY;
    private string? contextMenuTab;

    private List<OpenTab> SortedTabs => Tabs?.OrderByDescending(t => t.IsPinned).ToList() ?? new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CheckScrollOverflow();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // Defer scroll check to after render
        await Task.Yield();
        try { await CheckScrollOverflow(); } catch { }
    }

    private async Task CheckScrollOverflow()
    {
        try
        {
            var state = await JS.InvokeAsync<ScrollState>("ideTabScroll.getScrollState", scrollRef);
            showScrollLeft = state.ScrollLeft > 0;
            showScrollRight = state.ScrollLeft + state.ClientWidth < state.ScrollWidth - 1;
            StateHasChanged();
        }
        catch { }
    }

    private async Task ScrollLeft()
    {
        try
        {
            await JS.InvokeVoidAsync("ideTabScroll.scroll", scrollRef, -200);
            await Task.Delay(150);
            await CheckScrollOverflow();
        }
        catch { }
    }

    private async Task ScrollRight()
    {
        try
        {
            await JS.InvokeVoidAsync("ideTabScroll.scroll", scrollRef, 200);
            await Task.Delay(150);
            await CheckScrollOverflow();
        }
        catch { }
    }

    private record ScrollState(double ScrollLeft, double ClientWidth, double ScrollWidth);

    private void OnDragStart(string filePath)
    {
        draggedTab = filePath;
    }

    private void OnDragOver(string filePath)
    {
        if (draggedTab != null && draggedTab != filePath)
        {
            dragOverTab = filePath;
        }
    }

    private async Task OnDrop(string targetPath)
    {
        dragOverTab = null;
        if (draggedTab == null || Tabs == null || draggedTab == targetPath) return;

        var fromIndex = Tabs.FindIndex(t => t.FilePath == draggedTab);
        var toIndex = Tabs.FindIndex(t => t.FilePath == targetPath);
        draggedTab = null;

        if (fromIndex >= 0 && toIndex >= 0)
        {
            await OnTabReordered.InvokeAsync((fromIndex, toIndex));
        }
    }

    private async Task CloseTab(string filePath)
    {
        await OnTabClosed.InvokeAsync(filePath);
    }

    private void HandleContextMenu(MouseEventArgs e, string filePath)
    {
        contextMenuTab = filePath;
        contextMenuX = e.ClientX;
        contextMenuY = e.ClientY;
        showContextMenu = true;
    }

    private void CloseContextMenu()
    {
        showContextMenu = false;
        contextMenuTab = null;
    }

    private async Task TogglePin(OpenTab tab)
    {
        tab.IsPinned = !tab.IsPinned;
        CloseContextMenu();
        await OnTabPinToggled.InvokeAsync(tab.FilePath);
    }

    private async Task CloseOtherTabs()
    {
        if (Tabs == null || contextMenuTab == null) return;
        CloseContextMenu();
        var toClose = Tabs.Where(t => t.FilePath != contextMenuTab && !t.IsPinned).Select(t => t.FilePath).ToList();
        foreach (var path in toClose)
        {
            await OnTabClosed.InvokeAsync(path);
        }
    }

    private string GetFileIcon(string name)
    {
        var ext = System.IO.Path.GetExtension(name).ToLowerInvariant();
        return ext switch
        {
            ".cs" or ".js" or ".ts" or ".py" or ".rb" or ".go" or ".rs" or ".java" or
            ".cpp" or ".c" or ".h" or ".jsx" or ".tsx" or ".razor" => "bi-file-earmark-code",
            ".html" or ".htm" or ".xml" => "bi-filetype-html",
            ".css" or ".scss" => "bi-filetype-css",
            ".json" => "bi-filetype-json",
            ".md" => "bi-filetype-md",
            ".png" or ".jpg" or ".jpeg" or ".gif" or ".webp" or ".svg" => "bi-file-earmark-image",
            _ => "bi-file-earmark"
        };
    }

    public class OpenTab
    {
        public string FilePath { get; set; } = "";
        public string FileName { get; set; } = "";
        public bool IsDirty { get; set; }
        public string OriginalContent { get; set; } = "";
        public bool IsPinned { get; set; }
    }
}

<style>
    .ide-tab-bar {
        display: flex;
        align-items: stretch;
        background: #252526;
        min-height: 35px;
        overflow: hidden;
        position: relative;
    }

    .ide-tab-empty {
        display: flex;
        align-items: center;
        color: #858585;
        font-size: 13px;
    }

    .ide-tab-scroll {
        display: flex;
        overflow-x: auto;
        overflow-y: hidden;
        scrollbar-width: none;
        flex: 1;
        min-width: 0;
    }

    .ide-tab-scroll::-webkit-scrollbar {
        height: 0;
        display: none;
    }

    /* Scroll chevron buttons */
    .ide-tab-scroll-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        min-width: 24px;
        border: none;
        background: #333333;
        color: #cccccc;
        cursor: pointer;
        font-size: 0.7rem;
        z-index: 2;
        flex-shrink: 0;
        transition: background 0.15s;
    }

    .ide-tab-scroll-btn:hover {
        background: #3c3c3c;
        color: #ffffff;
    }

    .ide-tab {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 0 12px;
        height: 35px;
        font-size: 13px;
        cursor: pointer;
        white-space: nowrap;
        border-right: 1px solid #1e1e1e;
        color: #969696;
        min-width: 0;
        flex-shrink: 0;
        background: #2d2d2d;
        border-top: 2px solid transparent;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        transition: border-left-color 0.1s;
    }

    .ide-tab:hover {
        color: #cccccc;
        background: #2d2d2d;
    }

    .ide-tab.active {
        color: #ffffff;
        background: #1e1e1e;
        border-top-color: #0078d4;
    }

    .ide-tab.pinned {
        padding: 0 8px;
        border-right: 1px solid #333333;
    }

    .ide-tab.pinned.active {
        border-top-color: #0078d4;
    }

    .ide-tab.drag-over {
        border-left: 2px solid #0078d4;
    }

    .ide-tab-name {
        max-width: 150px;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .ide-tab-dirty {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #e2b93d;
        flex-shrink: 0;
    }

    .ide-tab-close {
        background: none;
        border: none;
        padding: 0;
        margin: 0;
        font-size: 16px;
        line-height: 1;
        color: #969696;
        opacity: 0;
        cursor: pointer;
        border-radius: 3px;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 20px;
        height: 20px;
    }

    .ide-tab:hover .ide-tab-close,
    .ide-tab.active .ide-tab-close {
        opacity: 1;
    }

    .ide-tab-close:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #ffffff;
    }

    /* Context menu */
    .ide-tab-context-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 10000;
    }

    .ide-tab-context-menu {
        position: fixed;
        background: #252526;
        border: 1px solid #3c3c3c;
        border-radius: 4px;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.5);
        min-width: 160px;
        padding: 4px 0;
        z-index: 10001;
    }

    .ide-tab-context-item {
        display: flex;
        align-items: center;
        padding: 6px 12px;
        font-size: 0.8rem;
        color: #cccccc;
        cursor: pointer;
        transition: background 0.1s;
    }

    .ide-tab-context-item:hover {
        background: #04395e;
    }

    /* Light mode */
    [data-bs-theme="light"] .ide-tab-bar {
        background: #ececec;
    }

    [data-bs-theme="light"] .ide-tab {
        background: #d9d9d9;
        border-right-color: #e0e0e0;
        color: #666666;
    }

    [data-bs-theme="light"] .ide-tab.active {
        background: #ffffff;
        color: #333333;
    }

    [data-bs-theme="light"] .ide-tab:hover {
        color: #333333;
    }

    [data-bs-theme="light"] .ide-tab-scroll-btn {
        background: #e0e0e0;
        color: #555555;
    }

    [data-bs-theme="light"] .ide-tab-scroll-btn:hover {
        background: #d0d0d0;
        color: #333333;
    }

    [data-bs-theme="light"] .ide-tab-context-menu {
        background: #ffffff;
        border-color: #d0d0d0;
    }

    [data-bs-theme="light"] .ide-tab-context-item {
        color: #333333;
    }

    [data-bs-theme="light"] .ide-tab-context-item:hover {
        background: #e0e8f0;
    }
</style>

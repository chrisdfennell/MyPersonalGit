@using MyPersonalGit.Data
@using Microsoft.Extensions.Localization
@using MyPersonalGit.Resources
@inject IWebIdeService WebIdeService
@inject IStringLocalizer<SharedResource> L

<div class="ide-search-panel">
    <div class="ide-search-header px-2 py-1 border-bottom">
        <span class="small fw-semibold"><i class="bi bi-search me-1"></i>@L["Ide_Search"]</span>
        <button class="btn btn-sm btn-link text-muted p-0 ms-auto" @onclick="ToggleReplace" title="@L["Ide_ToggleReplace"]">
            <i class="bi @(showReplace ? "bi-chevron-down" : "bi-chevron-right")"></i>
        </button>
    </div>

    <div class="ide-search-inputs px-2 py-2">
        <div class="input-group input-group-sm mb-1">
            <input type="text" class="form-control" placeholder="@L["Ide_SearchInFiles"]"
                   @bind="searchQuery" @bind:event="oninput"
                   @onkeydown="HandleSearchKeyDown" />
            <button class="btn btn-outline-secondary" @onclick="ExecuteSearch" disabled="@isSearching">
                <i class="bi bi-search"></i>
            </button>
        </div>
        @if (showReplace)
        {
            <div class="input-group input-group-sm mb-1">
                <input type="text" class="form-control" placeholder="@L["Ide_ReplaceWith"]"
                       @bind="replaceText" @bind:event="oninput" />
                <button class="btn btn-outline-secondary" @onclick="ReplaceAll" disabled="@(isSearching || results == null || results.Count == 0)"
                        title="@L["Ide_ReplaceAll"]">
                    <i class="bi bi-arrow-repeat"></i>
                </button>
            </div>
        }
        <input type="text" class="form-control form-control-sm" placeholder="@L["Ide_FileExtFilter"]"
               @bind="extFilter" @bind:event="oninput" />
    </div>

    <div class="ide-search-results">
        @if (isSearching)
        {
            <div class="text-center py-3">
                <span class="spinner-border spinner-border-sm text-muted"></span>
                <span class="text-muted small ms-1">@L["Ide_Searching"]</span>
            </div>
        }
        else if (replaceMessage != null)
        {
            <div class="text-success small px-3 py-2">
                <i class="bi bi-check-circle me-1"></i>@replaceMessage
            </div>
        }
        else if (hasSearched && (results == null || results.Count == 0))
        {
            <div class="text-muted small px-3 py-2">
                <i class="bi bi-emoji-frown me-1"></i>@L["Ide_NoResults"]
            </div>
        }
        else if (results != null && results.Count > 0)
        {
            <div class="small px-2 py-1 text-muted border-bottom d-flex align-items-center">
                <span>@results.Count result(s) in @groupedResults.Count file(s)</span>
                @if (showReplace && !string.IsNullOrEmpty(replaceText))
                {
                    <button class="btn btn-sm btn-link text-warning p-0 ms-auto" @onclick="ReplaceAll" title="@L["Ide_ReplaceAll"]">
                        @L["Ide_ReplaceAll"]
                    </button>
                }
            </div>
            @foreach (var group in groupedResults)
            {
                <div class="ide-search-file-group">
                    <div class="ide-search-file-header px-2 py-1 d-flex align-items-center">
                        <i class="bi bi-file-earmark-code me-1"></i>
                        <span class="fw-semibold">@GetFileName(group.Key)</span>
                        <span class="text-muted ms-1 small">@GetDirectory(group.Key)</span>
                        <span class="badge bg-secondary ms-auto rounded-pill">@group.Count()</span>
                        @if (showReplace && !string.IsNullOrEmpty(replaceText))
                        {
                            <button class="btn btn-sm btn-link text-warning p-0 ms-2" @onclick="() => ReplaceInFile(group.Key)"
                                    title="@L["Ide_ReplaceAllInFile"]">
                                <i class="bi bi-arrow-repeat"></i>
                            </button>
                        }
                    </div>
                    @foreach (var result in group.Take(50))
                    {
                        <div class="ide-search-result px-2 py-1" @onclick="() => SelectResult(result)" title="@result.FilePath:@result.LineNumber">
                            <div class="ide-search-result-path text-truncate">
                                <span class="text-muted">:@result.LineNumber</span>
                            </div>
                            <div class="ide-search-result-line font-monospace">
                                @HighlightMatch(result.LineContent)
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public string RepoName { get; set; } = "";
    [Parameter] public string Branch { get; set; } = "main";
    [Parameter] public EventCallback<(string filePath, int lineNumber)> OnResultSelected { get; set; }
    [Parameter] public EventCallback<(string search, string replace, string? filePath)> OnReplace { get; set; }

    private string searchQuery = "";
    private string replaceText = "";
    private string extFilter = "";
    private bool isSearching;
    private bool hasSearched;
    private bool showReplace;
    private string? replaceMessage;
    private List<SearchResult>? results;

    private ILookup<string, SearchResult> groupedResults =>
        (results ?? new List<SearchResult>()).ToLookup(r => r.FilePath);

    private void ToggleReplace()
    {
        showReplace = !showReplace;
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await ExecuteSearch();
    }

    private async Task ExecuteSearch()
    {
        if (string.IsNullOrWhiteSpace(searchQuery)) return;

        isSearching = true;
        hasSearched = true;
        replaceMessage = null;
        StateHasChanged();

        try
        {
            var ext = string.IsNullOrWhiteSpace(extFilter) ? null : extFilter.Trim();
            results = await WebIdeService.SearchFilesAsync(RepoName, Branch, searchQuery, ext);
        }
        catch
        {
            results = new();
        }
        finally
        {
            isSearching = false;
            StateHasChanged();
        }
    }

    private async Task SelectResult(SearchResult result)
    {
        await OnResultSelected.InvokeAsync((result.FilePath, result.LineNumber));
    }

    private async Task ReplaceInFile(string filePath)
    {
        if (string.IsNullOrEmpty(searchQuery) || replaceText == null) return;
        await OnReplace.InvokeAsync((searchQuery, replaceText, filePath));
        replaceMessage = $"Replaced in {GetFileName(filePath)}";
        // Re-search to refresh results
        await ExecuteSearch();
    }

    private async Task ReplaceAll()
    {
        if (string.IsNullOrEmpty(searchQuery) || replaceText == null || results == null) return;
        await OnReplace.InvokeAsync((searchQuery, replaceText, null));
        var fileCount = groupedResults.Count;
        replaceMessage = $"Replaced in {fileCount} file(s)";
        // Re-search to refresh results
        await ExecuteSearch();
    }

    private static string GetFileName(string path) => System.IO.Path.GetFileName(path);
    private static string GetDirectory(string path)
    {
        var dir = System.IO.Path.GetDirectoryName(path)?.Replace("\\", "/");
        return string.IsNullOrEmpty(dir) ? "" : dir;
    }

    private RenderFragment HighlightMatch(string line) => builder =>
    {
        if (string.IsNullOrEmpty(searchQuery) || string.IsNullOrEmpty(line))
        {
            builder.AddContent(0, line);
            return;
        }

        var idx = line.IndexOf(searchQuery, StringComparison.OrdinalIgnoreCase);
        if (idx < 0)
        {
            builder.AddContent(0, line);
            return;
        }

        var before = line[..idx];
        var match = line.Substring(idx, searchQuery.Length);
        var after = line[(idx + searchQuery.Length)..];

        builder.AddContent(1, before);
        builder.OpenElement(2, "mark");
        builder.AddContent(3, match);
        builder.CloseElement();
        builder.AddContent(4, after);
    };
}

<style>
    .ide-search-panel {
        display: flex;
        flex-direction: column;
        font-size: 0.8125rem;
        border-top: 1px solid var(--bs-border-color);
    }

    .ide-search-header {
        display: flex;
        align-items: center;
    }

    .ide-search-inputs .form-control {
        font-size: 0.75rem;
    }

    .ide-search-results {
        overflow-y: auto;
        flex: 1;
    }

    .ide-search-file-header {
        font-size: 0.75rem;
        background: var(--bs-tertiary-bg);
        position: sticky;
        top: 0;
        z-index: 1;
    }

    .ide-search-result {
        cursor: pointer;
        border-bottom: 1px solid var(--bs-border-color-translucent);
    }

    .ide-search-result:hover {
        background: var(--bs-tertiary-bg);
    }

    .ide-search-result-path {
        font-size: 0.75rem;
    }

    .ide-search-result-line {
        font-size: 0.6875rem;
        color: var(--bs-secondary-color);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        padding-left: 1.25rem;
    }

    .ide-search-result-line mark {
        background: var(--bs-warning-bg-subtle);
        padding: 0 1px;
        border-radius: 2px;
    }
</style>

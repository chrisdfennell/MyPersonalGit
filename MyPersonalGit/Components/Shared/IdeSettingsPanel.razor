@inject IJSRuntime JS
@using Microsoft.Extensions.Localization
@using MyPersonalGit.Resources
@inject IStringLocalizer<SharedResource> L

<div class="ide-settings-panel">
    <div class="ide-settings-header">
        <i class="bi bi-gear me-2"></i>@L["Ide_EditorSettings"]
    </div>
    <div class="ide-settings-body">
        <div class="ide-settings-group">
            <label class="ide-settings-label">@L["Ide_FontFamily"]</label>
            <select class="form-select form-select-sm" @bind="fontFamily" @bind:after="ApplySettings">
                <option value="'Cascadia Code', 'Fira Code', Consolas, monospace">Cascadia Code</option>
                <option value="'Fira Code', Consolas, monospace">Fira Code</option>
                <option value="'JetBrains Mono', Consolas, monospace">JetBrains Mono</option>
                <option value="Consolas, 'Courier New', monospace">Consolas</option>
                <option value="'Source Code Pro', Consolas, monospace">Source Code Pro</option>
                <option value="'IBM Plex Mono', Consolas, monospace">IBM Plex Mono</option>
                <option value="'Ubuntu Mono', Consolas, monospace">Ubuntu Mono</option>
                <option value="'Courier New', monospace">Courier New</option>
            </select>
        </div>

        <div class="ide-settings-group">
            <label class="ide-settings-label">@L["Ide_FontSize"]</label>
            <div class="d-flex align-items-center gap-2">
                <input type="range" class="form-range flex-grow-1" min="10" max="24" step="1"
                       @bind-value="fontSize" @bind-value:event="oninput" @onchange="ApplySettings" />
                <span class="ide-settings-value">@fontSize px</span>
            </div>
        </div>

        <div class="ide-settings-group">
            <label class="ide-settings-label">@L["Ide_TabSize"]</label>
            <div class="d-flex gap-2">
                @foreach (var size in new[] { 2, 4, 8 })
                {
                    <button class="btn btn-sm @(tabSize == size ? "btn-primary" : "btn-outline-secondary")"
                            @onclick="() => { tabSize = size; ApplySettings(); }">
                        @size
                    </button>
                }
            </div>
        </div>

        <div class="ide-settings-group">
            <label class="ide-settings-label">@L["Ide_WordWrap"]</label>
            <select class="form-select form-select-sm" @bind="wordWrap" @bind:after="ApplySettings">
                <option value="off">@L["Ide_Off"]</option>
                <option value="on">@L["Ide_On"]</option>
                <option value="wordWrapColumn">@L["Ide_WordWrapColumn"]</option>
            </select>
        </div>

        <div class="ide-settings-group">
            <label class="ide-settings-label">@L["Ide_Minimap"]</label>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" @bind="minimapEnabled" @bind:after="ApplySettings" />
                <label class="form-check-label small">@(minimapEnabled ? L["Ide_Visible"] : L["Ide_Hidden"])</label>
            </div>
        </div>

        <div class="ide-settings-group">
            <label class="ide-settings-label">@L["Ide_LineNumbers"]</label>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" @bind="lineNumbers" @bind:after="ApplySettings" />
                <label class="form-check-label small">@(lineNumbers ? L["Ide_On"] : L["Ide_Off"])</label>
            </div>
        </div>

        <div class="ide-settings-group">
            <label class="ide-settings-label">@L["Ide_RenderWhitespace"]</label>
            <select class="form-select form-select-sm" @bind="renderWhitespace" @bind:after="ApplySettings">
                <option value="none">@L["Ide_None"]</option>
                <option value="boundary">@L["Ide_Boundary"]</option>
                <option value="selection">@L["Ide_Selection"]</option>
                <option value="all">@L["Ide_All"]</option>
            </select>
        </div>

        <div class="ide-settings-group">
            <label class="ide-settings-label">@L["Ide_CodeFolding"]</label>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" @bind="foldingEnabled" @bind:after="ApplySettings" />
                <label class="form-check-label small">@(foldingEnabled ? L["Ide_Enabled"] : L["Ide_Disabled"])</label>
            </div>
        </div>

        <div class="ide-settings-group">
            <label class="ide-settings-label">@L["Ide_StickyScroll"]</label>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" @bind="stickyScrollEnabled" @bind:after="ApplySettings" />
                <label class="form-check-label small">@(stickyScrollEnabled ? L["Ide_Enabled"] : L["Ide_Disabled"])</label>
            </div>
        </div>

        <div class="ide-settings-group">
            <label class="ide-settings-label">@L["Ide_BracketPairGuides"]</label>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" @bind="bracketGuides" @bind:after="ApplySettings" />
                <label class="form-check-label small">@(bracketGuides ? L["Ide_Visible"] : L["Ide_Hidden"])</label>
            </div>
        </div>

        <div class="ide-settings-group">
            <label class="ide-settings-label">@L["Ide_FontLigatures"]</label>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" @bind="fontLigatures" @bind:after="ApplySettings" />
                <label class="form-check-label small">@(fontLigatures ? L["Ide_Enabled"] : L["Ide_Disabled"])</label>
            </div>
        </div>

        <div class="ide-settings-group">
            <label class="ide-settings-label">@L["Ide_FormatOnPaste"]</label>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" @bind="formatOnPaste" @bind:after="ApplySettings" />
                <label class="form-check-label small">@(formatOnPaste ? L["Ide_Enabled"] : L["Ide_Disabled"])</label>
            </div>
        </div>

        <div class="ide-settings-group">
            <label class="ide-settings-label">@L["Ide_AutoSave"]</label>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" @bind="autoSaveEnabled" @bind:after="ApplySettings" />
                <label class="form-check-label small">@(autoSaveEnabled ? L["Ide_Enabled"] : L["Ide_Disabled"])</label>
            </div>
        </div>

        @if (autoSaveEnabled)
        {
            <div class="ide-settings-group">
                <label class="ide-settings-label">@L["Ide_AutoSaveDelay"]</label>
                <div class="d-flex align-items-center gap-2">
                    <input type="range" class="form-range flex-grow-1" min="500" max="5000" step="500"
                           @bind-value="autoSaveDelay" @bind-value:event="oninput" @onchange="ApplySettings" />
                    <span class="ide-settings-value">@(autoSaveDelay)ms</span>
                </div>
            </div>
        }

        <hr class="my-2 opacity-25" />
        <div class="ide-settings-group">
            <label class="ide-settings-label">Code Snippets</label>
            <div class="small text-muted mb-1">Define custom snippets (prefix + Tab to expand). Uses VS Code snippet body syntax ($1, $2, $0 for cursors).</div>
            @for (var i = 0; i < userSnippets.Count; i++)
            {
                var idx = i;
                var snippet = userSnippets[idx];
                <div class="d-flex gap-1 mb-1 align-items-start" style="font-size: 0.75rem;">
                    <input class="form-control form-control-sm" style="width: 60px; font-size: 0.72rem;" placeholder="prefix"
                           value="@snippet.Prefix" @onchange="(e) => UpdateSnippetPrefix(idx, e)" />
                    <input class="form-control form-control-sm" style="width: 55px; font-size: 0.72rem;" placeholder="lang"
                           value="@snippet.Language" @onchange="(e) => UpdateSnippetLanguage(idx, e)" />
                    <input class="form-control form-control-sm" style="flex:1; font-size: 0.72rem;" placeholder="body"
                           value="@snippet.Body" @onchange="(e) => UpdateSnippetBody(idx, e)" />
                    <button class="btn btn-sm btn-outline-danger p-0 px-1" @onclick="() => RemoveSnippet(idx)">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            }
            <button class="btn btn-sm btn-outline-secondary w-100 mt-1" @onclick="AddSnippet">
                <i class="bi bi-plus me-1"></i>Add Snippet
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? EditorId { get; set; }
    [Parameter] public string? SplitEditorId { get; set; }
    [Parameter] public EventCallback<EditorSettings> OnSettingsChanged { get; set; }

    private record SnippetEntry(string Prefix, string Body, string Description, string Language);
    private List<SnippetEntry> userSnippets = new();

    private string fontFamily = "'Cascadia Code', 'Fira Code', Consolas, monospace";
    private int fontSize = 14;
    private int tabSize = 4;
    private string wordWrap = "off";
    private bool minimapEnabled = true;
    private bool lineNumbers = true;
    private string renderWhitespace = "selection";
    private bool foldingEnabled = true;
    private bool stickyScrollEnabled = false;
    private bool bracketGuides = true;
    private bool fontLigatures = false;
    private bool formatOnPaste = true;
    private bool autoSaveEnabled = false;
    private int autoSaveDelay = 1000;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Load settings from localStorage
            try
            {
                var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "ide-settings");
                if (!string.IsNullOrEmpty(saved))
                {
                    var settings = System.Text.Json.JsonSerializer.Deserialize<EditorSettings>(saved);
                    if (settings != null)
                    {
                        fontFamily = settings.FontFamily;
                        fontSize = settings.FontSize;
                        tabSize = settings.TabSize;
                        wordWrap = settings.WordWrap;
                        minimapEnabled = settings.MinimapEnabled;
                        lineNumbers = settings.LineNumbers;
                        renderWhitespace = settings.RenderWhitespace;
                        foldingEnabled = settings.FoldingEnabled;
                        stickyScrollEnabled = settings.StickyScrollEnabled;
                        bracketGuides = settings.BracketGuides;
                        fontLigatures = settings.FontLigatures;
                        formatOnPaste = settings.FormatOnPaste;
                        autoSaveEnabled = settings.AutoSaveEnabled;
                        autoSaveDelay = settings.AutoSaveDelay;
                        StateHasChanged();
                    }
                }
            }
            catch { }

            // Load snippets
            try
            {
                var snippetsJson = await JS.InvokeAsync<string>("ideSnippets.get");
                if (!string.IsNullOrEmpty(snippetsJson) && snippetsJson != "[]")
                {
                    userSnippets = System.Text.Json.JsonSerializer.Deserialize<List<SnippetEntry>>(snippetsJson,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
                    StateHasChanged();
                }
            }
            catch { }
        }
    }

    private void AddSnippet()
    {
        userSnippets.Add(new SnippetEntry("", "", "", "*"));
    }

    private void UpdateSnippetPrefix(int idx, ChangeEventArgs e)
    {
        if (idx < userSnippets.Count) { userSnippets[idx] = userSnippets[idx] with { Prefix = e.Value?.ToString() ?? "" }; SaveSnippets(); }
    }

    private void UpdateSnippetLanguage(int idx, ChangeEventArgs e)
    {
        if (idx < userSnippets.Count) { userSnippets[idx] = userSnippets[idx] with { Language = e.Value?.ToString() ?? "*" }; SaveSnippets(); }
    }

    private void UpdateSnippetBody(int idx, ChangeEventArgs e)
    {
        if (idx < userSnippets.Count) { userSnippets[idx] = userSnippets[idx] with { Body = e.Value?.ToString() ?? "" }; SaveSnippets(); }
    }

    private void RemoveSnippet(int idx)
    {
        if (idx < userSnippets.Count) { userSnippets.RemoveAt(idx); SaveSnippets(); }
    }

    private async void SaveSnippets()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(userSnippets.Where(s => !string.IsNullOrWhiteSpace(s.Prefix)));
            await JS.InvokeVoidAsync("ideSnippets.save", json);
        }
        catch { }
    }

    private async void ApplySettings()
    {
        var settings = new EditorSettings
        {
            FontFamily = fontFamily,
            FontSize = fontSize,
            TabSize = tabSize,
            WordWrap = wordWrap,
            MinimapEnabled = minimapEnabled,
            LineNumbers = lineNumbers,
            RenderWhitespace = renderWhitespace,
            FoldingEnabled = foldingEnabled,
            StickyScrollEnabled = stickyScrollEnabled,
            BracketGuides = bracketGuides,
            FontLigatures = fontLigatures,
            FormatOnPaste = formatOnPaste,
            AutoSaveEnabled = autoSaveEnabled,
            AutoSaveDelay = autoSaveDelay
        };

        // Save to localStorage
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(settings);
            await JS.InvokeVoidAsync("localStorage.setItem", "ide-settings", json);
        }
        catch { }

        // Apply to editors via JS interop
        try
        {
            var options = new
            {
                fontFamily = settings.FontFamily,
                fontSize = settings.FontSize,
                tabSize = settings.TabSize,
                wordWrap = settings.WordWrap,
                minimap = new { enabled = settings.MinimapEnabled },
                lineNumbers = settings.LineNumbers ? "on" : "off",
                renderWhitespace = settings.RenderWhitespace,
                folding = settings.FoldingEnabled,
                stickyScroll = new { enabled = settings.StickyScrollEnabled },
                guides = new { bracketPairs = settings.BracketGuides, indentation = settings.BracketGuides, highlightActiveBracketPair = settings.BracketGuides, highlightActiveIndentation = settings.BracketGuides },
                fontLigatures = settings.FontLigatures,
                formatOnPaste = settings.FormatOnPaste
            };

            if (!string.IsNullOrEmpty(EditorId))
            {
                await JS.InvokeVoidAsync("monacoInterop.updateEditorOptions", EditorId, options);
            }
            if (!string.IsNullOrEmpty(SplitEditorId))
            {
                await JS.InvokeVoidAsync("monacoInterop.updateEditorOptions", SplitEditorId, options);
            }
        }
        catch { }

        await OnSettingsChanged.InvokeAsync(settings);
    }

    public class EditorSettings
    {
        public string FontFamily { get; set; } = "'Cascadia Code', 'Fira Code', Consolas, monospace";
        public int FontSize { get; set; } = 14;
        public int TabSize { get; set; } = 4;
        public string WordWrap { get; set; } = "off";
        public bool MinimapEnabled { get; set; } = true;
        public bool LineNumbers { get; set; } = true;
        public string RenderWhitespace { get; set; } = "selection";
        public bool FoldingEnabled { get; set; } = true;
        public bool StickyScrollEnabled { get; set; } = false;
        public bool BracketGuides { get; set; } = true;
        public bool FontLigatures { get; set; } = false;
        public bool FormatOnPaste { get; set; } = true;
        public bool AutoSaveEnabled { get; set; } = false;
        public int AutoSaveDelay { get; set; } = 1000;
    }
}

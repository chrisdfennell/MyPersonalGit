<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script>(function(){var t=localStorage.getItem('theme')||'light';document.documentElement.setAttribute('data-bs-theme',t);})()</script>
    <!-- Using CDN for reliability to ensure CSS loads correctly -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="MyPersonalGit.styles.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/themes/prism.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/plugins/line-numbers/prism-line-numbers.min.css" />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <meta property="og:site_name" content="Personal Git" />
    <meta property="og:type" content="website" />
    <meta name="description" content="Self-hosted Git server with GitHub-like web interface" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/prism.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/plugins/autoloader/prism-autoloader.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/plugins/line-numbers/prism-line-numbers.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/qrcode-generator@1.4.4/qrcode.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"></script>
    <script>
        mermaid.initialize({ startOnLoad: false, theme: 'default' });
        window.renderMermaidAndMath = function() {
            // Markdig outputs <pre class="mermaid"> for ```mermaid blocks
            // Mermaid.js needs them as <div class="mermaid"> or just runs on .mermaid elements
            // Also handle <pre><code class="language-mermaid"> from other renderers
            document.querySelectorAll('pre code.language-mermaid').forEach(function(el) {
                var pre = el.parentElement;
                var div = document.createElement('div');
                div.className = 'mermaid';
                div.textContent = el.textContent;
                pre.replaceWith(div);
            });
            // Convert Markdig's <pre class="mermaid"> to <div class="mermaid"> for mermaid.run()
            document.querySelectorAll('pre.mermaid').forEach(function(el) {
                var div = document.createElement('div');
                div.className = 'mermaid';
                div.textContent = el.textContent;
                el.replaceWith(div);
            });
            try { mermaid.run(); } catch(e) {}
            // Render KaTeX math: $...$ and $$...$$
            document.querySelectorAll('.markdown-body').forEach(function(el) {
                try {
                    renderMathInElement(el, {
                        delimiters: [
                            { left: '$$', right: '$$', display: true },
                            { left: '$', right: '$', display: false },
                            { left: '\\[', right: '\\]', display: true },
                            { left: '\\(', right: '\\)', display: false }
                        ],
                        throwOnError: false
                    });
                } catch(e) {}
            });
        };
    </script>
    <script>
        window.editorHelper = {
            enableTabKey: function (elementId) {
                var el = document.getElementById(elementId);
                if (!el) return;
                el.addEventListener('keydown', function (e) {
                    if (e.key === 'Tab') {
                        e.preventDefault();
                        var start = el.selectionStart;
                        var end = el.selectionEnd;
                        el.value = el.value.substring(0, start) + '    ' + el.value.substring(end);
                        el.selectionStart = el.selectionEnd = start + 4;
                        el.dispatchEvent(new Event('input', { bubbles: true }));
                    }
                });
            },
            getScrollTop: function (elementId) {
                var el = document.getElementById(elementId);
                return el ? el.scrollTop : 0;
            },
            setScrollTop: function (elementId, val) {
                var el = document.getElementById(elementId);
                if (el) el.scrollTop = val;
            },
            autoresize: function (elementId) {
                var el = document.getElementById(elementId);
                if (!el) return;
                if (el._autoresizeHandler) {
                    el.removeEventListener('input', el._autoresizeHandler);
                }
                function doResize() {
                    el.style.height = 'auto';
                    el.style.height = el.scrollHeight + 'px';
                }
                doResize();
                el._autoresizeHandler = doResize;
                el.addEventListener('input', el._autoresizeHandler);
            }
        };
        window.sessionHelper = {
            set: function (key, value) { localStorage.setItem(key, value); },
            get: function (key) { return localStorage.getItem(key); },
            remove: function (key) { localStorage.removeItem(key); }
        };
        window.themeHelper = {
            init: function () {
                var saved = localStorage.getItem('theme') || 'light';
                document.documentElement.setAttribute('data-bs-theme', saved);
                return saved;
            },
            set: function (theme) {
                localStorage.setItem('theme', theme);
                document.documentElement.setAttribute('data-bs-theme', theme);
            },
            get: function () {
                return localStorage.getItem('theme') || 'light';
            }
        };
        window.diffHighlight = {
            apply: function() {
                document.querySelectorAll('[data-diff-lang]').forEach(function(container) {
                    var lang = container.getAttribute('data-diff-lang');
                    if (!lang || lang === 'none') return;
                    var grammar = Prism.languages[lang];
                    if (!grammar) {
                        try {
                            Prism.plugins.autoloader.loadLanguages(lang, function() {
                                window.diffHighlight.highlightContainer(container, lang);
                            });
                        } catch(e) {}
                        return;
                    }
                    window.diffHighlight.highlightContainer(container, lang);
                });
            },
            highlightContainer: function(container, lang) {
                var grammar = Prism.languages[lang];
                if (!grammar) return;
                container.querySelectorAll('.diff-text').forEach(function(el) {
                    if (el.getAttribute('data-highlighted')) return;
                    var text = el.textContent;
                    if (text.trim().length === 0) return;
                    el.innerHTML = Prism.highlight(text, grammar, lang);
                    el.setAttribute('data-highlighted', '1');
                });
            }
        };

        window.keyboardShortcuts = {
            _pending: null,
            _dotNetRef: null,
            init: function(dotNetRef) {
                this._dotNetRef = dotNetRef;
                document.addEventListener('keydown', this._handler.bind(this));
            },
            _handler: function(e) {
                var tag = (e.target.tagName || '').toLowerCase();
                var isInput = tag === 'input' || tag === 'textarea' || tag === 'select' || e.target.isContentEditable;

                // Esc always works
                if (e.key === 'Escape') {
                    document.activeElement?.blur();
                    if (this._dotNetRef) this._dotNetRef.invokeMethodAsync('OnShortcut', 'escape');
                    return;
                }

                // Don't fire shortcuts when typing in inputs
                if (isInput) return;

                if (e.key === '/') {
                    e.preventDefault();
                    var search = document.getElementById('global-search-input');
                    if (search) search.focus();
                    return;
                }

                if (e.key === '?') {
                    e.preventDefault();
                    if (this._dotNetRef) this._dotNetRef.invokeMethodAsync('OnShortcut', 'help');
                    return;
                }

                // Two-key combos: g + letter
                if (this._pending === 'g') {
                    this._pending = null;
                    var routes = { 'h': '/', 'i': '/search?type=issues', 'p': '/search?type=pulls', 'n': '/notifications', 'a': null, 's': null };
                    if (e.key in routes) {
                        e.preventDefault();
                        var route = routes[e.key];
                        if (route) window.location.href = route;
                        else if (this._dotNetRef) this._dotNetRef.invokeMethodAsync('OnShortcut', 'g' + e.key);
                    }
                    return;
                }

                if (e.key === 'g') {
                    this._pending = 'g';
                    setTimeout(function() { window.keyboardShortcuts._pending = null; }, 1000);
                    return;
                }
            },
            dispose: function() {
                document.removeEventListener('keydown', this._handler);
            }
        };

        window.lineLink = {
            scrollToHash: function() {
                var hash = window.location.hash;
                if (hash && hash.match(/^#L\d+$/)) {
                    var el = document.getElementById(hash.substring(1));
                    if (el) {
                        el.scrollIntoView({ block: 'center' });
                        // Highlight the line
                        document.querySelectorAll('.line-highlight').forEach(function(e) { e.classList.remove('line-highlight'); });
                        el.classList.add('line-highlight');
                    }
                }
            }
        };
        window.addEventListener('hashchange', function() { window.lineLink.scrollToHash(); });

        window.folderUpload = {
            setWebkitDirectory: function (elementId) {
                var el = document.getElementById(elementId);
                if (el) el.webkitdirectory = true;
            },
            getRelativePaths: function (elementId) {
                var el = document.getElementById(elementId);
                if (!el || !el.files) return [];
                var paths = [];
                for (var i = 0; i < el.files.length; i++) {
                    paths.push(el.files[i].webkitRelativePath || el.files[i].name);
                }
                return paths;
            }
        };
    </script>
    <script>
        // WebAuthn / Passkey helpers for Blazor interop
        window.generateQRCode = function(elementId, text) {
            var el = document.getElementById(elementId);
            if (!el || !text) return;
            var qr = qrcode(0, 'M');
            qr.addData(text);
            qr.make();
            el.innerHTML = qr.createSvgTag(4, 0);
        };

        window.webAuthn = {
            isSupported: function() {
                return !!window.PublicKeyCredential;
            },
            getUnsupportedReason: function() {
                if (window.PublicKeyCredential) return null;
                if (location.protocol !== 'https:' && location.hostname !== 'localhost' && location.hostname !== '127.0.0.1') {
                    return 'WebAuthn requires a secure context (HTTPS). You are accessing this site over HTTP (' + location.hostname + '). Set up a reverse proxy with TLS or access via localhost.';
                }
                return 'Your browser does not support WebAuthn/Passkeys.';
            },
            register: async function(options) {
                const publicKey = {
                    challenge: Uint8Array.from(atob(options.challenge.replace(/-/g,'+').replace(/_/g,'/')), c => c.charCodeAt(0)),
                    rp: { id: options.rpId, name: options.rpName },
                    user: {
                        id: Uint8Array.from(atob(options.userId.replace(/-/g,'+').replace(/_/g,'/')), c => c.charCodeAt(0)),
                        name: options.userName,
                        displayName: options.userDisplayName
                    },
                    pubKeyCredParams: [
                        { type: "public-key", alg: -7 },   // ES256
                        { type: "public-key", alg: -257 }  // RS256
                    ],
                    timeout: 60000,
                    attestation: "none",
                    excludeCredentials: (options.excludeCredentials || []).map(id => ({
                        type: "public-key",
                        id: Uint8Array.from(atob(id.replace(/-/g,'+').replace(/_/g,'/')), c => c.charCodeAt(0))
                    }))
                };
                const credential = await navigator.credentials.create({ publicKey });
                const b64url = (buf) => btoa(String.fromCharCode(...new Uint8Array(buf))).replace(/\+/g,'-').replace(/\//g,'_').replace(/=+$/,'');
                return JSON.stringify({
                    credentialId: b64url(credential.rawId),
                    clientDataJSON: b64url(credential.response.clientDataJSON),
                    attestationObject: b64url(credential.response.attestationObject),
                    publicKey: credential.response.getPublicKey ? b64url(credential.response.getPublicKey()) : "",
                    isPlatform: credential.authenticatorAttachment === "platform"
                });
            },
            authenticate: async function(options) {
                const publicKey = {
                    challenge: Uint8Array.from(atob(options.challenge.replace(/-/g,'+').replace(/_/g,'/')), c => c.charCodeAt(0)),
                    rpId: options.rpId,
                    timeout: 60000,
                    allowCredentials: (options.allowCredentials || []).map(id => ({
                        type: "public-key",
                        id: Uint8Array.from(atob(id.replace(/-/g,'+').replace(/_/g,'/')), c => c.charCodeAt(0))
                    }))
                };
                const assertion = await navigator.credentials.get({ publicKey });
                const b64url = (buf) => btoa(String.fromCharCode(...new Uint8Array(buf))).replace(/\+/g,'-').replace(/\//g,'_').replace(/=+$/,'');
                return JSON.stringify({
                    credentialId: b64url(assertion.rawId),
                    clientDataJSON: b64url(assertion.response.clientDataJSON),
                    authenticatorData: b64url(assertion.response.authenticatorData),
                    signature: b64url(assertion.response.signature)
                });
            }
        };
    </script>
    <script src="js/monaco-interop.js"></script>
    <script src="js/ide-ai-chat.js"></script>
    <script src="js/ide-collaboration.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js" crossorigin="anonymous"></script>
    <script>
        // Inject dark mode styles into Blazor's reconnect shadow DOM
        (function() {
            var darkCss = '.components-reconnect-dialog { background-color: #1e1e2e !important; color: #c9d1d9 !important; border: 1px solid #444 !important; box-shadow: 0 4px 24px rgba(0,0,0,0.7) !important; } .components-reconnect-dialog p { color: #8b949e !important; } .components-rejoining-animation div { border-color: #58a6ff !important; } .components-reconnect-overlay { background-color: rgba(0,0,0,0.6) !important; }';
            function injectIntoShadow() {
                if (document.documentElement.getAttribute('data-bs-theme') !== 'dark') return;
                var el = document.getElementById('components-reconnect-modal');
                if (el && el.shadowRoot && !el.shadowRoot.querySelector('#dark-reconnect-style')) {
                    var style = document.createElement('style');
                    style.id = 'dark-reconnect-style';
                    style.textContent = darkCss;
                    el.shadowRoot.appendChild(style);
                }
            }
            // Watch for the shadow host to appear and for theme changes
            new MutationObserver(function() { injectIntoShadow(); }).observe(document.documentElement, { childList: true, subtree: true, attributes: true, attributeFilter: ['data-bs-theme'] });
            // Also poll as fallback
            setInterval(injectIntoShadow, 1000);
        })();
    </script>
</body>

</html>